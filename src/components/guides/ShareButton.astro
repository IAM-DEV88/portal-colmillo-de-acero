---
interface Props {
  url?: string;
  title?: string;
  variant?: 'compact' | 'full';
}

const { url, title = "Compartir guía", variant = 'compact' } = Astro.props;
---

<div 
  x-data={`{ 
    copied: false, 
    copyUrl() { 
      const finalUrl = '${url}' || window.location.href;
      navigator.clipboard.writeText(finalUrl); 
      this.copied = true; 
      setTimeout(() => this.copied = false, 2000); 
    } 
  }`}
  class="relative inline-block"
>
  {variant === 'compact' ? (
    <button
      @click="copyUrl()"
      class="p-2 rounded-lg bg-gray-800/50 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all shadow-lg backdrop-blur-sm group"
      title={title}
    >
      <i class="fas transition-all" :class="copied ? 'fa-check text-green-500 scale-110' : 'fa-share-nodes group-hover:scale-110'"></i>
      
      <!-- Tooltip Toast -->
      <template x-if="copied">
        <div 
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1 bg-green-600 text-white text-[10px] font-black uppercase tracking-widest rounded shadow-xl whitespace-nowrap z-50"
        >
          ¡Enlace Copiado!
        </div>
      </template>
    </button>
  ) : (
    <button
      @click="copyUrl()"
      class="flex items-center gap-3 px-5 py-2.5 rounded-lg bg-gray-900/60 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all text-[10px] font-black uppercase tracking-[0.2em] shadow-lg backdrop-blur-md group"
    >
      <i class="fas transition-all" :class="copied ? 'fa-check text-green-500 scale-110' : 'fa-share-nodes group-hover:scale-110'"></i>
      <span x-text="copied ? '¡COPIADO!' : 'COMPARTIR GUÍA'"></span>
    </button>
  )}
</div>
