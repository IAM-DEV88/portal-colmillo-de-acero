---
const currentYear = new Date().getFullYear();
---

<footer
  class="bottom-0 left-0 right-0 w-full bg-gradient-to-r from-gray-900/95 to-amber-900/95 backdrop-blur-md border-t border-t-accent shadow-lg overflow-x-hidden"
>
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row items-center justify-between">
      <!-- Logo and guild name -->
      <div class="flex items-center mb-4 md:mb-0 group">
        <img
          src="/images/logo.png"
          alt="Colmillo de Acero"
          class="h-12 w-auto mr-3 transition-transform duration-300 group-hover:scale-110"
        />
        <span
          class="text-2xl font-bold bg-gradient-to-r from-accent to-accent-dark bg-clip-text text-transparent"
        >
          Colmillo de Acero
        </span>
      </div>

      <!-- Social links -->
      <div class="flex space-x-6 mb-4 md:mb-0">
        <a
          href="https://discord.gg/BwdpNV9sky"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent transition-all duration-300"
          aria-label="Discord"
        >
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
