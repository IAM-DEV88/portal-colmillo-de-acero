          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent transition-all duration-300"
          aria-label="YouTube"
        >
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path
