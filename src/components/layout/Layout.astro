---
import '../../styles/global.css';
import Navigation from './Navigation.astro';
import Footer from './Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title = 'Colmillo de Acero',
  description = 'Hermandad de World of Warcraft enfocada en el contenido PvE de alta dificultad. Únete a nosotros para dominar las raids y desafíos de Azeroth.',
  image = '/images/raids/default.jpg',
  type = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const socialImageURL = new URL(image, Astro.url);
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title} | Colmillo de Acero</title>
    <meta name="title" content={`${title} | Colmillo de Acero`} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${title} | Colmillo de Acero`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={`${title} | Colmillo de Acero`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />
    <script>
      // Initialize Alpine.js
      document.addEventListener('alpine:init', () => {
        // Initialize any Alpine.js components here
      });
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <style>
      [x-cloak] { display: none !important; }
      .transition-all { transition-property: all; }
      .duration-200 { transition-duration: 200ms; }
      .ease-in-out { transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); }
      .overflow-hidden { overflow: hidden; }
    </style>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
      // @ts-ignore - AOS is loaded from CDN
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof AOS !== 'undefined') {
          AOS.init({ duration: 800, once: true });
        }
      });
    </script>
    
    <!-- Admin Scripts -->
    {Astro.url.pathname.startsWith('/admin') && (
      <script is:inline src="/js/admin.js" type="module"></script>
    )}
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <!-- Hide Astro dev toolbar in development -->
    {import.meta.env.DEV && (
      <style>
        astro-dev-toolbar {
          display: none !important;
        }
      </style>
    )}
    
    <style is:inline>
      html {
        scroll-behavior: smooth;
      }
      
      ::selection {
        background: var(--color-accent);
      }
      
      *:focus {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }
.mobileShow { display: none; }
.mobileHide { display: block; }

@media (max-width: 768px) {
  .mobileShow { display: block; }
  .mobileHide { display: none; }
}
</style>
  </head>
  <body class="overflow-x-hidden w-full relative min-h-screen">
    <!-- Background Image with fixed positioning -->
    <div class="fixed inset-0 -z-10 w-screen h-screen bg-center bg-cover bg-no-repeat bg-fixed" style="background-image: url('/images/background.png'); transform: translateZ(0); backface-visibility: hidden; will-change: transform;"></div>
    <!-- Overlay to control background darkness if needed -->
    <div class="fixed inset-0 -z-10 w-screen h-screen bg-black/50"></div>
    <!-- Content wrapper with hardware acceleration -->
    <div class="relative z-10 min-h-screen">
      <Navigation />
      
      {/* Banner de Anuncios Responsivo con Aislamiento de Iframe */}
      <center class="mt-28 mb-4 px-4 overflow-hidden"> 
        <div class="mobileShow">
          <iframe 
            srcdoc={`
              <html>
                <body style="margin:0; padding:0; display:flex; justify-content:center;">
                  <script type="text/javascript">
                    atOptions = {
                      'key' : 'bc3afce27a408298cd40496786edc9ca',
                      'format' : 'iframe',
                      'height' : 50,
                      'width' : 320,
                      'params' : {}
                    };
                  </script>
                  <script type="text/javascript" src="https://www.highperformanceformat.com/bc3afce27a408298cd40496786edc9ca/invoke.js"></script>
                </body>
              </html>
            `}
            width="320"
            height="50"
            frameborder="0"
            scrolling="no"
            style="border:none; overflow:hidden;"
          ></iframe>
        </div>

        <div class="mobileHide">
          <iframe 
            srcdoc={`
              <html>
                <body style="margin:0; padding:0; display:flex; justify-content:center;">
                  <script type="text/javascript">
                    atOptions = {
                      'key' : '93c2b6087ec5ee18108cbc64fb95d610',
                      'format' : 'iframe',
                      'height' : 90,
                      'width' : 728,
                      'params' : {}
                    };
                  </script>
                  <script type="text/javascript" src="https://www.highperformanceformat.com/93c2b6087ec5ee18108cbc64fb95d610/invoke.js"></script>
                </body>
              </html>
            `}
            width="728"
            height="90"
            frameborder="0"
            scrolling="no"
            style="border:none; overflow:hidden;"
          ></iframe>
        </div>
      </center>

      <main class="min-h-screen relative z-10 pb-4 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <slot />
      </main>

      {/* Nuevo Banner de Apoyo a la Comunidad antes del Footer */}
      <center class="mb-12 px-4 overflow-hidden relative z-10">
        <div class="max-w-3xl mx-auto mb-4 p-4 bg-gradient-to-br from-amber-900/20 via-gray-900/40 to-blue-900/20 backdrop-blur-md border border-white/10 rounded-2xl shadow-xl">
          <p class="text-amber-200/90 text-xs md:text-sm font-bold uppercase tracking-widest italic flex items-center justify-center gap-3">
            <svg class="w-5 h-5 text-amber-500 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
            </svg>
            Con un solo clic en la publicidad, ayudas enormemente a mantener viva nuestra comunidad. ¡Gracias!
            <svg class="w-5 h-5 text-amber-500 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
            </svg>
          </p>
        </div>

        <div class="mobileShow">
          <iframe 
            srcdoc={`
              <html>
                <body style="margin:0; padding:0; display:flex; justify-content:center;">
                  <script type="text/javascript">
                    atOptions = {
                      'key' : 'bc3afce27a408298cd40496786edc9ca',
                      'format' : 'iframe',
                      'height' : 50,
                      'width' : 320,
                      'params' : {}
                    };
                  </script>
                  <script type="text/javascript" src="https://www.highperformanceformat.com/bc3afce27a408298cd40496786edc9ca/invoke.js"></script>
                </body>
              </html>
            `}
            width="320"
            height="50"
            frameborder="0"
            scrolling="no"
            style="border:none; overflow:hidden;"
          ></iframe>
        </div>

        <div class="mobileHide">
          <iframe 
            srcdoc={`
              <html>
                <body style="margin:0; padding:0; display:flex; justify-content:center;">
                  <script type="text/javascript">
                    atOptions = {
                      'key' : '93c2b6087ec5ee18108cbc64fb95d610',
                      'format' : 'iframe',
                      'height' : 90,
                      'width' : 728,
                      'params' : {}
                    };
                  </script>
                  <script type="text/javascript" src="https://www.highperformanceformat.com/93c2b6087ec5ee18108cbc64fb95d610/invoke.js"></script>
                </body>
              </html>
            `}
            width="728"
            height="90"
            frameborder="0"
            scrolling="no"
            style="border:none; overflow:hidden;"
          ></iframe>
        </div>
      </center>
      
      <!-- {/* Floating Action Button - Only show on home page */}
      {Astro.url.pathname === '/' && (
        <a 
          href="/servicios" 
          class="fixed bottom-8 right-8 z-50 flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-amber-500 to-amber-600 text-white shadow-lg hover:shadow-xl hover:text-white hover:shadow-amber-500/30 transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500"
          aria-label="Ver servicios para hermandades"
          title="Servicios para Hermandades"
        >
          <i class="fas fa-gem text-xl"></i>
        </a>
      )}
       -->
      <Footer />
      <slot name="modals" />
    </div> <!-- Close the content wrapper -->
    <!-- Toast Container -->
    <div id="toast-container" class="fixed bottom-4 right-4 space-y-2 z-50"></div>

    <!-- Visitor Tracking -->
    <script is:inline>
      (function() {
        // Skip tracking for admin pages
        if (window.location.pathname.startsWith('/admin')) return;

        const TRACK_KEY = 'last_tracked_url';
        const TRACK_TIME_KEY = 'last_tracked_time';
        
        const currentUrl = window.location.href;
        const now = Date.now();
        const lastUrl = sessionStorage.getItem(TRACK_KEY);
        const lastTime = parseInt(sessionStorage.getItem(TRACK_TIME_KEY) || '0');
        
        // Prevent duplicate tracking within 5 seconds for the same URL
        if (lastUrl === currentUrl && (now - lastTime < 5000)) {
            return;
        }
        
        sessionStorage.setItem(TRACK_KEY, currentUrl);
        sessionStorage.setItem(TRACK_TIME_KEY, now.toString());

        const payload = {
          url: currentUrl,
          referrer: document.referrer,
          screen: `${window.screen.width}x${window.screen.height}`,
          timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
          language: navigator.language
        };
        
        // Send tracking data
        fetch('/api/track-visit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          keepalive: true
        }).catch(err => console.debug('Tracking error', err));
      })();
    </script>
  </body>
</html>
