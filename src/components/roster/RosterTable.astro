---
// RosterTable.astro
// Componente principal para mostrar el roster de la hermandad.
// Refactorizado para reducir la carga de Vite/Astro y solucionar errores de build.

import {
  DEFAULT_CLASS_INFO,
  RACE_NAMES,
  FACTION_NAMES,
  PROFESSIONS,
  ROLES,
  PROFESSION_COLORS,
  DIFFICULTY_COLORS,
  RANK_ORDER
} from './rosterConstants';

import {
  processRosterMember,
  calculateStats,
  calculateRankDistribution,
  calculateClassDistribution,
  calculateRaceDistribution,
  calculateFactionDistribution,
  calculateProfessionDistribution,
  getRankPriority
} from '../../utils/rosterComponentHelpers';

import type { 
  RosterData, 
  Member, 
  RosterStats 
} from '../../types/roster';

// Definir las props del componente
interface Props {
  initialRosterData?: any[];
  raidRegistrations?: any[];
  lastUpdatedBy?: string;
  globalLastUpdate?: number;
  lastUpdatedAt?: string | null;
}

// Obtener las props
const { 
  initialRosterData: rawRosterData = [], 
  raidRegistrations = [],
  lastUpdatedBy = 'Desconocido',
  globalLastUpdate = 0,
  lastUpdatedAt = null
} = Astro.props;

// 1. Procesar miembros (Server-side)
const processedMembers = rawRosterData
  .map(processRosterMember)
  .filter((m) => !m.guildLeave);

// 2. Calcular estadísticas y distribuciones (Server-side)
const stats = calculateStats(processedMembers as Member[]);
const rankDistribution = calculateRankDistribution(processedMembers);
const classDistribution = calculateClassDistribution(processedMembers, DEFAULT_CLASS_INFO);
const raceDistribution = calculateRaceDistribution(processedMembers);
const factionDistribution = calculateFactionDistribution(processedMembers);
const professionDistribution = calculateProfessionDistribution(processedMembers);

// 3. Ordenar miembros para la vista inicial
const sortedMembers = [...processedMembers].sort((a, b) => {
  const priorityA = getRankPriority(a.rank);
  const priorityB = getRankPriority(b.rank);
  if (priorityA !== priorityB) return priorityA - priorityB;
  return a.name.localeCompare(b.name);
});

// 4. Preparar datos para el cliente
const rosterClientData = {
  members: sortedMembers,
  classInfo: DEFAULT_CLASS_INFO,
  totalMembers: processedMembers.length,
  stats: stats
};

const roleNames = {
  T: { name: 'Tanque' },
  H: { name: 'Sanador' },
  D: { name: 'DPS' },
};

const professionNames = Object.entries(PROFESSIONS).reduce((acc, [code, name]) => {
  acc[code] = { 
    name, 
    ...PROFESSION_COLORS[code] 
  };
  return acc;
}, {} as any);

// Helpers para la UI (Server-side rendering inicial)
const averageGearScore = stats.gearScoreStats.avg > 0 ? stats.gearScoreStats.avg.toFixed(1) : 'N/A';
const minGearScore = stats.gearScoreStats.min > 0 ? stats.gearScoreStats.min.toFixed(1) : 'N/A';
const maxGearScore = stats.gearScoreStats.max > 0 ? stats.gearScoreStats.max.toFixed(1) : 'N/A';

// Rangos únicos para el filtro
const ranks = [...new Set(processedMembers.map((m) => m.rank))].sort((a, b) => getRankPriority(a) - getRankPriority(b));

---

<div class="roster-component">
  <style>
    /* Estilos base del componente */
    #member-modal {
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease-in-out, visibility 0.2s ease-in-out;
    }
    #member-modal.show {
      opacity: 1;
      visibility: visible;
    }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(31, 41, 55, 0.5); border-radius: 3px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(245, 158, 11, 0.3); border-radius: 3px; }
    select { -webkit-appearance: none; appearance: none; }
  </style>

  <!-- Título y Header -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 px-2 mb-6">
    <div class="flex items-center space-x-4">
      <div class="w-12 h-12 bg-gradient-to-br from-amber-600 to-amber-800 rounded-xl flex items-center justify-center shadow-lg transform -rotate-2">
        <svg class="w-8 h-8 text-black" viewBox="0 0 32 32"><path fill="currentColor" d="M27.745 9.605c-2.737-4.441-7.647-7.397-11.759-8.808-1.394 0.445-2.781 1.056-4.12 1.823l5.301 4.128-1.447 1.463 5.196 3.968-9.746-3.045 1.995-1.925-5.295-1.681c-1.311 1.189-2.512 2.553-3.546 4.078 2.827 7.594 2.827 9.077 0 16.671 7.648 5.84 15.714 6.117 23.422 0-2.313-7.594-2.313-9.076 0-16.671zM23.884 17.982c-1.965-0.982-3.885-1.598-5.787-1.841-0.751 4.757-0.732 9.514 0.155 14.271h-3.73c1.153-4.768 0.981-9.535 0.143-14.303-1.956 0.217-3.908 0.839-5.884 1.873v-4.45c4.971-1.398 10.449-0.936 15.103 0v4.45z"/></svg>
      </div>
      <div>
        <h2 class="text-sm md:text-3xl font-black text-white uppercase tracking-tighter italic">
          Roster de la <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-200">Hermandad</span>
        </h2>
        <p class="text-amber-300/60 font-medium tracking-widest uppercase text-[10px]">Actualizado: {globalLastUpdate ? new Date(globalLastUpdate * 1000).toLocaleDateString() : 'Recientemente'}</p>
      </div>
    </div>
  </div>

  <!-- Estadísticas Superiores -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8 bg-gray-900/40 p-4 rounded-lg border border-amber-600/30">
    <!-- Total Miembros -->
    <div class="bg-gray-800/50 p-3 rounded border border-amber-600/20">
      <p class="text-xs text-amber-300/70 uppercase">Miembros</p>
      <p class="text-2xl font-bold text-white">{processedMembers.length}</p>
      <div class="flex gap-2 mt-1 text-[10px]">
        <span class="text-blue-300">M: {stats.mainAltDistribution.M}</span>
        <span class="text-purple-300">A: {stats.mainAltDistribution.A}</span>
      </div>
    </div>
    <!-- GS Promedio -->
    <div class="bg-gray-800/50 p-3 rounded border border-green-600/20">
      <p class="text-xs text-green-300/70 uppercase">Avg GearScore</p>
      <p class="text-2xl font-bold text-white">{averageGearScore}</p>
      <p class="text-[10px] text-gray-400">Min: {minGearScore} / Max: {maxGearScore}</p>
    </div>
    <!-- Roles -->
    <div class="bg-gray-800/50 p-3 rounded border border-blue-600/20">
      <p class="text-xs text-blue-300/70 uppercase">Distribución Roles</p>
      <div class="flex gap-3 mt-1">
        <span class="text-sm font-bold text-blue-400">T: {stats.roleDistribution.tank || 0}</span>
        <span class="text-sm font-bold text-green-400">H: {stats.roleDistribution.healer || 0}</span>
        <span class="text-sm font-bold text-red-400">D: {(stats.roleDistribution.melee || 0) + (stats.roleDistribution.ranged || 0)}</span>
      </div>
    </div>
    <!-- Líderes -->
    <div class="bg-gray-800/50 p-3 rounded border border-purple-600/20">
      <p class="text-xs text-purple-300/70 uppercase">Raid Leaders</p>
      <p class="text-2xl font-bold text-white">{stats.raidLeadersCount}</p>
    </div>
  </div>

  <!-- Contenedor Principal del Roster -->
  <div id="roster-container" class="bg-gray-900/40 border border-amber-600/30 rounded-lg p-6 mb-10">
    
    <!-- Filtros -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <input type="text" id="search" placeholder="Buscar jugador..." class="bg-gray-800 border border-amber-900/50 rounded px-3 py-2 text-sm text-white focus:ring-1 focus:ring-amber-500" />
      <select id="class-filter" class="bg-gray-800 border border-amber-900/50 rounded px-3 py-2 text-sm text-white">
        <option value="">Todas las clases</option>
        {Object.entries(DEFAULT_CLASS_INFO).map(([key, info]) => <option value={key}>{info.name}</option>)}
      </select>
      <select id="rank-filter" class="bg-gray-800 border border-amber-900/50 rounded px-3 py-2 text-sm text-white">
        <option value="">Todos los rangos</option>
        {ranks.map(rank => <option value={rank}>{rank}</option>)}
      </select>
    </div>

    <!-- Grid de Miembros -->
    <div id="roster-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3">
      <!-- Se llena via JS -->
    </div>

    <!-- Paginación -->
    <div class="flex items-center justify-between mt-6 pt-4 border-t border-gray-800">
      <div id="page-info" class="text-sm text-amber-200/50"></div>
      <div class="flex gap-2">
        <button id="prev-button" class="px-3 py-1 bg-gray-800 border border-amber-900/30 rounded disabled:opacity-30">Anterior</button>
        <button id="next-button" class="px-3 py-1 bg-gray-800 border border-amber-900/30 rounded disabled:opacity-30">Siguiente</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal -->
<div id="member-modal" class="fixed inset-0 z-[9999] hidden flex items-center justify-center p-4">
  <div class="fixed inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="relative bg-gray-800 border border-amber-600/30 rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto custom-scrollbar p-6">
    <div class="flex justify-between items-start mb-6">
      <div class="flex items-center gap-4">
        <div id="modal-class-icon" class="w-16 h-16 rounded border border-gray-700"></div>
        <div>
          <h3 id="modal-character-name" class="text-2xl font-bold italic"></h3>
          <p id="modal-header-rank" class="text-amber-400 text-xs uppercase font-bold tracking-wider"></p>
        </div>
      </div>
      <button id="close-modal" class="text-gray-400 hover:text-white">✕</button>
    </div>
    
    <div class="space-y-6">
      <div id="modal-tags" class="flex flex-wrap gap-2"></div>
      <div class="bg-gray-900/50 p-4 rounded border border-gray-700/30">
        <p class="text-xs text-gray-500 uppercase mb-2">Nota Pública</p>
        <p id="modal-note" class="text-sm text-gray-300 italic"></p>
      </div>
      <div id="modal-extra-info" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div id="recognitions-container" class="space-y-2"></div>
        <div id="raids-container" class="space-y-2"></div>
      </div>
    </div>
  </div>
</div>

<!-- Configuración de datos para el cliente -->
<div 
  id="roster-config-data" 
  class="hidden" 
  data-roster={JSON.stringify(rosterClientData)}
  data-roles={JSON.stringify(roleNames)}
  data-professions={JSON.stringify(professionNames)}
  data-races={JSON.stringify(RACE_NAMES)}
  data-factions={JSON.stringify(FACTION_NAMES)}
  data-registrations={JSON.stringify(raidRegistrations)}
></div>

<script src="./RosterTableClient.ts"></script>
