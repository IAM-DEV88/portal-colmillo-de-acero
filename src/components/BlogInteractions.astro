---
import { supabase } from '../lib/supabase';
import { RouletteService } from '../lib/roulette-service';

interface Props {
  postId: string;
  postTitle: string;
}

const { postId, postTitle } = Astro.props;

// Fetch approved comments for this post
const { data: comments } = await supabase
  .from('rd_blog_comments')
  .select('*')
  .eq('post_id', postId)
  .eq('is_approved', true)
  .order('created_at', { ascending: false });

const { data: postData } = await supabase
  .from('rd_blog_posts')
  .select('likes_count')
  .eq('id', postId)
  .single();

// Get user IP for initial like states
const clientIP = RouletteService.getClientIP(Astro.request);
const ipHash = RouletteService.getIpHash(clientIP);

// Check if user liked the post
const { data: userPostLike } = await supabase
  .from('rd_blog_likes')
  .select('id')
  .eq('post_id', postId)
  .eq('ip_hash', ipHash)
  .single();

// Check which comments the user liked
const { data: userCommentLikes } = await supabase
  .from('rd_blog_comment_likes')
  .select('comment_id')
  .eq('ip_hash', ipHash);

const likedCommentsMap = userCommentLikes?.reduce((acc: any, curr) => {
  acc[curr.comment_id] = true;
  return acc;
}, {}) || {};

const likesCount = postData?.likes_count || 0;
const isPostLiked = !!userPostLike;
---

<div class="mt-16 pt-12 border-t border-white/10" x-data={`blogInteractions('${postId}', ${likesCount}, ${isPostLiked})`}>
  <div class="flex flex-col md:flex-row items-center justify-between mb-12 gap-6">
    <div>
      <h2 class="text-3xl font-black text-white uppercase tracking-tighter italic">
        Conversación del <span class="text-amber-500">Blog</span>
      </h2>
      <p class="text-gray-400 text-xs font-medium uppercase tracking-widest mt-2">Comparte tus pensamientos sobre "{postTitle}"</p>
    </div>

    <div class="flex items-center gap-4">
      <!-- Like Button -->
      <button 
        @click="likePost"
        class="flex items-center gap-3 px-6 py-3 rounded-xl transition-all font-black text-xs uppercase tracking-widest group shadow-xl"
        :class="liked 
          ? 'bg-amber-500 text-gray-950 shadow-amber-500/20 scale-105' 
          : 'bg-amber-500/10 hover:bg-amber-500 border border-amber-500/30 text-amber-500 hover:text-gray-950'"
      >
        <i class="fas fa-heart" :class="liked ? 'scale-110 animate-pulse' : 'group-hover:scale-125 transition-transform'"></i>
        <span x-text="liked ? '¡TE GUSTA!' : 'ME GUSTA'"></span>
        <span class="opacity-50" x-text="likes"></span>
      </button>

      <button 
        @click="openModal = true"
        class="flex items-center gap-3 px-6 py-3 bg-blue-600/10 hover:bg-blue-600 border border-blue-600/30 text-blue-400 hover:text-white rounded-xl transition-all font-black text-xs uppercase tracking-widest group shadow-xl shadow-blue-900/20"
      >
        <i class="fas fa-comment group-hover:scale-110 transition-transform"></i>
        <span>Comentar</span>
      </button>
    </div>
  </div>

  <!-- Comments Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {comments && comments.length > 0 ? (
      comments.map((comment) => (
        <div class="bg-gray-900/40 backdrop-blur-sm border border-white/5 rounded-lg p-6 hover:border-amber-500/20 transition-all group flex flex-col">
          <div class="flex justify-between items-start mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20">
                <span class="text-amber-500 font-black text-lg italic">
                  {comment.player_name.charAt(0).toUpperCase()}
                </span>
              </div>
              <div>
                <h4 class="text-sm font-black text-white uppercase italic tracking-tighter">
                  {comment.player_name}
                </h4>
                <p class="text-[9px] text-gray-500 font-bold uppercase">
                  {new Date(comment.created_at).toLocaleDateString()}
                </p>
              </div>
            </div>
            
            <!-- Comment Like Button -->
            <button 
              onclick={`toggleCommentLike('${comment.id}', this)`}
              data-liked={likedCommentsMap[comment.id] ? "true" : "false"}
              class={`flex items-center gap-2 px-3 py-1.5 rounded-lg transition-all text-[10px] font-black italic border ${
                likedCommentsMap[comment.id] 
                ? 'bg-amber-500/20 border-amber-500 text-amber-500' 
                : 'bg-white/5 border-white/10 text-gray-500 hover:border-amber-500/30 hover:text-amber-500'
              }`}
            >
              <i class={`fas fa-heart ${likedCommentsMap[comment.id] ? 'animate-pulse' : ''}`}></i>
              <span class="count">{comment.likes_count || 0}</span>
            </button>
          </div>
          <p class="text-gray-300 text-sm italic leading-relaxed flex-grow">
            "{comment.content}"
          </p>
        </div>
      ))
    ) : (
      <div class="col-span-full py-16 text-center bg-white/5 border border-dashed border-white/10 rounded-lg">
        <p class="text-gray-500 text-xs font-black uppercase tracking-[0.2em] italic">
          Nadie ha comentado aún. ¡Sé el primero!
        </p>
      </div>
    )}
  </div>

  <!-- Comment Modal -->
  <template x-teleport="body">
    <div x-show="openModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4">
      <div class="fixed inset-0 bg-black/90 backdrop-blur-md" @click="openModal = false" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"></div>
      
      <div 
        class="relative w-full max-w-lg bg-gray-950 border border-amber-500/20 rounded-3xl p-8 shadow-2xl overflow-hidden"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 scale-95 translate-y-8"
        x-transition:enter-end="opacity-100 scale-100 translate-y-0"
      >
        <!-- Magic Decoration -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-amber-500/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10">
          <div class="flex justify-between items-center mb-8">
            <h3 class="text-2xl font-black text-white uppercase italic flex items-center gap-3">
              <i class="fas fa-feather-alt text-amber-500"></i>
              Tu <span class="text-amber-500">Aporte</span>
            </h3>
            <button @click="openModal = false" class="text-gray-500 hover:text-white transition-colors">
              <i class="fas fa-times text-2xl"></i>
            </button>
          </div>

          <form @submit.prevent="submitComment" class="space-y-6">
            <div>
              <label class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 italic">Nombre de tu Personaje</label>
              <input 
                type="text" 
                x-model="commentForm.player_name"
                required 
                placeholder="Ej: Arthas"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-sm text-white focus:border-amber-500/50 transition-all outline-none"
              />
            </div>
            <div>
              <label class="block text-[10px] font-black text-gray-500 uppercase tracking-widest mb-2 italic">Mensaje para la Comunidad</label>
              <textarea 
                x-model="commentForm.content"
                required 
                rows="5"
                placeholder="Comparte tu sabiduría..."
                class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-sm text-white focus:border-amber-500/50 transition-all outline-none resize-none"
              ></textarea>
            </div>
            
            <button 
              type="submit"
              :disabled="submitting"
              class="w-full py-5 bg-amber-600 hover:bg-amber-500 disabled:opacity-50 text-gray-950 font-black text-sm uppercase tracking-[0.2em] rounded-2xl transition-all shadow-xl shadow-amber-900/40 flex items-center justify-center gap-3"
            >
              <i class="fas fa-paper-plane" :class="submitting ? 'animate-pulse' : ''"></i>
              <span x-text="submitting ? 'Canalizando...' : 'Publicar Comentario'"></span>
            </button>

            <p class="text-[9px] text-gray-500 uppercase font-black italic text-center leading-relaxed">
              * Los comentarios son moderados por oficiales antes de aparecer
            </p>
          </form>
        </div>
      </div>
    </div>
  </template>
</div>

<script is:inline define:vars={{ postId }}>
  // Función global para likes de comentarios (fuera de Alpine para simplicidad en el loop de Astro)
  async function toggleCommentLike(commentId, btn) {
    const isLiked = btn.getAttribute('data-liked') === 'true';
    const countSpan = btn.querySelector('.count');
    let currentCount = parseInt(countSpan.innerText);

    try {
      const response = await fetch('/api/blog/like-comment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ commentId })
      });
      
      const result = await response.json();
      if (result.success) {
        const newLiked = result.liked;
        btn.setAttribute('data-liked', newLiked ? 'true' : 'false');
        
        // Update UI
        if (newLiked) {
          btn.classList.remove('bg-white/5', 'border-white/10', 'text-gray-500');
          btn.classList.add('bg-amber-500/20', 'border-amber-500', 'text-amber-500');
          btn.querySelector('i').classList.add('animate-pulse');
          countSpan.innerText = currentCount + 1;
          if (result.rewarded && window.showRewardToast) {
            window.showRewardToast('¡Por participar en el Blog!');
          }
        } else {
          btn.classList.add('bg-white/5', 'border-white/10', 'text-gray-500');
          btn.classList.remove('bg-amber-500/20', 'border-amber-500', 'text-amber-500');
          btn.querySelector('i').classList.remove('animate-pulse');
          countSpan.innerText = Math.max(0, currentCount - 1);
        }
      }
    } catch (e) {
      console.error('Error toggling comment like:', e);
    }
  }

  document.addEventListener('alpine:init', () => {
    Alpine.data('blogInteractions', (postId, initialLikes, initialLiked) => ({
      postId,
      likes: initialLikes,
      liked: initialLiked,
      openModal: false,
      submitting: false,
      commentForm: {
        player_name: '',
        content: ''
      },

      async likePost() {
        try {
          const response = await fetch('/api/blog/like', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ postId: this.postId })
          });
          
          const result = await response.json();
          if (result.success) {
            this.liked = result.liked;
            this.likes = result.liked ? this.likes + 1 : Math.max(0, this.likes - 1);
            
            if (result.rewarded && window.showRewardToast) {
              window.showRewardToast('¡Por tu apoyo al Blog!');
            }
          }
        } catch (e) {
          console.error('Error liking post:', e);
        }
      },

      async submitComment() {
        this.submitting = true;
        try {
          const response = await fetch('/api/blog/comment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              postId: this.postId,
              ...this.commentForm
            })
          });
          
          const result = await response.json();
          if (result.success) {
            this.openModal = false;
            this.commentForm = { player_name: '', content: '' };
            if (window.showRewardToast) {
              window.showRewardToast('Comentario enviado. Aparecerá tras ser moderado.');
            }
          }
        } catch (e) {
          console.error('Error submitting comment:', e);
        } finally {
          this.submitting = false;
        }
      }
    }));
  });
</script>
