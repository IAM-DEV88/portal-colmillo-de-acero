---
import Layout from '../components/layout/Layout.astro';

// Opciones dinámicas para el formulario
const raids = [
  { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
  { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
  { id: 'SR', name: 'Sagrario Rubí (SR)' },
];

const difficulties = ['Normal', 'Heroica'];
const sizes = ['10', '25'];
const days = ['Lunes', 'Martes', 'Miercoles', 'Jueves', 'Viernes', 'Sabado', 'Domingo'];
---

<Layout 
  title="Voto por Horario y Disponibilidad" 
  description="Participa en la organización de nuestras próximas raids. Vota por tus horarios preferidos para ICC, TOC y SR, y gana turnos extra para la ruleta de la hermandad.">
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tighter uppercase italic">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-yellow-200">🗳️ Centro de Votación</span> de Raids
      </h1>
      <p class="text-gray-400 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
        Tu opinión es clave para el éxito de la hermandad. Selecciona la banda, dificultad y el horario que mejor se adapte a ti. 
        <span class="text-amber-500 font-bold italic block mt-2">¡Recuerda: cada voto te otorga un giro extra en la ruleta!</span>
      </p>
    </div>

    <div>
      <!-- Formulario Paso a Paso (Alpine.js) -->
      <section
        x-data="recruitmentForm"
        class="mb-8 bg-gray-900/50 border border-gray-800 rounded-lg p-6 shadow-2xl backdrop-blur-sm transition-all duration-500 ease-in-out overflow-hidden"
        :style="'height: ' + height + 'px'"
        x-ref="container"
      >
        <div x-show="!completed" x-ref="formContent">
          <!-- Indicador de Progreso -->
          <div class="flex justify-between mb-8">
            <template x-for="n in totalSteps" :key="n">
              <div
                class="h-2 flex-1 mx-1 rounded-full transition-colors duration-300"
                :class="n <= step ? 'bg-amber-600' : 'bg-gray-800'"
              >
              </div>
            </template>
          </div>

          <!-- Paso 1: Selección de Banda -->
          <div
            x-show="step === 1"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">¿Qué banda buscas?</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-gray-400 mb-1">Selecciona la Banda</label>
                <div class="grid grid-cols-1 gap-2">
                  <template x-for="raid in raids" :key="raid.id">
                    <button
                      @click="formData.raid_name = raid.id; setTimeout(() => goToStep(2), 300)"
                      class="px-4 py-3 rounded-lg border text-left transition-all"
                      :class="formData.raid_name === raid.id ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400 hover:border-gray-600'"
                    >
                      <span x-text="raid.name"></span>
                    </button>
                  </template>
                </div>
              </div>
            </div>
          </div>

          <!-- Paso 2: Dificultad y Tamaño -->
          <div
            x-show="step === 2"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">Dificultad y Tamaño</h2>
            <div class="space-y-6">
              <div>
                <label class="block text-sm text-gray-400 mb-2">Dificultad</label>
                <div class="flex gap-4">
                  <template x-for="diff in difficulties" :key="diff">
                    <button
                      @click="formData.difficulty = diff; if(formData.size) setTimeout(() => goToStep(3), 300)"
                      class="flex-1 py-3 rounded-lg border transition-all"
                      :class="formData.difficulty === diff ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400'"
                      x-text="diff"></button>
                  </template>
                </div>
              </div>
              <div>
                <label class="block text-sm text-gray-400 mb-2">Tamaño de Banda</label>
                <div class="flex gap-4">
                  <template x-for="size in sizes" :key="size">
                    <button
                      @click="formData.size = size; if(formData.difficulty) setTimeout(() => goToStep(3), 300)"
                      class="flex-1 py-3 rounded-lg border transition-all"
                      :class="formData.size === size ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400'"
                      x-text="size + ' Jugadores'"></button>
                  </template>
                </div>
              </div>
            </div>
          </div>

          <!-- Paso 3: Día y Hora -->
          <div
            x-show="step === 3"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">¿Cuándo podrías asistir?</h2>
            <div class="space-y-6">
              <div>
                <label class="block text-sm text-gray-400 mb-2">Día de la Semana</label>
                <select
                  x-model="formData.day_of_week"
                  class="w-full bg-black/50 border border-gray-800 rounded-lg px-4 py-2 text-white outline-none"
                >
                  <option value="">Selecciona un día</option>
                  <template x-for="day in days" :key="day">
                    <option :value="day.toLowerCase()" x-text="day"></option>
                  </template>
                </select>
              </div>
              <div>
                <label class="block text-sm text-gray-400 mb-2">Hora Preferida (Server Time)</label>
                <input
                  type="time"
                  x-model="formData.preferred_time"
                  class="w-full bg-black/50 border border-gray-800 rounded-lg px-4 py-2 text-white outline-none"
                />
              </div>
            </div>
          </div>

          <!-- Navegación -->
          <div class="flex justify-between mt-12">
            <button
              x-show="step > 1"
              @click="goToStep(step - 1)"
              class="px-6 py-2 text-gray-400 hover:text-white transition-colors"
            >
              Anterior
            </button>
            <div class="flex-1"></div>
            <button
              @click="nextStep"
              class="px-8 py-2 bg-amber-600 hover:bg-amber-700 text-white font-bold rounded-lg transition-colors disabled:opacity-50"
              :disabled="!isStepValid()"
            >
              <span x-text="step === totalSteps ? 'Enviar Voto' : 'Siguiente'"></span>
            </button>
          </div>
        </div>

        <!-- Mensaje de éxito -->
        <div x-show="completed" x-ref="successContent" class="text-center py-12" x-transition>
          <div
            class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
          </div>
          <h2 class="text-2xl font-bold text-white mb-2">¡Voto Registrado!</h2>
          <p class="text-gray-400 mb-8">Gracias por ayudarnos a organizar las raids.</p>
          <button @click="reset" class="text-amber-500 hover:underline"> Enviar otro voto </button>
        </div>
      </section>

      <!-- Resumen de Votos (Alpine.js) -->
      <section x-data="voteSummary" class="space-y-6">
        <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
          <div class="flex flex-col gap-1">
            <h2 class="text-2xl font-black text-white uppercase tracking-tighter italic">Resumen de Interés</h2>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Consulta los horarios más votados por la hermandad</p>
          </div>
          <div class="flex bg-gray-900 p-1 rounded-lg border border-gray-800">
            <button
              @click="currentTab = 'list'"
              class="px-4 py-1.5 rounded-md text-sm font-medium transition-all"
              :class="currentTab === 'list' ? 'bg-amber-600 text-white shadow-lg' : 'text-gray-400 hover:text-white'"
            >
              Lista
            </button>
            <button
              @click="currentTab = 'map'"
              class="px-4 py-1.5 rounded-md text-sm font-medium transition-all"
              :class="currentTab === 'map' ? 'bg-amber-600 text-white shadow-lg' : 'text-gray-400 hover:text-white'"
            >
              Mapa Visual
            </button>
          </div>
        </div>

        <!-- Vista de Lista -->
        <div x-show="currentTab === 'list'" class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <template x-for="raid in raids" :key="raid.id">
            <div
              class="bg-gray-900/40 border border-gray-800 rounded-xl overflow-hidden shadow-2xl transition-all hover:border-amber-500/30 group"
            >
              <!-- Cabecera Compacta -->
              <div
                class="px-5 py-3 flex items-center justify-between bg-gradient-to-r from-gray-800/50 to-transparent border-b border-gray-800"
              >
                <div class="flex items-center gap-3">
                  <div class="w-2 h-8 bg-amber-500 rounded-full"></div>
                  <span class="text-lg font-black text-white tracking-tighter uppercase italic" x-text="raid.id"></span>
                </div>
                <span
                  class="text-[10px] font-black text-amber-500 bg-amber-500/10 px-2 py-1 rounded-md border border-amber-500/20 uppercase"
                  x-text="getCount(raid.id) + ' votos'"></span>
              </div>

              <!-- Contenido Siempre Visible -->
              <div class="p-4 bg-black/20">
                <div class="grid grid-cols-1 gap-2">
                  <template x-for="voto in getGroupedVotes(raid.id)" :key="voto.key">
                    <button
                      @click="voteLikeThis(voto)"
                      class="w-full text-left p-3 bg-gray-800/30 rounded-lg border border-white/5 flex justify-between items-center hover:bg-amber-600/10 hover:border-amber-600/40 transition-all group/item relative overflow-hidden"
                    >
                      <div class="flex items-center gap-3">
                        <div
                          class="w-8 h-8 rounded-lg bg-amber-600/10 flex items-center justify-center text-amber-500 group-hover/item:bg-amber-600 group-hover/item:text-white transition-all shadow-inner border border-amber-500/20"
                        >
                          <span class="text-sm font-black" x-text="voto.count"></span>
                        </div>
                        <div>
                          <div
                            class="text-xs font-black text-gray-200 group-hover/item:text-amber-400 transition-colors flex items-center gap-1.5"
                          >
                            <span x-text="voto.raid_name"></span>
                            <span class="text-gray-600">|</span>
                            <span x-text="voto.difficulty"></span>
                            <span class="text-gray-600">|</span>
                            <span x-text="voto.size" class="text-amber-500/90 font-mono"></span>
                          </div>
                          <div
                            class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-0.5"
                          >
                            Día: <span class="text-gray-400" x-text="voto.day_of_week"></span>
                          </div>
                        </div>
                      </div>
                      <div class="text-right">
                        <div
                          class="text-xs text-amber-500 font-black font-mono bg-black/40 px-2 py-1 rounded border border-white/5"
                          x-text="voto.preferred_time"
                        >
                        </div>
                      </div>
                    </button>
                  </template>
                  <div
                    x-show="getCount(raid.id) === 0"
                    class="text-center py-6 text-gray-600 text-xs italic bg-black/10 rounded-lg border border-dashed border-gray-800"
                  >
                    Sin votos aún.
                  </div>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Vista de Mapa Visual (Plano Cartesiano) -->
        <div
          x-show="currentTab === 'map'"
          class="bg-gray-900/50 border border-gray-800 rounded-lg p-6 shadow-2xl overflow-x-auto"
        >
          <div class="min-w-[600px]">
            <!-- Leyenda de Días (Eje X) -->
            <div class="grid grid-cols-8 gap-2 mb-4">
              <div
                class="text-gray-600 text-[10px] font-bold uppercase flex items-center justify-center"
              >
                Hora
              </div>
              <template x-for="day in days" :key="day">
                <div
                  class="text-amber-500 text-[10px] font-black uppercase text-center py-2 bg-gray-800/30 rounded border border-gray-700/50"
                  x-text="day.substring(0,3)"
                >
                </div>
              </template>
            </div>

            <!-- Grid de Horas (Eje Y) -->
            <div class="space-y-2 relative">
              <!-- Grid Lines -->
              <div class="absolute inset-0 grid grid-cols-8 gap-2 pointer-events-none opacity-10">
                <template x-for="i in 8" :key="i">
                  <div class="border-r border-gray-500 h-full"></div>
                </template>
              </div>

              <template
                x-for="hour in getUniqueHours()"
                :key="hour"
              >
                <div class="grid grid-cols-8 gap-2 h-16">
                  <div
                    class="text-gray-500 text-xs font-mono flex items-center justify-center border-r border-gray-800"
                    x-text="hour"
                  >
                  </div>

                  <template
                    x-for="dayName in days"
                    :key="dayName"
                  >
                    <div
                      class="relative bg-black/20 rounded-lg border border-gray-800/30 flex items-center justify-center"
                    >
                      <div class="flex flex-wrap gap-1 p-1 justify-center relative">
                        <template
                          x-for="voto in getMapGroupedVotes(dayName, hour)"
                          :key="voto.key"
                        >
                          <div
                            @click="voteLikeThis(voto)"
                            class="w-6 h-6 rounded-md cursor-pointer hover:scale-125 transition-transform flex items-center justify-center relative group/mapitem hover:z-[110]"
                            :class="getRaidStyle(voto).classes"
                          >
                            <i class="fas text-[10px] text-white/90" :class="getRaidStyle(voto).isHeroic ? 'fa-bolt animate-pulse' : getRaidStyle(voto).icon"></i>
                            
                            <!-- Contador de votos agrupados -->
                            <template x-if="voto.count > 1">
                              <div class="absolute -top-1.5 -right-1.5 bg-amber-500 text-black text-[8px] font-black px-1 rounded-full border border-black shadow-sm z-20">
                                <span x-text="voto.count + 'x'"></span>
                              </div>
                            </template>

                            <!-- Tooltip personalizado al pasar el mouse -->
                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover/mapitem:block z-[100] pointer-events-none">
                              <div class="bg-gray-950 text-white text-[9px] font-black px-2 py-1.5 rounded-lg border border-white/20 whitespace-nowrap shadow-[0_0_20px_rgba(0,0,0,0.8)] flex items-center gap-2">
                                <div class="w-1.5 h-1.5 rounded-full" :class="getRaidStyle(voto).classes.split(' ')[0]"></div>
                                <div>
                                  <span x-text="voto.raid_name"></span> | <span x-text="voto.difficulty"></span> | <span x-text="voto.size"></span>
                                  <div class="text-[8px] text-gray-400 mt-0.5" x-text="voto.count + ' personas interesadas'"></div>
                                </div>
                              </div>
                              <!-- Flechita del tooltip -->
                              <div class="w-2 h-2 bg-gray-950 border-r border-b border-white/20 rotate-45 absolute -bottom-1 left-1/2 -translate-x-1/2"></div>
                            </div>
                          </div>
                        </template>
                      </div>
                    </div>
                  </template>
                </div>
              </template>
            </div>

            <!-- Leyenda de Colores e Iconos Mejorada -->
            <div class="mt-12 pt-8 border-t border-gray-800">
              <div class="flex flex-wrap justify-center gap-x-16 gap-y-10">
                <!-- Colores e Iconos por Raid -->
                <div class="flex flex-col gap-4">
                  <span class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] text-center">Identificadores de Banda</span>
                  <div class="flex items-center gap-8">
                    <div class="flex items-center gap-3 group/leg">
                      <div class="w-8 h-8 rounded-lg bg-blue-500 flex items-center justify-center shadow-lg shadow-blue-500/20 border border-white/10 group-hover/leg:scale-110 transition-transform">
                        <i class="fas fa-chess-rook text-white text-sm"></i>
                      </div>
                      <span class="text-xs text-gray-300 font-black uppercase tracking-wider">ICC</span>
                    </div>
                    <div class="flex items-center gap-3 group/leg">
                      <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-500/20 border border-white/10 group-hover/leg:scale-110 transition-transform">
                        <i class="fas fa-shield-halved text-white text-sm"></i>
                      </div>
                      <span class="text-xs text-gray-300 font-black uppercase tracking-wider">TOC</span>
                    </div>
                    <div class="flex items-center gap-3 group/leg">
                      <div class="w-8 h-8 rounded-lg bg-red-500 flex items-center justify-center shadow-lg shadow-red-500/20 border border-white/10 group-hover/leg:scale-110 transition-transform">
                        <i class="fas fa-dragon text-white text-sm"></i>
                      </div>
                      <span class="text-xs text-gray-300 font-black uppercase tracking-wider">SR</span>
                    </div>
                  </div>
                </div>

                <!-- Indicadores de Dificultad y Tamaño -->
                <div class="flex flex-col gap-4 px-12 border-l border-gray-800">
                  <span class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] text-center">Modificadores Visuales</span>
                  <div class="flex items-center gap-10">
                    <div class="flex items-center gap-3">
                      <div class="flex -space-x-2">
                        <div class="w-7 h-7 rounded-md bg-gray-500 border border-white/10 z-0"></div>
                        <div class="w-7 h-7 rounded-md bg-gray-400 border border-white/40 ring-2 ring-white/30 shadow-[0_0_15px_rgba(255,255,255,0.4)] z-10 flex items-center justify-center">
                          <i class="fas fa-bolt text-[10px] text-white animate-pulse"></i>
                        </div>
                      </div>
                      <div class="text-[10px] leading-tight">
                        <p class="text-gray-200 font-black uppercase">Normal vs Heroico</p>
                        <p class="text-gray-500 font-bold tracking-tighter">Brillo intenso + Icono de Rayo</p>
                      </div>
                    </div>
                    
                    <div class="flex items-center gap-3">
                      <div class="flex items-end -space-x-2">
                        <div class="w-5 h-5 rounded-md bg-gray-700 border border-white/10 scale-90"></div>
                        <div class="w-8 h-8 rounded-md bg-gray-600 border-2 border-white/60 shadow-xl z-10 flex items-center justify-center">
                          <span class="text-[8px] font-black text-white">25</span>
                        </div>
                      </div>
                      <div class="text-[10px] leading-tight">
                        <p class="text-gray-200 font-black uppercase">10m vs 25m</p>
                        <p class="text-gray-500 font-bold tracking-tighter">Mayor tamaño + Borde marcado</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    // Lógica del Formulario
    Alpine.data('recruitmentForm', () => ({
      step: 1,
      totalSteps: 3,
      completed: false,
      height: 0,
      formData: {
        raid_name: '',
        difficulty: '',
        size: '',
        day_of_week: '',
        preferred_time: '',
      },
      raids: [
        { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
        { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
        { id: 'SR', name: 'Sagrario Rubí (SR)' },
      ],
      difficulties: ['Normal', 'Heroica'],
      sizes: ['10', '25'],
      days: ['Lunes', 'Martes', 'Miercoles', 'Jueves', 'Viernes', 'Sabado', 'Domingo'],

      init() {
        this.$nextTick(() => {
          this.updateHeight();
        });
      },

      updateHeight() {
        const content = this.completed ? this.$refs.successContent : this.$refs.formContent;
        if (content) {
          this.height = content.offsetHeight + 48; // Padding
        }
      },

      goToStep(n) {
        this.step = n;
        this.$nextTick(() => this.updateHeight());
      },

      isStepValid() {
        if (this.step === 1) return this.formData.raid_name !== '';
        if (this.step === 2) return this.formData.difficulty !== '' && this.formData.size !== '';
        if (this.step === 3)
          return this.formData.day_of_week !== '' && this.formData.preferred_time !== '';
        return false;
      },

      async nextStep() {
        if (this.step < this.totalSteps) {
          this.goToStep(this.step + 1);
        } else {
          await this.submit();
        }
      },

      async submit() {
        try {
          const response = await fetch('/api/schedule-vote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.formData),
          });

          const result = await response.json();

          if (response.ok) {
            this.completed = true;
            this.$nextTick(() => this.updateHeight());
            
            // Notificar al resumen para que se actualice
            window.dispatchEvent(new CustomEvent('vote-submitted'));

            // Mostrar notificación de recompensa si ganamos un turno
            if (result.rewarded && window.showRewardToast) {
              window.showRewardToast('¡Por participar en el voto de horario!');
            }
          } else {
            alert(result.error || 'Hubo un error al registrar tu voto.');
          }
        } catch (err) {
          console.error('Error:', err);
          alert('Error de conexión al servidor.');
        }
      },

      reset() {
        this.formData = {
          raid_name: '',
          difficulty: '',
          size: '',
          day_of_week: '',
          preferred_time: '',
        };
        this.completed = false;
        this.goToStep(1);
      },
    }));

    // Lógica del Resumen de Votos
    Alpine.data('voteSummary', () => ({
      open: ['ICC', 'TOC', 'SR'],
      votes: [],
      currentTab: 'list',
      raids: [
        { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
        { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
        { id: 'SR', name: 'Sagrario Rubí (SR)' },
      ],
      days: ['Lunes', 'Martes', 'Miercoles', 'Jueves', 'Viernes', 'Sabado', 'Domingo'],

      async init() {
        await this.loadVotes();
        window.addEventListener('vote-submitted', () => this.loadVotes());
      },

      async loadVotes() {
        try {
          const res = await fetch('/api/schedule-vote');
          this.votes = await res.json();
        } catch (err) {
          console.error('Error loading votes:', err);
        }
      },

      // Obtener todas las horas únicas que tienen votos para el mapa
      getUniqueHours() {
        const hours = new Set();
        this.votes.forEach(v => {
          if (v.preferred_time) {
            // Normalizar a formato HH:00 para el grid
            const hour = v.preferred_time.split(':')[0].padStart(2, '0') + ':00';
            hours.add(hour);
          }
        });
        
        // Si no hay votos, mostrar un rango base por defecto
        if (hours.size === 0) return ['18:00', '19:00', '20:00', '21:00', '22:00', '23:00', '00:00'];
        
        return Array.from(hours).sort((a, b) => {
          // Ordenar horas teniendo en cuenta el cruce de medianoche (ej: 00:00 va después de 23:00)
          const getVal = (h) => {
            const val = parseInt(h.split(':')[0]);
            return val < 6 ? val + 24 : val; // Horas de madrugada van al final
          };
          return getVal(a) - getVal(b);
        });
      },

      // Agrupar votos para el mapa visual (celda específica)
      getMapGroupedVotes(dayName, hour) {
        const cellVotes = this.votes.filter(v => 
          this.isSameDay(v.day_of_week, dayName) && 
          this.isSameHour(v.preferred_time, hour)
        );
        
        const groups = {};
        cellVotes.forEach(v => {
          const raid = (v.raid_name || '').trim().toUpperCase();
          const key = `${raid}-${v.difficulty}-${v.size}`;
          if (!groups[key]) {
            groups[key] = { ...v, count: 0, key };
          }
          groups[key].count++;
        });
        
        return Object.values(groups);
      },

      toggle(id) {
        if (this.open.includes(id)) {
          this.open = this.open.filter(i => i !== id);
        } else {
          this.open.push(id);
        }
      },

      getVotes(raidId) {
        return this.votes.filter((v) => v.raid_name.trim().toUpperCase() === raidId.trim().toUpperCase());
      },

      getGroupedVotes(raidId) {
        const raidVotes = this.getVotes(raidId);
        const groups = {};

        raidVotes.forEach((v) => {
          // Normalizar el nombre de la banda para agrupar (eliminar espacios/puntos extra)
          const normalizedRaidName = v.raid_name.trim().toUpperCase();
          const key = `${normalizedRaidName}-${v.difficulty}-${v.size}-${v.day_of_week}-${v.preferred_time}`;
          if (!groups[key]) {
            groups[key] = { ...v, raid_name: normalizedRaidName, count: 0, key };
          }
          groups[key].count++;
        });

        return Object.values(groups).sort((a, b) => b.count - a.count);
      },

      getCount(raidId) {
        return this.getVotes(raidId).length;
      },

      // Función de utilidad para comparar horas de forma robusta
      isSameHour(voteTime, gridHour) {
        if (!voteTime || !gridHour) return false;
        // Normalizar "1:00" a "01:00"
        const normalize = (t) => t.split(':')[0].padStart(2, '0');
        return normalize(voteTime) === normalize(gridHour);
      },

      // Función de utilidad para comparar días ignorando acentos
      isSameDay(day1, day2) {
        if (!day1 || !day2) return false;
        const normalize = (d) => d.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
        return normalize(day1) === normalize(day2);
      },

      getRaidStyle(voto) {
        const raid = (voto.raid_name || '').trim().toUpperCase();
        const diff = (voto.difficulty || '').trim().toLowerCase();
        const size = (voto.size || '').trim();
        const isHeroic = diff.includes('heroic') || diff.includes('heroica');

        // Mapa de colores base por Raid
        const baseColors = {
          'ICC': { normal: 'bg-blue-400', heroic: 'bg-blue-600', ring: 'ring-blue-500/50', icon: 'fa-chess-rook' },
          'TOC': { normal: 'bg-emerald-400', heroic: 'bg-emerald-600', ring: 'ring-emerald-500/50', icon: 'fa-shield-halved' },
          'SR': { normal: 'bg-red-400', heroic: 'bg-red-600', ring: 'ring-red-500/50', icon: 'fa-dragon' }
        };

        const colorSet = baseColors[raid] || { normal: 'bg-gray-400', heroic: 'bg-gray-600', ring: 'ring-gray-500/50', icon: 'fa-circle' };
        
        // 25m tienen un borde más grueso o sombra
        const sizeStyle = size === '25' ? 'border-white/40 border-2 scale-110 z-10' : 'border-white/10 border scale-90';
        const color = isHeroic ? colorSet.heroic : colorSet.normal;
        const heroicRing = isHeroic ? 'ring-2 ' + colorSet.ring + ' shadow-[0_0_10px_rgba(255,255,255,0.3)]' : '';

        return {
          classes: `${color} ${sizeStyle} ${heroicRing}`,
          icon: colorSet.icon,
          isHeroic,
          size
        };
      },

      async voteLikeThis(voto) {
        const confirmMsg = `¿Deseas votar por el mismo horario?\n\nBandas: ${voto.raid_name}\nDificultad: ${voto.difficulty}\nTamaño: ${voto.size}\nDía: ${voto.day_of_week.toUpperCase()}\nHora: ${voto.preferred_time}`;

        if (confirm(confirmMsg)) {
          try {
            const response = await fetch('/api/schedule-vote', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                raid_name: voto.raid_name,
                difficulty: voto.difficulty,
                size: voto.size,
                day_of_week: voto.day_of_week,
                preferred_time: voto.preferred_time,
              }),
            });

            const result = await response.json();

            if (response.ok) {
              alert('¡Voto registrado con éxito!');
              this.loadVotes();

              // Mostrar notificación de recompensa si ganamos un turno
              if (result.rewarded && window.showRewardToast) {
                window.showRewardToast('¡Por participar en el voto de horario!');
              }
            } else {
              alert(result.error || 'Hubo un error al procesar tu voto.');
            }
          } catch (err) {
            console.error('Error:', err);
            alert('Hubo un error de conexión.');
          }
        }
      },
    }));
  });
</script>

