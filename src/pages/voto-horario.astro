---
import Layout from '../components/layout/Layout.astro';

// Opciones dinámicas para el formulario
const raids = [
  { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
  { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
  { id: 'SR', name: 'Sagrario Rubí (SR)' },
];

const difficulties = ['Normal', 'Heroica'];
const sizes = ['10', '25'];
const days = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'];
---

<Layout title="Voto por horario | Colmillo de Acero">
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-white mb-4">🗳️ Voto por horario</h1>
      <p class="text-gray-400">Ayúdanos a organizar las próximas bandas según tu disponibilidad.</p>
    </div>

    <div>
      <!-- Formulario Paso a Paso (Alpine.js) -->
      <section
        x-data="recruitmentForm"
        class="mb-8 bg-gray-900/50 border border-gray-800 rounded-lg p-6 shadow-2xl backdrop-blur-sm transition-all duration-500 ease-in-out overflow-hidden"
        :style="'height: ' + height + 'px'"
        x-ref="container"
      >
        <div x-show="!completed" x-ref="formContent">
          <!-- Indicador de Progreso -->
          <div class="flex justify-between mb-8">
            <template x-for="n in totalSteps" :key="n">
              <div
                class="h-2 flex-1 mx-1 rounded-full transition-colors duration-300"
                :class="n <= step ? 'bg-amber-600' : 'bg-gray-800'"
              >
              </div>
            </template>
          </div>

          <!-- Paso 1: Selección de Banda -->
          <div
            x-show="step === 1"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">¿Qué banda buscas?</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm text-gray-400 mb-1">Selecciona la Banda</label>
                <div class="grid grid-cols-1 gap-2">
                  <template x-for="raid in raids" :key="raid.id">
                    <button
                      @click="formData.raid_name = raid.id; setTimeout(() => goToStep(2), 300)"
                      class="px-4 py-3 rounded-lg border text-left transition-all"
                      :class="formData.raid_name === raid.id ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400 hover:border-gray-600'"
                    >
                      <span x-text="raid.name"></span>
                    </button>
                  </template>
                </div>
              </div>
            </div>
          </div>

          <!-- Paso 2: Dificultad y Tamaño -->
          <div
            x-show="step === 2"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">Dificultad y Tamaño</h2>
            <div class="space-y-6">
              <div>
                <label class="block text-sm text-gray-400 mb-2">Dificultad</label>
                <div class="flex gap-4">
                  <template x-for="diff in difficulties" :key="diff">
                    <button
                      @click="formData.difficulty = diff; if(formData.size) setTimeout(() => goToStep(3), 300)"
                      class="flex-1 py-3 rounded-lg border transition-all"
                      :class="formData.difficulty === diff ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400'"
                      x-text="diff"></button>
                  </template>
                </div>
              </div>
              <div>
                <label class="block text-sm text-gray-400 mb-2">Tamaño de Banda</label>
                <div class="flex gap-4">
                  <template x-for="size in sizes" :key="size">
                    <button
                      @click="formData.size = size; if(formData.difficulty) setTimeout(() => goToStep(3), 300)"
                      class="flex-1 py-3 rounded-lg border transition-all"
                      :class="formData.size === size ? 'bg-amber-600/20 border-amber-600 text-white' : 'bg-black/30 border-gray-800 text-gray-400'"
                      x-text="size + ' Jugadores'"></button>
                  </template>
                </div>
              </div>
            </div>
          </div>

          <!-- Paso 3: Día y Hora -->
          <div
            x-show="step === 3"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 transform translate-x-4"
            x-transition:enter-end="opacity-100 transform translate-x-0"
          >
            <h2 class="text-xl font-semibold text-white mb-6">¿Cuándo podrías asistir?</h2>
            <div class="space-y-6">
              <div>
                <label class="block text-sm text-gray-400 mb-2">Día de la Semana</label>
                <select
                  x-model="formData.day_of_week"
                  class="w-full bg-black/50 border border-gray-800 rounded-lg px-4 py-2 text-white outline-none"
                >
                  <option value="">Selecciona un día</option>
                  <template x-for="day in days" :key="day">
                    <option :value="day.toLowerCase()" x-text="day"></option>
                  </template>
                </select>
              </div>
              <div>
                <label class="block text-sm text-gray-400 mb-2">Hora Preferida (Server Time)</label>
                <input
                  type="time"
                  x-model="formData.preferred_time"
                  class="w-full bg-black/50 border border-gray-800 rounded-lg px-4 py-2 text-white outline-none"
                />
              </div>
            </div>
          </div>

          <!-- Navegación -->
          <div class="flex justify-between mt-12">
            <button
              x-show="step > 1"
              @click="goToStep(step - 1)"
              class="px-6 py-2 text-gray-400 hover:text-white transition-colors"
            >
              Anterior
            </button>
            <div class="flex-1"></div>
            <button
              @click="nextStep"
              class="px-8 py-2 bg-amber-600 hover:bg-amber-700 text-white font-bold rounded-lg transition-colors disabled:opacity-50"
              :disabled="!isStepValid()"
            >
              <span x-text="step === totalSteps ? 'Enviar Voto' : 'Siguiente'"></span>
            </button>
          </div>
        </div>

        <!-- Mensaje de éxito -->
        <div x-show="completed" x-ref="successContent" class="text-center py-12" x-transition>
          <div
            class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6"
          >
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
          </div>
          <h2 class="text-2xl font-bold text-white mb-2">¡Voto Registrado!</h2>
          <p class="text-gray-400 mb-8">Gracias por ayudarnos a organizar las raids.</p>
          <button @click="reset" class="text-amber-500 hover:underline"> Enviar otro voto </button>
        </div>
      </section>

      <!-- Resumen de Votos (Alpine.js) -->
      <section x-data="voteSummary" class="space-y-6">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-2xl font-bold text-white">Resumen de Interés</h2>
          <div class="flex bg-gray-800/50 p-1 rounded-lg border border-gray-700">
            <button
              @click="currentTab = 'list'"
              class="px-4 py-1.5 rounded-md text-sm font-medium transition-all"
              :class="currentTab === 'list' ? 'bg-amber-600 text-white shadow-lg' : 'text-gray-400 hover:text-white'"
            >
              Lista
            </button>
            <button
              @click="currentTab = 'map'"
              class="px-4 py-1.5 rounded-md text-sm font-medium transition-all"
              :class="currentTab === 'map' ? 'bg-amber-600 text-white shadow-lg' : 'text-gray-400 hover:text-white'"
            >
              Mapa Visual
            </button>
          </div>
        </div>

        <!-- Vista de Lista -->
        <div x-show="currentTab === 'list'" class="space-y-4">
          <template x-for="raid in raids" :key="raid.id">
            <div
              class="bg-gray-900/30 border border-gray-800 rounded-lg overflow-hidden shadow-lg transition-all hover:border-gray-700"
            >
              <!-- Cabecera Expansible -->
              <button
                @click="toggle(raid.id)"
                class="w-full px-6 py-4 flex items-center justify-between hover:bg-gray-800/50 transition-colors"
              >
                <div class="flex items-center gap-4">
                  <span class="text-xl font-bold text-white" x-text="raid.id"></span>
                  <span
                    class="text-sm text-amber-500/80 font-mono bg-amber-500/10 px-2 py-0.5 rounded"
                    x-text="getCount(raid.id) + ' votos'"></span>
                </div>
                <svg
                  class="w-5 h-5 text-gray-500 transition-transform"
                  :class="open === raid.id ? 'rotate-180' : ''"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>

              <!-- Contenido Expansible -->
              <div x-show="open === raid.id" x-collapse>
                <div class="px-6 py-4 border-t border-gray-800 bg-black/20">
                  <div class="grid grid-cols-1 gap-3">
                    <template x-for="voto in getGroupedVotes(raid.id)" :key="voto.key">
                      <button
                        @click="voteLikeThis(voto)"
                        class="w-full text-left p-4 bg-gray-800/40 rounded-lg border border-gray-700/50 flex justify-between items-center hover:bg-amber-600/10 hover:border-amber-600/50 transition-all group relative overflow-hidden"
                      >
                        <div class="flex items-center gap-4">
                          <div
                            class="w-10 h-10 rounded-full bg-amber-600/20 flex items-center justify-center text-amber-500 group-hover:bg-amber-600 group-hover:text-white transition-all shadow-inner"
                          >
                            <span class="text-lg font-black" x-text="voto.count"></span>
                          </div>
                          <div>
                            <div
                              class="text-white font-bold group-hover:text-amber-400 transition-colors flex items-center gap-2"
                            >
                              <span x-text="voto.difficulty"></span>
                              <span class="text-gray-600">•</span>
                              <span x-text="voto.size" class="text-amber-500/90 font-mono"></span>
                            </div>
                            <div
                              class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mt-0.5 group-hover:text-gray-400 transition-colors"
                            >
                              Votado por <span x-text="voto.count"></span> personas
                            </div>
                          </div>
                        </div>
                        <div class="text-right">
                          <div
                            class="text-amber-500 text-xs font-black uppercase tracking-tighter"
                            x-text="voto.day_of_week"
                          >
                          </div>
                          <div
                            class="text-[10px] text-gray-400 font-mono bg-black/40 px-1.5 py-0.5 rounded mt-1 border border-white/5"
                            x-text="voto.preferred_time"
                          >
                          </div>
                        </div>

                        <!-- Mini badge indicator -->
                        <div
                          class="absolute -top-1 -right-4 bg-amber-600 text-white text-[8px] font-bold px-5 py-1 rotate-45 shadow-sm transform group-hover:scale-110 transition-transform"
                        >
                          <span x-text="voto.count"></span>
                        </div>
                      </button>
                    </template>
                    <div
                      x-show="getCount(raid.id) === 0"
                      class="text-center py-8 text-gray-600 italic bg-black/10 rounded-lg"
                    >
                      No hay votos para esta banda aún.
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Vista de Mapa Visual (Plano Cartesiano) -->
        <div
          x-show="currentTab === 'map'"
          class="bg-gray-900/50 border border-gray-800 rounded-lg p-6 shadow-2xl overflow-x-auto"
        >
          <div class="min-w-[600px]">
            <!-- Leyenda de Días (Eje X) -->
            <div class="grid grid-cols-8 gap-2 mb-4">
              <div
                class="text-gray-600 text-[10px] font-bold uppercase flex items-center justify-center"
              >
                Hora
              </div>
              <template x-for="day in days" :key="day">
                <div
                  class="text-amber-500 text-[10px] font-black uppercase text-center py-2 bg-gray-800/30 rounded border border-gray-700/50"
                  x-text="day.substring(0,3)"
                >
                </div>
              </template>
            </div>

            <!-- Grid de Horas (Eje Y) -->
            <div class="space-y-2 relative">
              <!-- Grid Lines -->
              <div class="absolute inset-0 grid grid-cols-8 gap-2 pointer-events-none opacity-10">
                <template x-for="i in 8" :key="i">
                  <div class="border-r border-gray-500 h-full"></div>
                </template>
              </div>

              <template
                x-for="hour in ['18:00', '19:00', '20:00', '21:00', '22:00', '23:00', '00:00', '01:00']"
                :key="hour"
              >
                <div class="grid grid-cols-8 gap-2 h-16">
                  <div
                    class="text-gray-500 text-xs font-mono flex items-center justify-center border-r border-gray-800"
                    x-text="hour"
                  >
                  </div>

                  <template
                    x-for="dayName in ['lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado', 'domingo']"
                    :key="dayName"
                  >
                    <div
                      class="relative bg-black/20 rounded-lg border border-gray-800/30 flex items-center justify-center overflow-hidden"
                    >
                      <div class="flex flex-wrap gap-1 p-1 justify-center">
                        <template
                          x-for="voto in votes.filter(v => v.day_of_week === dayName && v.preferred_time.startsWith(hour.split(':')[0]))"
                          :key="voto.id"
                        >
                          <div
                            @click="voteLikeThis(voto)"
                            class="w-3 h-3 rounded-sm cursor-pointer hover:scale-150 transition-transform shadow-sm"
                            :class="{
                              'bg-blue-500': voto.raid_name === 'ICC',
                              'bg-green-500': voto.raid_name === 'TOC',
                              'bg-red-500': voto.raid_name === 'SR'
                            }"
                            :title="voto.raid_name + ' ' + voto.difficulty + ' ' + voto.size"
                          >
                          </div>
                        </template>
                      </div>
                    </div>
                  </template>
                </div>
              </template>
            </div>

            <!-- Leyenda de Colores -->
            <div class="flex justify-center gap-6 mt-8 pt-6 border-t border-gray-800">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-sm bg-blue-500"></div>
                <span class="text-xs text-gray-400 font-bold uppercase">ICC</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-sm bg-green-500"></div>
                <span class="text-xs text-gray-400 font-bold uppercase">TOC</span>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-sm bg-red-500"></div>
                <span class="text-xs text-gray-400 font-bold uppercase">SR</span>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    // Lógica del Formulario
    Alpine.data('recruitmentForm', () => ({
      step: 1,
      totalSteps: 3,
      completed: false,
      height: 0,
      formData: {
        raid_name: '',
        difficulty: '',
        size: '',
        day_of_week: '',
        preferred_time: '',
      },
      raids: [
        { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
        { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
        { id: 'SR', name: 'Sagrario Rubí (SR)' },
      ],
      difficulties: ['Normal', 'Heroica'],
      sizes: ['10', '25'],
      days: ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'],

      init() {
        this.$nextTick(() => {
          this.updateHeight();
        });
      },

      updateHeight() {
        const content = this.completed ? this.$refs.successContent : this.$refs.formContent;
        if (content) {
          this.height = content.offsetHeight + 48; // Padding
        }
      },

      goToStep(n) {
        this.step = n;
        this.$nextTick(() => this.updateHeight());
      },

      isStepValid() {
        if (this.step === 1) return this.formData.raid_name !== '';
        if (this.step === 2) return this.formData.difficulty !== '' && this.formData.size !== '';
        if (this.step === 3)
          return this.formData.day_of_week !== '' && this.formData.preferred_time !== '';
        return false;
      },

      async nextStep() {
        if (this.step < this.totalSteps) {
          this.goToStep(this.step + 1);
        } else {
          await this.submit();
        }
      },

      async submit() {
        try {
          const response = await fetch('/api/schedule-vote', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.formData),
          });

          const result = await response.json();

          if (response.ok) {
            this.completed = true;
            this.$nextTick(() => this.updateHeight());
            
            // Notificar al resumen para que se actualice
            window.dispatchEvent(new CustomEvent('vote-submitted'));

            // Mostrar notificación de recompensa si ganamos un turno
            if (result.rewarded && window.showRewardToast) {
              window.showRewardToast('¡Por participar en el voto de horario!');
            }
          } else {
            alert(result.error || 'Hubo un error al registrar tu voto.');
          }
        } catch (err) {
          console.error('Error:', err);
          alert('Error de conexión al servidor.');
        }
      },

      reset() {
        this.formData = {
          raid_name: '',
          difficulty: '',
          size: '',
          day_of_week: '',
          preferred_time: '',
        };
        this.completed = false;
        this.goToStep(1);
      },
    }));

    // Lógica del Resumen de Votos
    Alpine.data('voteSummary', () => ({
      open: 'ICC',
      votes: [],
      currentTab: 'list',
      raids: [
        { id: 'ICC', name: 'Ciudadela de la Corona de Hielo (ICC)' },
        { id: 'TOC', name: 'Prueba del Cruzado (TOC)' },
        { id: 'SR', name: 'Sagrario Rubí (SR)' },
      ],
      days: ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'],

      async init() {
        await this.loadVotes();
        window.addEventListener('vote-submitted', () => this.loadVotes());
      },

      async loadVotes() {
        try {
          const res = await fetch('/api/schedule-vote');
          this.votes = await res.json();
        } catch (err) {
          console.error('Error loading votes:', err);
        }
      },

      toggle(id) {
        this.open = this.open === id ? null : id;
      },

      getVotes(raidId) {
        return this.votes.filter((v) => v.raid_name === raidId);
      },

      getGroupedVotes(raidId) {
        const raidVotes = this.getVotes(raidId);
        const groups = {};

        raidVotes.forEach((v) => {
          const key = `${v.raid_name}-${v.difficulty}-${v.size}-${v.day_of_week}-${v.preferred_time}`;
          if (!groups[key]) {
            groups[key] = { ...v, count: 0, key };
          }
          groups[key].count++;
        });

        return Object.values(groups).sort((a, b) => b.count - a.count);
      },

      getCount(raidId) {
        return this.getVotes(raidId).length;
      },

      async voteLikeThis(voto) {
        const confirmMsg = `¿Deseas votar por el mismo horario?\n\nBandas: ${voto.raid_name}\nDificultad: ${voto.difficulty}\nTamaño: ${voto.size}\nDía: ${voto.day_of_week.toUpperCase()}\nHora: ${voto.preferred_time}`;

        if (confirm(confirmMsg)) {
          try {
            const response = await fetch('/api/schedule-vote', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                raid_name: voto.raid_name,
                difficulty: voto.difficulty,
                size: voto.size,
                day_of_week: voto.day_of_week,
                preferred_time: voto.preferred_time,
              }),
            });

            const result = await response.json();

            if (response.ok) {
              alert('¡Voto registrado con éxito!');
              this.loadVotes();

              // Mostrar notificación de recompensa si ganamos un turno
              if (result.rewarded && window.showRewardToast) {
                window.showRewardToast('¡Por participar en el voto de horario!');
              }
            } else {
              alert(result.error || 'Hubo un error al procesar tu voto.');
            }
          } catch (err) {
            console.error('Error:', err);
            alert('Hubo un error de conexión.');
          }
        }
      },
    }));
  });
</script>

<style>
  input[type='time']::-webkit-calendar-picker-indicator {
    filter: invert(1);
    cursor: pointer;
  }
</style>
