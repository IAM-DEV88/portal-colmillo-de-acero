---
import Layout from '../components/layout/Layout.astro';
import { RAID_RULES, GENERAL_RULES, BOE_PRICES, FARM_PRICES, GUILD_RULES } from '../data/raidRules';

// SEO y metadatos
const title = "Reglas";
const description = "Consulta las reglas de loteo y normas de conducta para las raids de la hermandad Colmillo de Acero.";
---

<Layout title={title} description={description}>
  <main class="relative min-h-screen p-4">
    <div class="max-w-7xl mx-auto">
      {/* Encabezado Principal */}
      <div id="reglas-hermandad" class="flex flex-col md:flex-row md:justify-between md:items-end gap-4 px-2 mb-10">
        <div class="flex items-center space-x-4">
          <div class="w-12 h-12 bg-gradient-to-br from-amber-600 to-amber-800 rounded-lg flex items-center justify-center shadow-lg shadow-amber-900/20 transform -rotate-2 hover:rotate-0 transition-transform duration-300">
            <svg fill="#000000" viewBox="0 0 32 32" version="1.1" xmlns="http://www.w3.org/2000/svg">
              <title>scroll-unfurled</title>
              <path d="M26.693 23.878h-4.43l-0.042-0.076c0.016-2.709 1.069-5.48 3.069-7.666 1.495-1.633 2.623-3.783 3.202-5.918l-2.573-1.556 2.388-0.431-2.706-1.61 3.253-0.552c-0.326-2.442-1.8-4.25-4.828-4.25-2.955 0.574-11.374 0.749-15.729 0.185-0.552-0.18-1.108-0.285-1.651-0.304-0.004-0.001-0.008-0.002-0.012-0.003 0.002 0.001 0.005 0.002 0.007 0.003-1.416-0.047-2.738 0.501-3.647 1.882-1.263 1.919 0.082 5.213 3.046 5.213 0.167 0 0.32-0.009 0.46-0.026v0.023h3.702c-0.56 2.257-1.949 4.767-3.557 7.296-0.135 0.212-0.266 0.429-0.393 0.649l2.177 2.23-3.511 0.588c-2.042 5.364-1.711 11.361 3.013 11.361v-0l0.489 0.003v0.007h5.349v-0.010h14.097c4.25 0 4.833-7.039-1.171-7.039zM14.134 27.263c-0-0.029-0.001-0.059-0.002-0.089 0.001 0.030 0.002 0.059 0.002 0.089zM13.997 26.144c0.001 0.004 0.001 0.007 0.002 0.011-0.001-0.004-0.001-0.007-0.002-0.011-0.168-0.741-0.649-1.358-1.278-1.755h0c0.629 0.398 1.11 1.015 1.278 1.755zM14.128 27.071c-0.001-0.030-0.003-0.060-0.005-0.090 0.002 0.030 0.004 0.060 0.005 0.090zM14.114 26.871c-0.003-0.030-0.006-0.060-0.009-0.090 0.003 0.030 0.006 0.060 0.009 0.090zM14.090 26.662c-0.004-0.029-0.008-0.058-0.012-0.087 0.005 0.029 0.008 0.058 0.012 0.087zM14.055 26.439c-0.005-0.025-0.008-0.050-0.013-0.076 0.005 0.026 0.009 0.051 0.013 0.076zM7.393 8.433c0.876-0.746-0.036-2.509-1.085-3.976h3.617c0.605 1.167 0.667 2.514 0.358 3.976h-2.89zM10.181 24.754c1.618-0.538 3.452 0.49 3.816 2.094 0.062 0.274 0.102 0.533 0.122 0.778 0.002-0.026 0.004-0.052 0.005-0.078-0.040 0.579-0.212 1.061-0.488 1.459h-0.032c-0.031 0.044-0.063 0.087-0.096 0.128l0.050-0.022c-0.463 0.605-1.173 1.009-2.018 1.27h-0.878l0.043-0.019c-0.925-0-1.988-0.087-1.988-0.087 1.373-0.022 1.964-0.603 2.19-1.269-0.978 0.355-2.020-0.284-2.348-1.227-0.443-1.273 0.391-2.618 1.622-3.027zM14.132 27.362c-0.001 0.029-0.001 0.058-0.002 0.086 0.001-0.028 0.001-0.057 0.002-0.086zM13.563 29.108c0.025-0.033 0.049-0.066 0.073-0.099-0.023 0.034-0.048 0.067-0.073 0.099z"></path>
            </svg>
          </div>
          <div>
            <span class="text-sm md:text-3xl font-black text-white uppercase tracking-tighter italic block">
              Codigo <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-200 pr-1">Colmillo</span>
            </span>
            <span class="text-amber-300/60 font-medium tracking-widest uppercase text-[10px] flex items-center space-x-1">
              <span class="self-end">Código de conducta y normas oficiales</span>
            </span>
          </div>
        </div>
      </div>

      {/* Filtros de Navegación (Por Banda y Dificultad) */}
      <nav class="flex flex-wrap justify-center gap-3 mb-10" id="raid-filters">
        {RAID_RULES.map((raid, index) => (
          <button 
            class={`filter-btn px-5 py-2 rounded-lg transition-all font-bold uppercase tracking-wider text-xs md:text-sm border ${index === 0 ? 'active bg-amber-600 text-white border-amber-400 shadow-lg shadow-amber-500/20' : 'bg-gray-900/40 text-gray-300 border-amber-600/30 hover:border-amber-500/60 hover:bg-amber-900/20 shadow-xl backdrop-blur-sm'}`}
            data-filter={raid.raidId}
          >
            {raid.title}
          </button>
        ))}
      </nav>

      {/* Grid de Reglas por Banda (Visualización Única) */}
      <div class="flex w-full mb-12" id="rules-grid">
        {RAID_RULES.map((raid, index) => (
          <div 
            id={`card-${raid.raidId}`} 
            class="rule-card w-full bg-gradient-to-br from-amber-900/20 via-gray-900/90 to-amber-800/10 backdrop-blur-sm border border-amber-600/30 rounded-lg overflow-hidden flex-col shadow-2xl transition-all duration-300 hover:border-amber-500/60 group"
            data-type={raid.raidId}
            data-alias={raid.alias ? JSON.stringify(raid.alias) : '[]'}
            style={index === 0 ? "display: flex;" : "display: none;"}
          >
            {/* Header de la Banda */}
            <div class="px-6 py-6 bg-gradient-to-r from-gray-900/80 to-gray-800/40 border-b border-amber-600/30 flex justify-center items-center text-center relative">
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/90 to-transparent pointer-events-none" />
              <h3 class="text-2xl md:text-4xl font-black text-white group-hover:text-amber-400 transition-colors uppercase tracking-tight italic z-10">
                {raid.title}
              </h3>
            </div>

            <div class="p-4 md:p-8 space-y-12 flex-grow">
              {/* Contenido Especial para Reglas de Hermandad */}
              {raid.raidId === 'GUILD' && (
                <div class="space-y-12">
                  {/* Grid de Reglas Generales de Hermandad */}
                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {GUILD_RULES.map((section) => (
                      <div class="bg-gradient-to-br from-amber-900/10 via-gray-900/40 to-amber-800/5 backdrop-blur-sm border border-amber-600/20 rounded-lg p-6 hover:border-amber-500/40 transition-all group shadow-xl">
                        <h3 class="text-amber-400 font-black text-sm uppercase tracking-[0.2em] mb-4 flex items-center">
                          <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-2 shadow-[0_0_8px_rgba(245,158,11,0.5)]"></span>
                          {section.title}
                        </h3>
                        <ul class="space-y-3">
                          {section.rules.map((rule) => (
                            <li class="flex items-start text-[11px] md:text-xs text-gray-300 font-bold leading-relaxed">
                              <span class="text-amber-600 mr-2">›</span>
                              <span set:html={rule} />
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>

                  {/* Sección de Comercio (BOEs y Farmeo) */}
                  <div class="space-y-8">
                    <div class="flex items-center space-x-4 pt-8 border-t border-amber-600/20">
                      <div class="w-10 h-10 bg-gradient-to-br from-amber-600 to-amber-800 rounded-lg flex items-center justify-center shadow-lg">
                        <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      </div>
                      <div>
                        <h2 class="text-2xl font-black text-white uppercase tracking-tighter italic">Banco <span class="text-amber-400">Colmillo</span></h2>
                        <p class="text-[10px] text-amber-300/60 font-medium uppercase tracking-widest">Intercambio de BOEs y útiles del banco</p>
                      </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                      {/* Tabla de BOEs */}
                      <div class="bg-gray-900/60 border border-amber-600/20 rounded-lg overflow-hidden shadow-2xl">
                        <div class="bg-amber-600/10 px-6 py-4 border-b border-amber-600/20 flex justify-between items-center">
                          <span class="text-xs font-black text-amber-400 uppercase tracking-widest">Precios de BOEs</span>
                          <span class="text-[10px] text-gray-500 font-bold uppercase italic">Sujeto a Stock</span>
                        </div>
                        <div class="max-h-[500px] overflow-y-auto custom-scrollbar">
                          <table class="w-full text-left">
                            <thead class="sticky top-0 bg-gray-900/90 backdrop-blur-md z-10 border-b border-amber-600/10">
                              <tr>
                                <th class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-wider">Item</th>
                                <th class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Precio</th>
                              </tr>
                            </thead>
                            <tbody class="divide-y divide-amber-600/5">
                              {BOE_PRICES.map((boe) => (
                                <tr class="hover:bg-amber-600/5 transition-colors group">
                                  <td class="px-6 py-3 text-[11px] font-bold text-gray-200 group-hover:text-amber-200 transition-colors uppercase tracking-tight">{boe.item}</td>
                                  <td class="px-6 py-3 text-[11px] font-black text-amber-400 text-right tracking-tighter">{boe.price}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      </div>

                      {/* Tabla de Farmeo */}
                      <div class="bg-gray-900/60 border border-amber-600/20 rounded-lg overflow-hidden shadow-2xl h-fit">
                        <div class="bg-amber-600/10 px-6 py-4 border-b border-amber-600/20 flex justify-between items-center">
                          <span class="text-xs font-black text-amber-400 uppercase tracking-widest">Farmeo Intercambiable</span>
                          <span class="text-[10px] text-gray-500 font-bold uppercase italic">Aceptado como pago</span>
                        </div>
                        <div class="overflow-x-auto">
                          <table class="w-full text-left">
                            <thead>
                              <tr class="border-b border-amber-600/10">
                                <th class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-wider">Material</th>
                                <th class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-wider">Unidad</th>
                                <th class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-wider text-right">Valor</th>
                              </tr>
                            </thead>
                            <tbody class="divide-y divide-amber-600/5">
                              {FARM_PRICES.map((farm) => (
                                <tr class="hover:bg-amber-600/5 transition-colors group">
                                  <td class="px-6 py-3 text-[11px] font-bold text-gray-200 group-hover:text-amber-200 transition-colors uppercase tracking-tight">{farm.item}</td>
                                  <td class="px-6 py-3">
                                    <span class="text-[9px] font-black text-gray-500 uppercase border border-gray-700 px-1.5 py-0.5 rounded">{farm.unit}</span>
                                  </td>
                                  <td class="px-6 py-3 text-[11px] font-black text-amber-400 text-right tracking-tighter">{farm.price}</td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                        <div class="p-4 bg-amber-950/20 border-t border-amber-600/10">
                          <p class="text-[10px] text-amber-300/60 font-bold italic leading-relaxed text-center">
                            * El farmeo acumulado se utiliza para financiar los sorteos y mantener el stock del banco de hermandad.
                          </p>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* Reglas Específicas */}
              {raid.specificRules.length > 0 && (
                <div>
                  <h4 class="text-[10px] font-black text-amber-400 uppercase tracking-[0.3em] mb-4 flex items-center justify-center md:justify-start">
                    <div class="p-1 bg-amber-500/20 rounded mr-2 border border-amber-500/30">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    </div>
                    Reglas Específicas de Encuentro
                  </h4>
                  <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                    {raid.specificRules.map((s) => (
                      <li class="text-white text-xs md:text-sm flex items-start leading-relaxed font-bold bg-gray-900/40 p-3 rounded-lg border border-amber-600/20 shadow-sm h-full transition-all hover:border-amber-500/40 hover:bg-gray-800/60 group/rule">
                        <span class="text-amber-500 mr-2 text-lg font-black group-hover/rule:translate-x-1 transition-transform">›</span>
                        {s}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Loteo Detallado */}
              {raid.lootRules && raid.lootRules.length > 0 && (
                <div class="space-y-4">
                  <h4 class="text-[10px] font-black text-amber-400 uppercase tracking-[0.3em] mb-4 flex items-center justify-center md:justify-start">
                    <div class="p-1 bg-amber-500/20 rounded mr-2 border border-amber-500/30">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                      </svg>
                    </div>
                    Prioridades de Loteo
                  </h4>
                  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                    {raid.lootRules.map((loot) => (
                      <div class="p-3 bg-gray-900/80 rounded-lg border border-amber-600/20 hover:border-amber-500/50 hover:bg-gray-800/60 transition-all shadow-lg h-full flex flex-col group/item relative overflow-hidden">
                        <div class="flex justify-between items-center mb-2">
                          <span class="text-amber-200 font-black text-xs md:text-sm uppercase tracking-wider group-hover/item:text-amber-100 transition-colors italic">{loot.item}</span>
                        </div>
                        <p class="text-white text-[11px] md:text-xs leading-relaxed font-bold italic border-l-2 border-amber-500 pl-3 py-1 bg-amber-500/5 rounded-r-lg mb-auto">{loot.requirement}</p>
                        {loot.classes && (
                          <div class="mt-2 flex flex-wrap gap-1">
                            {loot.classes.map(c => (
                              <span class="text-[8px] md:text-[10px] bg-amber-900/40 text-amber-200 px-2 py-0.5 rounded-md border border-amber-700/50 font-black uppercase shadow-sm">
                                {c}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Normas de Hermandad Integradas (Añadido Estático) */}
              <div class="pt-10 border-t border-amber-600/30 mt-10">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
                  <div class="flex items-center justify-center md:justify-start">
                    <div class="p-2 bg-amber-500/20 rounded-lg mr-3 border border-amber-500/30">
                      <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                      </svg>
                    </div>
                    <h4 class="text-[10px] font-black text-amber-400 uppercase tracking-[0.3em]">Normas Generales de Raideo</h4>
                  </div>

                  {/* Social Links Integrados */}
                  <div class="flex items-center justify-center gap-3">
                    <a href="https://discord.gg/BwdpNV9sky" target="_blank" class="p-2 bg-indigo-600/20 hover:bg-indigo-600/40 border border-indigo-500/30 rounded-lg transition-all group/social" title="Discord">
                      <svg class="w-4 h-4 text-indigo-400 group-hover/social:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.1 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.8 8.18 1.8 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.891.077.077 0 00-.041.1c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.84 19.84 0 005.99-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z" />
                      </svg>
                    </a>
                    <a href="https://chat.whatsapp.com/BahYOaTMZfHIwYQGey3G91" target="_blank" class="p-2 bg-green-600/20 hover:bg-green-600/40 border border-green-500/30 rounded-lg transition-all group/social" title="WhatsApp">
                      <svg class="w-4 h-4 text-green-400 group-hover/social:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.966-.273-.099-.471-.148-.67.15-.197.297-.767.963-.94 1.16-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.795-1.484-1.781-1.66-2.075-.173-.297-.018-.458.13-.606.136-.135.298-.354.446-.531.149-.174.198-.298.298-.497.099-.198.05-.367-.025-.531-.075-.174-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.508-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.79.359-.272.3-1.04 1.016-1.04 2.477s1.065 2.873 1.213 3.074c.149.198 2.096 3.2 5.076 4.49.703.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.005-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.03-1.38l-.36-.214-3.741.982.998-3.648-.235-.372a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.29A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.549 4.142 1.595 5.945L0 24l6.335-1.652a11.882 11.882 0 005.723 1.464h.006c6.553 0 11.89-5.336 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                      </svg>
                    </a>
                  </div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
                  {GENERAL_RULES.map((rule) => (
                    <div class="flex items-center space-x-3 p-3 bg-blue-950/50 rounded-lg border border-amber-800/30 hover:bg-amber-900/30 transition-all group/rule">
                      <div class="w-1.5 h-1.5 rounded-full bg-amber-500 group-hover/rule:scale-125 transition-transform flex-shrink-0 shadow-[0_0_8px_rgba(245,158,11,0.5)]" />
                      <p class="text-gray-100 text-[11px] md:text-xs font-bold leading-tight uppercase tracking-tight" set:html={rule} />
                    </div>
                  ))}
                </div>

                {/* Footer de la Tarjeta */}
                <div class="flex items-center justify-between pt-6 border-t border-amber-600/20">
                  <div class="flex items-center space-x-2 opacity-50">
                    <div class="w-8 h-[1px] bg-amber-600/50" />
                    <span class="text-[9px] font-black text-amber-500 uppercase tracking-widest italic">Colmillo de Acero</span>
                  </div>
                  <span class="text-[9px] font-bold text-gray-500 uppercase tracking-tighter italic">
                    Actualizado: {new Date().toLocaleDateString('es-ES', { month: 'long', year: 'numeric' }).toUpperCase()}
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Botón Volver */}
      <div class="mt-12 text-center pb-8">
        <a href="/raids" class="inline-flex items-center px-8 py-3 bg-gray-800 text-white rounded-lg border border-gray-700 hover:bg-gray-700 hover:border-indigo-500 transition-all group font-bold uppercase tracking-widest text-sm shadow-xl">
          <svg class="w-5 h-5 mr-3 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver a Horarios
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  function setupFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const ruleCards = document.querySelectorAll('.rule-card');
    const rulesGrid = document.getElementById('rules-grid');

    function applyFilter(filter) {
      // Clases para estados (Sincronizadas con raids.astro)
      const activeClasses = ['active', 'bg-amber-600', 'text-white', 'border-amber-400', 'shadow-lg', 'shadow-amber-500/20'];
      const inactiveClasses = ['bg-gray-900/40', 'text-gray-300', 'border-amber-600/30', 'hover:border-amber-500/60', 'hover:bg-amber-900/20'];

      // Actualizar botones
      filterButtons.forEach(btn => {
        if (btn.getAttribute('data-filter') === filter) {
          btn.classList.add(...activeClasses);
          btn.classList.remove(...inactiveClasses);
        } else {
          btn.classList.remove(...activeClasses);
          btn.classList.add(...inactiveClasses);
        }
      });

      // Filtrar tarjetas (Mostrar solo una)
      ruleCards.forEach(card => {
        const type = card.getAttribute('data-type');
        const aliases = JSON.parse(card.getAttribute('data-alias') || '[]');
        
        const matchesFilter = type === filter || aliases.includes(filter);

        if (matchesFilter) {
          (card as HTMLElement).style.display = 'flex';
          (card as HTMLElement).style.animation = 'fadeIn 0.5s ease-out forwards';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    }

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        applyFilter(filter);
        // Actualizar hash sin disparar scroll
        history.pushState(null, "", `#${encodeURIComponent(filter)}`);
      });
    });

    // Detectar hash inicial
    const hash = decodeURIComponent(window.location.hash.substring(1));
    if (hash) {
      let targetType = hash;
      let found = false;
      
      // Buscar si el hash corresponde a un Type o a un Alias
      ruleCards.forEach(card => {
        const type = card.getAttribute('data-type');
        const aliases = JSON.parse(card.getAttribute('data-alias') || '[]');
        if (type === hash || aliases.includes(hash)) {
          targetType = type;
          found = true;
        }
      });

      if (found) {
        applyFilter(targetType);
        
        // Bloquear scroll jump del navegador
        if ('scrollRestoration' in history) {
          history.scrollRestoration = 'manual';
        }
        
        // Asegurar que la página empiece arriba del todo
        window.scrollTo(0, 0);
        setTimeout(() => window.scrollTo(0, 0), 0);
      }
    } else {
      // Si no hay hash, mostrar la primera por defecto
      const firstFilter = filterButtons[0]?.getAttribute('data-filter');
      if (firstFilter) applyFilter(firstFilter);
    }
  }

  // Ejecutar inmediatamente para evitar el salto si es posible
  setupFilters();
  // Y también al cargar el DOM por si acaso
  document.addEventListener('DOMContentLoaded', setupFilters);
</script>

<style>
  /* Animación sutil de entrada */
  main {
    animation: fadeIn 0.8s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
