---
import Layout from '../components/layout/Layout.astro';
import { RAID_RULES, GENERAL_RULES } from '../data/raidRules';

// SEO y metadatos
const title = "Reglas de Raid | Colmillo de Acero";
const description = "Consulta las reglas de loteo, requisitos de GearScore y normas de conducta para las raids de la hermandad Colmillo de Acero.";
---

<Layout title={title} description={description}>
  <main class="relative min-h-screen p-4">
    <div class="max-w-7xl mx-auto">
      {/* Encabezado compacto */}
      <div class="text-center mb-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-3 tracking-tight">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-orange-500 uppercase tracking-tighter">
            Reglas de Raideo
          </span>
        </h1>
        <p class="text-gray-100 max-w-2xl mx-auto text-base md:text-lg font-medium">
          Normativas oficiales para garantizar un ambiente justo y eficiente en nuestras bandas.
        </p>
      </div>

      {/* Filtros de Navegación (Por Banda y Dificultad) */}
      <nav class="flex flex-wrap justify-center gap-3 mb-10" id="raid-filters">
        {RAID_RULES.map((raid, index) => (
          <button 
            class={`filter-btn px-5 py-2 rounded-lg transition-all font-bold uppercase tracking-wider text-xs md:text-sm ${index === 0 ? 'active bg-indigo-600 text-white border-2 border-indigo-400 shadow-lg shadow-indigo-500/20' : 'bg-gray-800 text-gray-200 border border-gray-700 hover:border-indigo-500/50 hover:bg-gray-700'}`}
            data-filter={raid.raidId}
          >
            {raid.title}
          </button>
        ))}
      </nav>

      {/* Grid de Reglas por Banda (Visualización Única) */}
      <div class="flex w-full mb-12" id="rules-grid">
        {RAID_RULES.map((raid, index) => (
          <div 
            id={raid.raidId} 
            class="rule-card w-full bg-gray-900/60 backdrop-blur-md border-2 border-gray-800 rounded-lg overflow-hidden flex-col shadow-2xl transition-all group"
            data-type={raid.raidId}
            data-alias={raid.alias ? JSON.stringify(raid.alias) : '[]'}
            style={index === 0 ? "display: flex;" : "display: none;"}
          >
            {/* Header de la Banda */}
            <div class="px-6 py-4 bg-gradient-to-r from-gray-900 to-gray-800 border-b-2 border-gray-800 flex justify-center items-center text-center">
              <h3 class="text-xl md:text-3xl font-black text-white group-hover:text-indigo-400 transition-colors uppercase tracking-tight">
                {raid.title}
              </h3>
            </div>

            <div class="p-2 space-y-10 flex-grow">
              {/* Reglas Específicas */}
              {raid.specificRules.length > 0 && (
                <div>
                  <h4 class="text-xs font-black text-indigo-400 uppercase tracking-[0.2em] mb-5 flex items-center justify-center md:justify-start">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Reglas Específicas de Encuentro
                  </h4>
                  <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {raid.specificRules.map((s) => (
                      <li class="text-white text-base md:text-xl flex items-start leading-relaxed font-bold bg-gray-800/50 p-5 rounded-lg border-2 border-gray-700/50 shadow-sm h-full transition-colors hover:border-indigo-500/30">
                        <span class="text-indigo-400 mr-4 text-2xl font-black">›</span>
                        {s}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Loteo Detallado */}
              {raid.lootRules && raid.lootRules.length > 0 && (
                <div class="space-y-5">
                  <h4 class="text-xs font-black text-indigo-400 uppercase tracking-[0.2em] mb-5 flex items-center justify-center md:justify-start">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                    Reglas de Loteo
                  </h4>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    {raid.lootRules.map((loot) => (
                      <div class="p-4 bg-gray-800/60 rounded-lg border-2 border-gray-700 hover:border-indigo-500/50 hover:bg-gray-800/80 transition-all shadow-2xl h-full flex flex-col group/item">
                        <div class="flex justify-between items-center">
                          <span class="text-indigo-300 font-black text-base md:text-md uppercase tracking-wider group-hover/item:text-indigo-200 transition-colors">{loot.item}</span>
                        </div>
                        <p class="text-white text-base md:text-md leading-relaxed font-bold italic border-l-4 border-indigo-500 pl-5 py-3 bg-indigo-500/10 rounded-lg mb-auto">{loot.requirement}</p>
                        {loot.classes && (
                          <div class="mt-5 flex flex-wrap gap-2">
                            {loot.classes.map(c => (
                              <span class="text-[11px] md:text-sm bg-indigo-900 text-white px-4 py-1.5 rounded-lg border border-indigo-700 font-black uppercase shadow-md">
                                {c}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Normas de Hermandad Integradas (Añadido Estático) */}
              <div class="p-4 border-t-2 border-gray-800/50">
                <div class="flex items-center mb-6 justify-center md:justify-start">
                  <div class="p-2 bg-amber-500/20 rounded-lg mr-3 border border-amber-500/30">
                    <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <h4 class="text-xs font-black text-amber-400 uppercase tracking-[0.2em]">Normas Generales de Raideo</h4>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {GENERAL_RULES.map((rule) => (
                    <div class="flex items-start space-x-4 p-4 bg-amber-900/10 rounded-lg border border-amber-800/20 hover:bg-amber-900/20 transition-all shadow-inner">
                      {rule}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Botón Volver */}
      <div class="mt-12 text-center pb-8">
        <a href="/raids" class="inline-flex items-center px-8 py-3 bg-gray-800 text-white rounded-lg border border-gray-700 hover:bg-gray-700 hover:border-indigo-500 transition-all group font-bold uppercase tracking-widest text-sm shadow-xl">
          <svg class="w-5 h-5 mr-3 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver a Horarios
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
  function setupFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const ruleCards = document.querySelectorAll('.rule-card');
    const rulesGrid = document.getElementById('rules-grid');

    function applyFilter(filter) {
      // Clases para estados
      const activeClasses = ['active', 'bg-indigo-600', 'text-white', 'border-2', 'border-indigo-400', 'shadow-lg', 'shadow-indigo-500/20'];
      const inactiveClasses = ['bg-gray-800', 'text-gray-200', 'border', 'border-gray-700', 'hover:border-indigo-500/50', 'hover:bg-gray-700'];

      // Actualizar botones
      filterButtons.forEach(btn => {
        if (btn.getAttribute('data-filter') === filter) {
          btn.classList.add(...activeClasses);
          btn.classList.remove(...inactiveClasses);
        } else {
          btn.classList.remove(...activeClasses);
          btn.classList.add(...inactiveClasses);
        }
      });

      // Filtrar tarjetas (Mostrar solo una)
      ruleCards.forEach(card => {
        const id = card.id;
        const aliases = JSON.parse(card.getAttribute('data-alias') || '[]');
        
        const matchesFilter = id === filter || aliases.includes(filter);

        if (matchesFilter) {
          (card as HTMLElement).style.display = 'flex';
          (card as HTMLElement).style.animation = 'fadeIn 0.5s ease-out forwards';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    }

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        applyFilter(filter);
        // Actualizar hash sin disparar scroll
        history.pushState(null, "", `#${encodeURIComponent(filter)}`);
      });
    });

    // Detectar hash inicial
    const hash = decodeURIComponent(window.location.hash.substring(1));
    if (hash) {
      let targetId = hash;
      
      // Buscar si el hash corresponde a un ID o a un Alias
      ruleCards.forEach(card => {
        const aliases = JSON.parse(card.getAttribute('data-alias') || '[]');
        if (aliases.includes(hash)) {
          targetId = card.id;
        }
      });

      const targetCard = document.getElementById(targetId);
      if (targetCard) {
        applyFilter(targetId);
        // Asegurar que la página esté al inicio
        window.scrollTo(0, 0);
      }
    } else {
      // Si no hay hash, mostrar la primera por defecto
      const firstFilter = filterButtons[0]?.getAttribute('data-filter');
      if (firstFilter) applyFilter(firstFilter);
    }
  }

  // Ejecutar al cargar
  document.addEventListener('DOMContentLoaded', setupFilters);
</script>

<style>
  /* Animación sutil de entrada */
  main {
    animation: fadeIn 0.8s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
