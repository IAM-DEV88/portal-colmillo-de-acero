    <script is:inline define:vars={{ raidEligibleMembers, raids: JSON.stringify(wotlkRaids) }}>
      // Initialize raids in global scope
      window.wotlkRaids = JSON.parse(raids);
      
      // Function to open the edit modal
      window.openEditModal = function(registration) {
        console.log('Opening edit modal with registration:', registration);
        
        // Set basic form fields
        document.getElementById('edit-id').value = registration.id;
        document.getElementById('edit-player-name').value = registration.player_name || '';
        document.getElementById('edit-player-class').value = registration.player_class || '';
        document.getElementById('edit-player-role').value = registration.player_role || '';
        document.getElementById('edit-day').value = registration.day_of_week || '';
        document.getElementById('edit-time').value = registration.start_time || '';
        document.getElementById('edit-status').value = registration.status || 'aceptado';
        
        // Set the selected raid
        const raidId = registration.raid_id ? String(registration.raid_id) : '';
        console.log('Setting raid_id:', raidId);
        
        const raidSelect = document.getElementById('edit-raid-id');
        if (raidSelect) {
          // Ensure the select element has options before trying to set value
          if (raidSelect.options.length > 0) {
            // Convert raidId to string for comparison since option values are strings
            const raidIdStr = String(raidId);
            let found = false;
            
            // Check if the raid_id exists in the options
            for (let i = 0; i < raidSelect.options.length; i++) {
              if (raidSelect.options[i].value === raidIdStr) {
                raidSelect.value = raidIdStr;
                found = true;
                console.log('Found matching raid option:', raidIdStr);
                break;
              }
            }
            
            // If no matching option found, select the first one
            if (!found && raidSelect.options.length > 0) {
              raidSelect.value = raidSelect.options[0].value;
              console.log('No matching raid found, defaulting to first option');
            }
          } else {
            console.warn('No raid options available in the select element');
          }
        } else {
          console.error('Could not find edit-raid-id element');
        }
        
        document.getElementById('edit-modal').classList.remove('hidden');
      };
      
      // Function to close the edit modal
      window.closeEditModal = function() {
        document.getElementById('edit-modal').classList.add('hidden');
      };
      // Function to open the new schedule modal
      window.openNewScheduleModal = function(raidId, raidName) {
        const modal = document.getElementById('new-schedule-modal');
        const title = document.getElementById('new-schedule-title');
        const raidIdInput = document.getElementById('new-schedule-raid-id');
        
        if (modal && title && raidIdInput) {
          title.textContent = `Nuevo Horario - ${raidName}`;
          raidIdInput.value = raidId;
          modal.classList.remove('hidden');
          document.body.classList.add('overflow-hidden');
          
          // Set default time to next hour
          const now = new Date();
          const nextHour = new Date(now.getTime() + 60 * 60 * 1000);
          const timeInput = document.getElementById('new-schedule-time');
          if (timeInput) {
            timeInput.value = `${String(nextHour.getHours()).padStart(2, '0')}:00`;
          }
        }
      };

      // Function to close the new schedule modal
      window.closeNewScheduleModal = function() {
        const modal = document.getElementById('new-schedule-modal');
        if (modal) {
          modal.classList.add('hidden');
          document.body.classList.remove('overflow-hidden');
        }
      };

      // Show error message
      function showError(message) {
        const errorDiv = document.createElement('div');
        errorDiv.className = 'fixed top-4 right-4 bg-red-900 text-white px-4 py-2 rounded-md shadow-lg z-50';
        errorDiv.textContent = message;
        document.body.appendChild(errorDiv);
        setTimeout(() => errorDiv.remove(), 5000);
      }

      // Show success message
      function showSuccess(message) {
        const successDiv = document.createElement('div');
        successDiv.className = 'fixed top-4 right-4 bg-green-900 text-white px-4 py-2 rounded-md shadow-lg z-50';
        successDiv.textContent = message;
        document.body.appendChild(successDiv);
        setTimeout(() => successDiv.remove(), 5000);
      }

      // Handle new schedule form submission
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('new-schedule-form');
        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = 'Guardando...';
            
            try {
              const formData = new FormData(form);
              const data = {
                raid_id: document.getElementById('new-schedule-raid-id').value,
                player_name: formData.get('player_name').trim(),
                player_class: formData.get('player_class'),
                player_role: formData.get('player_role'),
                day_of_week: formData.get('day_of_week'),
                start_time: formData.get('start_time'),
                raid_role: formData.get('raid_role'),
                status: 'aceptado'
              };
              
              // Basic validation
              if (!data.player_name) {
                throw new Error('Por favor ingresa el nombre del personaje');
              }
              
              // Prepare the data for the API
              const requestData = {
                action: 'create',
                raid_id: document.getElementById('new-schedule-raid-id').value,
                player_name: formData.get('player_name').trim(),
                player_class: formData.get('player_class'),
                player_role: formData.get('player_role'),
                day_of_week: formData.get('day_of_week'),
                start_time: formData.get('start_time'),
                raid_role: formData.get('raid_role'),
                status: 'aceptado' // Auto-accept admin-created schedules
              };

              const response = await fetch('/api/admin/update-registration', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include', // This ensures cookies are sent with the request
                body: JSON.stringify(requestData)
              });
              
              const responseData = await response.json();
              
              if (!response.ok) {
                throw new Error(responseData.error || 'Error al crear el horario');
              }
              
              showSuccess('Horario creado exitosamente');
              // Give a moment for the success message to be seen
              setTimeout(() => window.location.reload(), 1000);
            } catch (error) {
              console.error('Error:', error);
              showError(error.message || 'Error al crear el horario');
            } finally {
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
              }
            }
          });
        }
      });

      // Roster Modal Functions
      window.openRosterModal = function(raidId) {
        const modal = document.getElementById('roster-modal');
        const content = document.getElementById('roster-modal-content');
        const raidNameEl = document.getElementById('roster-modal-raid-name');
        const copyAllBtn = document.getElementById('roster-modal-copy-all');
        
        if (!modal || !content) return;

        const members = raidEligibleMembers[raidId] || [];
        
        // Group by role
        const tanks = members.filter(m => m.role === 'T');
        const healers = members.filter(m => m.role === 'H');
        const dps = members.filter(m => m.role === 'D');

        // Get raid name
        const raidData = window.wotlkRaids.find(r => r.id === String(raidId));
        const raidName = raidData ? raidData.name : 'Raid';

        // Collect all names for the "Copy All" button
        const allPlayerNames = members.map(m => {
          const role = m.role?.toLowerCase() || '';
          const className = m.class?.toLowerCase() || '';
          const isRanged = className.includes('mage') || className.includes('warlock') || className.includes('hunter') || (className.includes('druid') && !role.includes('tank')) || (className.includes('priest') && !role.includes('heal')) || (className.includes('shaman') && !role.includes('heal'));
          const prefix = role.includes('tank') ? 'T' : role.includes('heal') ? 'H' : (isRanged ? 'R' : 'M');
          return prefix + m.name;
        });

        // Set up "Copy All" button
        if (copyAllBtn) {
          if (allPlayerNames.length > 0) {
            copyAllBtn.classList.remove('hidden');
            copyAllBtn.onclick = () => window.copyRosterInvite(allPlayerNames, raidName, 'Todos');
          } else {
            copyAllBtn.classList.add('hidden');
          }
        }

        // Helper to render member list
        const renderList = (list, title, colorClass, iconPath, id, roleSpanish) => {
          if (list.length === 0) return '';

        // Mapeo de avatares de clase (consistente con raids.astro)
        const classAvatars = {
          'death-knight': 'class_deathknight.jpg',
          'druid': 'class_druid.jpg',
          'hunter': 'class_hunter.jpg',
          'mage': 'class_mage.jpg',
          'paladin': 'class_paladin.jpg',
          'priest': 'class_priest.jpg',
          'rogue': 'class_rogue.jpg',
          'shaman': 'class_shaman.jpg',
          'warlock': 'class_warlock.jpg',
          'warrior': 'class_warrior.jpg'
        };

        const getAvatar = (className) => {
          const file = classAvatars[className.toLowerCase().replace(/\s+/g, '-')] || `class_${className.toLowerCase().replace(/\s+/g, '')}.jpg`;
          return `/images/avatars/${file}`;
        };

        return `
          <div class="mb-4 last:mb-0 border border-gray-700/50 rounded-md overflow-hidden bg-gray-800/20">
            <div class="flex items-center justify-between p-3 bg-gray-800/50">
              <button 
                type="button"
                class="flex items-center flex-1 hover:bg-gray-800/50 transition-colors -m-3 p-3 rounded-lg"
                onclick="document.getElementById('${id}-content').classList.toggle('hidden'); document.getElementById('${id}-chevron').classList.toggle('rotate-180');"
              >
                <div class="flex items-center">
                  <div class="p-1.5 rounded-md ${colorClass} bg-opacity-20 mr-3">
                    <svg class="w-4 h-4 ${colorClass.replace('bg-', 'text-')}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      ${iconPath}
                    </svg>
                  </div>
                  <h4 class="text-sm font-bold text-gray-200 uppercase tracking-wide">${title} <span class="text-xs text-gray-500 ml-1">(${list.length})</span></h4>
                </div>
                <svg id="${id}-chevron" class="w-5 h-5 text-gray-500 transform transition-transform duration-200 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>
            
            <div id="${id}-content" class="hidden p-3 border-t border-gray-700/50 bg-gray-900/20">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                ${list.map(m => `
                  <div class="flex items-center justify-between bg-gray-800/40 p-2 rounded border border-gray-700/30">
                    <div class="flex items-center overflow-hidden">
                      <img src="${getAvatar(m.class)}" class="w-6 h-6 rounded-full mr-2 object-cover" onerror="this.src='/images/avatars/default.png'" />
                      <span class="text-sm font-medium text-gray-200 truncate">${m.name}</span>
                    </div>
                    <span class="text-xs font-mono text-amber-400 bg-amber-900/20 px-1.5 py-0.5 rounded border border-amber-700/30">
                      ${(m.gearScore / 1000).toFixed(1)}k
                    </span>
                  </div>
                `).join('')}
              </div>
            </div>
          </div>
        `;
        };

        const tankIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />';
        const healIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />';
        const dpsIcon = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />';

        let html = '';
        html += renderList(tanks, 'Tanques', 'bg-blue-500', tankIcon, 'tanks', 'tanques');
        html += renderList(healers, 'Sanadores', 'bg-green-500', healIcon, 'healers', 'sanadores');
        html += renderList(dps, 'DPS', 'bg-red-500', dpsIcon, 'dps', 'DPS');

        if (html === '') {
          html = '<div class="text-center text-gray-400 py-8">No hay miembros elegibles para esta raid.</div>';
        }

        content.innerHTML = html;
        
        raidNameEl.textContent = `Miembros Elegibles - ${raidName}`;
        modal.classList.remove('hidden');
      };

      window.closeRosterModal = function() {
        const modal = document.getElementById('roster-modal');
        if (modal) {
          modal.classList.add('hidden');
        }
      };

      // Modal functions for multi-part invites
      window.currentInviteChunks = [];

      window.openInvitePartsModal = function(chunks) {
        console.log('openInvitePartsModal called with chunks:', chunks.length);
        const modal = document.getElementById('invite-parts-modal');
        const content = document.getElementById('invite-parts-content');
        
        if (!modal || !content) {
          console.error('Modal or content element not found!');
          return;
        }
        
        // Store chunks globally to avoid escaping issues in HTML attributes
        window.currentInviteChunks = chunks;
        
        content.innerHTML = chunks.map((chunk, index) => `
          <div class="flex items-center justify-between bg-gray-700/50 p-3 rounded border border-gray-600">
            <div class="mr-4">
              <span class="text-sm font-bold text-white">Lista ${index + 1}</span>
              <span class="text-xs text-gray-400 ml-2">(${chunk.count} jugadores)</span>
            </div>
            <button
              type="button"
              onclick="copyInviteChunk(${index})"
              class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-medium rounded transition-colors flex items-center"
            >
              <svg class="w-3 h-3 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              Copiar Lista
            </button>
          </div>
        `).join('');
        
        modal.classList.remove('hidden');
      };

      window.copyInviteChunk = function(index) {
        const chunk = window.currentInviteChunks[index];
        if (chunk) {
          window.copyToClipboard(chunk.command);
        }
      };

      window.closeInvitePartsModal = function() {
        const modal = document.getElementById('invite-parts-modal');
        if (modal) {
          modal.classList.add('hidden');
        }
      };

      // Helper to copy text to clipboard
      window.copyToClipboard = function(text) {
        navigator.clipboard.writeText(text).then(() => {
          const toast = document.createElement('div');
          toast.className = 'fixed bottom-4 right-4 bg-green-600 text-white px-4 py-2 rounded-md shadow-lg z-50 animate-fade-in';
          toast.textContent = 'Lista de nombres copiada al portapapeles';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 2000);
        }).catch(err => {
          console.error('Error copying:', err);
          alert('Error al copiar. Por favor selecciona y copia manualmente.');
        });
      };

      // Helper to generate command chunks
      function generateInviteChunks(names) {
        const MAX_LENGTH = 5000;
        const chunks = [];
        let currentChunkNames = [];
        let currentLength = 0;

        names.forEach((name) => {
          const nameStr = name.replace(/\s+/g, '');
          const separator = currentChunkNames.length > 0 ? ',' : '';
          const itemLength = nameStr.length + separator.length;

          if (currentLength + itemLength > MAX_LENGTH) {
            if (currentChunkNames.length > 0) {
              chunks.push({ command: currentChunkNames.join(','), count: currentChunkNames.length });
            }
            currentChunkNames = [nameStr];
            currentLength = nameStr.length;
          } else {
            currentChunkNames.push(nameStr);
            currentLength += itemLength;
          }
        });

        if (currentChunkNames.length > 0) {
          chunks.push({ command: currentChunkNames.join(','), count: currentChunkNames.length });
        }

        return chunks;
      }

      // Copy WoW invite command to clipboard
      window.copyInviteCommand = function(playerNames, raidName, dayOfWeek, startTime) {
        console.log('copyInviteCommand called', { playerNames: playerNames.length, raidName });
        const names = playerNames.filter(name => name && name.trim());
        if (names.length === 0) return;

        const chunks = generateInviteChunks(names);
        console.log('Chunks generated:', chunks.length);
        
        if (chunks.length === 1) {
          window.copyToClipboard(chunks[0].command);
        } else if (chunks.length > 1) {
          window.openInvitePartsModal(chunks);
        }
      };

      // Copy roster invite command with role-specific message
      window.copyRosterInvite = function(playerNames, raidName, roleSpanish) {
        console.log('copyRosterInvite called', { playerNames: playerNames.length, raidName, roleSpanish });
        const names = playerNames.filter(name => name && name.trim());
        if (names.length === 0) return;

        const chunks = generateInviteChunks(names);
        console.log('Chunks generated:', chunks.length);
        
        if (chunks.length === 1) {
          window.copyToClipboard(chunks[0].command);
        } else if (chunks.length > 1) {
          window.openInvitePartsModal(chunks);
        }
      };

      // Client-side filtering by status
      window.filterByStatus = function(status) {
        const rows = document.querySelectorAll('.registration-card');
        const groups = document.querySelectorAll('.raid-group');
        const schedules = document.querySelectorAll('.schedule-details');

        // Reset display
        rows.forEach(row => row.classList.remove('hidden'));
        groups.forEach(group => group.classList.remove('hidden'));
        schedules.forEach(schedule => schedule.classList.remove('hidden'));

        if (status === 'all') return;

        // Hide rows that don't match status
        rows.forEach(row => {
          const badge = row.querySelector('.status-badge');
          if (!badge) return;
          
          const text = badge.textContent.trim().toLowerCase();
          const target = status === 'en_revision' ? 'revisión' : status === 'aceptado' ? 'aceptado' : 'en espera';
          
          if (text !== target) {
            row.classList.add('hidden');
          }
        });

        // Hide empty schedules and groups
        schedules.forEach(schedule => {
          const visibleRows = schedule.querySelectorAll('.registration-card:not(.hidden)');
          if (visibleRows.length === 0) {
            schedule.classList.add('hidden');
          } else {
            schedule.open = true;
          }
        });

        groups.forEach(group => {
          const visibleSchedules = group.querySelectorAll('.schedule-details:not(.hidden)');
          if (visibleSchedules.length === 0) {
            group.classList.add('hidden');
          } else {
            group.open = true;
          }
        });
      };
    </script>
  )
}
