---
// src/pages/admin.astro
import Layout from '../components/layout/Layout.astro';
import { supabase } from '../lib/supabase';
import { getRaidName, normalizeRaidName } from '../lib/raids';
import { rosterService } from '../services/rosterService';

// Import roster utils
import { validatePublicNote } from '../utils/rosterUtils';

// Use rosterService to fetch data with caching
const rosterData = await rosterService.getFormattedRoster();
const rosterError = null;

// Define a default raid structure for when we only have a name
const createRaidFromName = (name: string, id: string = '', gs: number = 5000): any => {
  const nameLower = name.toLowerCase();
  let image = '/images/raids/iccfarm.jpg';
  if (nameLower.includes('toc')) image = '/images/raids/tocfarm.jpg';
  else if (nameLower.includes('sr') || nameLower.includes('sagrario')) image = '/images/raids/sr.jpg';
  else if (nameLower.includes('lk')) image = '/images/raids/icclk.jpg';

  return {
    id: id || name, // El ID técnico (normalizado si se provee)
    name,           // El nombre original para mostrar
    image,
    description: 'Raid oficial de la hermandad.',
    minGearScore: gs,
    rules: ''
  };
};

// Initialize messages
let errorMessage = '';
let successMessage = '';
let registrations = [];
let isLoading = true;

// Handle POST requests
let formData: FormData | null = null;
if (Astro.request.method === 'POST') {
  try {
    formData = await Astro.request.formData();
    
    // Check if it's a Lua upload
    const file = formData.get('lua_file') as File;
    
    if (file && file.size > 0) {
        if (file.name.endsWith('.lua')) {
            console.log('Processing Lua upload...');
            
            // Re-create FormData for the API call
            const apiFormData = new FormData();
            apiFormData.append('file', file);
            
            // Construct absolute URL for the API
            const origin = Astro.url.origin || 'http://localhost:4321';
            const apiUrl = new URL('/api/admin/upload-lua', origin);
            console.log('Calling API:', apiUrl.toString());
            
            // Call the API endpoint
            const response = await fetch(apiUrl, {
                method: 'POST',
                body: apiFormData,
                headers: {
                    // Important: Pass the session cookie
                    'Cookie': Astro.request.headers.get('cookie') || ''
                }
            });
            
            console.log('API Response status:', response.status);
            
            if (!response.ok) {
                const text = await response.text();
                console.error('API Error Response:', text);
                try {
                    const jsonError = JSON.parse(text);
                    errorMessage = jsonError.error || `Error ${response.status}: ${text}`;
                } catch {
                    errorMessage = `Error ${response.status}: ${text}`;
                }
            } else {
                const result = await response.json();
                console.log('API Result:', result);
                successMessage = result.message || 'Archivo Lua procesado correctamente';
            }
        } else {
             errorMessage = 'El archivo debe tener extensión .lua';
        }
    }
  } catch (e) {
    console.error('Error handling POST:', e);
    // Only show error if we haven't set a success/error message yet
    if (!errorMessage && !successMessage) {
        errorMessage = `Error inesperado: ${e.message}`;
    }
  }
}

// Create a list of all possible raids
const wotlkRaids: any[] = [];
const seenRaids = new Set<string>();

// 1. First populate from rosterData (Supabase)
if (rosterData && rosterData.players) {
  Object.values(rosterData.players).forEach((member: any) => {
    const leaderData = member.leaderData;
    if (!leaderData || !leaderData.cores || !Array.isArray(leaderData.cores)) return;

    leaderData.cores.forEach((core) => {
      if (!core.raid) return;

      const coreRaidKey = core.raid.toUpperCase().trim(); // Usar versión en mayúsculas para deduplicar
      
      if (!seenRaids.has(coreRaidKey)) {
        seenRaids.add(coreRaidKey);
        // Usamos el nombre original tanto para mostrar como para ID técnico para evitar filtrado excesivo
        wotlkRaids.push(createRaidFromName(core.raid, core.raid, core.gs || 5000));
      }
    });
  });
}

// Check if we still need more raids from wotlkRaids global (if any predefined)
// wotlkRaids.length logic...

// Check for admin password
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD || import.meta.env.VITE_ADMIN_PASSWORD;

// Validate that the admin password is set in production
if (import.meta.env.PROD && !ADMIN_PASSWORD) {
  console.error('Error: ADMIN_PASSWORD is not set in environment variables');
  throw new Error('Server configuration error: Admin password not set');
}

// For development, use a default password if not set
const devPassword = 'dev123'; // Change this to your preferred default dev password
const isDev = import.meta.env.DEV;

// Password for Official role
const OFFICIAL_PASSWORD = import.meta.env.OFFICIAL_PASSWORD;

const session = Astro.cookies.get('admin_session')?.value;
const userRole = Astro.cookies.get('admin_role')?.value || 'admin'; // 'admin' or 'official'

if (!session) {
  // If form was submitted
  if (Astro.request.method === 'POST' && formData) {
    const password = formData.get('password');
    const currentAdminPassword = isDev && !ADMIN_PASSWORD ? devPassword : ADMIN_PASSWORD;

    if (password === currentAdminPassword) {
      Astro.cookies.set('admin_session', 'authenticated', {
        path: '/',
        maxAge: 60 * 60 * 8, // 8 hours
        httpOnly: true,
        secure: import.meta.env.PROD,
      });
      Astro.cookies.set('admin_role', 'admin', { path: '/' });
      return Astro.redirect('/admin');
    } else if (password === OFFICIAL_PASSWORD) {
      Astro.cookies.set('admin_session', 'authenticated', {
        path: '/',
        maxAge: 60 * 60 * 8, // 8 hours
        httpOnly: true,
        secure: import.meta.env.PROD,
      });
      Astro.cookies.set('admin_role', 'official', { path: '/' });
      return Astro.redirect('/admin');
    } else {
      return Astro.redirect('/admin?error=invalid');
    }
  }

  // Set login form messages
  const error = Astro.url.searchParams.get('error');
  errorMessage = error === 'invalid' ? 'Contraseña incorrecta' : '';
  const success = Astro.url.searchParams.get('success');
  successMessage = success === 'updated' ? 'Solicitud actualizada correctamente' : '';
  isLoading = false;
} else {
  try {
    const { data, error } = await supabase
      .from('raid_registrations')
      .select('*')
      .order('id', { ascending: false });

    if (error) {
      errorMessage = `Error al cargar las solicitudes: ${error.message}`;
    } else {
      registrations = data || [];
      
      // 2. Second populate from supabase registrations
      registrations.forEach((reg) => {
        if (!reg.raid_id) return;
        
        const raidName = getRaidName(reg.raid_id);
        const raidKey = raidName.toUpperCase().trim(); // Usar versión en mayúsculas para deduplicar
        
        if (!seenRaids.has(raidKey)) {
          seenRaids.add(raidKey);
          wotlkRaids.push(createRaidFromName(raidName, raidName, 5000));
        }
      });
    }
  } catch (err) {
    errorMessage = 'Error inesperado al cargar los datos';
  } finally {
    isLoading = false;
  }
}

// Add logs to debug in server console
console.log('Final wotlkRaids count:', wotlkRaids.length);
console.log('Raids detected:', wotlkRaids.map(r => r.name));

// If still empty after both sources, add a default
if (wotlkRaids.length === 0) {
  wotlkRaids.push(createRaidFromName('ICC25N', 5000));
}

// Process roster data to get eligible members per raid (available for all contexts)
const parsedMembers = Object.entries(rosterData.players || {})
  .filter(([_, member]: [string, any]) => !member.guildLeave) // Filtrar jugadores que han salido
  .map(([playerName, member]: [string, any]) => {
  const publicNote = member.publicNote || '';
  const validation = validatePublicNote(publicNote, playerName);

  const charBlock = validation.blocks?.find((b) => b.type === 'character')?.parsedData;

  let gs = 0;
  let role = 'D';

  if (charBlock) {
    let rawGs = charBlock.mainGearScore || 0;
    if (rawGs > 0 && rawGs < 100) {
      gs = rawGs * 1000;
    } else {
      gs = rawGs;
    }
    role = charBlock.mainRole || 'D';
  }

  return {
    name: playerName,
    class: member.class,
    role: role,
    gearScore: gs,
    publicNote: publicNote,
  };
});

// Calculate eligible members for each raid (all members with GS >= minGearScore)
const raidEligibleMembers: Record<string, typeof parsedMembers> = {};
wotlkRaids.forEach((raid) => {
  const minGs = raid.minGearScore;
  
  // Usamos el ID original para el mapeo
  raidEligibleMembers[raid.id] = parsedMembers.filter((m) => 
    m.gearScore >= minGs
  );
});

// Debug: Log environment variables (remove in production)
console.log('Supabase URL:', import.meta.env.VITE_SUPABASE_URL ? 'Set' : 'Not set');
---

{/* If not authenticated, show login form */}
{
  !session ? (
    <Layout title="Admin - Iniciar Sesión">
      <div class="min-h-screen bg-gray-900 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
        <div class="sm:mx-auto sm:w-full sm:max-w-md">
          <h2 class="mt-6 text-center text-3xl font-extrabold text-white">
            Panel de Administración
          </h2>
          {errorMessage && (
            <div class="mt-4 bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded">
              {errorMessage}
            </div>
          )}
          {successMessage && (
            <div class="mt-4 bg-green-900/50 border border-green-700 text-green-200 px-4 py-3 rounded">
              {successMessage}
            </div>
          )}
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
          <div class="bg-gray-800/50 backdrop-blur-sm py-8 px-4 shadow sm:rounded-md sm:px-10">
            <form class="space-y-6" method="POST">
              <div>
                <label for="password" class="block text-sm font-medium text-gray-300">
                  Contraseña de administrador
                </label>
                <div class="mt-1">
                  <input
                    id="password"
                    name="password"
                    type="password"
                    required
                    class="appearance-none block w-full px-3 py-2 border border-gray-700 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-amber-500 focus:border-amber-500 sm:text-sm bg-gray-900 text-white"
                  />
                </div>
              </div>

              <div>
                <button
                  type="submit"
                  class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-amber-600 hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500"
                >
                  Iniciar sesión
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </Layout>
  ) : (
    <Layout title="Admin - Gestión de Solicitudes">
      <div class="">
        <div class="max-w-7xl mx-auto space-y-8">
          {/* Header & Actions */}
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center bg-gray-800/50 backdrop-blur-sm p-6 rounded-md border border-gray-700/50 shadow-xl">
            <div>
              <h1 class="text-3xl font-bold text-white mb-2">Panel de Administración</h1>
              <p class="text-gray-400">Gestiona las solicitudes de raid y el roster</p>
            </div>
            <div class="flex items-center space-x-4 mt-4 md:mt-0">
              <button
                id="toggle-all-btn"
                class="px-4 py-2 text-sm font-medium text-gray-300 hover:text-white bg-gray-700/50 hover:bg-gray-600/50 border border-gray-600/50 rounded-md transition-all"
                onclick="const details = document.querySelectorAll('details'); const isOpen = this.dataset.open === 'true'; details.forEach(d => d.open = !isOpen); this.dataset.open = !isOpen; this.textContent = !isOpen ? 'Colapsar Todo' : 'Expandir Todo';"
                data-open="false"
              >
                Expandir Todo
              </button>
              <form method="POST" action="/api/admin/logout">
                <button
                  type="submit"
                  class="px-4 py-2 text-sm font-medium text-red-400 hover:text-white bg-red-900/20 hover:bg-red-900/40 border border-red-800/50 rounded-md transition-all flex items-center space-x-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                    />
                  </svg>
                  <span>Cerrar sesión</span>
                </button>
              </form>
            </div>
          </div>

          {errorMessage && (
            <div class="bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded-md flex items-center animate-fade-in">
              <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              {errorMessage}
            </div>
          )}
          
          {successMessage && (
            <div class="bg-green-900/50 border border-green-700 text-green-200 px-4 py-3 rounded-md flex items-center animate-fade-in">
              <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {successMessage}
            </div>
          )}

          {/* Upload Lua Section */}
          <div class="bg-gray-800/50 backdrop-blur-sm p-6 rounded-md border border-gray-700/50 shadow-xl">
            <h2 class="text-xl font-bold text-white mb-4">Actualizar Roster (Lua)</h2>
            <form method="POST" enctype="multipart/form-data" class="flex items-center space-x-4">
              <input
                type="file"
                name="lua_file"
                accept=".lua"
                required
                class="block w-full text-sm text-gray-400
                  file:mr-4 file:py-2 file:px-4
                  file:rounded-md file:border-0
                  file:text-sm file:font-semibold
                  file:bg-amber-600 file:text-white
                  hover:file:bg-amber-700
                  cursor-pointer"
              />
              <button
                type="submit"
                class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md shadow-sm text-sm font-medium transition-colors"
              >
                Subir y Procesar
              </button>
            </form>
            <p class="text-xs text-gray-500 mt-2">
              Sube el archivo <code>RaidDominion-main.lua</code> para actualizar la base de datos de jugadores y cores.
            </p>
          </div>

          {isLoading ? (
            <div class="flex justify-center items-center h-64">
              <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-amber-500" />
            </div>
          ) : (
            <>
              {/* Stats Overview */}
              <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div 
                  class="bg-gray-800/50 backdrop-blur-sm p-4 rounded-md border border-gray-700/50 cursor-pointer hover:bg-gray-700/50 transition-colors"
                  onclick="filterByStatus('all')"
                >
                  <div class="text-gray-400 text-sm font-medium mb-1">Total Solicitudes</div>
                  <div class="text-3xl font-bold text-white">{registrations.length}</div>
                </div>
                <div 
                  class="bg-blue-900/20 backdrop-blur-sm p-4 rounded-md border border-blue-700/30 cursor-pointer hover:bg-blue-900/40 transition-colors"
                  onclick="filterByStatus('en_revision')"
                >
                  <div class="text-blue-300 text-sm font-medium mb-1">En Revisión</div>
                  <div class="text-3xl font-bold text-blue-400">
                    {registrations.filter((r) => r.status === 'en_revision').length}
                  </div>
                </div>
                <div 
                  class="bg-green-900/20 backdrop-blur-sm p-4 rounded-md border border-green-700/30 cursor-pointer hover:bg-green-900/40 transition-colors"
                  onclick="filterByStatus('aceptado')"
                >
                  <div class="text-green-300 text-sm font-medium mb-1">Aceptados</div>
                  <div class="text-3xl font-bold text-green-400">
                    {registrations.filter((r) => r.status === 'aceptado').length}
                  </div>
                </div>
                <div 
                  class="bg-amber-900/20 backdrop-blur-sm p-4 rounded-md border border-amber-700/30 cursor-pointer hover:bg-amber-900/40 transition-colors"
                  onclick="filterByStatus('en_espera')"
                >
                  <div class="text-amber-300 text-sm font-medium mb-1">En Espera</div>
                  <div class="text-3xl font-bold text-amber-400">
                    {registrations.filter((r) => r.status === 'en_espera').length}
                  </div>
                </div>
              </div>

              {/* Raid Groups */}
              <div class="space-y-6">
                {wotlkRaids.length === 0 ? (
                  <div class="text-center py-12 bg-gray-800/30 rounded-md border border-gray-700/50">
                    <svg
                      class="mx-auto h-12 w-12 text-gray-500"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                      />
                    </svg>
                    <p class="mt-2 text-gray-400">No hay solicitudes para mostrar</p>
                  </div>
                ) : (
                  (() => {
                    // First group by normalized raid name
                    const raidGroups = new Map();
                    
                    // Initialize raidGroups with all raids from wotlkRaids
                    wotlkRaids.forEach(raid => {
                      const normalizedKey = raid.id.toUpperCase().trim();
                      if (!raidGroups.has(normalizedKey)) {
                        raidGroups.set(normalizedKey, {
                          raid_id: raid.id, // Keep original ID for reference
                          raid_name: raid.name,
                          schedules: new Map(),
                        });
                      }
                    });

                    // Add information from roster.json cores
                    if (rosterData && rosterData.players) {
                      Object.entries(rosterData.players).forEach(([playerName, member]: [string, any]) => {
                        const leaderData = member.leaderData;
                        if (!leaderData || !leaderData.cores || !Array.isArray(leaderData.cores)) return;

                        leaderData.cores.forEach((core) => {
                          if (!core.raid) return;

                          const normalizedRaidKey = core.raid.toUpperCase().trim();
                          const raidGroup = raidGroups.get(normalizedRaidKey);
                          if (!raidGroup) return;

                          // Parse schedule string (e.g., "Viernes 19:30")
                          const scheduleParts = core.schedule ? core.schedule.split(' ') : [];
                          const day = scheduleParts[0] || 'Desconocido';
                          const time = scheduleParts[1] || '--:--';
                          const scheduleKey = `${day.toLowerCase()}-${time}`;

                          if (!raidGroup.schedules.has(scheduleKey)) {
                            raidGroup.schedules.set(scheduleKey, {
                              day_of_week: day,
                              start_time: time,
                              registrations: [],
                              core_members: [],
                              is_core: true
                            });
                          }

                          const schedule = raidGroup.schedules.get(scheduleKey);

                          // Add the leader themselves first
                          if (!schedule.core_members.some(cm => cm.name === playerName)) {
                            schedule.core_members.push({
                              name: playerName,
                              class: member.class || 'Desconocido',
                              role: 'Líder de Raid',
                              isLeader: 1,
                              source: 'roster'
                            });
                          } else {
                            // If leader is already in list, make sure isLeader is 1
                            const leaderIdx = schedule.core_members.findIndex(cm => cm.name === playerName);
                            if (leaderIdx !== -1) {
                              schedule.core_members[leaderIdx].isLeader = 1;
                            }
                          }

                          if (core.members && Array.isArray(core.members)) {
                            // Avoid duplicates in core_members
                            core.members.forEach(m => {
                              if (!schedule.core_members.some(cm => cm.name === m.name)) {
                                schedule.core_members.push({
                                  ...m,
                                  source: 'roster'
                                });
                              }
                            });
                          }
                        });
                      });
                    }
                    
                    registrations.forEach((reg) => {
                      const raidName = getRaidName(reg.raid_id);
                      const normalizedRaidKey = raidName.toUpperCase().trim();
                      
                      if (!raidGroups.has(normalizedRaidKey)) {
                        raidGroups.set(normalizedRaidKey, {
                          raid_id: raidName,
                          raid_name: raidName,
                          schedules: new Map(),
                        });
                      }
                      
                      const raidGroup = raidGroups.get(normalizedRaidKey);
                      const normalizedDay = reg.day_of_week?.toLowerCase() || '';
                      const scheduleKey = `${normalizedDay}-${reg.start_time}`;
                      
                      if (!raidGroup.schedules.has(scheduleKey)) {
                        raidGroup.schedules.set(scheduleKey, {
                          day_of_week: reg.day_of_week,
                          start_time: reg.start_time,
                          registrations: [],
                          core_members: [],
                        });
                      }
                      
                      raidGroup.schedules.get(scheduleKey).registrations.push(reg);
                    });

                    // Convert to arrays and sort
                    const sortedRaids = Array.from(raidGroups.values())
                      .sort((a, b) => a.raid_name.localeCompare(b.raid_name))
                      .map(raid => {
                        const dayOrder = { lunes: 1, martes: 2, miercoles: 3, miércoles: 3, jueves: 4, viernes: 5, sabado: 6, sábado: 6, domingo: 7 };
                        
                        raid.schedules = Array.from(raid.schedules.values()).sort((a, b) => {
                          const dayA = a.day_of_week?.toLowerCase() || '';
                          const dayB = b.day_of_week?.toLowerCase() || '';
                          const dayDiff = (dayOrder[dayA] || 8) - (dayOrder[dayB] || 8);
                          if (dayDiff !== 0) return dayDiff;
                          return (a.start_time || '').localeCompare(b.start_time || '');
                        });
                        
                        return raid;
                      });

                    return sortedRaids.map((raid) => {
                      const raidDisplayName = raid.raid_name.toUpperCase();
                      const totalPlayers = raid.schedules.reduce((sum, s) => sum + s.registrations.length + s.core_members.length, 0);
                      const totalPending = raid.schedules.reduce((sum, s) => 
                        sum + s.registrations.filter(r => r.status === 'en_revision').length, 0
                      );
                      const totalAcceptedSupabase = raid.schedules.reduce((sum, s) => 
                        sum + s.registrations.filter(r => r.status === 'aceptado').length, 0
                      );
                      
                      // Contador que excluye core_members (solo cuenta Supabase)
                      const supabaseCount = raid.schedules.reduce((sum, s) => sum + s.registrations.length, 0);
                      
                      const eligibleCount = raidEligibleMembers[raid.raid_id]?.length || 0;

                      return (
                        <div 
                          class="raid-group bg-gray-800/20 backdrop-blur-md rounded-xl border border-white/5 overflow-hidden transition-all duration-500 hover:border-amber-500/30 hover:shadow-2xl hover:shadow-amber-900/10 group"
                          data-raid-name={raidDisplayName}
                          x-data="{ open: false }"
                          :class="open ? 'bg-gray-800/40 border-amber-500/20 shadow-2xl' : ''"
                        >
                          <div 
                            @click="open = !open"
                            class="flex items-center justify-between p-5 cursor-pointer select-none transition-colors"
                            :class="open ? 'bg-gray-800/30' : 'hover:bg-white/5'"
                          >
                            <div class="flex items-center space-x-5 flex-1">
                              <div 
                                class="w-10 h-10 flex items-center justify-center rounded-lg bg-gray-700/30 text-gray-400 transition-all duration-300 group-hover:scale-110"
                                :class="open ? 'bg-amber-500/20 text-amber-400 rotate-90 shadow-lg shadow-amber-500/10' : ''"
                              >
                                <svg
                                  class="w-5 h-5 transition-transform duration-300"
                                  fill="none"
                                  viewBox="0 0 24 24"
                                  stroke="currentColor"
                                >
                                  <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2.5"
                                    d="M9 5l7 7-7 7"
                                  />
                                </svg>
                              </div>
                              
                              <div class="flex-1">
                                <div class="flex items-center justify-between mb-1.5">
                                  <div class="flex items-center flex-col space-3">
                                    <h3 class="text-xl font-black tracking-tight text-white group-hover:text-amber-400 transition-colors">
                                      {raidDisplayName}
                                    </h3>
                                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-gray-700/50 text-gray-400 border border-gray-600/30">
                                      {raid.schedules.length === 1 ? 'HORARIO' : 'HORARIOS'}: {raid.schedules.length}
                                    </span>
                                  </div>

                                  <div class="flex items-center flex-col space-y-2">
                                    <button
                                      type="button"
                                      @click.stop={`copyInviteCommand(${JSON.stringify(
                                        Array.from(new Set(
                                          raid.schedules.flatMap(schedule => [
                                            ...(schedule.core_members || []).map(m => {
                                              const role = m.role?.toLowerCase() || '';
                                              const className = m.class?.toLowerCase() || '';
                                              const isRanged = className.includes('mage') || className.includes('warlock') || className.includes('hunter') || (className.includes('druid') && !role.includes('tank')) || (className.includes('priest') && !role.includes('heal')) || (className.includes('shaman') && !role.includes('heal'));
                                              const prefix = role.includes('tank') ? 'T' : role.includes('heal') ? 'H' : (isRanged ? 'R' : 'M');
                                              return prefix + m.name;
                                            }),
                                            ...schedule.registrations.map(r => {
                                              const role = r.player_role?.toLowerCase() || '';
                                              const className = r.player_class?.toLowerCase() || '';
                                              const isRanged = className.includes('mage') || className.includes('warlock') || className.includes('hunter') || (className.includes('druid') && !role.includes('tank')) || (className.includes('priest') && !role.includes('heal')) || (className.includes('shaman') && !role.includes('heal'));
                                              const prefix = role.includes('tank') ? 'T' : role.includes('heal') ? 'H' : (isRanged ? 'R' : 'M');
                                              return prefix + r.player_name;
                                            })
                                          ])
                                        ))
                                      )}, '${raidDisplayName}', '', '')`}
                                      class="flex items-center px-3 py-1.5 bg-indigo-500/10 hover:bg-indigo-500/20 border border-indigo-500/20 text-indigo-300 text-[10px] font-bold uppercase tracking-wider rounded-lg transition-all"
                                      title="Copiar lista de nombres de TODOS los horarios"
                                    >
                                      <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                      </svg>
                                        Solicitudes
                                    </button>
                                    
                                    <button
                                      type="button"
                                      @click.stop={`openRosterModal('${raid.raid_id}')`}
                                      class="flex items-center px-3 py-1.5 bg-blue-500/10 hover:bg-blue-500/20 border border-blue-500/20 text-blue-300 text-[10px] font-bold uppercase tracking-wider rounded-lg transition-all"
                                      title="Ver miembros elegibles del roster"
                                    >
                                      <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                      </svg>
                                      {eligibleCount} Hermandad
                                    </button>

                                    {userRole === 'admin' && (
                                      <button
                                        type="button"
                                        @click.stop={`openNewScheduleModal('${raid.raid_id}', '${raidDisplayName}')`}
                                        class="flex items-center px-3 py-1.5 bg-amber-600 hover:bg-amber-500 text-white text-[10px] font-bold uppercase tracking-wider rounded-lg transition-all shadow-lg shadow-amber-900/20 active:scale-95"
                                      >
                                        <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path>
                                        </svg>
                                        Nuevo Horario
                                      </button>
                                    )}
                                  </div>
                                </div>
                                
                                <div class="flex items-center space-x-4 text-[11px] text-gray-400 font-medium">
                                  <div class="flex items-center">
                                    <div class="w-2 h-2 rounded-full bg-blue-500 mr-2 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></div>
                                    <span>{supabaseCount} Solicitudes</span>
                                  </div>
                                  
                                  {totalPending > 0 && (
                                    <div class="flex items-center text-blue-300">
                                      <div class="w-2 h-2 rounded-full bg-blue-400 mr-2 animate-pulse shadow-[0_0_8px_rgba(96,165,250,0.5)]"></div>
                                      <span>{totalPending} Pendientes</span>
                                    </div>
                                  )}

                                  <div class="flex-1 max-w-[120px] ml-auto">
                                    <div class="flex items-center justify-between mb-1">
                                      <span class="text-[9px] text-gray-500 uppercase">Progreso</span>
                                      <span class="text-[9px] text-green-400 font-bold">{supabaseCount > 0 ? Math.min(100, Math.round((totalAcceptedSupabase / supabaseCount) * 100)) : 0}%</span>
                                    </div>
                                    <div class="h-1.5 w-full bg-gray-700/50 rounded-full overflow-hidden border border-white/5">
                                      <div
                                        class="h-full bg-gradient-to-r from-green-500 to-emerald-400 transition-all duration-1000 ease-out shadow-[0_0_10px_rgba(16,185,129,0.3)]"
                                        style={`width: ${supabaseCount > 0 ? Math.min(100, (totalAcceptedSupabase / supabaseCount) * 100) : 0}%`}
                                      />
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div 
                            x-show="open" 
                            x-collapse 
                            class="border-t border-white/5 bg-gray-900/40"
                          >
                            <div class="p-5 space-y-4">
                              {raid.schedules.map((schedule) => {
                                const pendingCount = schedule.registrations.filter(r => r.status === 'en_revision').length;
                                const supabaseCountSchedule = schedule.registrations.length;

                                return (
                                  <div 
                                    class="bg-gray-800/40 rounded-xl border border-white/5 overflow-hidden schedule-details transition-all hover:border-white/10" 
                                    data-day={schedule.day_of_week.toLowerCase()}
                                    x-data="{ sOpen: false }"
                                    :class="sOpen ? 'bg-gray-800/60 ring-1 ring-white/10 shadow-xl' : ''"
                                  >
                                    <div 
                                      @click="sOpen = !sOpen"
                                      class="flex items-center justify-between p-4 cursor-pointer hover:bg-white/5 transition-colors"
                                    >
                                      <div class="flex items-center space-x-4 flex-1">
                                        <div 
                                          class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-700/30 text-gray-500 transition-all duration-300"
                                          :class="sOpen ? 'bg-amber-500/10 text-amber-400 rotate-90' : ''"
                                        >
                                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                                          </svg>
                                        </div>
                                        
                                        <div class="flex items-center space-x-4">
                                          <div class="flex flex-col">
                                            <span class="text-sm font-black text-white uppercase tracking-tight">{schedule.day_of_week}</span>
                                            <span class="text-[10px] text-amber-500 font-bold leading-tight">{schedule.start_time} ST</span>
                                          </div>
                                          
                                          <div class="h-6 w-px bg-white/10"></div>
                                          
                                          <div class="flex items-center space-x-3">
                                            <div class="flex flex-col">
                                              <span class="text-[10px] text-gray-500 uppercase font-bold">Solicitudes</span>
                                              <span class="text-xs text-white font-medium">{supabaseCountSchedule}</span>
                                            </div>
                                            
                                            {pendingCount > 0 && (
                                              <div class="flex flex-col">
                                                <span class="text-[10px] text-blue-400/70 uppercase font-bold">Pendientes</span>
                                                <span class="text-xs text-blue-400 font-bold">{pendingCount}</span>
                                              </div>
                                            )}
                                          </div>
                                        </div>
                                      </div>

                                      <div class="flex items-center space-x-4">
                                        <div class="flex flex-col items-end mr-2">
                                          <span class="text-[9px] text-gray-500 uppercase font-bold mb-1">Llenado</span>
                                          <div class="h-1.5 w-20 bg-gray-700/50 rounded-full overflow-hidden border border-white/5">
                                            <div
                                              class="h-full bg-gradient-to-r from-blue-500 to-indigo-400 shadow-[0_0_8px_rgba(59,130,246,0.3)]"
                                              style={`width: ${supabaseCountSchedule > 0 ? Math.min(100, (schedule.registrations.filter(r => r.status === 'aceptado').length / supabaseCountSchedule) * 100) : 0}%`}
                                            />
                                          </div>
                                        </div>
                                      </div>
                                    </div>

                                    <div 
                                      x-show="sOpen" 
                                      x-collapse
                                      class="border-t border-white/5"
                                    >
                                      <div x-data="{ tab: 'supabase' }">
                                        {/* Tab Headers */}
                                        <div class="flex border-b border-white/5 bg-gray-900/50">
                                          <button 
                                            @click="tab = 'supabase'"
                                            type="button"
                                            class="flex-1 px-4 py-3 text-[10px] font-black uppercase tracking-widest transition-all border-b-2 relative"
                                            :class="tab === 'supabase' ? 'text-blue-400 border-blue-500 bg-blue-500/5' : 'text-gray-500 border-transparent hover:text-gray-400 hover:bg-gray-800/30'"
                                          >
                                            <span class="relative z-10">Solicitudes Web ({schedule.registrations.length})</span>
                                            <div x-show="tab === 'supabase'" class="absolute inset-0 bg-blue-500/5 blur-sm"></div>
                                          </button>
                                          <button 
                                            @click="tab = 'roster'"
                                            type="button"
                                            class="flex-1 px-4 py-3 text-[10px] font-black uppercase tracking-widest transition-all border-b-2 relative"
                                            :class="tab === 'roster' ? 'text-indigo-400 border-indigo-500 bg-indigo-500/5' : 'text-gray-500 border-transparent hover:text-gray-400 hover:bg-gray-800/30'"
                                          >
                                            <span class="relative z-10">Roster Core ({schedule.core_members.length})</span>
                                            <div x-show="tab === 'roster'" class="absolute inset-0 bg-indigo-500/5 blur-sm"></div>
                                          </button>
                                        </div>

                                        <div class="overflow-x-auto custom-scrollbar">
                                          <table class="min-w-full divide-y divide-white/5">
                                            <thead class="bg-black/20">
                                              <tr>
                                                <th scope="col" class="px-6 py-4 text-left text-[10px] font-black text-gray-500 uppercase tracking-widest">Jugador / Info</th>
                                                <th scope="col" class="px-6 py-4 text-right text-[10px] font-black text-gray-500 uppercase tracking-widest">Gestión</th>
                                              </tr>
                                            </thead>
                                            
                                            {/* TAB 1: Solicitudes Externas (Supabase) */}
                                            <tbody class="divide-y divide-white/5 bg-gray-800/20" x-show="tab === 'supabase'">
                                              {schedule.registrations.length === 0 ? (
                                                <tr>
                                                  <td colspan="2" class="px-6 py-12 text-center text-xs text-gray-500 font-medium italic">
                                                    No hay solicitudes externas registradas.
                                                  </td>
                                                </tr>
                                              ) : (
                                                schedule.registrations.map((reg) => (
                                                  <tr class="registration-card hover:bg-white/5 transition-colors group/row">
                                                    <td class="px-6 py-4">
                                                      <div class="flex flex-col space-y-2">
                                                        <div class="flex items-center justify-between">
                                                          {userRole === 'admin' ? (
                                                            <button
                                                              type="button"
                                                              onclick={`openEditModal(${JSON.stringify(reg)})`}
                                                              class="text-left group/name flex items-center space-x-2"
                                                            >
                                                              <div class="text-sm font-bold text-white group-hover/name:text-amber-400 transition-colors">
                                                                {reg.player_name}
                                                              </div>
                                                              <svg class="w-3 h-3 text-gray-600 opacity-0 group-hover/name:opacity-100 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                                                              </svg>
                                                            </button>
                                                          ) : (
                                                            <div class="text-sm font-bold text-white">
                                                              {reg.player_name}
                                                            </div>
                                                          )}
                                                        </div>

                                                        <div class="flex items-center space-x-2">
                                                          <span class="px-1.5 py-0.5 rounded text-[9px] font-black uppercase tracking-tighter bg-gray-700/50 text-gray-300 border border-white/5">
                                                            {reg.player_class}
                                                          </span>
                                                          <span class="text-[9px] text-gray-500 font-bold uppercase">
                                                            {reg.player_role}
                                                          </span>
                                                        </div>
                                                        
                                                          <span
                                                            class={`status-badge inline-flex items-center px-2 py-0.5 rounded text-[9px] font-black uppercase tracking-tighter border ${
                                                              reg.status === 'aceptado'
                                                                ? 'bg-green-500/10 text-green-400 border-green-500/20 shadow-[0_0_10px_rgba(34,197,94,0.1)]'
                                                                : reg.status === 'en_espera'
                                                                  ? 'bg-amber-500/10 text-amber-400 border-amber-500/20 shadow-[0_0_10px_rgba(245,158,11,0.1)]'
                                                                  : 'bg-blue-500/10 text-blue-400 border-blue-500/20 shadow-[0_0_10px_rgba(59,130,246,0.1)]'
                                                            }`}
                                                          >
                                                            {reg.status === 'en_revision'
                                                              ? 'Revisión'
                                                              : reg.status === 'aceptado'
                                                                ? 'Aceptado'
                                                                : reg.status === 'en_espera'
                                                                  ? 'Espera'
                                                                  : reg.status}
                                                          </span>
                                                      </div>
                                                    </td>
                                                    <td class="px-6 py-4 whitespace-nowrap text-right">
                                                      <div class="flex justify-end space-x-1.5 opacity-60 group-hover/row:opacity-100 transition-opacity">
                                                        {userRole === 'admin' && (
                                                          <>
                                                            <form method="post" action="/api/admin/update-status" class="inline">
                                                              <input type="hidden" name="id" value={reg.id} />
                                                              <input type="hidden" name="status" value="aceptado" />
                                                              <button type="submit" disabled={reg.status === 'aceptado'} class="p-2 rounded-lg bg-green-500/10 text-green-400 hover:bg-green-500/20 border border-green-500/20 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
                                                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                                                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                                </svg>
                                                              </button>
                                                            </form>

                                                            <form method="post" action="/api/admin/update-status" class="inline">
                                                              <input type="hidden" name="id" value={reg.id} />
                                                              <input type="hidden" name="status" value="en_revision" />
                                                              <button type="submit" disabled={reg.status === 'en_revision'} class="p-2 rounded-lg bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 border border-blue-500/20 transition-all disabled:opacity-30 disabled:cursor-not-allowed">
                                                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                                                  <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" /><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                                                </svg>
                                                              </button>
                                                            </form>

                                                            <form method="post" action="/api/admin/delete" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar esta solicitud?');">
                                                              <input type="hidden" name="id" value={reg.id} />
                                                              <button type="submit" class="p-2 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500/20 border border-red-500/20 transition-all">
                                                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                                                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                                                </svg>
                                                              </button>
                                                            </form>
                                                          </>
                                                        )}
                                                      </div>
                                                    </td>
                                                  </tr>
                                                ))
                                              )}
                                            </tbody>

                                            {/* TAB 2: Miembros del Core (Confirmados en roster.json) */}
                                            <tbody class="divide-y divide-white/5 bg-indigo-500/5" x-show="tab === 'roster'" x-cloak>
                                              {schedule.core_members && schedule.core_members.length > 0 ? (
                                                schedule.core_members.map((member) => (
                                                  <tr class="hover:bg-indigo-500/10 transition-colors border-l-2 border-indigo-500/50">
                                                    <td class="px-6 py-4">
                                                      <div class="flex flex-col space-y-1">
                                                        <div class="flex items-center space-x-2">
                                                          <div class="text-sm font-black text-white">{member.name}</div>
                                                        </div>
                                                        <div class="flex items-center space-x-2">
                                                          <span class="px-1.5 py-0.5 rounded text-[9px] font-black uppercase tracking-tighter bg-indigo-500/10 text-indigo-300 border border-indigo-500/10">
                                                            {member.class || '---'}
                                                          </span>
                                                          <span class="text-[9px] text-gray-500 font-bold uppercase">
                                                            {member.role || '---'}
                                                          </span>
                                                        </div>
                                                      </div>
                                                    </td>
                                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                      <span class="text-gray-600 text-[10px] font-bold uppercase tracking-tight italic">Sincronizado</span>
                                                    </td>
                                                  </tr>
                                                ))
                                              ) : (
                                                <tr>
                                                  <td colspan="2" class="px-6 py-12 text-center text-xs text-gray-500 font-medium italic">
                                                    No hay miembros del core definidos.
                                                  </td>
                                                </tr>
                                              )}
                                            </tbody>
                                          </table>
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        </div>
                      );
                    });
                  })()
                )}
              </div>
            </>
          )}
        </div>

        {/* Edit Player Modal */}
        <div
          id="edit-modal"
          class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-50 flex items-center justify-center p-4"
        >
          <div class="bg-gray-800 rounded-md shadow-2xl max-w-lg w-full border border-gray-700">
            <div class="p-4 border-b border-gray-700 flex justify-between items-center">
              <h2 class="text-xl font-bold text-white">Editar Registro</h2>
              <button
                onclick="closeEditModal()"
                class="text-gray-400 hover:text-white transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"
                  />
                </svg>
              </button>
            </div>

            <form
              id="edit-form"
              method="POST"
              action="/api/admin/update-registration"
              class="p-4 space-y-3"
            >
              <input type="hidden" name="id" id="edit-id" />
              <input type="hidden" name="status" id="edit-status" value="aceptado" />
              
              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">Banda</label>
                <select
                  name="raid_id"
                  id="edit-raid-id"
                  required
                  class="w-full px-3 py-2 text-sm bg-gray-700 border border-gray-600 rounded-md text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent"
                >
                  {wotlkRaids.map((raid) => (
                    <option value={raid.id}>
                      {raid.name}
                    </option>
                  ))}
                </select>
              </div>

              <div>
                <label class="block text-xs font-medium text-gray-400 mb-1">
                  Nombre del Jugador
                </label>
                <input
                  type="text"
                  name="player_name"
                  id="edit-player-name"
                  required
                  class="w-full px-3 py-2 text-sm bg-gray-700 border border-gray-600 rounded-md text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent"
                />
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs font-medium text-gray-400 mb-1">Clase</label>
                  <select
                    name="player_class"
                    id="edit-player-class"
                    required
                    class="w-full px-3 py-2 text-sm bg-gray-700 border border-gray-600 rounded-md text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent"
                  >
                    <option value="death-knight">Caballero de la Muerte</option>
                    <option value="druid">Druida</option>
                    <option value="hunter">Cazador</option>
                    <option value="mage">Mago</option>
                    <option value="paladin">Paladín</option>
                    <option value="priest">Sacerdote</option>
                    <option value="rogue">Pícaro</option>
                    <option value="shaman">Chamán</option>
                    <option value="warlock">Brujo</option>
                    <option value="warrior">Guerrero</option>
                  </select>
                </div>

                <div>
                  <label class="block text-xs font-medium text-gray-400 mb-1">Rol</label>
                  <select
                    name="player_role"
                    id="edit-player-role"
                    required
                    class="w-full px-3 py-2 text-sm bg-gray-700 border border-gray-600 rounded-md text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent"
                  >
                    <option value="tank">Tank</option>
                    <option value="healer">Healer</option>
                    <option value="melee">Melee</option>
                    <option value="ranged">Ranged</option>
                  </select>
                </div>
