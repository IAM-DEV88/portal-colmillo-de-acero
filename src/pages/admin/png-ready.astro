---
import Layout from '../../components/layout/Layout.astro';
import AdminNav from '../../components/admin/AdminNav.astro';

const userRole = Astro.locals.userRole || 'admin';

---

<Layout title="PNG Ready PRO - Editor Elite">
  <div class="py-4 space-y-4 h-[calc(100vh-2rem)] flex flex-col">
    <AdminNav userRole={userRole} activePage="png-ready" />
    
    <div class="flex-1 grid grid-cols-1 xl:grid-cols-[1fr_300px] gap-4 min-h-0">
      
      <!-- WORKSPACE AREA -->
      <div class="relative bg-[#0d0d0f] rounded-2xl border border-white/5 shadow-2xl overflow-hidden flex flex-col group/workspace">
        <!-- Floating Toolbar (Superior) -->
        <div class="absolute top-4 left-1/2 -translate-x-1/2 z-40 flex items-center gap-1.5 bg-[#141416]/80 backdrop-blur-2xl border border-white/10 p-1 rounded-2xl shadow-2xl ring-1 ring-white/5">
          <button id="tool-pan" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95 group/tool relative" title="Pan (H)">
            <i class="fas fa-hand text-[13px]"></i>
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-black/80 backdrop-blur-md text-[8px] px-2 py-1 rounded-md opacity-0 group-hover/tool:opacity-100 transition-opacity whitespace-nowrap border border-white/10 font-black tracking-widest uppercase">Mano</span>
          </button>
          <button id="tool-magic" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95 group/tool relative active" title="Varita Mágica (M)">
            <i class="fas fa-wand-magic-sparkles text-[13px]"></i>
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-black/80 backdrop-blur-md text-[8px] px-2 py-1 rounded-md opacity-0 group-hover/tool:opacity-100 transition-opacity whitespace-nowrap border border-white/10 font-black tracking-widest uppercase">Varita</span>
          </button>
          <div class="w-px h-4 bg-white/10 mx-0.5"></div>
          <button id="undo-btn" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95 disabled:opacity-20 group/tool relative" disabled title="Deshacer (Ctrl+Z)">
            <i class="fas fa-rotate-left text-[13px]"></i>
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-black/80 backdrop-blur-md text-[8px] px-2 py-1 rounded-md opacity-0 group-hover/tool:opacity-100 transition-opacity whitespace-nowrap border border-white/10 font-black tracking-widest uppercase">Deshacer</span>
          </button>
          <div class="w-px h-4 bg-white/10 mx-0.5"></div>
          <button id="zoom-out" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95" title="Zoom Out">
            <i class="fas fa-minus text-[10px]"></i>
          </button>
          <div id="zoom-level" class="text-[9px] font-black text-cyan-500/80 min-w-[45px] text-center select-none font-mono">100%</div>
          <button id="zoom-in" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95" title="Zoom In">
            <i class="fas fa-plus text-[10px]"></i>
          </button>
          <div class="w-px h-4 bg-white/10 mx-0.5"></div>
          <button id="reset-view" class="w-9 h-9 rounded-xl flex items-center justify-center transition-all hover:bg-white/5 text-gray-400 active:scale-95 group/tool relative" title="Reset (R)">
            <i class="fas fa-expand text-[13px]"></i>
            <span class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-black/80 backdrop-blur-md text-[8px] px-2 py-1 rounded-md opacity-0 group-hover/tool:opacity-100 transition-opacity whitespace-nowrap border border-white/10 font-black tracking-widest uppercase">Encajar</span>
          </button>
        </div>

        <!-- Main Viewport -->
        <div id="viewport" class="flex-1 relative overflow-hidden cursor-default select-none">
          <!-- Dark Pattern Background -->
          <div class="absolute inset-0 bg-[#0d0d0f]">
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 40px 40px;"></div>
          </div>
          
          <!-- Dropzone -->
          <div id="dropzone-area" class="absolute inset-0 z-20 flex flex-col items-center justify-center text-center p-12 transition-all">
            <input type="file" id="image-input" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-30" />
            <div class="w-20 h-20 bg-white/5 rounded-[2.5rem] flex items-center justify-center border border-white/10 mb-6 shadow-2xl group-hover/workspace:scale-110 transition-all duration-700 ring-1 ring-white/5">
              <i class="fas fa-cloud-arrow-up text-2xl text-cyan-500/50"></i>
            </div>
            <h2 class="text-white/90 text-sm font-black uppercase tracking-[0.4em]">Importar Imagen</h2>
            <p class="text-white/20 text-[8px] mt-3 font-black tracking-[0.3em] uppercase">PNG • JPG • WEBP</p>
          </div>

          <!-- Canvas Transform Container -->
          <div id="canvas-transform" class="absolute inset-0 flex items-center justify-center pointer-events-none will-change-transform" style="transform: translate(0px, 0px) scale(1);">
            <div id="image-container" class="relative pointer-events-auto shadow-[0_0_150px_rgba(0,0,0,0.8)]">
              <img id="result-image" src="" alt="" draggable="false" class="max-w-none block bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] bg-zinc-950 rounded-sm" />
              <div id="click-overlay" class="absolute inset-0 z-10 hidden"></div>
            </div>
          </div>

          <!-- Processing Overlay -->
          <div id="canvas-loader" class="hidden absolute inset-0 z-50 bg-black/60 backdrop-blur-md flex flex-col items-center justify-center gap-4 transition-all duration-300">
            <div class="relative">
              <div class="w-12 h-12 border-t-2 border-cyan-500 rounded-full animate-spin"></div>
              <div class="absolute inset-0 w-12 h-12 border-2 border-cyan-500/10 rounded-full"></div>
            </div>
            <p class="text-cyan-500 font-black text-[9px] uppercase tracking-[0.6em] animate-pulse">Renderizando PNG</p>
          </div>
        </div>

        <!-- Footer Bar -->
        <div class="bg-[#141416] border-t border-white/5 px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2.5">
              <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
              <span id="status-text" class="text-[9px] font-black text-white/30 uppercase tracking-[0.2em]">Listo para procesar</span>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button id="clear-all" class="px-5 py-2.5 bg-white/5 hover:bg-white/10 text-white/40 hover:text-white/80 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all border border-white/5">Limpiar</button>
            <a id="download-btn" href="" download="result.png" class="px-7 py-2.5 bg-cyan-600 hover:bg-cyan-500 text-white text-[9px] font-black uppercase tracking-[0.3em] rounded-xl transition-all shadow-lg shadow-cyan-900/40 ring-1 ring-cyan-400/20">Descargar PRO</a>
          </div>
        </div>
      </div>

      <!-- SIDEBAR CONTROLS -->
      <aside class="flex flex-col gap-4 overflow-y-auto pr-1 custom-scrollbar w-full max-w-[320px]">
        <div class="bg-[#141416] rounded-2xl border border-white/5 p-6 shadow-2xl flex flex-col gap-8">
          <div>
            <h3 class="text-[10px] font-black text-white/30 uppercase tracking-[0.3em] mb-6 flex items-center gap-2.5">
              <i class="fas fa-sliders text-cyan-500/60"></i> Configuración
            </h3>

            <div class="space-y-8">
              <!-- Algorithm Mode -->
              <div class="space-y-4">
                <label class="text-[9px] font-black text-white/40 uppercase tracking-[0.2em]">Modo de Extracción</label>
                <div class="flex p-1 bg-black/40 rounded-2xl border border-white/5 ring-1 ring-white/5">
                  <button id="mode-global" class="mode-btn active flex-1 py-2.5 rounded-xl text-[8px] font-black uppercase tracking-widest transition-all">Global</button>
                  <button id="mode-exterior" class="mode-btn flex-1 py-2.5 rounded-xl text-[8px] font-black uppercase tracking-widest transition-all text-white/20">Exterior</button>
                </div>
              </div>

              <!-- Threshold -->
              <div class="space-y-5">
                <div class="flex justify-between items-center">
                  <label class="text-[9px] font-black text-white/40 uppercase tracking-[0.2em]">Tolerancia</label>
                  <span id="threshold-value" class="text-cyan-400 font-mono text-[10px] bg-cyan-500/10 px-2 py-0.5 rounded-md border border-cyan-500/20">230</span>
                </div>
                <div class="relative flex items-center group">
                  <input type="range" id="threshold-slider" min="150" max="255" value="230" class="w-full h-1 bg-white/5 rounded-lg appearance-none cursor-pointer accent-cyan-500" />
                </div>
              </div>

            <!-- Feather -->
            <div class="space-y-5">
              <div class="flex justify-between items-center">
                <label class="text-[9px] font-black text-white/40 uppercase tracking-[0.2em]">Suavizado Alpha</label>
                <span id="feather-value" class="text-cyan-400 font-mono text-[10px] bg-cyan-500/10 px-2 py-0.5 rounded-md border border-cyan-500/20">0</span>
              </div>
              <div class="relative flex items-center group">
                <input type="range" id="feather-slider" min="0" max="10" value="0" class="w-full h-1 bg-white/5 rounded-lg appearance-none cursor-pointer accent-cyan-500" />
              </div>
            </div>

            <!-- Erosion (Contracción) -->
            <div class="space-y-5">
              <div class="flex justify-between items-center">
                <label class="text-[9px] font-black text-white/40 uppercase tracking-[0.2em]">Pulido de Borde</label>
                <span id="erosion-value" class="text-emerald-400 font-mono text-[10px] bg-emerald-500/10 px-2 py-0.5 rounded-md border border-emerald-500/20">0</span>
              </div>
              <div class="relative flex items-center group">
                <input type="range" id="erosion-slider" min="0" max="5" value="0" class="w-full h-1 bg-white/5 rounded-lg appearance-none cursor-pointer accent-emerald-500" />
              </div>
            </div>
            </div>
          </div>

          <div class="pt-6 border-t border-white/5">
            <h4 class="text-[9px] font-black text-white/20 uppercase tracking-[0.3em] mb-4">Quick Shortcuts</h4>
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex flex-col gap-1">
                <span class="text-[7px] text-white/30 uppercase font-black">Mover</span>
                <span class="text-[9px] text-white/70 font-mono">Espacio</span>
              </div>
              <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex flex-col gap-1">
                <span class="text-[7px] text-white/30 uppercase font-black">Varita</span>
                <span class="text-[9px] text-white/70 font-mono">M</span>
              </div>
              <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex flex-col gap-1">
                <span class="text-[7px] text-white/30 uppercase font-black">Zoom</span>
                <span class="text-[9px] text-white/70 font-mono">Scroll</span>
              </div>
              <div class="bg-black/40 border border-white/5 p-3 rounded-xl flex flex-col gap-1">
                <span class="text-[7px] text-white/30 uppercase font-black">Reset</span>
                <span class="text-[9px] text-white/70 font-mono">R</span>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  // DOM Elements
  const imageInput = document.getElementById('image-input') as HTMLInputElement;
  const dropzoneArea = document.getElementById('dropzone-area');
  const resultImage = document.getElementById('result-image') as HTMLImageElement;
  const clickOverlay = document.getElementById('click-overlay');
  const canvasLoader = document.getElementById('canvas-loader');
  const downloadBtn = document.getElementById('download-btn') as HTMLAnchorElement;
  const clearAllBtn = document.getElementById('clear-all');
  const viewport = document.getElementById('viewport');
  const canvasTransform = document.getElementById('canvas-transform');
  const zoomLevelDisplay = document.getElementById('zoom-level');
  const magicToolBtn = document.getElementById('tool-magic');
  const panToolBtn = document.getElementById('tool-pan');
  const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
  const statusText = document.getElementById('status-text');

  // Sliders
  const thresholdSlider = document.getElementById('threshold-slider') as HTMLInputElement;
  const thresholdValue = document.getElementById('threshold-value');
  const featherSlider = document.getElementById('feather-slider') as HTMLInputElement;
  const featherValue = document.getElementById('feather-value');
  const erosionSlider = document.getElementById('erosion-slider') as HTMLInputElement;
  const erosionValue = document.getElementById('erosion-value');

  // State
  let currentFile: File | null = null;
  let processedBlob: Blob | null = null;
  let history: Blob[] = [];
  let currentMode = 'global';
  let activeTool: 'magic' | 'pan' = 'pan';
  let debounceTimer: any;

  // Transform State (Zoom & Pan)
  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  let isDragging = false;
  let startX = 0;
  let startY = 0;
  let isSpacePressed = false;

  // --- Transform Logic ---
  const updateTransform = (animate = false) => {
    if (canvasTransform) {
      if (animate) canvasTransform.style.transition = 'transform 0.3s cubic-bezier(0.23, 1, 0.32, 1)';
      else canvasTransform.style.transition = 'none';
      
      canvasTransform.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    }
    if (zoomLevelDisplay) {
      zoomLevelDisplay.textContent = `${Math.round(scale * 100)}%`;
    }
  };

  const setScaleAtPoint = (newScale: number, pointX: number, pointY: number) => {
    const rect = viewport?.getBoundingClientRect();
    if (!rect) return;

    const mouseX = pointX - rect.left;
    const mouseY = pointY - rect.top;

    // Relative to canvas center
    const xBefore = (mouseX - rect.width / 2 - translateX) / scale;
    const yBefore = (mouseY - rect.height / 2 - translateY) / scale;

    scale = newScale;

    translateX = (mouseX - rect.width / 2) - (xBefore * scale);
    translateY = (mouseY - rect.height / 2) - (yBefore * scale);

    updateTransform();
  };

  viewport?.addEventListener('wheel', (e) => {
    if (!currentFile) return;
    e.preventDefault();
    const zoomSpeed = 0.15;
    const factor = e.deltaY > 0 ? (1 - zoomSpeed) : (1 + zoomSpeed);
    const newScale = Math.max(0.1, Math.min(20, scale * factor));
    setScaleAtPoint(newScale, e.clientX, e.clientY);
  }, { passive: false });

  viewport?.addEventListener('mousedown', (e) => {
    if (!currentFile || e.button !== 0) return;
    
    if (isSpacePressed || activeTool === 'pan') {
      e.preventDefault(); // Evitar arrastre nativo e interrupción de mouseup
      isDragging = true;
      startX = e.clientX - translateX;
      startY = e.clientY - translateY;
      viewport.style.cursor = 'grabbing';
    }
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    translateX = e.clientX - startX;
    translateY = e.clientY - startY;
    updateTransform();
  });

  const stopDragging = () => {
    isDragging = false;
    if (viewport) viewport.style.cursor = isSpacePressed || activeTool === 'pan' ? 'grab' : 'default';
  };

  window.addEventListener('mouseup', stopDragging);
  window.addEventListener('blur', stopDragging); // Asegurar que el arrastre pare si se pierde el foco
  window.addEventListener('mouseleave', stopDragging); // Por si el mouse sale de la ventana mientras arrastra

  document.getElementById('zoom-in')?.addEventListener('click', () => { 
    const rect = viewport?.getBoundingClientRect();
    if (rect) setScaleAtPoint(scale * 1.2, rect.left + rect.width / 2, rect.top + rect.height / 2);
  });
  document.getElementById('zoom-out')?.addEventListener('click', () => { 
    const rect = viewport?.getBoundingClientRect();
    if (rect) setScaleAtPoint(scale / 1.2, rect.left + rect.width / 2, rect.top + rect.height / 2);
  });
  
  const resetView = () => {
    scale = 1; translateX = 0; translateY = 0; 
    updateTransform(true);
  };
  document.getElementById('reset-view')?.addEventListener('click', resetView);

  // Keyboard Shortcuts
  window.addEventListener('keydown', (e) => {
    if (e.code === 'Space') { 
      isSpacePressed = true;
      if (viewport) viewport.style.cursor = 'grab';
    }
    if (e.key.toLowerCase() === 'm') setTool('magic');
    if (e.key.toLowerCase() === 'h') setTool('pan');
    if (e.key.toLowerCase() === 'r') resetView();
    if (e.key.toLowerCase() === 'z' && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      undo();
    }
  });

  window.addEventListener('keyup', (e) => {
    if (e.code === 'Space') {
      isSpacePressed = false;
      if (viewport) viewport.style.cursor = activeTool === 'pan' ? 'grab' : 'default';
    }
  });

  // --- Tool Logic ---
  const setTool = (tool: 'magic' | 'pan') => {
    activeTool = tool;
    magicToolBtn?.classList.toggle('bg-cyan-500/10', tool === 'magic');
    magicToolBtn?.classList.toggle('text-cyan-400', tool === 'magic');
    magicToolBtn?.classList.toggle('ring-1', tool === 'magic');
    magicToolBtn?.classList.toggle('ring-cyan-500/20', tool === 'magic');
    
    panToolBtn?.classList.toggle('bg-cyan-500/10', tool === 'pan');
    panToolBtn?.classList.toggle('text-cyan-400', tool === 'pan');
    panToolBtn?.classList.toggle('ring-1', tool === 'pan');
    panToolBtn?.classList.toggle('ring-cyan-500/20', tool === 'pan');

    clickOverlay?.classList.toggle('hidden', tool !== 'magic');
    if (viewport) viewport.style.cursor = tool === 'pan' ? 'grab' : 'default';
  };

  magicToolBtn?.addEventListener('click', () => setTool('magic'));
  panToolBtn?.addEventListener('click', () => setTool('pan'));
  
  // Iniciar con herramienta de mano por defecto
  setTool('pan');

  // --- Processing Logic ---
  const processImage = async (clickCoords: {x: number, y: number} | null = null) => {
    if (!currentFile) return;

    canvasLoader?.classList.remove('hidden');
    if (statusText) statusText.textContent = 'Procesando...';

    const formData = new FormData();
    // Siempre acumulativo: si existe processedBlob, lo usamos como base
    const baseImage = processedBlob ? processedBlob : currentFile;
    formData.append('image', baseImage);
    formData.append('threshold', thresholdSlider.value);
    formData.append('feather', featherSlider.value);
    formData.append('erosion', erosionSlider.value); // Enviar erosión
    formData.append('mode', currentMode);

    if (clickCoords) {
      const rect = resultImage.getBoundingClientRect();
      // Mapear clic a coordenadas reales de la imagen considerando zoom/pan
      const scaleX = resultImage.naturalWidth / rect.width;
      const scaleY = resultImage.naturalHeight / rect.height;
      formData.append('clickX', Math.round(clickCoords.x * scaleX).toString());
      formData.append('clickY', Math.round(clickCoords.y * scaleY).toString());
    }

    try {
      const response = await fetch('/api/admin/png-ready', { method: 'POST', body: formData });
      if (response.ok) {
        // Solo guardamos en el historial si el nuevo estado es diferente
        const newBlob = await response.blob();
        if (processedBlob) history.push(processedBlob);
        if (history.length > 20) history.shift();
        updateUndoButton();

        processedBlob = newBlob;
        const url = URL.createObjectURL(processedBlob);
        resultImage.src = url;
        downloadBtn.href = url;
        downloadBtn.download = `ready-${currentFile.name.split('.')[0]}.png`;
        
        dropzoneArea?.classList.add('hidden');
        resultImage.classList.remove('hidden');
        if (statusText) statusText.textContent = 'Imagen Optimizada';
      }
    } catch (error) {
      console.error(error);
      if (statusText) statusText.textContent = 'Error en proceso';
    } finally {
      canvasLoader?.classList.add('hidden');
    }
  };

  const undo = () => {
    if (history.length === 0) return;
    const lastState = history.pop();
    if (lastState) {
      processedBlob = lastState;
      const url = URL.createObjectURL(processedBlob);
      resultImage.src = url;
      downloadBtn.href = url;
      updateUndoButton();
    }
  };

  const updateUndoButton = () => {
    if (undoBtn) {
      undoBtn.disabled = history.length === 0;
      undoBtn.classList.toggle('opacity-20', history.length === 0);
    }
  };

  undoBtn?.addEventListener('click', undo);

  const debouncedProcess = () => {
    // Ya no reseteamos nada, permitiendo que sea acumulativo
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => processImage(), 400);
  };

  clickOverlay?.addEventListener('mousedown', (e: MouseEvent) => {
    if (activeTool !== 'magic' || isSpacePressed) return;
    const rect = clickOverlay.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    processImage({ x, y });
  });

  imageInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      currentFile = file;
      processedBlob = null;
      history = [];
      updateUndoButton();
      resetView();
      processImage();
    }
  });

  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.mode-btn').forEach(b => {
        b.classList.remove('active', 'text-white');
        b.classList.add('text-white/20');
      });
      btn.classList.add('active', 'text-white');
      btn.classList.remove('text-white/20');
      currentMode = btn.id === 'mode-exterior' ? 'exterior' : 'global';
      
      // El modo de extracción NO es acumulativo: reiniciamos el estado
      processedBlob = null;
      history = [];
      updateUndoButton();
      
      debouncedProcess();
    });
  });

  thresholdSlider?.addEventListener('input', () => {
    if (thresholdValue) thresholdValue.textContent = thresholdSlider.value;
    if (currentFile) debouncedProcess();
  });

  featherSlider?.addEventListener('input', () => {
    if (featherValue) featherValue.textContent = featherSlider.value;
    if (currentFile) debouncedProcess();
  });

  erosionSlider?.addEventListener('input', () => {
    if (erosionValue) erosionValue.textContent = erosionSlider.value;
    if (currentFile) debouncedProcess();
  });

  clearAllBtn?.addEventListener('click', () => {
    currentFile = null; processedBlob = null; history = [];
    updateUndoButton();
    imageInput.value = '';
    dropzoneArea?.classList.remove('hidden');
    resultImage.src = '';
    resetView();
    if (statusText) statusText.textContent = 'Workspace Limpio';
  });
</script>

<style>
  .mode-btn.active {
    background: rgba(6, 182, 212, 0.15);
    color: #06b6d4;
    border: 1px solid rgba(6, 182, 212, 0.3);
    box-shadow: 0 4px 12px rgba(6, 182, 212, 0.1);
  }
  
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 14px;
    height: 14px;
    background: #06b6d4;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.5);
    border: 2px solid #141416;
  }

  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  #result-image {
    cursor: inherit;
