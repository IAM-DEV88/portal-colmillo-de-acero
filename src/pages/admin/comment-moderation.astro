---
import Layout from '../../components/layout/Layout.astro';
import { supabase } from '../../lib/supabase';

// Solo permitir acceso a administradores
const session = Astro.cookies.get('admin_session')?.value;
const userRole = Astro.cookies.get('admin_role')?.value;

if (!session || userRole !== 'admin') {
  return Astro.redirect('/admin');
}

let errorMessage = '';
let successMessage = '';

// Handle POST requests for moderation
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action') as string;

    if (action === 'approve_comment') {
      const commentId = formData.get('comment_id') as string;
      const { error } = await supabase.from('guide_comments').update({ is_approved: true }).eq('id', commentId);
      if (error) errorMessage = error.message;
      else successMessage = 'Comentario aprobado';
    }
    
    if (action === 'delete_comment') {
      const commentId = formData.get('comment_id') as string;
      const { error } = await supabase.from('guide_comments').delete().eq('id', commentId);
      if (error) errorMessage = error.message;
      else successMessage = 'Comentario eliminado';
    }
  } catch (e) {
    errorMessage = `Error: ${e.message}`;
  }
}

// Fetch pending comments for moderation
const { data: pendingComments } = await supabase
  .from('guide_comments')
  .select('*, guides(title)')
  .eq('is_approved', false)
  .order('created_at', { ascending: true });

---

<Layout title="Moderación de Comentarios | Panel Admin">
  <div class="max-w-7xl mx-auto py-12 px-4 space-y-8">
    <div class="flex items-center justify-between bg-gray-800/50 backdrop-blur-sm p-6 rounded-md border border-gray-700/50 shadow-xl">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-purple-600 rounded-lg flex items-center justify-center shadow-lg shadow-purple-900/20">
          <i class="fas fa-comments text-2xl text-white"></i>
        </div>
        <div>
          <h1 class="text-3xl font-black text-white uppercase tracking-tighter italic">
            Moderación de <span class="text-purple-400">Comentarios</span>
          </h1>
          <p class="text-gray-400 text-xs font-medium uppercase tracking-widest mt-1">Gestión de la comunidad y guías</p>
        </div>
      </div>
      <a 
        href="/admin" 
        class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-white/10 text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2"
      >
        <i class="fas fa-arrow-left"></i>
        Volver al Panel
      </a>
    </div>

    {errorMessage && (
      <div class="bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded-md flex items-center animate-fade-in">
        <i class="fas fa-exclamation-circle mr-3"></i>
        {errorMessage}
      </div>
    )}
    
    {successMessage && (
      <div class="bg-green-900/50 border border-green-700 text-green-200 px-4 py-3 rounded-md flex items-center animate-fade-in">
        <i class="fas fa-check-circle mr-3"></i>
        {successMessage}
      </div>
    )}

    <div id="module-guides" class="bg-gray-800/50 backdrop-blur-sm p-6 rounded-md border border-purple-700/30 shadow-xl">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black text-white uppercase tracking-widest italic flex items-center gap-3">
          <i class="fas fa-comments text-purple-400"></i>
          Comentarios Pendientes
        </h2>
        <span class="px-3 py-1 bg-purple-500/10 text-purple-300 text-[10px] font-black uppercase tracking-widest border border-purple-500/20 rounded-full">
          {pendingComments?.length || 0} Pendientes
        </span>
      </div>

      {pendingComments && pendingComments.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {pendingComments.map((comment: any) => (
            <div class="bg-gray-900/60 border border-white/5 rounded-lg p-5 hover:border-purple-500/30 transition-all group">
              <div class="flex justify-between items-start mb-3">
                <div>
                  <p class="text-[10px] font-black text-purple-400 uppercase tracking-widest mb-1 italic">
                    En Guía: {comment.guides?.title || 'Guía Desconocida'}
                  </p>
                  <h4 class="text-sm font-black text-white uppercase italic">{comment.player_name}</h4>
                </div>
                <span class="text-[9px] font-bold text-gray-600 italic">
                  {new Date(comment.created_at).toLocaleDateString()}
                </span>
              </div>
              
              <p class="text-xs text-gray-400 mb-6 bg-black/30 p-3 rounded-lg border border-white/5 italic">
                "{comment.content}"
              </p>

              <div class="flex gap-2">
                <form method="POST" class="flex-1">
                  <input type="hidden" name="action" value="approve_comment" />
                  <input type="hidden" name="comment_id" value={comment.id} />
                  <button 
                    type="submit"
                    class="w-full py-2 bg-green-600/10 hover:bg-green-600 border border-green-600/30 text-green-400 hover:text-white text-[10px] font-black uppercase tracking-widest rounded-lg transition-all"
                  >
                    Aprobar
                  </button>
                </form>
                <form method="POST" class="flex-1">
                  <input type="hidden" name="action" value="delete_comment" />
                  <input type="hidden" name="comment_id" value={comment.id} />
                  <button 
                    type="submit"
                    class="w-full py-2 bg-red-600/10 hover:bg-red-600 border border-red-600/30 text-red-400 hover:text-white text-[10px] font-black uppercase tracking-widest rounded-lg transition-all"
                  >
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="py-12 text-center bg-gray-900/20 rounded-lg border border-dashed border-white/5">
          <i class="fas fa-check-circle text-gray-700 text-3xl mb-3"></i>
          <p class="text-gray-500 text-[10px] font-black uppercase tracking-widest italic">No hay comentarios pendientes de moderación</p>
        </div>
      )}
    </div>
  </div>
</Layout>
