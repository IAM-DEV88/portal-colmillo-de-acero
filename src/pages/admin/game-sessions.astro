                                Pozo
                              </span>
                              <span class="text-sm text-amber-400 font-black">
                                {gs.gold_pool} ⚜️
                              </span>
                            </div>
                            {gs.has_won_choker && (
                              <div class="flex flex-col items-center ml-2 border border-purple-500/30 bg-purple-900/20 px-2 py-1 rounded">
                                <span class="text-[9px] text-purple-400 uppercase font-bold">
                                  <i class="fas fa-gem mr-1" />
                                  Choker
                                </span>
                              </div>
                            )}
                          </div>
                        </td>
                        <td class="px-5 py-4 whitespace-nowrap text-right">
                          <button
                            type="button"
                            data-session={JSON.stringify(gs)}
                            onclick="window.openEditSessionModal(this.dataset.session)"
                            class="px-3 py-1.5 bg-blue-500/10 hover:bg-blue-500/20 border border-blue-500/30 text-blue-400 text-[10px] font-bold uppercase tracking-wider rounded transition-all hover:scale-105"
