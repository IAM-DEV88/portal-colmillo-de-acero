                <div class="flex items-center gap-4">
                  <span class="text-xs font-bold text-green-200 bg-green-900/50 px-3 py-1.5 rounded-full border border-green-500/30">
                    {recentSessions.length} Jugadores
                  </span>
                  <i class="fas fa-chevron-down text-green-500/70 transition-transform duration-300 group-open:-rotate-180" />
                </div>
              </summary>
              <div class="p-0 border-t border-green-500/20 max-h-[500px] overflow-y-auto custom-scrollbar">
                <table class="min-w-full divide-y divide-white/5">
                  <thead class="bg-black/40 sticky top-0 backdrop-blur-md z-10">
                    <tr>
                      <th class="px-5 py-3 text-left text-[10px] font-black text-green-500/70 uppercase tracking-widest w-1/4">
