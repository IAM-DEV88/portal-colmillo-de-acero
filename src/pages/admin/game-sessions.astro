---
import Layout from '../../components/layout/Layout.astro';
import AdminNav from '../../components/admin/AdminNav.astro';
import { supabase } from '../../lib/supabase';

const session = Astro.cookies.get('admin_session')?.value;
const userRole = Astro.cookies.get('admin_role')?.value || 'admin';

let errorMessage = '';
let successMessage = '';
let gameSessionsData = [];
let isLoading = true;

let recentSessions: any[] = [];
let todaySessions: any[] = [];
let inactiveSessions: any[] = [];

if (!session) {
  return Astro.redirect('/admin'); // Force login through main admin page
} else {
  try {
    const { data: gsData, error: gsError } = await supabase
      .from('game_sessions')
      .select('*')
      .order('last_active', { ascending: false });

    if (gsError) {
      errorMessage = 'Error al cargar las sesiones: ' + gsError.message;
    } else {
      gameSessionsData = gsData || [];

      const now = Date.now();
      gameSessionsData.forEach((gs) => {
        const lastActive = new Date(gs.last_active || now).getTime();
        const diffMinutes = (now - lastActive) / 60000;

        if (diffMinutes < 60) {
          recentSessions.push(gs);
        } else if (diffMinutes < 1440) {
          todaySessions.push(gs);
        } else {
          inactiveSessions.push(gs);
        }
      });
    }

    const success = Astro.url.searchParams.get('success');
    if (success === 'session_updated') successMessage = 'Sesión actualizada correctamente';
    const error = Astro.url.searchParams.get('error');
    if (error === 'session_update_failed') errorMessage = 'Error al actualizar sesión';
  } catch (e) {
    errorMessage = 'Error inesperado';
  } finally {
    isLoading = false;
  }
}

const formatDate = (dateStr: string | number | Date | undefined) => {
  if (!dateStr) return 'N/A';
  const d = new Date(dateStr);
  return d.toLocaleString('es-ES', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
  });
};
---

<Layout title="Admin - Sesiones Ruleta">
  <div class="max-w-7xl mx-auto space-y-8">
    <AdminNav userRole={userRole} activePage="game-sessions" />

    <div class="space-y-4">
      {
        errorMessage && (
          <div class="bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded-xl flex items-center animate-fade-in shadow-lg">
            <i class="fas fa-exclamation-circle mr-3" /> {errorMessage}
          </div>
        )
      }
      {
        successMessage && (
          <div class="bg-green-900/50 border border-green-700 text-green-200 px-4 py-3 rounded-xl flex items-center animate-fade-in shadow-lg">
            <i class="fas fa-check-circle mr-3" /> {successMessage}
