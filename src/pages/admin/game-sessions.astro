  >
    <div
      class="bg-gray-900 rounded-xl shadow-[0_0_30px_rgba(0,0,0,0.8)] max-w-lg w-full border border-gray-700/50 overflow-hidden relative"
    >
      <div
        class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-amber-600 via-amber-400 to-amber-600"
      >
      </div>
      <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-gray-900/80">
        <div class="flex items-center gap-3">
          <i class="fas fa-gamepad text-amber-500 text-xl"></i>
          <h2 class="text-lg font-black tracking-widest uppercase text-white">Editar Sesión</h2>
        </div>
        <button
          type="button"
          onclick="window.closeEditSessionModal()"
          class="text-gray-500 hover:text-white transition-colors p-1"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path></svg
          >
        </button>
      </div>
      <form id="edit-session-form" class="p-6 space-y-5 bg-gray-800/20">
        <input type="hidden" name="ip_hash" id="edit-session-hash" />

        <div class="bg-black/30 p-4 rounded-lg border border-white/5 space-y-4">
          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-widest text-gray-500 mb-1.5"
              >Identificador Único (IP Hash)</label
            >
            <input
              type="text"
              id="edit-session-hash-display"
              disabled
              class="w-full px-4 py-2.5 text-xs bg-gray-900/80 border border-gray-700/50 rounded-md text-gray-500 font-mono tracking-wider opacity-70"
            />
          </div>
          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-widest text-amber-500/80 mb-1.5"
              >Nombre de Personaje(s)</label
            >
            <input
              type="text"
              name="character_names"
              id="edit-session-chars"
              placeholder="Ej: Arthas, Jaina"
              class="w-full px-4 py-2.5 text-sm bg-gray-900 border border-amber-500/30 rounded-md text-white font-medium focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-all outline-none"
            />
          </div>
          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-widest text-green-500/80 mb-1.5"
              >Turnos Disponibles (Créditos)</label
            >
            <input
              type="number"
              name="credits"
              id="edit-session-credits"
              min="0"
              class="w-full px-4 py-2.5 text-sm bg-gray-900 border border-green-500/30 rounded-md text-white font-black focus:ring-2 focus:ring-green-500/50 focus:border-green-500 transition-all outline-none"
            />
          </div>
        </div>

        <div class="flex justify-end space-x-3 pt-4 border-t border-gray-800 mt-2">
          <button
            type="button"
            onclick="window.closeEditSessionModal()"
            class="px-5 py-2.5 text-[11px] font-bold tracking-[0.2em] uppercase text-gray-400 hover:text-white bg-transparent hover:bg-gray-800 rounded-lg transition-all border border-gray-700 hover:border-gray-500"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="px-6 py-2.5 text-[11px] font-black tracking-[0.2em] uppercase bg-gradient-to-r from-amber-600 to-amber-500 hover:from-amber-500 hover:to-amber-400 text-white rounded-lg transition-all shadow-[0_0_15px_rgba(245,158,11,0.4)] hover:shadow-[0_0_25px_rgba(245,158,11,0.6)] hover:-translate-y-0.5 active:translate-y-0"
          >
            Guardar Cambios
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    details > summary {
      list-style: none; /* Hide default triangle for standard browsers */
    }
    details > summary::-webkit-details-marker {
      display: none; /* Hide default triangle for WebKit browsers */
    }
  </style>

  <script is:inline>
    window.openEditSessionModal = function (sessionData) {
      const session = typeof sessionData === 'string' ? JSON.parse(sessionData) : sessionData;
      document.getElementById('edit-session-hash').value = session.ip_hash || '';
      document.getElementById('edit-session-hash-display').value = session.ip_hash || '';
      document.getElementById('edit-session-chars').value = session.character_names || '';
      document.getElementById('edit-session-credits').value = session.credits || 0;
      document.getElementById('edit-session-modal').classList.remove('hidden');
    };
    window.closeEditSessionModal = function () {
      document.getElementById('edit-session-modal').classList.add('hidden');
    };

    function showLiveToast(message, isError = false) {
      const div = document.createElement('div');
      div.className = `fixed bottom-6 right-6 ${isError ? 'bg-red-900 border-red-500 text-red-100' : 'bg-green-900 border-green-500 text-green-100'} border-2 px-6 py-4 rounded-xl shadow-[0_0_20px_rgba(0,0,0,0.5)] font-bold animate-fade-in z-[100] flex items-center min-w-[300px]`;
      div.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-triangle text-red-500' : 'fa-check-circle text-green-500'} mr-4 text-2xl drop-shadow-md"></i> <span class="tracking-wide">${message}</span>`;
      document.body.appendChild(div);
      setTimeout(() => {
        div.classList.add('opacity-0', 'transition-opacity', 'duration-500');
        setTimeout(() => div.remove(), 500);
      }, 3500);
    }

    document.getElementById('edit-session-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      const formData = new FormData(this);
      const submitBtn = this.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Guardando...';

      try {
        const res = await fetch('/api/admin/update-game-session', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (res.ok && data.success) {
          const row = document.querySelector(`tr[data-hash="${data.ip_hash}"]`);
          if (row) {
            if (data.character_names !== undefined) {
              row.querySelector('.char-names-display').innerHTML =
                data.character_names || 'Desconocido';
            }
            if (data.credits !== undefined) {
              row.querySelector('.credits-display').textContent = data.credits;
            }
            // Update the dataset so next edit keeps the modified data
            const btn = row.querySelector('button[data-session]');
            if (btn) {
              let d = JSON.parse(btn.dataset.session);
              d.character_names = data.character_names;
              d.credits = data.credits;
              btn.dataset.session = JSON.stringify(d);
            }
          }
          window.closeEditSessionModal();
          showLiveToast('Sesión actualizada correctamente');
        } else {
          showLiveToast(data.error || 'Error al actualizar sesión', true);
        }
      } catch (err) {
        showLiveToast('Error de conexión al procesar AJAX', true);
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  </script>
</Layout>
