                    <tr>
                      <th class="px-5 py-3 text-left text-[10px] font-black text-gray-500 uppercase tracking-widest w-1/4">
                        Jugador / IP Hash
                      </th>
                      <th class="px-5 py-3 text-left text-[10px] font-black text-gray-500 uppercase tracking-widest w-1/4">
