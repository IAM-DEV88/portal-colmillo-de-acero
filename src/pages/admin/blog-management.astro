---
import Layout from '../../components/layout/Layout.astro';
import AdminNav from '../../components/admin/AdminNav.astro';
import { BlogService } from '../../lib/blog-service';
import { supabase } from '../../lib/supabase';
import { DiscordService } from '../../services/discordService';

// Solo permitir acceso a administradores
const userRole = Astro.locals.userRole || 'admin';
if (userRole !== 'admin') {
  return Astro.redirect('/admin');
}

let errorMessage = '';
let successMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');
    const postId = formData.get('post_id') as string;

    if (action === 'generate') {
      const topic = formData.get('topic') as string;
      const isTest = formData.get('is_test') === 'true';
      const newPost = await BlogService.generatePost(topic, isTest);
      
      const { data: insertedPost, error } = await supabase
        .from('rd_blog_posts')
        .insert([newPost])
        .select();

      if (error) throw error;

      // Notificar en Discord
      if (insertedPost && insertedPost[0]) {
        await DiscordService.notifyNewBlogPost(insertedPost[0]);
      }

      successMessage = isTest 
        ? '¡Post de PRUEBA generado con éxito!' 
        : '¡Crónica generada y publicada!';
    } else if (action === 'toggle_visibility') {
      const isHidden = formData.get('is_hidden') === 'true';
      const { error } = await supabase
        .from('rd_blog_posts')
        .update({ is_hidden: !isHidden })
        .eq('id', postId);
      if (error) throw error;
      successMessage = 'Visibilidad actualizada';
    } else if (action === 'delete') {
      const { error } = await supabase
        .from('rd_blog_posts')
        .delete()
        .eq('id', postId);
      if (error) throw error;
      successMessage = 'Post eliminado definitivamente';
    }
  } catch (e: any) {
    errorMessage = `Error: ${e.message}`;
  }
}

// Obtener posts recientes y contador del día
const today = new Date();
today.setHours(0, 0, 0, 0);

const { data: posts } = await supabase
  .from('rd_blog_posts')
  .select('*')
  .order('created_at', { ascending: false });

const dailyPostsCount = posts?.filter(p => new Date(p.created_at) >= today).length || 0;
---

<Layout title="Gestión de Blog | Panel Admin">
  <div class="max-w-7xl mx-auto py-8 px-4 space-y-6">
    <AdminNav userRole={userRole} activePage="blog" />

    <!-- Header -->
    <div class="flex items-center justify-between bg-gray-900/80 backdrop-blur-md p-6 rounded-lg border border-white/5 shadow-xl">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-amber-500 rounded-lg flex items-center justify-center shadow-lg shadow-amber-900/20">
          <i class="fas fa-book-open text-xl text-gray-950"></i>
        </div>
        <div>
          <h1 class="text-2xl font-black text-white uppercase tracking-tighter italic leading-none">
            Gestión de <span class="text-amber-500">Blog</span>
          </h1>
          <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest mt-1 italic">Escriba de la Hermandad</p>
        </div>
      </div>
      
      <div class="flex items-center gap-6">
        <div class="text-right hidden md:block">
          <p class="text-[9px] text-gray-500 font-black uppercase tracking-widest mb-1">Hoy: {dailyPostsCount} / 6</p>
          <div class="w-24 h-1 bg-white/5 rounded-full overflow-hidden">
            <div 
              class={`h-full transition-all duration-500 ${dailyPostsCount >= 6 ? 'bg-red-500' : 'bg-amber-500'}`}
              style={`width: ${(dailyPostsCount / 6) * 100}%`}
            ></div>
          </div>
        </div>
      </div>
    </div>

    {errorMessage && (
      <div class="bg-red-900/50 border border-red-700/50 text-red-200 px-4 py-3 rounded-lg flex items-center animate-fade-in">
        <i class="fas fa-exclamation-triangle mr-3 text-sm"></i>
        <span class="text-xs font-bold italic">{errorMessage}</span>
      </div>
    )}
    
    {successMessage && (
      <div class="bg-green-900/50 border border-green-700/50 text-green-200 px-4 py-3 rounded-lg flex items-center animate-fade-in">
        <i class="fas fa-check-circle mr-3 text-sm"></i>
        <span class="text-xs font-bold italic">{successMessage}</span>
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
      <!-- Generator Form -->
      <div class="lg:col-span-1">
        <div class="bg-gray-950 border border-amber-500/20 rounded-lg p-6 sticky top-6 shadow-xl">
          <h2 class="text-sm font-black text-white uppercase italic tracking-widest mb-4 flex items-center gap-2">
            <i class="fas fa-wand-magic-sparkles text-amber-500"></i>
            Canalizar <span class="text-amber-500">Post</span>
          </h2>
          
          <form method="POST" class="space-y-4" x-data="{ isTest: false }">
            <input type="hidden" name="action" value="generate" />
            <input type="hidden" name="is_test" :value="isTest" />
            
            <textarea 
              name="topic" 
              rows="3"
              placeholder="Tema opcional..."
              class="w-full bg-black/40 border border-white/10 rounded-lg px-4 py-3 text-xs text-white focus:border-amber-500/50 transition-all outline-none resize-none"
            ></textarea>

            <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg border border-white/5">
              <span class="text-[9px] font-black text-white uppercase italic">Modo Testeo</span>
              <button 
                type="button"
                @click="isTest = !isTest"
                class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors focus:outline-none"
                :class="isTest ? 'bg-amber-600' : 'bg-gray-700'"
              >
                <span class="inline-block h-3 w-3 transform rounded-full bg-white transition-transform" :class="isTest ? 'translate-x-5' : 'translate-x-1'"></span>
              </button>
            </div>
            
            <button 
              type="submit"
              class="w-full py-4 text-gray-950 font-black text-[10px] uppercase tracking-widest rounded-lg transition-all shadow-lg flex items-center justify-center gap-2 group"
              :class="isTest ? 'bg-blue-600 hover:bg-blue-500' : 'bg-amber-600 hover:bg-amber-500'"
            >
              <i class="fas fa-feather-alt"></i>
              <span x-text="isTest ? 'Probar Generación' : 'Generar Crónica'"></span>
            </button>
          </form>
        </div>
      </div>

      <!-- Recent Posts List -->
      <div class="lg:col-span-3">
        <div class="bg-gray-900/50 border border-white/5 rounded-lg p-6 shadow-xl">
          <h2 class="text-sm font-black text-white uppercase italic tracking-widest mb-6 flex items-center gap-2">
            <i class="fas fa-history text-gray-500"></i>
            Crónicas <span class="text-gray-500">Recientes</span>
          </h2>

          <div class="space-y-3">
            {posts && posts.map((post) => (
              <div class="group bg-black/40 border border-white/5 rounded-lg p-4 hover:border-amber-500/20 transition-all flex items-center gap-4">
                <div class="relative w-16 h-16 flex-shrink-0">
                  <img src={post.image_url} class="w-full h-full rounded-lg object-cover grayscale group-hover:grayscale-0 transition-all" />
                  {post.is_hidden && (
                    <div class="absolute inset-0 bg-black/60 flex items-center justify-center rounded-lg">
                      <i class="fas fa-eye-slash text-xs text-white"></i>
                    </div>
                  )}
                </div>
                
                <div class="flex-grow min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[8px] font-black text-amber-500 uppercase tracking-widest">{post.category}</span>
                    <span class="text-[8px] font-bold text-gray-600 uppercase italic">{new Date(post.created_at).toLocaleDateString()}</span>
                  </div>
                  <h3 class="text-xs font-black text-white uppercase italic truncate group-hover:text-amber-500 transition-colors">
                    {post.title}
                  </h3>
                </div>

                <div class="flex gap-2">
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="toggle_visibility" />
                    <input type="hidden" name="post_id" value={post.id} />
                    <input type="hidden" name="is_hidden" value={(post.is_hidden ?? false).toString()} />
                    <button type="submit" class={`w-8 h-8 rounded-lg flex items-center justify-center transition-all ${post.is_hidden ? 'bg-green-500/10 text-green-400 hover:bg-green-500 hover:text-white' : 'bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white'}`} title={post.is_hidden ? 'Mostrar' : 'Ocultar'}>
                      <i class={`fas ${post.is_hidden ? 'fa-eye' : 'fa-eye-slash'} text-[10px]`}></i>
                    </button>
                  </form>
                  
                  <a href={`/blog/${post.slug}`} target="_blank" class="w-8 h-8 bg-white/5 rounded-lg flex items-center justify-center text-gray-400 hover:bg-amber-500 hover:text-gray-950 transition-all">
                    <i class="fas fa-external-link-alt text-[10px]"></i>
                  </a>

                  <form method="POST" class="inline" onsubmit="return confirm('¿Eliminar definitivamente?')">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="post_id" value={post.id} />
                    <button type="submit" class="w-8 h-8 bg-red-600/10 text-red-500 hover:bg-red-600 hover:text-white rounded-lg flex items-center justify-center transition-all">
                      <i class="fas fa-trash text-[10px]"></i>
                    </button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
