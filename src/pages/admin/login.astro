---
import Layout from '../../components/layout/Layout.astro';
import { createSessionToken } from '../../lib/auth';

let errorMessage = Astro.url.searchParams.get('error');
if (errorMessage === 'invalid_token' || errorMessage === 'session_expired') {
  errorMessage = 'Tu sesión ha expirado o es inválida. Inicia sesión de nuevo.';
}

const isDev = import.meta.env.DEV;
const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD || import.meta.env.VITE_ADMIN_PASSWORD;
const OFFICIAL_PASSWORD = import.meta.env.OFFICIAL_PASSWORD;
const devPassword = 'dev123';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const password = formData.get('password');
    const currentAdminPassword = isDev && !ADMIN_PASSWORD ? devPassword : ADMIN_PASSWORD;

    let role = '';
    if (password === currentAdminPassword) role = 'admin';
    else if (password === OFFICIAL_PASSWORD) role = 'official';

    if (role) {
      const token = await createSessionToken({ role });
      Astro.cookies.set('admin_session', token, {
        path: '/',
        maxAge: 60 * 60 * 8, // 8 hours
        httpOnly: true,
        secure: import.meta.env.PROD,
      });
      // admin_role is kept just for UI fast checks
      Astro.cookies.set('admin_role', role, { path: '/' });
      return Astro.redirect('/admin');
    } else {
      errorMessage = 'Contraseña incorrecta';
    }
  } catch (e) {
    errorMessage = 'Error en inicio de sesión';
  }
}
---

<Layout title="Admin - Iniciar Sesión">
  <div
    class="min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8 relative overflow-hidden bg-gray-950"
  >
    <div
      class="absolute inset-0 bg-[url('/images/raids/iccfarm.jpg')] bg-cover bg-center opacity-10"
    >
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-gray-900/80 to-gray-950">
    </div>

    <div class="sm:mx-auto sm:w-full sm:max-w-md relative z-10 animate-fade-in-up">
      <h2
        class="mt-6 text-center text-3xl sm:text-4xl font-black text-white uppercase tracking-widest drop-shadow-[0_0_15px_rgba(245,158,11,0.5)]"
      >
        Colmillo de Acero
      </h2>
      <p class="mt-2 text-center text-sm font-medium text-amber-500 uppercase tracking-[0.3em]">
        Acceso Clasificado
      </p>

      {
        errorMessage && (
          <div class="mt-6 mx-4 sm:mx-0 bg-red-900/30 border border-red-500/50 text-red-300 px-5 py-3 rounded-xl text-center shadow-[0_0_20px_rgba(220,38,38,0.2)] animate-fade-in">
            <i class="fas fa-shield-alt mr-2" /> {errorMessage}
          </div>
        )
      }
    </div>

    <div class="mt-8 sm:mx-auto w-full sm:max-w-md relative z-10 px-4 sm:px-0">
      <div
        class="bg-gray-900/80 backdrop-blur-xl py-10 px-6 sm:px-8 shadow-[0_0_40px_rgba(0,0,0,0.8)] rounded-2xl border border-white/10 group hover:border-amber-500/30 transition-all duration-500"
      >
        <form class="space-y-7" method="POST">
          <div>
            <label
              for="password"
              class="block text-xs font-black uppercase tracking-widest text-gray-400"
            >
              Clave de seguridad
            </label>
            <div class="mt-2 relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <i
                  class="fas fa-lock text-gray-600 group-focus-within:text-amber-500 transition-colors"
                ></i>
              </div>
              <input
                id="password"
                name="password"
                type="password"
                required
                class="appearance-none block w-full pl-11 pr-3 py-3.5 border border-gray-700/50 rounded-xl placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 bg-black/50 text-white font-mono tracking-widest transition-all shadow-inner"
                placeholder="••••••••"
              />
            </div>
          </div>

          <div>
            <button
              type="submit"
              class="w-full relative flex justify-center py-4 px-4 rounded-xl text-xs font-black tracking-widest uppercase text-white overflow-hidden group/btn disabled:opacity-50"
            >
              <div
                class="absolute inset-0 bg-gradient-to-r from-amber-600 to-amber-500 transition-transform duration-300 group-hover/btn:scale-[1.02]"
              >
              </div>
              <div
                class="absolute inset-0 opacity-0 group-hover/btn:opacity-100 shadow-[0_0_20px_rgba(245,158,11,0.6)] transition-opacity duration-300"
              >
              </div>
              <span class="relative flex items-center">
                Autenticar <i
                  class="fas fa-chevron-right ml-2 opacity-70 group-hover/btn:translate-x-1 transition-transform"
                ></i>
              </span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>
