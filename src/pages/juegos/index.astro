---
import Layout from '../../components/layout/Layout.astro';
---

<Layout 
  title="Zona de Juegos" 
  description="Bienvenido a la Zona de Juegos de Colmillo de Acero. Gasta tus turnos en minijuegos para ganar recompensas y gloria."
>
  <main class="py-20 px-4 min-h-screen relative z-10">
    <div class="max-w-6xl mx-auto">
      
      <!-- Header con Mascota -->
      <header class="mb-12 animate-fade-in flex flex-col md:flex-row items-center justify-center gap-8 bg-black/40 p-8 rounded-2xl border border-indigo-500/20 backdrop-blur-sm shadow-[0_0_30px_rgba(79,70,229,0.15)] relative overflow-hidden">
        
        <div class="relative w-48 md:w-64 flex-shrink-0 group">
          <img 
            src="/images/mascotaJuegos.png" 
            alt="Mascota Gamer Colmillo de Acero" 
            class="w-full h-auto drop-shadow-[0_10px_20px_rgba(99,102,241,0.4)] transform group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        
        <div class="text-center md:text-left max-w-xl z-10">
          <h1 class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-indigo-500 font-title tracking-wider uppercase italic mb-4">
            Zona de Juegos
          </h1>
          <p class="text-gray-300 text-sm md:text-base leading-relaxed">
            Bienvenido al rincón más divertido de la ciudadela. Utiliza tus <strong class="text-amber-500">turnos diarios</strong> para participar en nuestros desafíos exclusivos y gana oro o items legendarios para tus aventuras en Azeroth.
          </p>
        </div>
      </header>

      <!-- Game Hub Grid (Estilo Compacto) -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        
        <!-- Ruleta -->
        <a href="/ruleta" class="group relative overflow-hidden rounded-xl bg-gradient-to-r from-gray-900 to-gray-800 border border-amber-900/50 hover:border-amber-500 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-[0_0_20px_rgba(245,158,11,0.2)] flex items-center p-4 gap-4">
          <div class="absolute inset-0 bg-[url('/images/background.png')] bg-cover bg-center opacity-10 group-hover:opacity-20 transition-opacity mix-blend-overlay"></div>
          
          <div class="w-16 h-16 rounded-lg bg-amber-900/30 border border-amber-500/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform flex-shrink-0 shadow-inner">
            🎰
          </div>
          
          <div class="flex-grow z-10">
            <h2 class="text-lg font-black text-amber-500 uppercase tracking-tighter mb-1">Ruleta de la Fortuna</h2>
            <p class="text-gray-400 text-[10px] leading-tight">Gira para ganar oro o la mítica Gargantilla.</p>
          </div>
          
          <div class="z-10 flex-shrink-0">
            <span class="inline-flex items-center justify-center bg-amber-500 text-black text-[10px] font-bold px-3 py-1.5 rounded uppercase tracking-widest shadow-md">
              1 Turno
            </span>
          </div>
        </a>

        <!-- Defensa de la Ciudadela -->
        <a href="/juegos/defensa" class="group relative overflow-hidden rounded-xl bg-gradient-to-r from-gray-900 to-gray-800 border border-indigo-900/50 hover:border-indigo-500 transition-all duration-300 transform hover:-translate-y-1 shadow-lg hover:shadow-[0_0_20px_rgba(99,102,241,0.2)] flex items-center p-4 gap-4">
          <div class="absolute inset-0 bg-gradient-to-t from-indigo-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          
          <div class="w-16 h-16 rounded-lg bg-indigo-900/30 border border-indigo-500/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform flex-shrink-0 shadow-inner">
            🛡️
          </div>
          
          <div class="flex-grow z-10">
            <h2 class="text-lg font-black text-indigo-400 uppercase tracking-tighter mb-1">Tower Defense</h2>
            <p class="text-gray-400 text-[10px] leading-tight">Defiende el portal contra oleadas de enemigos.</p>
          </div>
          
          <div class="z-10 flex-shrink-0">
            <span class="inline-flex items-center justify-center bg-indigo-500 text-white text-[10px] font-bold px-3 py-1.5 rounded uppercase tracking-widest shadow-md">
              1 Turno
            </span>
          </div>
        </a>

      </div>


      <!-- Volver -->
      <div class="mt-16 flex justify-center">
        <a href="/" class="text-gray-500 hover:text-amber-500 text-sm font-bold uppercase tracking-widest transition-colors flex items-center gap-2">
          <i class="fas fa-arrow-left"></i> Volver al Inicio
        </a>
      </div>

    </div>
  </main>
</Layout>
