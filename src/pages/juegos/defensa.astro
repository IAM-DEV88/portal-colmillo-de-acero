---
import Layout from '../../components/layout/Layout.astro';
---

<Layout
  title="Defensa de la Ciudadela"
  description="Defiende el portal contra oleadas de adds. Gasta tus turnos para participar."
>
  <main class="relative z-10 flex flex-col items-center py-12 px-2 md:px-4 min-h-screen overflow-x-hidden">
    <!-- Header -->
    <div
      class="w-full max-w-5xl mx-auto mb-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-black/90 p-4 rounded-xl border border-indigo-500/30 shadow-[0_0_30px_rgba(79,70,229,0.2)]"
    >
      <div>
        <h1
          class="text-2xl md:text-3xl font-black text-indigo-400 uppercase tracking-widest italic"
        >
          Defensa de la Ciudadela
        </h1>
        <p class="text-gray-400 text-xs md:text-sm">Etapa de pruebas. Cada intento costara 1 Turno.</p>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex flex-col items-center md:items-end">
          <span class="text-[10px] text-amber-500/70 uppercase font-bold tracking-widest"
            >Tus Turnos</span
          >
          <span
            id="credits-display"
            class="text-white text-2xl font-extrabold drop-shadow-[0_0_10px_rgba(251,191,36,0.5)]"
            >--</span
          >
        </div>
      </div>
    </div>

    <!-- Game Area -->
    <div
      id="game-container"
      class="w-full max-w-5xl mx-auto relative rounded-xl overflow-hidden border-2 border-indigo-900/50 shadow-2xl bg-gray-900 aspect-video flex items-center justify-center"
    >
      <!-- UI Overlay (Bottom HUD - Distributed Evenly) -->
      <div class="absolute bottom-2 left-14 right-20 md:left-20 md:right-24 z-20 flex justify-between gap-1 pointer-events-none px-4">
        <div
          class="bg-black/85 text-white px-1.5 md:px-2 py-0.5 rounded border border-white/10 font-mono text-[9px] md:text-xs shadow-xl flex flex-col items-center min-w-[45px] md:min-w-[60px]"
        >
          <span class="text-gray-400 text-[6px] md:text-[7px] block uppercase tracking-tighter">Salud</span>
          <span id="health-display" class="text-red-400 font-bold">100</span>
        </div>
        <div
          class="bg-black/85 text-white px-1.5 md:px-2 py-0.5 rounded border border-white/10 font-mono text-[9px] md:text-xs shadow-xl flex flex-col items-center min-w-[45px] md:min-w-[60px]"
        >
          <span class="text-gray-400 text-[6px] md:text-[7px] block uppercase tracking-tighter">Acero</span>
          <span id="abyssals-display" class="text-slate-300 font-bold">100</span>
        </div>
        <div
          class="bg-black/85 text-white px-1.5 md:px-2 py-0.5 rounded border border-white/10 font-mono text-[9px] md:text-xs shadow-xl flex flex-col items-center min-w-[65px] md:min-w-[85px]"
        >
          <span class="text-gray-400 text-[6px] md:text-[7px] block uppercase tracking-tighter">Táctica</span>
          <div class="flex flex-col items-center leading-none">
            <div id="upgrades-display" class="text-amber-400 font-bold">0</div>
            <div class="flex items-center gap-1 mt-0.5">
              <div class="flex items-center gap-0.5">
                <span class="text-[7px] md:text-[8px]">🔧</span>
                <span id="repair-cost-display" class="text-green-500 font-bold text-[7px] md:text-[8px]">50</span>
              </div>
              <span class="text-gray-600 text-[7px]">|</span>
              <div class="flex items-center gap-0.5">
                <span class="text-[7px] md:text-[8px]">⬆️</span>
                <span id="upgrade-cost-display" class="text-orange-500 font-bold text-[7px] md:text-[8px]">150</span>
              </div>
            </div>
          </div>
        </div>
        <div
          class="bg-black/85 text-white px-1.5 md:px-2 py-0.5 rounded border border-white/10 font-mono text-[9px] md:text-xs shadow-xl flex flex-col items-center min-w-[35px] md:min-w-[50px]"
        >
          <span class="text-gray-400 text-[6px] md:text-[7px] block uppercase tracking-tighter">Oleada</span>
          <span id="wave-display" class="text-indigo-400 font-bold">0</span>
        </div>
        <div
          class="bg-black/85 text-white px-1.5 md:px-2 py-0.5 rounded border border-white/10 font-mono text-[9px] md:text-xs shadow-xl flex flex-col items-center min-w-[35px] md:min-w-[50px]"
        >
          <span class="text-gray-400 text-[6px] md:text-[7px] block uppercase tracking-tighter">Puestos</span>
          <span id="tower-count-display" class="text-blue-400 font-bold">0/30</span>
        </div>
      </div>

      <!-- Left Vertical Tools Column -->
      <div
        class="absolute left-2 top-2 bottom-2 md:left-4 md:top-4 md:bottom-4 w-14 md:w-16 z-30 flex flex-col items-center py-4 gap-4 pointer-events-none"
      >
        <div class="flex flex-col gap-4 pointer-events-auto">
          <!-- Fullscreen Button -->
          <button
            id="fullscreen-btn"
            class="w-10 h-10 md:w-11 md:h-11 rounded-xl bg-black/90 border border-white/20 text-white/60 flex items-center justify-center shadow-lg hover:bg-indigo-900 hover:text-white hover:border-indigo-400 transition-all hover:scale-110 active:scale-95 group"
            title="Pantalla Completa"
          >
            <span class="text-lg group-hover:rotate-12 transition-transform">⛶</span>
          </button>

          <!-- Config Button -->
          <button
            id="config-btn"
            class="w-10 h-10 md:w-11 md:h-11 rounded-xl bg-black/90 border border-white/20 text-white/60 flex items-center justify-center shadow-lg hover:bg-indigo-900 hover:text-white hover:border-indigo-400 transition-all hover:scale-110 active:scale-95 group"
            title="Configuración"
          >
            <span class="text-lg group-hover:rotate-90 transition-transform">⚙️</span>
          </button>

          <!-- Sell Button -->
          <button
            class="tower-btn w-10 h-10 md:w-11 md:h-11 rounded-xl bg-black/90 border border-red-500/20 text-red-500/60 flex items-center justify-center shadow-lg hover:bg-red-950 hover:text-red-400 hover:border-red-500 transition-all hover:scale-110 active:scale-95 group"
            data-type="sell"
            title="Vender Torre"
          >
            <span class="text-lg group-hover:rotate-12 transition-transform">💰</span>
          </button>
        </div>

        <div class="w-8 h-[1px] bg-white/10 my-1"></div>

        <div class="flex flex-col gap-4 pointer-events-auto">
          <!-- Repair Button -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-xl bg-green-900/40 border border-green-500/50 hover:bg-green-800/50 hover:border-green-400 transition-all flex items-center justify-center shadow-lg"
            data-type="repair"
            data-cost="50"
          >
            <span class="text-lg md:text-xl">🔧</span>
            <span
              class="absolute -top-6 left-1/2 -translate-x-1/2 bg-black/90 text-amber-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-amber-900/50 z-10 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap"
              >50m</span
            >
          </button>

          <!-- Upgrade Button -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-xl bg-orange-900/40 border border-orange-500/50 hover:bg-orange-800/50 hover:border-orange-400 transition-all flex items-center justify-center shadow-lg"
            data-type="upgrade"
            data-cost="150"
          >
            <span class="text-lg md:text-xl">⬆️</span>
            <span
              class="absolute -top-6 left-1/2 -translate-x-1/2 bg-black/90 text-orange-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-orange-900/50 z-10 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap"
              >150m</span
            >
          </button>
        </div>
      </div>

      <!-- Config Modal -->
      <div
        id="config-modal"
        class="absolute inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm hidden"
      >
        <div
          class="w-full max-w-xs bg-gray-950 border border-indigo-500/50 rounded-2xl p-6 shadow-2xl"
        >
          <h2 class="text-xl font-black text-indigo-400 uppercase tracking-widest mb-6 italic text-center">Configuración</h2>
          
          <div class="space-y-6">
            <!-- Sounds Toggle -->
            <div class="flex items-center justify-between">
              <span class="text-white font-bold uppercase tracking-tighter">Sonidos</span>
              <button
                id="toggle-sound"
                class="w-14 h-7 rounded-full bg-indigo-950 border border-indigo-500/50 relative transition-colors"
              >
                <div
                  id="sound-switch"
                  class="absolute top-1 left-1 w-5 h-5 rounded-full bg-indigo-400 transition-transform translate-x-7"
                ></div>
              </button>
            </div>

            <!-- Turbo Toggle -->
            <div class="flex items-center justify-between">
              <div class="flex flex-col">
                <span class="text-white font-bold uppercase tracking-tighter">Modo Turbo</span>
                <span class="text-[10px] text-amber-500/70 font-bold uppercase tracking-widest">Velocidad x2</span>
              </div>
              <button
                id="toggle-turbo"
                class="w-14 h-7 rounded-full bg-gray-800 border border-gray-600 relative transition-colors"
              >
                <div
                  id="turbo-switch"
                  class="absolute top-1 left-1 w-5 h-5 rounded-full bg-gray-400 transition-transform"
                ></div>
              </button>
            </div>
          </div>

          <button
            id="close-config"
            class="w-full mt-8 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-black uppercase tracking-widest rounded-xl transition-colors shadow-lg shadow-indigo-600/20"
          >
            Cerrar
          </button>
        </div>
      </div>

      <!-- Towers Panel (Right) -->
      <div
        class="absolute right-2 top-2 bottom-2 md:right-4 md:top-4 md:bottom-4 w-16 md:w-20 bg-black border border-indigo-500/30 rounded-xl md:rounded-2xl z-20 flex flex-col items-center py-2 md:py-4 gap-3 md:gap-4 touch-pan-y overflow-y-auto custom-scrollbar shadow-2xl"
      >
        <span
          class="text-[7px] md:text-[8px] text-indigo-300 uppercase font-black tracking-[0.2em] text-center leading-tight mb-1 drop-shadow-sm px-1"
          >Puestos de Avanzada</span
        >

        <!-- Towers Column -->
        <div class="flex flex-col gap-4 md:gap-6 px-1 md:px-2">
          <!-- Tower 1 -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-lg md:rounded-xl bg-slate-900/30 border border-slate-500/50 hover:bg-slate-800/50 hover:border-slate-400 transition-all flex items-center justify-center shadow-lg"
            data-type="basic"
            data-cost="20"
            title="Colmillo Ligero: Defensa rápida y económica"
          >
            <div class="w-5 h-5 md:w-6 md:h-6 bg-slate-400 rounded-sm group-hover:scale-110 transition-transform shadow-[0_0_8px_rgba(148,163,184,0.5)]"></div>
            <span
              class="absolute -bottom-2.5 left-1/2 -translate-x-1/2 bg-black/90 text-slate-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-slate-900/50 z-10 pointer-events-none whitespace-nowrap"
              >20a</span
            >
          </button>

          <!-- Tower 2 -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-lg md:rounded-xl bg-purple-900/30 border border-purple-500/50 hover:bg-purple-800/50 hover:border-purple-400 transition-all flex items-center justify-center shadow-lg"
            data-type="sniper"
            data-cost="100"
            title="Mirada del Lobo: Gran alcance y daño crítico"
          >
            <div class="w-3.5 h-3.5 md:w-4 md:h-4 bg-purple-400 rounded-full group-hover:scale-110 transition-transform shadow-[0_0_8px_rgba(168,85,247,0.5)]"></div>
            <span
              class="absolute -bottom-2.5 left-1/2 -translate-x-1/2 bg-black/90 text-purple-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-purple-900/50 z-10 pointer-events-none whitespace-nowrap"
              >100a</span
            >
          </button>

          <!-- Tower 3 -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-lg md:rounded-xl bg-red-900/30 border border-red-500/50 hover:bg-red-800/50 hover:border-red-400 transition-all flex items-center justify-center shadow-lg"
            data-type="splash"
            data-cost="200"
            title="Rugido de Acero: Daño en área devastador"
          >
            <div class="w-4 h-4 md:w-5 md:h-5 bg-red-400 rotate-45 group-hover:scale-110 transition-transform shadow-[0_0_8px_rgba(239,68,68,0.5)]"></div>
            <span
              class="absolute -bottom-2.5 left-1/2 -translate-x-1/2 bg-black/90 text-red-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-red-900/50 z-10 pointer-events-none whitespace-nowrap"
              >200a</span
            >
          </button>

          <!-- Tower 4 -->
          <button
            class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-lg md:rounded-xl bg-cyan-900/30 border border-cyan-500/50 hover:bg-cyan-800/50 hover:border-cyan-400 transition-all flex items-center justify-center shadow-lg"
            data-type="nova"
            data-cost="300"
            title="Aullido Ártico: Ralentiza y daña en el tiempo"
          >
            <div class="w-4 h-4 md:w-5 md:h-5 bg-cyan-400 rounded-full group-hover:scale-110 transition-transform flex items-center justify-center shadow-[0_0_8px_rgba(34,211,238,0.5)]">
              <span class="text-[8px] md:text-[10px] text-black font-black">❄️</span>
            </div>
            <span
              class="absolute -bottom-2.5 left-1/2 -translate-x-1/2 bg-black/90 text-cyan-400 text-[8px] md:text-[9px] font-black px-1.5 py-0.5 rounded border border-cyan-900/50 z-10 pointer-events-none whitespace-nowrap"
              >300a</span
            >
          </button>
        </div>

        <div class="w-12 md:w-14 h-[1px] bg-white/10 my-2 md:my-4 shrink-0"></div>

        <!-- Pause Button -->
        <button
          id="pause-btn"
          class="tower-btn group relative w-10 h-10 md:w-11 md:h-11 shrink-0 rounded-lg md:rounded-xl bg-yellow-900/30 border border-yellow-500/50 hover:bg-yellow-800/50 hover:border-yellow-400 transition-all flex items-center justify-center shadow-lg"
        >
          <span class="text-lg md:text-xl text-white font-bold tracking-wider">⏸️</span>
          <span
            class="absolute -left-16 top-1/2 -translate-y-1/2 bg-black text-amber-400 text-[10px] font-bold px-2 rounded border border-yellow-500 opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity whitespace-nowrap"
            >-10m</span
          >
        </button>

        <div class="mt-auto pt-2 md:pt-4 text-center text-[6px] md:text-[7px] text-gray-500 italic px-1 shrink-0 uppercase tracking-tighter">
          Toca torre
        </div>
      </div>

      <!-- Canvas -->
      <canvas
        id="game-canvas"
        width="1024"
        height="600"
        class="w-full h-full bg-gray-900 block cursor-crosshair object-contain"></canvas>

      <!-- Event Warning Overlay (Tension UI) -->
      <div
        id="event-warning"
        class="absolute top-2 z-25 pointer-events-none opacity-0 transition-opacity duration-300 left-1/2 -translate-x-1/2"
      >
        <div
          class="bg-red-950/95 border border-red-500/40 px-3 py-1 rounded-lg shadow-2xl transform scale-75 transition-transform duration-300"
          id="warning-box"
        >
          <h3
            class="text-[10px] md:text-xs font-black text-red-500 uppercase tracking-widest animate-pulse flex items-center gap-1.5"
          >
            <span>⚠️</span>
            <span id="warning-text">¡PELIGRO!</span>
            <span>⚠️</span>
          </h3>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <a
        href="/juegos"
        class="text-gray-500 hover:text-indigo-400 text-sm font-bold uppercase tracking-widest transition-colors flex items-center gap-2"
      >
        <i class="fas fa-arrow-left"></i> Volver a Zona de Juegos
      </a>
    </div>
  </main>

  <script is:inline>
    // --- GAME STATE ---
    let credits = 0;
    let gameState = 'intro'; // intro, playing, gameover
    let abyssals = 50;
    let upgrades = 0; // Renamed from gold
    let health = 100;
    let wave = 0;
    let selectedTowerType = null;
    let isEventActive = false;
    let isCityFallen = false; // Tracks if health is 0 but enemies are still arriving
    let isPaused = false;
    let isTurbo = false;
    let enemiesLeftToSpawn = 0;
    let isMouseDown = false;
    let mouseX = 0;
    let mouseY = 0;
    let inspectedTower = null; // Currently inspected tower for info plate
    let isShiftDown = false;
    let screenShake = 0; // Current screen shake intensity

    // Sound state
    let soundsEnabled = true;

    // Drag and Drop Mobile state
    let isDragging = false;
    let draggedType = null;
    let dragStartX = 0;
    let dragStartY = 0;

    let curseTimer = 0;
    let curseCooldown = 600;
    let curseNotification = null;

    let globalFreezeTimer = 0;
    let globalFrenzyTimer = 0;
    let globalBloodlust = 0;
    const BLOODLUST_THRESHOLD = 20;
    let bloodlustTimer = 0;
    const TOWER_LIMIT = 30;

    let path = [];

    // --- SPRITE ASSETS ---
    const spriteSheet = new Image();
    const bgImage = new Image();
    
    let spritesLoaded = false;
    let bgLoaded = false;

    spriteSheet.onload = () => {
      spritesLoaded = true;
      updateUIButtonIcons();
    };
    bgImage.onload = () => {
      bgLoaded = true;
      if (path && path.length > 0) redrawBackground();
    };

    // Set sources after handlers are attached and variables declared
    spriteSheet.src = '/images/sprites.png';
    bgImage.src = '/images/fondoDefensa.png';

    const SPRITE_MAP = {
      towers: {
        basic: { sx: 0, sy: 54, sw: 62, sh: 68 }, // Torre de piedra (izquierda)
        sniper: { sx: 65, sy: 50, sw: 45, sh: 110 }, // Torre con orbe púrpura
        splash: { sx: 109, sy: 55, sw: 70, sh: 135 }, // Torre oscura con fuego
        nova: { sx: 184, sy: 53, sw: 60, sh: 150 }, // Torre de hielo (derecha)
      },

      enemies: {
        zombie: { sx: 16, sy: 130, sw: 40, sh: 60 }, // Ghoul (Left)
        brujo: { sx: 250, sy: 65, sw: 60, sh: 70 }, // Fantasma/Banshee (Right)
        valkiria: { sx: 250, sy: 130, sw: 50, sh: 70 }, // Nigromante (Middle-Left)
        berserker: { sx: 250, sy: 0, sw: 60, sh: 70 }, // Berserker (Middle-Right)
        orbe: { sx: 70, sy: 165, sw: 40, sh: 40 }, // Orbe Oscuro (Below Sniper)
      },

      items: {
        gem_purple: { sx: 640, sy: 310, sw: 70, sh: 70 }, // Gema púrpura
        gem_blue: { sx: 720, sy: 310, sw: 70, sh: 70 }, // Gema azul
        shield: { sx: 800, sy: 310, sw: 70, sh: 70 }, // Escudo dorado
        fang: { sx: 640, sy: 400, sw: 70, sh: 70 }, // Colmillo
        claw: { sx: 720, sy: 400, sw: 70, sh: 70 }, // Garra
      },
    };

    function updateUIButtonIcons() {
      document.querySelectorAll('.tower-btn').forEach((btn) => {
        const type = btn.dataset.type;
        if (!type) return;

        const sprite = SPRITE_MAP.towers[type];
        if (sprite) {
          // Find the icon element (div or span)
          const iconEl = btn.querySelector('div') || btn.querySelector('span:not(.absolute)');
          if (iconEl) {
            // Create a dedicated sprite container if it doesn't exist
            let spriteContainer = btn.querySelector('.btn-sprite-icon');
            if (!spriteContainer) {
              spriteContainer = document.createElement('div');
              spriteContainer.className = 'btn-sprite-icon w-10 h-10 group-hover:scale-110 transition-transform pointer-events-none';
              btn.prepend(spriteContainer);
              // Hide the original placeholder icon
              iconEl.style.display = 'none';
            }

            const btnSize = 40; // Target size in pixels
            const scale = btnSize / Math.max(sprite.sw, sprite.sh);
            
            spriteContainer.style.backgroundImage = `url('${spriteSheet.src}')`;
            spriteContainer.style.backgroundPosition = `-${sprite.sx * scale}px -${sprite.sy * scale}px`;
            spriteContainer.style.backgroundSize = `${spriteSheet.width * scale}px ${spriteSheet.height * scale}px`;
            spriteContainer.style.backgroundRepeat = 'no-repeat';
            spriteContainer.style.width = `${sprite.sw * scale}px`;
            spriteContainer.style.height = `${sprite.sh * scale}px`;
            spriteContainer.style.margin = 'auto';
          }
        }
      });
    }

    // --- CANVAS & ENTITIES ---
    const canvas = document.getElementById('game-canvas');
    const ctx = canvas.getContext('2d');
    const bgCanvas = document.createElement('canvas');
    const bgCtx = bgCanvas.getContext('2d');

    // --- IN-CANVAS TOASTS & COMBOS ---
    const canvasToasts = [];
    let currentCombo = 0;
    let comboTimer = 0;

    // Kill combo
    let currentKillCombo = 0;
    let killComboTimer = 0;

    function showCanvasToast(msg, type = 'info') {
      // Accelerate fade of existing toasts
      canvasToasts.forEach(t => t.life = Math.min(t.life, 30));
      
      canvasToasts.push({
        msg,
        type,
        life: 100, // Longer life for new ones
        yOffset: 0,
      });
    }

    function addCombo() {
      currentCombo++;
      comboTimer = 120;

      if (currentCombo > 1) {
        let existing = canvasToasts.find((t) => t.isCombo);
        if (existing) {
          existing.msg = `${currentCombo}x RUNA COMBO!`;
          existing.life = 60;
          existing.yOffset = 0;
          playSFX('pickup');
        } else {
          canvasToasts.push({
            msg: `${currentCombo}x RUNA COMBO!`,
            type: 'combo',
            life: 60,
            yOffset: 0,
            isCombo: true,
          });
        }
      }
    }

    function addKillCombo() {
      currentKillCombo++;
      killComboTimer = 60;

      if (currentKillCombo > 1) {
        let existing = canvasToasts.find((t) => t.isKillCombo);
        if (existing) {
          existing.msg = `${currentKillCombo} MULTI-KILL!`;
          existing.life = 60;
          existing.yOffset = 0;
          upgrades += currentKillCombo * 5;
        } else {
          canvasToasts.push({
            msg: `${currentKillCombo} MULTI-KILL!`,
            type: 'killcombo',
            life: 60,
            yOffset: 0,
            isKillCombo: true,
          });
        }
      }
    }

    const ENEMY_TYPES = [
      {
        id: 'zombie',
        name: 'Errante del Vacío',
        color: '#94A3B8',
        speedMod: 1,
        hpMod: 1.1,
        attackType: 'normal',
        effectText: '¡La Plaga del Vacío se acerca!',
      },
      {
        id: 'brujo',
        name: 'Sacerdote de Sombras',
        color: '#A855F7',
