    function redrawBackground() {
      bgCanvas.width = canvas.width;
      bgCanvas.height = canvas.height;
      
      if (bgLoaded) {
        // Draw image background
        bgCtx.drawImage(bgImage, 0, 0, bgCanvas.width, bgCanvas.height);
        
        // Add a slight dark overlay to improve readability
        bgCtx.fillStyle = '#00000066'; // Fixed hex with alpha
        bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
      } else {
        bgCtx.fillStyle = '#111827';
        bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
      }

      if (path && path.length > 0) {
        bgCtx.beginPath();
        bgCtx.moveTo(path[0].x, path[0].y);
        for (let i = 1; i < path.length; i++) {
          bgCtx.lineTo(path[i].x, path[i].y);
        }
        bgCtx.strokeStyle = '#374151AA'; // gray-700 with fixed alpha
        bgCtx.lineWidth = 40;
        bgCtx.lineCap = 'round';
        bgCtx.lineJoin = 'round';
        bgCtx.stroke();

        // Path inner glow/line
        bgCtx.strokeStyle = '#1F2937AA';
        bgCtx.lineWidth = 36;
        bgCtx.stroke();
      }
    }

    function generateRandomPath() {
      const maxW = canvas.width;
      const maxH = canvas.height;

      const newPath = [];

      // Start on left edge, avoiding HUD
      // HUD is approx (420, 80)
      let currentY = Math.random() * 200 + 200; // Start between 200 and 400
      newPath.push({ x: 0, y: currentY });

      let currentX = 0;

      // We want to avoid the Right Panel (x > 940)
      // We want to avoid the HUD (x < 420, y < 80)
      // We want to avoid the Tools Panel (x < 180, y > 520)
      while (currentX < maxW - 200) {
        currentX += Math.random() * (maxW * 0.15) + maxW * 0.15;
        if (currentX > maxW - 150) currentX = maxW - 150;

        // Vertical safe zone: y between 100 and 500
        let minY = 100;
        let maxY = maxH - 100;

        currentY = Math.random() * (maxY - minY) + minY;
        newPath.push({ x: currentX, y: currentY });
      }

      // End path: ALWAYS at the Portal location
      // Based on fondoDefensa.png, the portal is roughly at x=940, y=280
      const portalX = 940;
      const portalY = 280;
      newPath.push({ x: portalX, y: portalY });

      path = newPath;
      redrawBackground();

      return newPath;
    }

    const GRID_SIZE = 40;

    // Check if position overlaps with path
    function isCollidingWithPath(x, y) {
      const pathRadius = 30; // Half of path width
      for (let i = 0; i < path.length - 1; i++) {
        const p1 = path[i];
        const p2 = path[i + 1];
        // Line segment collision logic (simplified distance to segment)
        const l2 = Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2);
        if (l2 === 0) continue;
        let t = ((x - p1.x) * (p2.x - p1.x) + (y - p1.y) * (p2.y - p1.y)) / l2;
        t = Math.max(0, Math.min(1, t));
        const dist = Math.hypot(x - (p1.x + t * (p2.x - p1.x)), y - (p1.y + t * (p2.y - p1.y)));
        if (dist < pathRadius + 15) return true; // +15 for tower padding
      }
      return false;
    }

