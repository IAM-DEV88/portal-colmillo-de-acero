      document.querySelectorAll('.tower-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget;
          const type = target.dataset.type;

          if (selectedTowerType === type) {
            // Toggle off
            selectedTowerType = null;
            target.classList.remove('ring-4', 'ring-amber-400');
          } else if (type) {
            // Toggle on / Switch
            inspectedTower = null; // Clear inspection when building
            inspectedEnemy = null; // AAA: Clear enemy inspection too
            document
              .querySelectorAll('.tower-btn')
              .forEach((b) => b.classList.remove('ring-4', 'ring-amber-400'));
            target.classList.add('ring-4', 'ring-amber-400');
            selectedTowerType = type;
          }
          updateHUD();
        });

        // Touch start for drag
        btn.addEventListener('touchstart', (e) => {
          if (gameState !== 'playing') return;
          const type = btn.dataset.type;
          // Only towers can be dragged (not repair/upgrade for now to keep it simple, or they can be too)
          if (type && !['repair', 'upgrade'].includes(type)) {
            isDragging = true;
            draggedType = type;
          }
        }, { passive: true });
      });

      // Global touch listeners for dragging
      window.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const touch = e.touches[0];
        const rect = canvas.getBoundingClientRect();
        
        // Update mouseX/mouseY for preview drawing
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        mouseX = (touch.clientX - rect.left) * scaleX;
        mouseY = (touch.clientY - rect.top) * scaleY;

        // Prevent scrolling when dragging over the game area
        if (touch.clientX >= rect.left && touch.clientX <= rect.right &&
            touch.clientY >= rect.top && touch.clientY <= rect.bottom) {
          if (e.cancelable) e.preventDefault();
        }
      }, { passive: false });

      window.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        
        const touch = e.changedTouches[0];
        const rect = canvas.getBoundingClientRect();
        
        // Check if dropped on canvas
        if (touch.clientX >= rect.left && touch.clientX <= rect.right &&
            touch.clientY >= rect.top && touch.clientY <= rect.bottom) {
          const scaleX = canvas.width / rect.width;
          const scaleY = canvas.height / rect.height;
          const x = (touch.clientX - rect.left) * scaleX;
          const y = (touch.clientY - rect.top) * scaleY;
          
          handleConstruction(x, y, draggedType, GRID_SIZE * 1.2); // Use mobile hit radius
        }
        
        isDragging = false;
        draggedType = null;
      });

      // Config Modal Handlers
      const configBtn = document.getElementById('config-btn');
      const configModal = document.getElementById('config-modal');
      const closeConfig = document.getElementById('close-config');
      const toggleSound = document.getElementById('toggle-sound');
      const soundSwitch = document.getElementById('sound-switch');

      // Unit Info Plate Action Listeners
      const inspectPlate = document.getElementById('unit-info-plate');
      const repairInspectBtn = document.getElementById('inspect-repair');
      const powerupInspectBtn = document.getElementById('inspect-powerup');
      const upgradeInspectBtn = document.getElementById('inspect-upgrade');

      if (repairInspectBtn) {
        repairInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const cost = getTowerCost('repair');
          if (inspectedTower.hp >= inspectedTower.maxHp) {
            showCanvasToast('El puesto ya tiene la salud máxima', 'error');
            playSFX('error');
            return;
          }
          if (upgrades >= cost) {
            upgrades -= cost;
            // AAA: Increased heal amount as requested
            const healAmount = Math.max(10, Math.ceil(inspectedTower.maxHp * 0.25));
            inspectedTower.hp = Math.min(inspectedTower.maxHp, inspectedTower.hp + healAmount);
            
            updateHUD();
            showCanvasToast(`¡Reparación Completa! +${healAmount} HP`, 'success');
            addFloatingText(inspectedTower.x, inspectedTower.y, `+${healAmount} HP`, '#10B981');
            createExplosion(inspectedTower.x, inspectedTower.y, '#10B981', 8);
            playSFX('build');
          } else {
            showCanvasToast(`Táctica insuficiente (${cost}t)`, 'error');
            playSFX('error');
          }
        });
      }

      if (powerupInspectBtn) {
        powerupInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const cost = getTowerCost('powerup');
          if (abyssals >= cost) {
            abyssals -= cost;
            inspectedTower.buffs.steelShield = 900;
            updateHUD();
            showCanvasToast('¡Sobrecarga de Acero!', 'success');
            createExplosion(inspectedTower.x, inspectedTower.y, '#94A3B8', 12);
            playSFX('build');
          } else {
            showCanvasToast(`Acero insuficiente (${cost}a)`, 'error');
            playSFX('error');
          }
        });
      }

      const sellInspectBtn = document.getElementById('inspect-sell');
      if (sellInspectBtn) {
        sellInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const refund = calculateSellValue(inspectedTower);
          abyssals += refund;
          const index = towers.indexOf(inspectedTower);
          if (index > -1) {
            const visualY = inspectedTower.y + (((inspectedTower.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            createExplosion(inspectedTower.x, visualY, '#EF4444', 15);
            addFloatingText(inspectedTower.x, visualY, `+${refund}a`, '#34D399');
            towers.splice(index, 1);
            inspectedTower = null;
            updateHUD();
            playSFX('pickup');
            showCanvasToast(`Puesto retirado: +${refund} acero`, 'success');
            updateTowerPairing();
          }
        });
      }

      if (upgradeInspectBtn) {
        upgradeInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const cost = getTowerCost('upgrade', inspectedTower);
          if (upgrades >= cost) {
            upgrades -= cost;
            inspectedTower.level++;
            
            // Scaled damage (Ensure it grows at least +1 if multiplier is too small)
            const oldDmg = inspectedTower.damage;
            inspectedTower.damage = Math.max(oldDmg + 1, Math.floor(oldDmg * GAME_CONFIG.balance.upgradeDamageMultiplier));
            
            const oldRange = inspectedTower.range;
            inspectedTower.range = Math.floor(oldRange * GAME_CONFIG.balance.upgradeRangeMultiplier);
            inspectedTower.oldRange = oldRange;
            inspectedTower.upgradePulse = 1.0;
            
            // HP Upgrade (Balanced for small numbers)
            inspectedTower.maxHp += GAME_CONFIG.balance.upgradeHPBonus;
            inspectedTower.hp += GAME_CONFIG.balance.upgradeHPBonus;
            
            // Fire Rate Upgrade (Lower is faster, with cap)
            if (inspectedTower.fireRate > 5) {
              inspectedTower.fireRate = Math.max(5, Math.floor(inspectedTower.fireRate * GAME_CONFIG.balance.upgradeFireRateMultiplier));
            }

            updateHUD();
            showCanvasToast(`¡Puesto Mejorado! Nivel ${inspectedTower.level}`, 'success');
            createExplosion(inspectedTower.x, inspectedTower.y, '#F59E0B', 25);
            playSFX('build');
          } else {
            showCanvasToast(`Táctica insuficiente (${formatNumber(cost)}t)`, 'error');
            playSFX('error');
          }
        });
