---
import Layout from '../../components/layout/Layout.astro';
---

<Layout
  title="Defensa de la Ciudadela"
  description="Defiende el portal contra oleadas de adds. Gasta tus turnos para participar."
>
  <main class="relative z-10 flex flex-col items-center py-4 px-2 md:px-4 min-h-screen overflow-x-hidden bg-[#05050a]">
    <!-- Compact Credits Info (Top Floating) -->
    <div class="absolute top-4 right-4 z-[60] flex items-center gap-3 bg-black/80 backdrop-blur-xl px-4 py-2 rounded-2xl border border-white/10 shadow-2xl pointer-events-none">
      <span class="text-[8px] text-amber-500/70 uppercase font-black tracking-[0.2em]">Créditos</span>
      <span id="credits-display" class="text-white text-xl font-black font-mono tracking-tighter">--</span>
    </div>

    <!-- Game Area -->
    <div
      id="game-container"
      class="w-full max-w-6xl mx-auto relative rounded-3xl overflow-hidden border border-white/5 shadow-[0_0_100px_rgba(0,0,0,0.5)] bg-[#0a0a12] aspect-video flex items-center justify-center mt-2"
    >
      <!-- Unified Tactical Console (Bottom HUD) -->
      <div id="tactical-hud" class="absolute bottom-0 left-0 w-full z-50 pointer-events-none">
        <div class="bg-[#08080c]/95 border-t border-white/10 shadow-[0_-20px_50px_rgba(0,0,0,0.9)] backdrop-blur-3xl flex items-center h-16 relative group/hud pointer-events-auto px-4">
          
          <!-- Tactical Accent Decor -->
          <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-indigo-500/40 to-transparent"></div>
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-[2px] bg-indigo-500/60 blur-[1px]"></div>

          <!-- Section 1: Mission Vitality (Left) -->
          <div class="flex items-center gap-4 pr-4 border-r border-white/5 h-10 shrink-0">
            <div class="flex flex-col items-center min-w-[65px]">
              <span class="text-[7px] text-red-500/60 font-black uppercase tracking-widest">Integridad</span>
              <div class="flex items-center gap-1.5">
                <span id="health-display" class="text-xl font-black text-red-500 font-mono tracking-tighter leading-none drop-shadow-[0_0_10px_rgba(239,68,68,0.3)]">100</span>
                <span class="text-[10px] animate-pulse">❤️</span>
              </div>
            </div>
            <div class="flex flex-col items-center min-w-[45px]">
              <span class="text-[7px] text-indigo-400/60 font-black uppercase tracking-widest">Oleada</span>
              <span id="wave-display" class="text-xl font-black text-white font-mono leading-none">0</span>
            </div>
          </div>

          <!-- Section 2: Global Resources (Center-Left) -->
          <div class="flex items-center gap-4 px-4 border-r border-white/5 h-10 shrink-0">
            <div class="flex flex-col items-center min-w-[50px]">
              <span class="text-[7px] text-slate-400 font-black uppercase tracking-widest">Acero</span>
              <div class="flex items-center gap-1">
                <span class="text-[10px]">⚙️</span>
                <span id="abyssals-display" class="text-base font-black text-slate-100 font-mono leading-none">10</span>
              </div>
            </div>
            <div class="flex flex-col items-center min-w-[50px]">
              <span class="text-[7px] text-amber-400 font-black uppercase tracking-widest">Táctica</span>
              <div class="flex items-center gap-1">
                <span class="text-[10px]">⚡</span>
                <span id="upgrades-display" class="text-base font-black text-amber-400 font-mono leading-none">5</span>
              </div>
            </div>
          </div>

          <!-- Section 3: Central Intelligence Slot (DYNAMIC) -->
          <div class="flex-1 h-full flex items-center justify-center relative min-w-0 px-4">
            <!-- Standby State -->
            <div id="selection-empty" class="flex flex-col items-center opacity-20 group-hover/hud:opacity-40 transition-opacity">
              <span class="text-[8px] text-white font-black uppercase tracking-[0.4em] italic">Consola en Espera</span>
              <div class="flex gap-1 mt-1">
                <div class="w-1 h-1 bg-indigo-500 rounded-full animate-bounce"></div>
                <div class="w-1 h-1 bg-indigo-500 rounded-full animate-bounce [animation-delay:0.2s]"></div>
                <div class="w-1 h-1 bg-indigo-500 rounded-full animate-bounce [animation-delay:0.4s]"></div>
              </div>
            </div>

            <!-- Tower Inspection View -->
            <div id="tower-inspect-view" class="hidden w-full h-full flex items-center gap-4 animate-in slide-in-from-bottom-2 duration-300">
              <div class="flex flex-col min-w-[110px] max-w-[130px]">
                <span id="inspect-name" class="text-[10px] font-black text-indigo-400 uppercase truncate italic leading-none">NOMBRE</span>
                <div class="flex items-center gap-2 mt-1">
                  <span id="inspect-level" class="text-[7px] text-white/40 font-black uppercase">Nv.1</span>
                  <span id="inspect-stars" class="text-[8px] text-amber-400 font-black tracking-tighter">★★★</span>
                </div>
              </div>

              <div class="flex items-center gap-4 flex-1 justify-around px-4 border-x border-white/5 h-8">
                <div class="flex flex-col items-center">
                  <span class="text-[8px] text-gray-500 uppercase font-black">Potencia</span>
                  <span id="inspect-dmg" class="text-lg text-white font-mono font-black leading-none">0</span>
                </div>
                <div class="flex flex-col items-center">
                  <span class="text-[8px] text-gray-500 uppercase font-black">Alcance</span>
                  <span id="inspect-range" class="text-lg text-indigo-300 font-mono font-black leading-none">0</span>
                </div>
                <div class="flex flex-col items-center min-w-[60px]">
                  <span class="text-[8px] text-red-500/60 uppercase font-black">Salud</span>
                  <span id="inspect-hp-text" class="text-lg text-red-400 font-mono font-black leading-none">0/0</span>
                </div>
                <div class="flex flex-col items-center min-w-[70px]">
                  <span class="text-[8px] text-amber-500/60 uppercase font-black">Habilidad</span>
                  <span id="inspect-ability-percent" class="text-lg text-amber-400 font-mono font-black leading-none">0%</span>
                  <div class="w-full h-1 bg-gray-900 rounded-full overflow-hidden border border-white/10 mt-1">
                    <div id="inspect-vet-bar" class="h-full bg-gradient-to-r from-amber-600 to-amber-400 transition-all shadow-[0_0_5px_rgba(251,191,36,0.5)]" style="width: 0%"></div>
                  </div>
                </div>
              </div>

              <!-- Tower Context Actions -->
              <div class="flex items-center gap-1.5 shrink-0 ml-2">
                <button id="inspect-repair" class="relative group w-11 h-11 rounded-2xl bg-green-900/20 border border-green-500/30 flex flex-col items-center justify-center hover:bg-green-500/20 transition-all active:scale-90" title="Reparar (R)">
                  <span class="absolute -top-2 -left-2 bg-green-600 text-[9px] font-black text-white px-1.5 py-0.5 rounded shadow-[0_0_10px_rgba(22,163,74,0.5)] z-20 border border-white/20">R</span>
                  <span id="inspect-repair-cost" class="text-base font-black text-green-400 leading-none">--</span>
                  <span class="text-[8px] mt-0.5 opacity-60">🔧</span>
                </button>
                <button id="inspect-powerup" class="relative group w-11 h-11 rounded-2xl bg-blue-900/20 border border-blue-500/30 flex flex-col items-center justify-center hover:bg-blue-500/20 transition-all active:scale-90" title="Sobrecarga (C)">
                  <span class="absolute -top-2 -left-2 bg-blue-600 text-[9px] font-black text-white px-1.5 py-0.5 rounded shadow-[0_0_10px_rgba(37,99,235,0.5)] z-20 border border-white/20">C</span>
                  <span id="inspect-powerup-cost" class="text-base font-black text-blue-400 leading-none">--</span>
                  <span class="text-[8px] mt-0.5 opacity-60">⚙️</span>
                </button>
                <button id="inspect-upgrade" class="relative group w-11 h-11 rounded-2xl bg-orange-900/20 border border-orange-500/30 flex flex-col items-center justify-center hover:bg-orange-500/20 transition-all active:scale-90" title="Mejorar (E)">
                  <span class="absolute -top-2 -left-2 bg-orange-600 text-[9px] font-black text-white px-1.5 py-0.5 rounded shadow-[0_0_10px_rgba(234,88,12,0.5)] z-20 border border-white/20">E</span>
                  <span id="inspect-upgrade-cost" class="text-base font-black text-orange-400 leading-none">--</span>
                  <span class="text-[8px] mt-0.5 opacity-60">⬆️</span>
                </button>
                <button id="inspect-sell" class="relative group w-11 h-11 rounded-2xl bg-red-900/20 border border-red-500/30 flex flex-col items-center justify-center hover:bg-red-500/20 transition-all active:scale-90" title="Vender (T)">
                  <span class="absolute -top-2 -left-2 bg-red-600 text-[9px] font-black text-white px-1.5 py-0.5 rounded shadow-[0_0_10px_rgba(220,38,38,0.5)] z-20 border border-white/20">T</span>
                  <span id="inspect-sell-value" class="text-base font-black text-red-400 leading-none">--</span>
                  <span class="text-[8px] mt-0.5 opacity-60">💰</span>
                </button>
              </div>
            </div>

            <!-- Enemy Inspection View -->
            <div id="enemy-inspect-view" class="hidden w-full h-full flex items-center gap-6 animate-in slide-in-from-bottom-2 duration-300">
              <div class="flex flex-col min-w-[130px]">
                <span id="enemy-inspect-name" class="text-[10px] font-black text-red-500 uppercase italic tracking-widest truncate">ENEMIGO</span>
                <span id="enemy-inspect-type" class="text-[6px] text-white/30 uppercase font-black tracking-widest">Amenaza Detectada</span>
              </div>
              <div class="flex-1 max-w-xs flex flex-col gap-1">
                <div class="flex justify-between items-center"><span class="text-[7px] text-red-400/70 font-black uppercase tracking-widest">Vitalidad</span><span id="enemy-inspect-hp-text" class="text-[8px] text-white font-mono">0/0</span></div>
                <div class="w-full h-1.5 bg-gray-900 rounded-full overflow-hidden border border-white/5 shadow-inner">
                  <div id="enemy-inspect-hp-bar" class="h-full bg-gradient-to-r from-red-600 to-orange-500 shadow-[0_0_10px_rgba(239,68,68,0.4)]" style="width: 100%"></div>
                </div>
              </div>
              <div class="flex items-center gap-6 text-[8px] font-black text-white/40">
                <div class="flex flex-col items-center"><span>VELOCIDAD</span><span id="enemy-inspect-speed" class="text-white font-mono">1.0x</span></div>
                <div class="flex flex-col items-center"><span>CONDICIÓN</span><span id="enemy-inspect-status" class="text-amber-400">ESTABLE</span></div>
              </div>
            </div>
          </div>

          <!-- Section 4: Tactical Command (Right) -->
          <div class="flex items-center pl-4 border-l border-white/5 h-full shrink-0">
            <div class="flex flex-col gap-1.5 min-w-[100px]">
              <!-- Spacebar Trigger -->
              <button
                id="main-action-btn"
                class="h-7 w-full bg-indigo-950/40 hover:bg-indigo-900/60 border border-indigo-500/30 rounded-xl shadow-[0_0_20px_rgba(79,70,229,0.2)] transition-all group active:scale-95 flex items-center justify-center relative overflow-hidden px-3"
              >
                <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                <span id="main-action-span" class="text-[9px] font-black uppercase tracking-[0.2em] text-indigo-300 group-hover:text-white leading-none">INICIAR</span>
                <span class="ml-2 text-[7px] font-black text-indigo-400/50 uppercase tracking-widest hidden group-hover:block">SPACE</span>
              </button>

              <!-- System Quick Controls -->
              <button 
                id="restart-btn" 
                class="h-5 w-full bg-red-950/10 hover:bg-red-900/30 border border-red-500/20 rounded-lg flex items-center justify-center gap-2 text-[8px] font-black text-red-400/70 hover:text-red-400 transition-all group" 
                title="Reiniciar [L]"
              >
                <span class="group-hover:rotate-180 transition-transform duration-500">🔄</span>
                <span class="uppercase tracking-widest">REINICIAR</span>
              </button>
            </div>
          </div>

        </div>
      </div>

      <!-- Tools Menu (Right Floating Dock - System Options) -->
      <div class="absolute right-4 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none">
        <div class="bg-black/85 backdrop-blur-2xl border border-white/10 rounded-3xl p-2 shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex flex-col gap-3 pointer-events-auto border-r-indigo-500/30">
          <!-- Fullscreen -->
          <button
            id="fullscreen-btn"
            class="w-10 h-10 rounded-2xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group relative active:scale-90"
            title="Pantalla Completa [W]"
          >
            <span class="absolute -top-1 -left-1 bg-black/80 text-[5px] font-black text-white/40 px-1 rounded border border-white/5 z-20">W</span>
            <span class="text-base group-hover:scale-110 transition-transform">⛶</span>
          </button>

          <!-- Config -->
          <button
            id="config-btn"
            class="w-10 h-10 rounded-2xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group relative active:scale-90"
            title="Configuración"
          >
            <span class="text-base group-hover:rotate-45 transition-transform">⚙️</span>
          </button>
        </div>
      </div>

      <!-- Config Modal -->
      <div id="restart-confirm-modal" class="hidden absolute inset-0 z-[110] flex items-center justify-center bg-black/60 backdrop-blur-md p-4">
        <div class="w-full max-w-sm bg-black/85 backdrop-blur-2xl border border-white/10 border-b-red-500/50 rounded-3xl shadow-[0_0_50px_rgba(239,68,68,0.3)] p-6 transform animate-in zoom-in duration-200">
          <div class="text-center space-y-4">
            <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto border border-red-500/20">
              <span class="text-3xl">🔄</span>
            </div>
            <div class="space-y-2">
              <h3 class="text-xl font-black text-white tracking-tight uppercase italic">¿REINICIAR PARTIDA?</h3>
              <p class="text-slate-400 text-xs leading-relaxed uppercase tracking-wider">
                Perderás todo el progreso de la oleada actual. Esta acción consume <span class="text-indigo-400 font-bold">1 turno</span>.
              </p>
            </div>
            <div class="flex gap-3 pt-2">
              <button 
                id="cancel-restart-btn"
                class="flex-1 px-4 py-3 rounded-2xl bg-white/5 text-slate-300 font-black text-[10px] hover:bg-white/10 transition-all uppercase tracking-[0.2em]"
              >
                Cancelar
              </button>
              <button 
                id="confirm-restart-btn"
                class="flex-1 px-4 py-3 rounded-2xl bg-red-600 text-white font-black text-[10px] hover:bg-red-500 transition-all shadow-lg shadow-red-600/20 uppercase tracking-[0.2em]"
              >
                Reiniciar
              </button>
            </div>
          </div>
        </div>
      </div>

      <div
        id="config-modal"
        class="absolute inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-md hidden p-4"
      >
        <div
          class="w-full max-w-lg max-h-[90vh] bg-black/85 backdrop-blur-2xl border border-white/10 border-b-indigo-500/50 rounded-3xl shadow-[0_0_50px_rgba(79,70,229,0.3)] flex flex-col overflow-hidden"
        >
          <div class="p-6 overflow-y-auto custom-scrollbar flex-1">
            <div class="flex items-center justify-center gap-3 mb-6">
              <div class="w-8 h-[1px] bg-indigo-500/50"></div>
              <h2 class="text-xl font-black text-indigo-400 uppercase tracking-[0.3em] italic text-center">Configuración</h2>
              <div class="w-8 h-[1px] bg-indigo-500/50"></div>
            </div>
            
            <div class="space-y-6">
              <!-- Keybinds Section -->
              <div class="space-y-3">
                <div class="flex items-center justify-between border-b border-white/10 pb-2">
                  <span class="text-[10px] text-white font-black uppercase tracking-widest">Atajos de Teclado</span>
                  <span class="text-[8px] text-indigo-400 font-black italic animate-pulse">CLIC PARA REASIGNAR</span>
                </div>
                
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-2" id="keybinds-list">
                  <!-- Keybinds will be injected here -->
                </div>
              </div>

              <!-- Toggles Section -->
              <div class="grid grid-cols-2 gap-3 mt-4">
                <!-- Sounds -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Sonidos</span>
                  <button id="toggle-sound" class="w-12 h-6 rounded-full bg-indigo-950/50 border border-indigo-500/30 relative transition-all group shadow-inner">
                    <div id="sound-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-indigo-400 shadow-[0_0_10px_rgba(129,140,248,0.5)] transition-transform translate-x-6"></div>
                  </button>
                </div>

                <!-- Turbo -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Turbo x2</span>
                  <button id="toggle-turbo" class="w-12 h-6 rounded-full bg-gray-900/50 border border-white/10 relative transition-all group shadow-inner">
                    <div id="turbo-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>

                <!-- Fog of War -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Niebla</span>
                  <button id="toggle-fog" class="w-12 h-6 rounded-full bg-indigo-950/50 border border-indigo-500/30 relative transition-all group shadow-inner">
                    <div id="fog-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-indigo-400 shadow-[0_0_10px_rgba(129,140,248,0.5)] transition-transform translate-x-6"></div>
                  </button>
                </div>

                <!-- Show Ranges -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Rangos</span>
                  <button id="toggle-ranges" class="w-12 h-6 rounded-full bg-gray-900/50 border border-white/10 relative transition-all group shadow-inner">
                    <div id="ranges-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="p-4 bg-white/[0.02] border-t border-white/5 flex gap-3">
            <button
              id="close-config"
              class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black uppercase tracking-[0.2em] rounded-2xl transition-all shadow-lg shadow-indigo-600/20 active:scale-[0.98]"
            >
              Confirmar Cambios
            </button>
          </div>
        </div>
      </div>

      <!-- Build Menu (Left Floating Dock) -->
      <div
        class="absolute left-4 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none"
      >
        <div class="bg-black/85 backdrop-blur-2xl border border-white/10 rounded-3xl p-2 shadow-[0_20px_50px_rgba(0,0,0,0.5)] flex flex-col gap-4 pointer-events-auto border-l-indigo-500/30">
          <div class="flex flex-col gap-6 md:gap-5">
            <!-- Tower 1 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-2xl bg-slate-900/30 border border-slate-500/40 hover:bg-slate-800/50 hover:border-slate-400 transition-all flex items-center justify-center shadow-lg active:scale-90"
              data-type="basic"
              data-cost="4"
              title="Colmillo Ligero: Defensa rápida (Límite: 8) [A]"
            >
              <div class="w-5 h-5 md:w-5 md:h-5 bg-slate-400 rounded-sm group-hover:scale-110 transition-transform"></div>
              <span class="absolute -top-1 -left-1 bg-slate-500 text-[7px] font-black text-white px-1.5 py-0.5 rounded-br-lg rounded-tl-lg shadow-[0_0_10px_rgba(100,116,139,0.5)] z-20 border-r border-b border-white/20">A</span>
              <span class="count-tag absolute -top-1.5 -right-1.5 bg-slate-800 text-slate-400 text-[7px] font-black px-1 rounded-full border border-slate-500/30 z-10 pointer-events-none">0/8</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-slate-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-slate-900/50 z-10 pointer-events-none">10a</span>
            </button>

            <!-- Tower 2 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-2xl bg-purple-900/30 border border-purple-500/40 hover:bg-purple-800/50 hover:border-purple-400 transition-all flex items-center justify-center shadow-lg active:scale-90"
              data-type="sniper"
              data-cost="15"
              title="Mirada del Lobo: Gran alcance y daño crítico (Límite: 4) [S]"
            >
              <div class="w-4 h-4 md:w-3.5 md:h-3.5 bg-purple-400 rounded-full group-hover:scale-110 transition-transform"></div>
              <span class="absolute -top-1 -left-1 bg-purple-600 text-[7px] font-black text-white px-1.5 py-0.5 rounded-br-lg rounded-tl-lg shadow-[0_0_10px_rgba(147,51,234,0.5)] z-20 border-r border-b border-white/20">S</span>
              <span class="count-tag absolute -top-1.5 -right-1.5 bg-purple-900 text-purple-400 text-[7px] font-black px-1 rounded-full border border-purple-500/30 z-10 pointer-events-none">0/4</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-purple-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-purple-900/50 z-10 pointer-events-none">20a</span>
            </button>

            <!-- Tower 3 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-2xl bg-red-900/30 border border-red-500/40 hover:bg-red-800/50 hover:border-red-400 transition-all flex items-center justify-center shadow-lg active:scale-90"
              data-type="splash"
              data-cost="25"
              title="Rugido de Acero: Daño en área devastador (Límite: 2) [D]"
            >
              <div class="w-4.5 h-4.5 md:w-4 md:h-4 bg-red-400 rotate-45 group-hover:scale-110 transition-transform"></div>
