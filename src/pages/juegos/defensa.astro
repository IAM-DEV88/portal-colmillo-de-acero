            console.log(`Error attempting to enable fullscreen: ${err.message} (${err.name})`);
          });
        } else {
          document.exitFullscreen();
        }
      });
      document.querySelectorAll('.tower-btn').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget;
          const type = target.dataset.type;

          if (selectedTowerType === type) {
            // Toggle off
            selectedTowerType = null;
            target.classList.remove('ring-4', 'ring-amber-400');
          } else if (type) {
            // Toggle on / Switch
            inspectedTower = null; // Clear inspection when building
            document
              .querySelectorAll('.tower-btn')
              .forEach((b) => b.classList.remove('ring-4', 'ring-amber-400'));
            target.classList.add('ring-4', 'ring-amber-400');
            selectedTowerType = type;
          }
        });

        // Touch start for drag
        btn.addEventListener('touchstart', (e) => {
          if (gameState !== 'playing') return;
          const type = btn.dataset.type;
          // Only towers can be dragged (not repair/upgrade for now to keep it simple, or they can be too)
          if (type && !['repair', 'upgrade'].includes(type)) {
            isDragging = true;
            draggedType = type;
            const touch = e.touches[0];
            dragStartX = touch.clientX;
            dragStartY = touch.clientY;
          }
        }, { passive: true });
      });

      // Global touch listeners for dragging
      window.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const touch = e.touches[0];
        const rect = canvas.getBoundingClientRect();
        
        // Update mouseX/mouseY for preview drawing
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        mouseX = (touch.clientX - rect.left) * scaleX;
        mouseY = (touch.clientY - rect.top) * scaleY;

        // Prevent scrolling when dragging over the game area
        if (touch.clientX >= rect.left && touch.clientX <= rect.right &&
            touch.clientY >= rect.top && touch.clientY <= rect.bottom) {
          if (e.cancelable) e.preventDefault();
        }
      }, { passive: false });

      window.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        
        const touch = e.changedTouches[0];
        const rect = canvas.getBoundingClientRect();
        
        // Check if dropped on canvas
        if (touch.clientX >= rect.left && touch.clientX <= rect.right &&
            touch.clientY >= rect.top && touch.clientY <= rect.bottom) {
          const scaleX = canvas.width / rect.width;
          const scaleY = canvas.height / rect.height;
          const x = (touch.clientX - rect.left) * scaleX;
          const y = (touch.clientY - rect.top) * scaleY;
          
          handleConstruction(x, y, draggedType, GRID_SIZE * 1.2); // Use mobile hit radius
        }
        
        isDragging = false;
        draggedType = null;
      });

      // Config Modal Handlers
      const configBtn = document.getElementById('config-btn');
      const configModal = document.getElementById('config-modal');
      const closeConfig = document.getElementById('close-config');
      const toggleSound = document.getElementById('toggle-sound');
      const soundSwitch = document.getElementById('sound-switch');

      // Unit Info Plate Action Listeners
      const inspectPlate = document.getElementById('unit-info-plate');
      const closeInspectBtn = document.getElementById('inspect-close');
      const repairInspectBtn = document.getElementById('inspect-repair');
      const upgradeInspectBtn = document.getElementById('inspect-upgrade');

      if (closeInspectBtn) {
          closeInspectBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            inspectedTower = null;
            playSFX('click');
          });
        }

        const enemyInspectCloseBtn = document.getElementById('enemy-inspect-close');
        if (enemyInspectCloseBtn) {
          enemyInspectCloseBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            inspectedEnemy = null;
            playSFX('click');
          });
        }

      if (repairInspectBtn) {
        repairInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const cost = getTowerCost('repair');
          if (inspectedTower.hp >= inspectedTower.maxHp) {
            showCanvasToast('El puesto ya tiene la salud máxima', 'error');
            playSFX('error');
            return;
          }
          if (upgrades >= cost) {
            upgrades -= cost;
            inspectedTower.hp = Math.min(inspectedTower.maxHp, inspectedTower.hp + 50);
            inspectedTower.buffs.steelShield = 600;
            updateHUD();
            showCanvasToast('¡Refuerzo de Acero!', 'success');
            createExplosion(inspectedTower.x, inspectedTower.y, '#94A3B8', 20);
            playSFX('build');
          } else {
            showCanvasToast('Táctica insuficiente', 'error');
            playSFX('error');
          }
        });
      }

      const sellInspectBtn = document.getElementById('inspect-sell');
      if (sellInspectBtn) {
        sellInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const refund = calculateSellValue(inspectedTower);
          abyssals += refund;
          const index = towers.indexOf(inspectedTower);
          if (index > -1) {
            const visualY = inspectedTower.y + (((inspectedTower.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            createExplosion(inspectedTower.x, visualY, '#EF4444', 15);
            addFloatingText(inspectedTower.x, visualY, `+${refund}a`, '#34D399');
            towers.splice(index, 1);
            inspectedTower = null;
            updateHUD();
            playSFX('pickup');
            showCanvasToast(`Puesto retirado: +${refund} acero`, 'success');
            updateTowerPairing();
          }
        });
      }

      if (upgradeInspectBtn) {
        upgradeInspectBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!inspectedTower) return;
          const cost = getTowerCost('upgrade');
          if (upgrades >= cost) {
            upgrades -= cost;
            inspectedTower.level++;
            inspectedTower.damage = Math.floor(inspectedTower.damage * 1.5);
            const oldRange = inspectedTower.range;
            inspectedTower.range = Math.floor(inspectedTower.range * 1.1);
            inspectedTower.oldRange = oldRange;
            inspectedTower.upgradePulse = 1.0;
            inspectedTower.maxHp += 50;
            inspectedTower.hp += 50;
            updateHUD();
            showCanvasToast(`Puesto Nivel ${inspectedTower.level}`, 'success');
            createExplosion(inspectedTower.x, inspectedTower.y, '#F59E0B', 25);
            playSFX('build');
          } else {
            showCanvasToast('Táctica insuficiente', 'error');
            playSFX('error');
          }
        });
      }

      function updateSoundUI() {
        if (soundsEnabled) {
          toggleSound.classList.remove('bg-gray-800', 'border-gray-600');
          toggleSound.classList.add('bg-indigo-900/50', 'border-indigo-500/50');
          soundSwitch.classList.remove('translate-x-0');
          soundSwitch.classList.add('translate-x-7');
        } else {
          toggleSound.classList.remove('bg-indigo-900/50', 'border-indigo-500/50');
          toggleSound.classList.add('bg-gray-800', 'border-gray-600');
          soundSwitch.classList.remove('translate-x-7');
          soundSwitch.classList.add('translate-x-0');
        }
      }

      function renderKeybinds() {
        const list = document.getElementById('keybinds-list');
        if (!list) return;
        list.innerHTML = '';
        Object.keys(KEYBINDS).forEach(key => {
          const btn = document.createElement('button');
          btn.className = `flex flex-col items-center p-1.5 rounded-md border transition-all ${isRebinding === key ? 'bg-indigo-600 border-white ring-1 ring-indigo-400' : 'bg-white/5 border-white/10 hover:bg-white/10'}`;
          
          const label = document.createElement('span');
          label.className = 'text-[6px] text-gray-500 uppercase font-black leading-tight';
          label.innerText = KEY_LABELS[key];
          
          const val = document.createElement('span');
          val.className = 'text-[10px] text-white font-bold uppercase';
          const keyVal = KEYBINDS[key];
          val.innerText = keyVal === ' ' ? 'ESP' : keyVal.toUpperCase();
          
          btn.appendChild(label);
          btn.appendChild(val);
          
          btn.onclick = () => {
            isRebinding = key;
            renderKeybinds();
          };
          
          list.appendChild(btn);
        });
      }

      configBtn.addEventListener('click', () => {
        configModal.classList.remove('hidden');
        updateSoundUI();
        updateTurboUI();
        updateFogUI();
        updateRangesUI();
        renderKeybinds();
      });

      closeConfig.addEventListener('click', () => {
        configModal.classList.add('hidden');
      });

      toggleSound.addEventListener('click', () => {
        soundsEnabled = !soundsEnabled;
        updateSoundUI();
        playSFX('click');
      });

      window.addEventListener('keydown', (e) => {
        if (gameState !== 'playing' && gameState !== 'intro') return;

        // --- REBINDING LOGIC ---
        if (isRebinding) {
          e.preventDefault();
          const key = e.key.toLowerCase();
          
          // Basic validation
          if (key === 'escape') {
            isRebinding = null;
            renderKeybinds();
            return;
          }

          // Check for duplicates
          const exists = Object.entries(KEYBINDS).find(([k, v]) => v === key && k !== isRebinding);
          if (exists) {
            showCanvasToast(`¡Tecla ${key} ya en uso por ${KEY_LABELS[exists[0]]}!`, 'error');
            playSFX('error');
            return;
          }

          KEYBINDS[isRebinding] = key;
          isRebinding = null;
          renderKeybinds();
          showCanvasToast('¡Control reasignado!', 'success');
          playSFX('click');
          return;
        }

        if (e.key === 'Shift') isShiftDown = true;
        const key = e.key.toLowerCase();

        // --- TAB NAVIGATION (Cycle focus by lowest HP) ---
        if (key === 'tab') {
          e.preventDefault();
          if (towers.length === 0) return;

          // Sort towers by health percentage (ascending)
          const sorted = [...towers].sort((a, b) => (a.hp / a.maxHp) - (b.hp / b.maxHp));
          
          if (!inspectedTower) {
            inspectedTower = sorted[0];
          } else {
            // Find next in sorted list
            const currentIndex = sorted.indexOf(inspectedTower);
            const nextIndex = (currentIndex + 1) % sorted.length;
            inspectedTower = sorted[nextIndex];
          }
          
          selectedTowerType = null;
          playSFX('click');
          return;
        }

        // --- SPACE / ACTION KEY (Pause/Resume/Start) ---
        if (key === KEYBINDS.action) {
          e.preventDefault();
          if (gameState === 'intro' || gameState === 'gameover') {
            // Start game if possible
            if (credits > 0) {
              playSFX('start');
              startGame();
            } else {
              playSFX('error');
              if (window.showToast) window.showToast('No tienes turnos suficientes', 'error');
            }
          } else if (gameState === 'playing') {
            if ((enemies.length === 0 && !isEventActive) || wave === 0) {
              // Start next wave
              playSFX('start');
              if (wave === 0) wave = 1;
              spawnWave();
            } else {
              // Toggle Pause
              const pb = document.getElementById('pause-btn');
              if (pb) pb.click();
            }
          }
          return;
        }

        // --- REPAIR / UPGRADE KEYS ---
        if (key === KEYBINDS.repair) {
          if (inspectedTower) {
            const rb = document.getElementById('inspect-repair');
            if (rb) rb.click();
          } else {
            const btn = document.querySelector(`[data-type="repair"]`);
            if (btn) btn.click();
          }
          return;
        }

        if (key === KEYBINDS.upgrade) {
          if (inspectedTower) {
            const ub = document.getElementById('inspect-upgrade');
            if (ub) ub.click();
          } else {
            const btn = document.querySelector(`[data-type="upgrade"]`);
            if (btn) btn.click();
          }
          return;
        }

        // --- TOWER SELECTION KEYS ---
        const towerMap = {
          [KEYBINDS.tower1]: 'basic',
          [KEYBINDS.tower2]: 'sniper',
          [KEYBINDS.tower3]: 'splash',
          [KEYBINDS.tower4]: 'nova',
        };

        if (towerMap[key]) {
          const btn = document.querySelector(`[data-type="${towerMap[key]}"]`);
          if (btn) btn.click();
        }

        // --- FULLSCREEN & SOUND TOGGLES ---
        if (key === KEYBINDS.fullscreen) {
          const fb = document.getElementById('fullscreen-btn');
          if (fb) fb.click();
        }

        if (key === KEYBINDS.sounds) {
          const sb = document.getElementById('toggle-sound');
          if (sb) sb.click();
        }
      });

      window.addEventListener('keyup', (e) => {
        if (e.key === 'Shift') isShiftDown = false;
      });

      canvas.addEventListener('mousedown', (e) => {
        isMouseDown = true;
        handleCanvasAction(e);
      });

      canvas.addEventListener('touchstart', (e) => {
        isMouseDown = true;
        const touch = e.touches[0];
        // Create a fake event object that handleCanvasAction expects
        const fakeEvent = {
          clientX: touch.clientX,
          clientY: touch.clientY,
          type: 'touchstart'
        };
        handleCanvasAction(fakeEvent);
        if (e.cancelable) e.preventDefault();
      }, { passive: false });

      window.addEventListener('mouseup', () => {
        isMouseDown = false;
      });

      window.addEventListener('touchend', () => {
        isMouseDown = false;
      });

      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        mouseX = (e.clientX - rect.left) * scaleX;
        mouseY = (e.clientY - rect.top) * scaleY;

        if (isMouseDown && isShiftDown && selectedTowerType) {
          handleCanvasAction(e);
        }
      });

      function handleCanvasAction(e) {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        const x = (e.clientX - rect.left) * scaleX;
        const y = (e.clientY - rect.top) * scaleY;
        
        // Fat Finger Compensation: Use larger radius for touch
        const isTouch = e.type && e.type.startsWith('touch');
        const clickRadius = isTouch ? 65 : 30; // Increased for mobile
        const towerHitRadius = isTouch ? GRID_SIZE * 1.6 : GRID_SIZE * 0.8; // Increased for mobile

        // Visual Feedback for touch interaction
        if (isMouseDown && isTouch) {
          lastInteractionPos = { x, y, radius: clickRadius, life: 20 };
        }

        // Check if start button clicked
        if (gameState === 'intro' || gameState === 'gameover') {
          if (isMouseDown) {
            const btnX = canvas.width / 2;
            const btnY = canvas.height / 2 + 150;
            if (x > btnX - 150 && x < btnX + 150 && y > btnY - 50 && y < btnY + 50) {
              if (credits > 0) {
                playSFX('start');
                startGame();
              } else {
                playSFX('error');
                if (window.showToast) window.showToast('No tienes turnos suficientes', 'error');
              }
            }
          }
          return;
        }

        if (gameState !== 'playing') return;

        // PRIORITIZE BONUSES (Runes) - Especially on mobile
        if (isMouseDown) {
          for (let i = bonuses.length - 1; i >= 0; i--) {
            const b = bonuses[i];
            const dist = Math.hypot(b.x - x, b.y - y);
            if (dist < clickRadius) {
              // Click radius
              if (b.type === 'abyssal_rune') {
                abyssals += b.reward;
                showCanvasToast(`¡+${b.reward} Acero!`, 'success');
                createExplosion(b.x, b.y, '#94A3B8', 20);
                addFloatingText(b.x, b.y, `+${b.reward}a`, '#94A3B8');
                addCombo();
              } else if (b.type === 'upgrades') {
                upgrades += b.reward;
                showCanvasToast(`¡+${b.reward} Táctica!`, 'success');
                createExplosion(b.x, b.y, '#FCD34D', 20);
                addFloatingText(b.x, b.y, `+${b.reward}t`, '#FCD34D');
                addCombo();
              } else if (b.type === 'heal') {
                health = health + 20;
                showCanvasToast('¡Ciudadela Reforzada (+20)!', 'success');
                createExplosion(b.x, b.y, '#10B981', 20);
                addFloatingText(b.x, b.y, '+20 HP', '#10B981', 'buff');
              } else if (b.type === 'freeze') {
                enemies.forEach((en) => (en.speed *= 0.5));
                globalFreezeTimer = 300;
                showCanvasToast('¡Enemigos de la Plaga ralentizados!', 'info');
                createExplosion(b.x, b.y, '#60A5FA', 30);
                addFloatingText(b.x, b.y, '❄️ Lentos', '#60A5FA', 'debuff');
              } else if (b.type === 'frenzy') {
                towers.forEach((t) => (t.buffs.doubleShot = 300));
                globalFrenzyTimer = 300;
                showCanvasToast('¡Frenesí! Colmillos acelerados.', 'error');
                createExplosion(b.x, b.y, '#EF4444', 30);
                addFloatingText(b.x, b.y, '🔥 Frenesí', '#EF4444', 'buff');
              } else if (b.type === 'nuke') {
                enemies.forEach((en) => {
                  en.hp -= 50;
                  addFloatingText(en.x, en.y, '-50', '#FCD34D');
                });
                showCanvasToast('¡Bombardeo! Daño masivo a la Plaga.', 'success');
                createExplosion(canvas.width / 2, canvas.height / 2, '#F59E0B', 50);
                addFloatingText(b.x, b.y, '💥 Bombardeo', '#F59E0B', 'buff');
                addScreenShake(15);
              }
              updateHUD();
              bonuses.splice(i, 1);
              playSFX('pickup');
              return;
            }
          }
        }

        // SMART SELECTION CYCLING (TAB-LIKE)
        if (isMouseDown && !selectedTowerType) {
          const nearbyTowers = towers.filter((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - x, (t.y + i * GRID_SIZE) - y) < towerHitRadius) return true;
            }
            return false;
          });

          const nearbyEnemies = enemies.filter((en) => {
            return Math.hypot(en.x - x, en.y - y) < clickRadius; 
          });

          const candidates = [...nearbyTowers, ...nearbyEnemies];

          if (candidates.length > 0) {
            let nextIndex = 0;
            // If something is already selected and it's in our candidates, pick the next one
            const currentSelected = inspectedTower || inspectedEnemy;
            if (currentSelected) {
              const currentIndex = candidates.indexOf(currentSelected);
              if (currentIndex !== -1) {
                nextIndex = (currentIndex + 1) % candidates.length;
              }
            }

            const selection = candidates[nextIndex];
            if (towers.includes(selection)) {
              inspectedTower = selection;
              inspectedEnemy = null;
            } else {
              inspectedEnemy = selection;
              inspectedTower = null;
            }
            playSFX('click');
            return;
          }

          // Clicked empty space
          inspectedTower = null;
          inspectedEnemy = null;
        }

        // Check if next wave button clicked (or Ready button in wave 0)
        if ((enemies.length === 0 && !isEventActive) || wave === 0) {
          if (isMouseDown) {
            const btnX = canvas.width / 2;
            const btnY = canvas.height / 2 + 150; // Centered vertically in play area, away from HUD
            if (x > btnX - 150 && x < btnX + 150 && y > btnY - 50 && y < btnY + 50) {
              playSFX('start');
              if (wave === 0) wave = 1;
              spawnWave();
              return;
            }
          }
        }

        if (!selectedTowerType) return;
        handleConstruction(x, y, selectedTowerType, towerHitRadius);
      }

      function handleConstruction(x, y, type, hitRadius = GRID_SIZE * 0.8) {
        const cost = getTowerCost(type);

        // Snap to Grid
        const gridX = Math.round(x / GRID_SIZE) * GRID_SIZE;
        const gridY = Math.round(y / GRID_SIZE) * GRID_SIZE;

        // --- SELL MODE ---
        if (type === 'sell') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            const refund = calculateSellValue(targetTower);
            const visualY = targetTower.y + (((targetTower.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            
            abyssals += refund;
            const index = towers.indexOf(targetTower);
            if (index > -1) {
              towers.splice(index, 1);
              if (inspectedTower === targetTower) inspectedTower = null;
            }
            
            addFloatingText(targetTower.x, visualY, `+${refund}a`, '#34D399');
            showCanvasToast(`Puesto retirado: +${refund} acero`, 'success');
            createExplosion(targetTower.x, visualY, '#EF4444', 15);
            playSFX('pickup');
            updateHUD();
            updateTowerPairing();
          }
          return;
        }

        // --- REPAIR MODE ---
        if (type === 'repair') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            if (targetTower.hp >= targetTower.maxHp) {
              showCanvasToast('El puesto ya tiene la salud máxima', 'error');
              playSFX('error');
              return;
            }
            if (upgrades >= cost) {
              upgrades -= cost;
              targetTower.hp = Math.min(targetTower.maxHp, targetTower.hp + 50); // Heal 50 HP
              
              // Apply Steel Reinforcement (Repair Bonus)
              targetTower.buffs.steelShield = 600; // 10 seconds of bonus
              showCanvasToast(`¡Refuerzo de Acero! Multidisparo activado`, 'success');
              
              updateHUD();
              createExplosion(targetTower.x, targetTower.y, '#94A3B8', 20);
              playSFX('build');
            } else {
              showCanvasToast('Táctica insuficiente para reparar', 'error');
              playSFX('error');
            }
          }
          return;
        }

        // --- UPGRADE MODE ---
        else if (type === 'upgrade') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            const upgradeCount = isShiftDown ? 3 : 1;
            let upgradedLevels = 0;

            for (let i = 0; i < upgradeCount; i++) {
              const currentUpgradeCost = getTowerCost('upgrade');
              if (upgrades >= currentUpgradeCost) {
                upgrades -= currentUpgradeCost;
                targetTower.level = (targetTower.level || 1) + 1;
                targetTower.damage = Math.floor(targetTower.damage * 1.5); // +50% Damage
                
                const oldRange = targetTower.range;
                targetTower.range = Math.floor(targetTower.range * 1.1); // +10% Range
                targetTower.oldRange = oldRange;
                targetTower.upgradePulse = 1.0; // Specific upgrade expansion pulse
                
                targetTower.maxHp += 50;
                targetTower.hp += 50;
                targetTower.rangePulse = 1.0; // Keep the normal pulse too
                upgradedLevels++;
                playSFX('build');
              } else {
                if (i === 0) {
                  showCanvasToast(`Táctica insuficiente (${currentUpgradeCost}t)`, 'error');
                  playSFX('error');
                }
                break;
              }
            }

            if (upgradedLevels > 0) {
              updateHUD();
              showCanvasToast(
                upgradedLevels > 1
                  ? `¡Evolución Táctica! Nivel ${targetTower.level}`
                  : `Puesto Nivel ${targetTower.level}`,
                'success'
              );
              createExplosion(targetTower.x, targetTower.y, '#F59E0B', 20 + upgradedLevels * 5);
            }
          }
          return;
        }

        // Check Collisions
        if (isCollidingWithPath(gridX, gridY)) {
          if (!isShiftDown) {
            showCanvasToast('No puedes construir sobre el camino', 'error');
            playSFX('error');
          }
          return;
        }

        // Define UI bounding boxes for construction validation
        const inRightUI = gridX > canvas.width - 80; 
        const inLeftUI = gridX < 80; 
        const inBottomHUD = gridY > canvas.height - 60; 
        const inStartButton = gridX > canvas.width / 2 - 130 && gridX < canvas.width / 2 + 130 && gridY > canvas.height / 2 + 100 && gridY < canvas.height / 2 + 200;

        if (inRightUI || inLeftUI || inBottomHUD || (inStartButton && (enemies.length === 0 || wave === 0))) {
          if (!isShiftDown) {
            showCanvasToast('No puedes construir sobre la interfaz', 'error');
            playSFX('error');
          }
          return;
        }

        const stats = TOWER_STATS[type];
        const h = stats.gridHeight || 1;
        let isOccupied = false;
        let isOnPath = false;
        let outOfBounds = false;

        for (let i = 0; i < h; i++) {
          const checkY = gridY + i * GRID_SIZE;
          if (checkY > canvas.height - 40) outOfBounds = true; // Much lower limit now

          if (
            towers.some((t) => {
              const th = t.gridHeight || 1;
              for (let j = 0; j < th; j++) {
                if (Math.hypot(t.x - gridX, t.y + j * GRID_SIZE - checkY) < GRID_SIZE * 0.8)
                  return true;
              }
              return false;
            })
          )
            isOccupied = true;

          if (isCollidingWithPath(gridX, checkY)) isOnPath = true;
        }

        if (isOccupied || isOnPath || outOfBounds) {
          if (!isShiftDown) {
            showCanvasToast(
              isOccupied
                ? 'Espacio ocupado'
                : isOnPath
                  ? 'No puedes construir en el camino'
                  : 'Fuera de límites',
              'error'
            );
            playSFX('error');
          }
          return;
        }

        if (towers.length >= TOWER_LIMIT) {
          if (!isShiftDown) {
            showCanvasToast(`Límite de torres alcanzado (${TOWER_LIMIT})`, 'error');
            playSFX('error');
          }
          return;
        }

        if (abyssals >= cost) {
          towers.push({
            x: gridX,
            y: gridY,
            type,
            level: 1,
            kills: 0,
            veterancy: 1,
            cooldown: 0,
            buffs: {
              doubleShot: 0,
              freeze: 0,
              steelShield: 0,
              weakened: 0, // Debuff: Reduced damage
              blinded: 0,  // Debuff: Reduced range
              rusted: 0    // Debuff: Very reduced damage
            },
            ...TOWER_STATS[type],
          });
          abyssals -= cost;
          updateHUD();
          playSFX('build');
          
          // Recalculate pairs after a new tower is built
          updateTowerPairing();

          // Deselect if shift is not pressed
          if (!isShiftDown) {
            selectedTowerType = null;
            document
              .querySelectorAll('.tower-btn')
              .forEach((b) => b.classList.remove('ring-4', 'ring-amber-400'));
          }
        } else {
          if (!isShiftDown) {
            showCanvasToast('Acero insuficiente', 'error');
          }
        }
      }
    });

    // --- SOUND EFFECTS ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playSFX(type) {
      if (!soundsEnabled) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      const osc = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      osc.connect(gainNode);
      gainNode.connect(audioCtx.destination);

      const now = audioCtx.currentTime;
      if (type === 'shoot') {
        osc.type = 'square';
        osc.frequency.setValueAtTime(400, now);
        osc.frequency.exponentialRampToValueAtTime(100, now + 0.1);
        gainNode.gain.setValueAtTime(0.08, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
        osc.start(now);
        osc.stop(now + 0.1);
      } else if (type === 'nova') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(800, now);
        osc.frequency.exponentialRampToValueAtTime(100, now + 0.5);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
        osc.start(now);
        osc.stop(now + 0.5);
      } else if (type === 'hit') {
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(150, now);
        osc.frequency.exponentialRampToValueAtTime(50, now + 0.2);
        gainNode.gain.setValueAtTime(0.08, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
        osc.start(now);
        osc.stop(now + 0.2);
      } else if (type === 'hit_shield') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(300, now);
        osc.frequency.exponentialRampToValueAtTime(200, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
        osc.start(now);
        osc.stop(now + 0.1);
      } else if (type === 'build') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(600, now);
        osc.frequency.setValueAtTime(800, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.3);
        osc.start(now);
        osc.stop(now + 0.3);
      } else if (type === 'error') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(200, now);
        osc.frequency.setValueAtTime(150, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.3);
        osc.start(now);
        osc.stop(now + 0.3);
      } else if (type === 'start') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(440, now);
        osc.frequency.linearRampToValueAtTime(880, now + 0.3);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.5);
        osc.start(now);
        osc.stop(now + 0.5);
      } else if (type === 'pickup') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(800, now);
        osc.frequency.setValueAtTime(1200, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.2);
        osc.start(now);
        osc.stop(now + 0.2);
      }
    }

    // --- GAME LOOP ---
    async function startGame() {
      if (credits <= 0) return;

      credits -= 1;
      document.getElementById('credits-display').innerText = credits;

      // Reset Stats
      health = 100;
      upgrades = 50;
      abyssals = 100; // Adjusted initial abyssals
      wave = 0; // 0 indicates preparation phase
      enemiesLeftToSpawn = 0;
      passiveUpgradesTimer = 0;
      towers.length = 0;
      enemies.length = 0;
      projectiles.length = 0;
      enemyProjectiles.length = 0;
      bonuses.length = 0;
      darkRunes.length = 0;
      darkRuneTimer = 0;
      particles.length = 0;
      floatingTexts.length = 0;
      isEventActive = false;
      isCityFallen = false;
      isPaused = false;
      document.getElementById('pause-btn').querySelector('span').innerText = '⏸️';
      globalFreezeTimer = 0;
      globalFrenzyTimer = 0;

      gameState = 'playing';

      updateHUD();
      showCanvasToast('Fase de preparación: Construye tus defensas', 'info');
    }

    function addEnemyLevel(enemy) {
      // Rule: Level 1 for the first 7 waves, then strictly increase (Wave 8 = Lvl 2)
      enemy.level = wave <= 7 ? 1 : wave - 6;
    }

    function spawnWave() {
      const currentEnemyLevel = wave <= 7 ? 1 : wave - 6;
      
      // Update Repair Cost UI
      const repairBtnSpan = document.querySelector('[data-type="repair"] .cost-tag');
      if (repairBtnSpan) repairBtnSpan.innerText = `${Math.floor(50 + wave * 3.5)}t`;

      // Progression: n enemies in wave n
      const enemyCount = wave; 
      const isBossWave = wave > 0 && wave % 5 === 0;

      enemiesLeftToSpawn = 0; // All spawned at once

      if (isBossWave) {
        showCanvasToast('¡ALERTA! Un Comandante de la Plaga se aproxima...', 'error');
        playSFX('error');
      }

      const buffedIndices = new Set();
      if (!isBossWave) {
        const numBuffs = Math.floor(Math.random() * (1 + Math.floor(wave / 4)));
        for (let i = 0; i < numBuffs; i++) {
          buffedIndices.add(Math.floor(Math.random() * enemyCount));
        }
      }

      // Spawn all enemies at once
      for (let spawned = 0; spawned < enemyCount; spawned++) {
        // Position offset to prevent perfect stacking
        const offsetX = (Math.random() - 0.5) * 40;
        const offsetY = (Math.random() - 0.5) * 40;

        if (isBossWave && spawned === Math.floor(enemyCount / 2)) {
          // Boss spawn: Random type
          const type = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
          
          const newEnemy = {
            id: type.id,
            x: path[0].x - 10 + offsetX,
            y: path[0].y + offsetY,
            hp: (500 + currentEnemyLevel * 150) * type.hpMod,
            maxHp: (500 + currentEnemyLevel * 150) * type.hpMod,
            speed: (0.7 + currentEnemyLevel * 0.015) * type.speedMod,
            pathIndex: 0,
            color: type.color,
            isBoss: true,
            hasRangeBuff: true,
            isNecromancer: type.isNecromancer || false,
            isBerserker: type.isBerserker || false,
            isGhost: type.isGhost || false,
            reward: Math.floor((20 + currentEnemyLevel * 15) * 0.85),
            cooldown: 40,
            attackRange: 220,
            damage: 35 + currentEnemyLevel * 3,
            attackType: type.attackType,
            noDamageTimer: 0,
            isCasting: 0,
          };
          addEnemyLevel(newEnemy);
          enemies.push(newEnemy);
        } else {
          // RANDOM ENEMY SPAWN
          const type = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
          const hasBuff = buffedIndices.has(spawned);

          const newEnemy = {
            id: type.id,
            x: path[0].x - 10 + offsetX,
            y: path[0].y + offsetY,
            hp: (60 + currentEnemyLevel * 30) * type.hpMod,
            maxHp: (60 + currentEnemyLevel * 30) * type.hpMod,
            speed: (1.3 + currentEnemyLevel * 0.04) * type.speedMod,
            pathIndex: 0,
            color: type.color,
            isBoss: false,
            hasRangeBuff: hasBuff,
            isNecromancer: type.isNecromancer || false,
            isBerserker: type.isBerserker || false,
            isGhost: type.isGhost || false,
            reward: Math.floor((3 + currentEnemyLevel * 4) * 0.85),
            cooldown: Math.random() * 80 + 40,
            basicCooldown: type.basicRate || 60,
            maxBasicCooldown: type.basicRate || 60,
            basicDamage: type.basicDamage || 10,
            attackRange: hasBuff ? 260 : 190,
            damage: 15 + Math.floor(currentEnemyLevel * 1.2),
            attackType: type.attackType,
            noDamageTimer: 0,
            isCasting: 0,
          };
          addEnemyLevel(newEnemy);
          enemies.push(newEnemy);
        }
      }

      checkWaveClear();
    }

    function checkWaveClear() {
      const checkInterval = setInterval(() => {
        if (gameState !== 'playing') {
          clearInterval(checkInterval);
          return;
        }

        if (enemies.length === 0) {
          clearInterval(checkInterval);

          // Check map generation milestone (every 7 waves, triggers AFTER wave clear)
          if (wave > 0 && wave % 7 === 0) {
            path = generateRandomPath();
            
            // Destruir solo las torres que se interpongan en el nuevo camino
            let destroyedCount = 0;
            for (let i = towers.length - 1; i >= 0; i--) {
              const t = towers[i];
              const gh = t.gridHeight || 1;
              let collides = false;
              for (let j = 0; j < gh; j++) {
                if (isCollidingWithPath(t.x, t.y + j * GRID_SIZE)) {
                  collides = true;
                  break;
                }
              }
              
              if (collides) {
                createExplosion(t.x, t.y, '#EF4444', 15);
                towers.splice(i, 1);
                destroyedCount++;
              }
            }

            if (destroyedCount > 0) {
              showCanvasToast(`¡Terremoto! ${destroyedCount} puestos destruidos por el nuevo camino.`, 'error');
            } else {
              showCanvasToast('¡Terremoto! El terreno ha cambiado.', 'info');
            }
            
            addScreenShake(30); // Massive shake for map reset
            if (inspectedTower && !towers.includes(inspectedTower)) inspectedTower = null;
          }

          wave++;
          updateHUD();
          showCanvasToast(`¡Oleada ${wave - 1} completada!`, 'success');

          // Random events between waves (70% chance after wave 1)
          if (wave > 1 && Math.random() < 0.7) {
            triggerRandomEvent();
          }
          // The next wave is now triggered manually by the button on canvas
        }
      }, 1000);
    }

    function gameOver() {
      gameState = 'gameover';
    }

    function updateHUD() {
      const repairCost = getTowerCost('repair');
      const upgradeCost = getTowerCost('upgrade');

      document.getElementById('health-display').innerText = health;
      document.getElementById('upgrades-display').innerText = Math.floor(upgrades);
      document.getElementById('repair-cost-display').innerText = repairCost;
      document.getElementById('upgrade-cost-display').innerText = upgradeCost;
      document.getElementById('credits-display').innerText = credits;

      if (document.getElementById('abyssals-display'))
        document.getElementById('abyssals-display').innerText = Math.floor(abyssals);
      document.getElementById('wave-display').innerText = wave;
      document.getElementById('tower-count-display').innerText = `${towers.length}/${TOWER_LIMIT}`;

      // Update tower buttons costs and visual feedback (Sidebars)
      document.querySelectorAll('.tower-btn').forEach((btn) => {
        const type = btn.getAttribute('data-type');
        const costEl = btn.querySelector('.cost-tag');
        if (type) {
          const cost = getTowerCost(type);
          if (costEl) {
            costEl.innerText = `${cost}${type === 'repair' || type === 'upgrade' ? 't' : 'a'}`;
          }

          // Visual Feedback: Red if cannot afford, Green if can
          const isTactic = type === 'repair' || type === 'upgrade' || type === 'pause';
          const canAfford = isTactic ? upgrades >= cost : abyssals >= cost;
          
          if (type !== 'sell') { // Skip sell only
            // Remove all potential border colors
            const borderClasses = [
              'border-red-500/50', 'border-green-500/50', 'border-slate-500/50', 
              'border-purple-500/50', 'border-cyan-500/50', 'border-yellow-500/50',
              'border-emerald-500/50', 'border-orange-500/50', 'border-slate-500/40',
              'border-purple-500/40', 'border-red-500/40', 'border-emerald-500/40',
              'border-green-500/40', 'border-orange-500/40', 'border-yellow-500/40'
            ];
            btn.classList.remove(...borderClasses);

            if (canAfford) {
              btn.classList.add('border-green-500/50');
              btn.classList.remove('opacity-50');
            } else {
              btn.classList.add('border-red-500/50');
              btn.classList.add('opacity-50');
            }
          }
        }
      });

      // Update inspection plate action buttons
      const repairBtn = document.getElementById('inspect-repair');
      const upgradeBtn = document.getElementById('inspect-upgrade');
      const repairCostEl = document.getElementById('inspect-repair-cost');
      const upgradeCostEl = document.getElementById('inspect-upgrade-cost');

      if (repairBtn) repairBtn.title = `Reparar (${repairCost}t)`;
      if (upgradeBtn) upgradeBtn.title = `Mejorar (${upgradeCost}t)`;
      if (repairCostEl) repairCostEl.innerText = `${repairCost}t`;
      if (upgradeCostEl) upgradeCostEl.innerText = `${upgradeCost}t`;
    }

    // --- RANDOM EVENTS ---
    function triggerRandomEvent() {
      // Safety check: Only trigger if wave is active and not preparation
      if (gameState !== 'playing' || wave === 0 || (enemies.length === 0 && enemiesLeftToSpawn === 0)) return;
      
      isEventActive = true;
      const events = ['meteor', 'bonus', 'curse', 'blessing'];
      const chosenEvent = events[Math.floor(Math.random() * events.length)];

      const warningEl = document.getElementById('event-warning');
      const boxEl = document.getElementById('warning-box');
      const textEl = document.getElementById('warning-text');

      if (chosenEvent === 'meteor') {
        textEl.innerText = '¡FUEGO DEL VACÍO INMINENTE!';
        boxEl.className =
          'bg-red-900/80 border border-red-500 p-6 rounded-2xl backdrop-blur-md shadow-[0_0_50px_rgba(239,68,68,0.5)] transform scale-100 transition-transform duration-300';
      } else if (chosenEvent === 'curse') {
        textEl.innerText = '¡MALDICIÓN DE LA PLAGA!';
        boxEl.className =
          'bg-purple-900/80 border border-purple-500 p-6 rounded-2xl backdrop-blur-md shadow-[0_0_50px_rgba(168,85,247,0.5)] transform scale-100 transition-transform duration-300';
        textEl.parentElement.classList.replace('text-red-500', 'text-purple-500');
        textEl.parentElement.classList.replace('text-amber-500', 'text-purple-500');
      } else if (chosenEvent === 'blessing') {
        textEl.innerText = '¡BENDICIÓN DE LA LUZ!';
        boxEl.className =
          'bg-emerald-900/80 border border-emerald-500 p-6 rounded-2xl backdrop-blur-md shadow-[0_0_50px_rgba(16,185,129,0.5)] transform scale-100 transition-transform duration-300';
        textEl.parentElement.classList.replace('text-red-500', 'text-emerald-500');
        textEl.parentElement.classList.replace('text-amber-500', 'text-emerald-500');
      } else {
        textEl.innerText = '¡BOTÍN DE GUERRA DETECTADO!';
        boxEl.className =
          'bg-amber-900/80 border border-amber-500 p-6 rounded-2xl backdrop-blur-md shadow-[0_0_50px_rgba(245,158,11,0.5)] transform scale-100 transition-transform duration-300';
        textEl.parentElement.classList.replace('text-red-500', 'text-amber-500');
        textEl.parentElement.classList.replace('text-purple-500', 'text-amber-500');
        textEl.parentElement.classList.replace('text-emerald-500', 'text-amber-500');
      }

      warningEl.classList.remove('opacity-0');
      warningEl.classList.add('opacity-100');

      setTimeout(() => {
        warningEl.classList.remove('opacity-100');
        warningEl.classList.add('opacity-0');
        boxEl.classList.replace('scale-100', 'scale-90');

        // Execute event
        if (chosenEvent === 'meteor') executeMeteorStrike();
        else if (chosenEvent === 'curse') executeCurse();
        else if (chosenEvent === 'blessing') executeBlessing();
        else executeBonusDrop();

        isEventActive = false;
        // Manual start instead of automatic
      }, 3000);
    }

    function executeBlessing() {
      const blessings = [
        {
          id: 'divine_shield',
          apply: () => {
            if (towers.length === 0) return false;
            towers.forEach(t => {
              t.buffs.steelShield = 600; // 10 seconds of shield
              t.hp = Math.min(t.maxHp, t.hp + t.maxHp * 0.2); // Small heal too
            });
            createExplosion(canvas.width / 2, 100, '#60A5FA', 40);
            return '¡Escudo Divino sobre todos los puestos!';
          }
        },
        {
          id: 'tactical_genius',
          apply: () => {
            const gain = 150 + wave * 10;
            upgrades += gain;
            updateHUD();
            createExplosion(canvas.width / 2, canvas.height / 2, '#F59E0B', 30);
            return `¡Genio Táctico! +${Math.round(gain)} Táctica.`;
          }
        },
        {
          id: 'steel_supply',
          apply: () => {
            const gain = 100 + wave * 5;
            abyssals += gain;
            updateHUD();
            createExplosion(canvas.width / 2, canvas.height / 2, '#94A3B8', 30);
            return `¡Suministros de Acero! +${Math.round(gain)} Acero.`;
          }
        },
        {
          id: 'inspiration',
          apply: () => {
            if (towers.length === 0) return false;
            towers.forEach(t => {
              t.buffs.doubleShot = 420; // 7 seconds of frenzy
            });
            createExplosion(canvas.width / 2, 100, '#EF4444', 40);
            return '¡Inspiración Heroica! Todos los puestos ganan Frenesí.';
          }
        },
        {
          id: 'healing_light',
          apply: () => {
            const heal = 15;
            const oldHealth = health;
            health = Math.min(100, health + heal);
            updateHUD();
            createExplosion(canvas.width / 2, canvas.height / 2, '#10B981', 30);
            return health > oldHealth ? `¡Luz Sanadora! +${Math.round(health - oldHealth)} Salud.` : '¡Luz Sanadora! Ciudadela purificada.';
          }
        }
      ];

      const blessing = blessings[Math.floor(Math.random() * blessings.length)];
      const result = blessing.apply();
      if (result) {
        showCanvasToast(result, 'success');
        playSFX('start');
      }
    }

    function executeCurse() {
      const curses = [
        {
          id: 'freeze_tower',
          apply: () => {
            if (towers.length === 0) return false;
            const t = towers[Math.floor(Math.random() * towers.length)];
            t.buffs.freeze = 300;
            createExplosion(t.x, t.y, '#C084FC', 30);
            return '¡Puesto paralizado por la Plaga!';
          },
        },
        {
          id: 'citadel_shiver',
          apply: () => {
            health = Math.max(1, health - 10);
            updateHUD();
            createExplosion(canvas.width / 2, canvas.height / 2, '#8B5CF6', 20);
            return '¡Temblor en la Ciudadela! -10 Salud.';
          },
        },
        {
          id: 'weaken_towers',
          apply: () => {
            if (towers.length === 0) return false;
            towers.forEach((t) => {
              t.buffs.weakened = 300; // Reduced from 600 (5 seconds)
            });
            createExplosion(canvas.width / 2, 100, '#8B5CF6', 25);
            return '¡Puestos debilitados temporalmente por el Vacío!';
          },
        },
        {
          id: 'enemy_buff',
          apply: () => {
            enemies.forEach((e) => {
              e.speed *= 1.3;
              e.hp += 20;
            });
            createExplosion(canvas.width / 2, canvas.height / 2, '#7C3AED', 30);
            return '¡Furia de la Plaga! Enemigos reforzados.';
          },
        },
        {
          id: 'slow_fire',
          apply: () => {
            if (towers.length === 0) return false;
            towers.forEach((t) => {
              t.buffs.weakened = 240; // Reduced from 480 (4 seconds)
              // Repurposing weakened for slow fire too if I don't want too many timers
              // Or add a dedicated fireRate debuff if needed.
            });
            createExplosion(canvas.width / 2, 100, '#6D28D9', 20);
            return '¡Maldición de Lentitud temporal en los Colmillos!';
          },
        },
        {
          id: 'dark_fog',
          apply: () => {
            if (towers.length === 0) return false;
            towers.forEach((t) => {
              t.buffs.blinded = 300; // Reduced from 600 (5 seconds)
            });
            createExplosion(canvas.width / 2, canvas.height / 2, '#4A1D96', 40);
            return '¡Niebla Abisal! Rango de visión reducido temporalmente.';
          },
        },
        {
          id: 'rust',
          apply: () => {
            if (towers.length === 0) return false;
            const t = towers[Math.floor(Math.random() * towers.length)];
            t.buffs.rusted = 300; // Reduced from 600 (5 seconds)
            createExplosion(t.x, t.y, '#7C2D12', 15);
            return '¡Oxidación Temporal! El daño del puesto se reduce.';
          },
        },
      ];

      const curse = curses[Math.floor(Math.random() * curses.length)];
      const result = curse.apply();
      if (result) {
        showCurseNotification(result);
        addScreenShake(8);
        playSFX('error');
      }
    }

    function executeMeteorStrike() {
      if (towers.length === 0) {
        health -= 20;
        updateHUD();
        createExplosion(canvas.width / 2, canvas.height / 2, '#EF4444', 50);
        showCanvasToast('¡Impacto en la Ciudadela! (-20 HP)', 'error');
        addScreenShake(20);
        if (health <= 0) gameOver();
        return;
      }

      // Damage random tower instead of destroying it instantly
      const targetIndex = Math.floor(Math.random() * towers.length);
      const t = towers[targetIndex];
      const damage = t.maxHp * 0.6; // 60% of max HP
      
      createExplosion(t.x, t.y, '#EF4444', 40); 
      addFloatingText(t.x, t.y - 30, `-${Math.round(damage)} ¡IMPACTO!`, '#EF4444', 'large');
      
      applyDamageToTower(t, damage);
      
      updateHUD();
      addScreenShake(15);
      playSFX('explosion');
    }

    function executeBonusDrop() {
      const dropCount = Math.floor(Math.random() * 3) + 2; 
      const types = ['abyssal_rune', 'upgrades', 'heal', 'freeze', 'frenzy', 'nuke']; 

      for (let i = 0; i < dropCount; i++) {
        const type = types[Math.floor(Math.random() * types.length)];
        bonuses.push({
          x: Math.random() * (canvas.width - 250) + 125, // Centered horizontally
          y: Math.random() * (canvas.height - 150) + 75, // Centered vertically, avoid HUD
          vx: (Math.random() - 0.5) * (1 + wave * 0.2), 
          vy: (Math.random() - 0.5) * (1 + wave * 0.2),
          life: 300, 
          type: type,
          reward:
            type === 'upgrades' || type === 'abyssal_rune'
              ? Math.floor((Math.random() * 100 + 50) * 0.85)
              : 0,
        });
      }
      showCanvasToast('¡Recupera el botín antes de que desaparezca!', 'info');
    }

    function applyDamageToEnemy(e, damage, color, sourceTower = null) {
      e.noDamageTimer = 0; // Reset sprint timer
      if (e.shield && e.shield > 0) {
        const shieldDamage = Math.min(e.shield, damage);
        e.shield -= shieldDamage;
        damage -= shieldDamage;
        addFloatingText(e.x, e.y - 15, `-${Math.round(shieldDamage)} (Escudo)`, '#60A5FA');
        createExplosion(e.x, e.y, '#60A5FA', 3);
        if (e.shield <= 0) {
          e.color = e.originalColor || e.color;
          addFloatingText(e.x, e.y - 25, 'Escudo Roto', '#9CA3AF');
        }
      }

      if (damage > 0) {
        e.hp -= damage;
        addFloatingText(e.x, e.y - 10, `-${Math.round(damage)}`, color || '#FCD34D');
      }

      if (e.hp <= 0) {
        const index = enemies.indexOf(e);
        if (index > -1) {
          if (inspectedEnemy === e) inspectedEnemy = null;
          abyssals += e.reward;
          addKillCombo();
          
          // Bloodlust Mechanic
          globalBloodlust++;
          if (globalBloodlust >= BLOODLUST_THRESHOLD) {
            globalBloodlust = 0;
            bloodlustTimer = 300; // 5 seconds of bloodlust
            showCanvasToast('¡FRENESÍ DE SANGRE ACTIVADO!', 'success');
            playSFX('start');
            addScreenShake(15);
          }

          // Veterancy System: 1 Killing Blow = 1 Star
          if (sourceTower) {
            sourceTower.kills = (sourceTower.kills || 0) + 1;
            sourceTower.veterancy = (sourceTower.veterancy || 1) + 1;
            sourceTower.damage *= 1.02; // 2% bonus per star (kill) - Reduced from 5%

            // Auto Level Up at 9 Stars (Triggered on 10th kill) - Increased from 5
            if (sourceTower.veterancy > 10) {
              sourceTower.veterancy = 1;
              sourceTower.level = (sourceTower.level || 1) + 1;
              sourceTower.damage *= 1.1; // 10% bonus per level - Reduced from 20%
              sourceTower.maxHp += 50;
              // Evolution recovers 25% of health
              const recovery = sourceTower.maxHp * 0.25;
              sourceTower.hp = Math.min(sourceTower.maxHp, sourceTower.hp + recovery);
              
              addFloatingText(sourceTower.x, sourceTower.y - 20, '¡EVOLUCIÓN!', '#F59E0B', 'buff');
              createExplosion(sourceTower.x, sourceTower.y, '#F59E0B', 12);
            } else {
              addFloatingText(sourceTower.x, sourceTower.y - 20, '+1 ⭐', '#FCD34D', 'normal');
              createExplosion(sourceTower.x, sourceTower.y, '#FCD34D', 6);
            }
          }

          // Random rune drop on enemy death (10% chance for normal, 100% for boss)
          if (e.isBoss || Math.random() > 0.9) {
            const types = ['abyssal_rune', 'heal', 'freeze', 'frenzy', 'nuke'];
            const type = types[Math.floor(Math.random() * types.length)];
            bonuses.push({
              x: e.x,
              y: e.y,
              vx: (Math.random() - 0.5) * 2,
              vy: (Math.random() - 0.5) * 2,
              life: 300,
              type: type,
              reward: type === 'abyssal_rune' ? Math.floor((Math.random() * 50 + 20) * 0.85) : 0,
            });
          }

          if (e.isBoss) addScreenShake(12);
          enemies.splice(index, 1);
          updateHUD();
          createExplosion(e.x, e.y, e.color, 8);

          if (isCityFallen && enemies.length === 0) {
            gameOver();
          }
        }
      }
    }

    function addFloatingText(x, y, text, color = '#FFFFFF', type = 'normal') {
      if (floatingTexts.length > 40) floatingTexts.shift(); // Performance limit
      floatingTexts.push({ x, y, text, color, life: 60, vy: -1, type });
    }

    function addScreenShake(intensity = 10) {
      screenShake = Math.max(screenShake, intensity);
    }

    // --- RENDER & LOGIC ---
    let lastTime = 0;
    function gameLoop(timestamp) {
      lastTime = timestamp;

      if (gameState === 'playing' && !isPaused) {
        update();
        if (isTurbo) update(); // Double update for Turbo mode
      }
      draw();
      requestAnimationFrame(gameLoop);
    }

    function showCurseNotification(msg) {
      curseNotification = { msg, life: 240 }; // 4 segundos
    }

    function update() {
      // Passive upgrades generation + limit drain
      if (
        gameState === 'playing' &&
        wave > 0 &&
        !isPaused &&
        (enemies.length > 0 || enemiesLeftToSpawn > 0)
      ) {
        // Random Event Chance (During wave - Increased Frequency)
        if (Math.random() < 0.003) { // Tripled frequency (~every 5-7 seconds)
           triggerRandomEvent();
        }

        passiveUpgradesTimer++;
        if (passiveUpgradesTimer >= 60) {
          passiveUpgradesTimer = 0;
          
          // Passive generation (Increased by 250% from base tension)
          // Táctica (0.36 * 3.5 = 1.26)
          if (upgrades < 400) { 
            upgrades += 1.26; 
          } else if (upgrades >= 450) {
            upgrades -= 2;
          }

          // Acero (0.16 * 3.5 = 0.56)
          abyssals += 0.56; 

          if (abyssals >= 500) {
            abyssals -= 5;
          }
          updateHUD();
        }
      }

      // Check Game Over by starvation (No towers + No money to buy any tower)
      if (
        towers.length === 0 &&
        abyssals < TOWER_STATS.basic.cost &&
        wave > 0 &&
        gameState === 'playing' &&
        !isCityFallen
      ) {
        health = 0;
        isCityFallen = true;
        showCanvasToast('¡RECURSOS AGOTADOS! La Ciudadela ha quedado indefensa.', 'error');
        addScreenShake(30);
        playSFX('error');
      }

      // Dark Rune Spawner
      if (wave > 0 && enemies.length > 0 && !isPaused) {
        darkRuneTimer++;
        if (darkRuneTimer >= 480) {
          // Every ~8 seconds
          darkRuneTimer = 0;
          if (path.length > 3) {
            // Pick a node closer to the start (between 2nd and 4th node)
            const maxNode = Math.min(path.length - 1, 4);
            const node = path[Math.floor(Math.random() * (maxNode - 1)) + 1];

            const types = ['power', 'shield', 'haste', 'heal'];
            const type = types[Math.floor(Math.random() * types.length)];

            darkRunes.push({ x: node.x, y: node.y, life: 1200, type }); // 20 seconds life
            showCanvasToast(`¡Marca de la Plaga (${type}) detectada!`, 'error');
            playSFX('error');
          }
        }
      }

      // Update dark runes
      for (let i = darkRunes.length - 1; i >= 0; i--) {
        let r = darkRunes[i];
        if (enemies.length > 0 && !isEventActive) r.life--;
        if (r.life <= 0) darkRunes.splice(i, 1);
      }

      // Move enemies
      for (let i = enemies.length - 1; i >= 0; i--) {
        let e = enemies[i];

        // Check Clone Expiration
        if (e.isClone && e.lifeTimer > 0) {
          e.lifeTimer--;
          if (e.lifeTimer <= 0) {
            createExplosion(e.x, e.y, e.color, 10);
            addFloatingText(e.x, e.y - 20, 'Desvanecido', '#9CA3AF');
            enemies.splice(i, 1);
            continue;
          }
        }

        // Check Dark Power expiration
        if (e.darkPowerTimer > 0) {
          e.darkPowerTimer--;
          if (e.darkPowerTimer <= 0) {
            e.attackRange /= 2;
            e.cooldownMultiplier = 1;
            e.speed *= 2;
            e.color = e.originalColor || e.color;
            addFloatingText(e.x, e.y - 25, 'Poder Desvanecido', '#9CA3AF');
          }
        }

        // Check Haste expiration
        if (e.hasteTimer > 0) {
          e.hasteTimer--;
          if (e.hasteTimer <= 0) {
            e.speed /= 2;
            e.color = e.originalColor || e.color;
            addFloatingText(e.x, e.y - 25, 'Celeridad Desvanecida', '#9CA3AF');
          }
        }

        // Last Enemy Frenzy
        if (enemies.length === 1 && enemiesLeftToSpawn <= 0 && !e.hasFrenzy) {
          e.hasFrenzy = true;
          e.speed *= 2.5;
          e.damage *= 1.5;
          e.color = '#F43F5E';
          addFloatingText(e.x, e.y - 20, '¡ÚLTIMO ALIENTO!', '#F43F5E', 'buff');
          showCanvasToast('¡El último enemigo saltó en furia!', 'error');
          addScreenShake(15);
          playSFX('error');
        }
        let target = path[e.pathIndex + 1];

        if (!target) {
          // Reached end
          if (!isCityFallen) {
            health -= 10;
            if (health <= 0) {
              isCityFallen = true;
              health = 0;
              showCanvasToast('¡La Ciudadela ha sido destruida!', 'error');
              addScreenShake(30);
              playSFX('error');
            } else {
              upgrades = Math.max(0, upgrades - 1); 
              showCanvasToast('¡Enemigo escapó! -10 HP, -1t', 'error');
              addScreenShake(10); 
              playSFX('error');
            }
          }

          if (isCityFallen) {
            // Drain tactics for every enemy that arrives after falling
            upgrades = Math.max(0, upgrades - 20);
            addFloatingText(e.x, e.y - 20, '-20t', '#EF4444');
          }

          if (inspectedEnemy === e) inspectedEnemy = null;
          enemies.splice(i, 1);
          updateHUD();
          createExplosion(e.x, e.y, '#EF4444');

          // Check if it's game over time (city fallen AND no more enemies)
          if (isCityFallen && enemies.length === 0) {
            gameOver();
          }

          continue;
        }

        // Check collision with darkRunes
        for (let j = darkRunes.length - 1; j >= 0; j--) {
          const r = darkRunes[j];
          if (Math.hypot(e.x - r.x, e.y - r.y) < 30) {
            darkRunes.splice(j, 1);
            if (!e.originalColor) e.originalColor = e.color;
            createExplosion(e.x, e.y, '#D946EF', 20);

            if (r.type === 'shield') {
              e.shield = (e.shield || 0) + e.maxHp * 0.5; // 50% max HP shield
              e.color = '#60A5FA'; // Blue shield
              addFloatingText(e.x, e.y - 25, '🛡️ Escudo', '#60A5FA', 'buff');
            } else if (r.type === 'haste') {
              if (e.hasteTimer > 0) e.speed /= 2; // Reset current haste speed before re-applying
              e.hasteTimer = 600; // 10 seconds
              e.speed *= 2;
              e.color = '#FCD34D'; // Yellow haste
              addFloatingText(e.x, e.y - 25, '⚡ Celeridad', '#FCD34D', 'buff');
            } else if (r.type === 'heal') {
              e.hp = Math.min(e.maxHp, e.hp + e.maxHp * 0.4); // 40% heal
              // Area heal for nearby enemies
              enemies.forEach((other) => {
                if (Math.hypot(e.x - other.x, e.y - other.y) < 100) {
                  other.hp = Math.min(other.maxHp, other.hp + other.maxHp * 0.2);
                  addFloatingText(other.x, other.y - 15, '+❤️', '#10B981');
                }
              });
              e.color = '#10B981'; // Green heal
              addFloatingText(e.x, e.y - 25, '💚 Sanación', '#10B981', 'buff');
            } else {
              // Default: 'power'
              if (e.darkPowerTimer > 0) {
                e.attackRange /= 2;
                e.speed *= 2;
              }
              e.darkPowerTimer = 600; // 10 seconds duration
              e.attackRange *= 2;
              e.cooldownMultiplier = 0.5;
              e.speed *= 0.5;
              e.color = '#D946EF';
              addFloatingText(e.x, e.y - 25, '¡Poder Oscuro!', '#D946EF', 'debuff');
            }
          }
        }

        // Necromancer Ability: Spawn Skeletons
        // Necromancer Ability: Spawn skeletons
        if (e.isNecromancer && !isPaused) {
          e.spawnTimer = (e.spawnTimer || 0) + 1;
          if (e.spawnTimer >= 240) {
            // Every 4 seconds
            e.spawnTimer = 0;
            const currentEnemyLevel = wave <= 7 ? 1 : wave - 6;
            const skeleton = {
              id: 'zombie', // Use zombie sprite for skeletons
              x: e.x,
              y: e.y,
              hp: (20 + currentEnemyLevel * 5) * 5, // Scaled with current level balance
              maxHp: (20 + currentEnemyLevel * 5) * 5,
              speed: 1.5,
              pathIndex: e.pathIndex,
              color: '#F9FAFB', // White/Bone
              isBoss: false,
              reward: 0,
              level: currentEnemyLevel,
              attackRange: 150,
              basicCooldown: 60,
              maxBasicCooldown: 60,
              basicDamage: 5 + Math.floor(currentEnemyLevel * 0.5),
              damage: 5 + Math.floor(currentEnemyLevel * 0.5),
              attackType: 'normal',
              lifeTimer: 300, // 5 seconds at 60fps
              isClone: true, // Reuse the vanishing logic
              noDamageTimer: 0,
              isCasting: 0,
            };
            enemies.push(skeleton);
            
            // Focus redirection: Towers lose focus on the Warlock
            projectiles.forEach(p => {
              if (p.target === e) {
                p.target = skeleton;
              }
            });

            // Move Warlock to end of array so towers pick skeleton first next frame
            const idx = enemies.indexOf(e);
            if (idx > -1) {
              enemies.splice(idx, 1);
              enemies.push(e);
            }

            createExplosion(e.x, e.y, '#F9FAFB', 6);
            addFloatingText(e.x, e.y, '¡Levántate!', '#F9FAFB', 'buff');
          }
        }

        // Berserker Ability: Rage speed
        if (e.isBerserker) {
          const currentEnemyLevel = wave <= 7 ? 1 : wave - 6;
          const healthRatio = e.hp / e.maxHp;
          const baseSpeed = (1.5 + currentEnemyLevel * 0.05);
          e.speed = baseSpeed * (1.5 - healthRatio * 0.5); // Faster when low hp
          if (e.slowTimer > 0) e.speed *= 0.5; // Apply slow even to berserkers
        }

        // --- STATUS TIMERS ---
        if (e.slowTimer > 0) {
          e.slowTimer--;
          if (e.slowTimer <= 0) {
            e.speed = e.originalSpeed || e.speed;
            e.originalSpeed = null;
          }
        }

        if (e.dotTimer > 0) {
          e.dotTimer--;
          if (e.dotTimer % 30 === 0) { // Tick every 0.5s
            applyDamageToEnemy(e, e.dotDamage || 5, '#F97316');
          }
        }

        // Ghost Ability: Translucency
        if (e.isGhost) {
          e.ghostAlpha = (e.ghostAlpha || 0.5) + Math.sin(Date.now() / 200) * 0.05;
        }

        // --- TARGETING (Nearest Tower) ---
        const rangeSq = e.attackRange * e.attackRange;
        let targetTower = null;
        let minDistanceSq = Infinity;

        towers.forEach(t => {
          const tdx = e.x - t.x;
          const gh = t.gridHeight || 1;
          const targetY = t.y + ((gh - 1) * GRID_SIZE) / 2;
          const tdy = e.y - targetY;
          const distSq = tdx * tdx + tdy * tdy;

          if (distSq <= rangeSq && distSq < minDistanceSq) {
            minDistanceSq = distSq;
            targetTower = t;
          }
        });

        // --- SPRINT & MOVEMENT ---
        e.noDamageTimer = (e.noDamageTimer || 0) + 1;
        
        if (e.isCasting <= 0) {
          // NOT CASTING: Can move (even if attacking slowly)
          const dx = target.x - e.x;
          const dy = target.y - e.y;
          const dist = Math.hypot(dx, dy);
          
          let moveSpeed = e.speed;
          
          if (targetTower) {
            // IN COMBAT: Advance much slower (25% speed) to stay in range of more towers
            moveSpeed *= 0.25;
            e.noDamageTimer = 0;
            e.hasSprinted = false; // Reset sprint flag
          } else if (e.noDamageTimer > 180) { // 3s
            // SPRINT: 40% faster when not receiving damage for 3 seconds
            moveSpeed *= 1.4;
            if (!e.hasSprinted) {
              e.hasSprinted = true;
              const quotes = SPRINT_QUOTES[e.id] || ['¡A por ellos!', '¡Rápido!', '¡No paréis!'];
              const quote = quotes[Math.floor(Math.random() * quotes.length)];
              addFloatingText(e.x, e.y - 30, quote, '#FCD34D', 'large');
              playSFX('start');
            }
            if (e.noDamageTimer % 20 === 0) {
              createExplosion(e.x, e.y, '#FCD34D', 2);
            }
          }

          if (dist < moveSpeed) {
            e.x = target.x;
            e.y = target.y;
            e.pathIndex++;
          } else {
            e.x += (dx / dist) * moveSpeed;
            e.y += (dy / dist) * moveSpeed;
          }
        }

        // Enemy attacks towers
        if (e.cooldown > 0 && !isPaused) e.cooldown--;
        if (e.basicCooldown > 0 && !isPaused) e.basicCooldown--;
        
        // --- CASTING LOGIC (Special Attack) ---
        if (e.isCasting > 0) {
          e.isCasting--;
          if (e.isCasting <= 0) {
            // FINISH CASTING: Special Ability!
            if (e.attackType === 'clones') {
              // Shadow Clones: Spawn 2 smaller ghosts that last 3 seconds
              const spawnedClones = [];
              for (let j = 0; j < 2; j++) {
                const clone = {
                  ...e,
                  isCasting: 0,
                  cooldown: 180,
                  basicCooldown: 60,
                  hp: e.hp/5,
                  maxHp: e.hp/5,
                  isBoss: false,
                  reward: 0,
                  lifeTimer: 180, 
                  isClone: true,
                  x: e.x + (Math.random() - 0.5) * 40,
                  y: e.y + (Math.random() - 0.5) * 40,
                  noDamageTimer: 0,
                };
                enemies.push(clone);
                spawnedClones.push(clone);
              }

              projectiles.forEach(p => {
                if (p.target === e && spawnedClones.length > 0) {
                  p.target = spawnedClones[Math.floor(Math.random() * spawnedClones.length)];
                }
              });

              const idx = enemies.indexOf(e);
              if (idx > -1) {
                enemies.splice(idx, 1);
                enemies.push(e);
              }

              addFloatingText(e.x, e.y - 30, '¡CLONES DE SOMBRA!', '#D946EF', 'large');
              playSFX('ghost');
            } else {
              // Projectile Special Attacks
              enemyProjectiles.push({
                x: e.x,
                y: e.y,
                target: e.castTarget,
                targetY: e.castTargetY,
                speed: e.attackType === 'axe' ? 7 : 4,
                damage: e.damage * 2.5, // Special deals more damage
                color: e.color,
                attackType: e.attackType,
              });
              if (e.attackType === 'inferno') playSFX('explosion');
              else if (e.attackType === 'plague') playSFX('hit_shield');
              else playSFX('shoot');
            }
            e.cooldown = e.maxCooldown || 360;
            e.castTarget = null;
          }
          continue; 
        }

        // Logic for basic and starting special attacks
        if (targetTower) {
          const gh = targetTower.gridHeight || 1;
          const targetY = targetTower.y + ((gh - 1) * GRID_SIZE) / 2;

          // Check for Special Attack first
          if (e.cooldown <= 0) {
            const baseType = ENEMY_TYPES.find(t => t.id === e.id);
            e.isCasting = baseType ? baseType.castTime : 180;
            e.maxCooldown = baseType ? baseType.cooldown : 360;
            e.castTarget = targetTower;
            e.castTargetY = targetY;
            
            // Show custom quote if available
            if (baseType && baseType.quote) {
              addFloatingText(e.x, e.y - 35, baseType.quote, e.color, 'large');
            } else {
              addFloatingText(e.x, e.y - 20, '¡CANALIZANDO!', e.color, 'normal');
            }
            continue; 
          }
          
          // Basic Attack while not casting and on basic cooldown
          if (e.basicCooldown <= 0) {
            enemyProjectiles.push({
              x: e.x,
              y: e.y,
              target: targetTower,
              targetY: targetY,
              speed: 5,
              damage: e.basicDamage || 10,
              color: e.color,
              attackType: 'normal',
            });
            e.basicCooldown = e.maxBasicCooldown || 60;
            playSFX('shoot');
          }
        }
      }

      // Update Bloodlust timer
      if (bloodlustTimer > 0) bloodlustTimer--;

      // Towers shoot
      towers.forEach((t) => {
        if (t.buffs.freeze > 0) {
          t.buffs.freeze--;
          return; // Frozen towers can't shoot
        }

        if (t.buffs.doubleShot > 0) {
          t.buffs.doubleShot--;
        }

        if (t.buffs.steelShield > 0) {
          t.buffs.steelShield--;
        }

        if (t.buffs.weakened > 0) t.buffs.weakened--;
        if (t.buffs.blinded > 0) t.buffs.blinded--;
        if (t.buffs.rusted > 0) t.buffs.rusted--;

        if (t.cooldown > 0) t.cooldown--;
        else {
          const gh = t.gridHeight || 1;
          const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;

          // Target calculations
          let effectiveRange = t.range;
          if (t.buffs.blinded > 0) effectiveRange *= 0.6;
          const rangeSq = effectiveRange * effectiveRange;

          // Find target based on role
          let target = null;
          if (t.isHealer) {
            // RESTRICTION: Healers only work during active waves
            if (enemies.length === 0) return;

            // Find most damaged nearby tower
            let minHpRatio = 1;
            towers.forEach(other => {
              if (other === t) return;
              const dx = other.x - t.x;
              const ghOther = other.gridHeight || 1;
              const vyOther = other.y + ((ghOther - 1) * GRID_SIZE) / 2;
              const dy = vyOther - visualY;
              if (dx * dx + dy * dy <= rangeSq) {
                const ratio = other.hp / other.maxHp;
                if (ratio < 1 && ratio < minHpRatio) {
                  minHpRatio = ratio;
                  target = other;
                }
              }
            });
          } else {
            // Find nearest enemy
            let minDistanceSq = Infinity;
            enemies.forEach((e) => {
              if (Math.abs(e.x - t.x) > effectiveRange) return;
              if (Math.abs(e.y - visualY) > effectiveRange) return;
              const dx = e.x - t.x;
              const dy = e.y - visualY;
              const distSq = dx * dx + dy * dy;
              if (distSq <= rangeSq && distSq < minDistanceSq) {
                minDistanceSq = distSq;
                target = e;
              }
            });
          }

          if (target) {
            const isCrit = Math.random() < (t.critChance || 0.1);
            let finalValue = isCrit ? t.damage * 2 : t.damage;
            
            // Apply Debuffs only if not healing (or maybe they affect heal too?)
            if (!t.isHealer) {
              if (t.buffs.weakened > 0) finalValue *= 0.6;
              if (t.buffs.rusted > 0) finalValue *= 0.4;
            }
            
            if (isCrit) {
              const quote = t.quotes[Math.floor(Math.random() * t.quotes.length)];
              addFloatingText(t.x, visualY - 30, quote, t.color, 'normal');
              addScreenShake(3);
              playSFX('hit_shield');
            }

            // --- SPECIAL ABILITY LOGIC ---
            const stats = TOWER_STATS[t.type];
            if (stats.specialThreshold) {
              t.shotsFired = (t.shotsFired || 0) + 1;

              if (inspectedTower === t) {
                const percent = Math.min(100, (t.shotsFired / stats.specialThreshold) * 100);
                const vetBar = document.getElementById('inspect-vet-bar');
                if (vetBar) {
                  vetBar.style.width = `${percent}%`;
                  vetBar.className = percent >= 100 ? 'h-full bg-amber-400 animate-pulse' : 'h-full bg-amber-500';
                }
              }

              if (t.shotsFired >= stats.specialThreshold) {
                t.shotsFired = 0;
                addFloatingText(t.x, visualY - 40, stats.specialQuote, t.color, 'large');
                createExplosion(t.x, visualY, t.color, 25);
                playSFX('start');
                
                if (t.type === 'basic') {
                  t.buffs.doubleShot = 180;
                } else if (t.type === 'sniper') {
                  applyDamageToEnemy(target, t.damage * 4, '#FCD34D', t);
                  addScreenShake(6);
                } else if (t.type === 'splash') {
                  for (let i = 0; i < 3; i++) {
                    const ox = (Math.random() - 0.5) * 80;
                    const oy = (Math.random() - 0.5) * 80;
                    setTimeout(() => {
                      createExplosion(target.x + ox, target.y + oy, '#EF4444', 20);
                      enemies.forEach(en => {
                        if (Math.hypot(en.x - (target.x + ox), en.y - (target.y + oy)) < 80) {
                          applyDamageToEnemy(en, t.damage * 0.8, '#EF4444', t);
                        }
                      });
                    }, i * 100);
                  }
                } else if (t.type === 'nova') {
                  // Special Healer: Mass Restore
                  towers.forEach(other => {
                    const dx = other.x - t.x;
                    const dy = other.y - visualY;
                    if (dx * dx + dy * dy <= t.range * t.range * 4) { // double area for special
                      const heal = other.maxHp * 0.25;
                      other.hp = Math.min(other.maxHp, other.hp + heal);
                      addFloatingText(other.x, other.y, `+${Math.round(heal)}`, '#10B981');
                      createExplosion(other.x, other.y, '#10B981', 10);
                    }
                  });
                }
              }
            }

            if (t.isHealer) {
              // Healer logic: Heal target immediately
              target.hp = Math.min(target.maxHp, target.hp + finalValue);
              addFloatingText(target.x, target.y, `+${Math.round(finalValue)}`, t.color);
              createExplosion(target.x, target.y, t.color, 5);
              playSFX('blessing');
            } else {
              const shoot = (targetObj, damageMod = 1) => {
                projectiles.push({
                  x: t.x,
                  y: visualY,
                  target: targetObj,
                  speed: t.isNova ? 15 : 8,
                  damage: finalValue * damageMod,
                  color: t.color,
                  splash: t.splash,
                  splashRadius: t.splashRadius,
                  isNova: t.isNova,
                  isSlow: t.isSlow,
                  slowDuration: t.slowDuration,
                  isDoT: t.isDoT,
                  dotDuration: t.dotDuration,
                  sourceTower: t, 
                  isCrit: isCrit,
                });
              };

              shoot(target);

              if (t.buffs.steelShield > 0) {
                const rangeSq = t.range * t.range;
                const secondaryTarget = enemies.find(e => {
                  if (e === target) return false;
                  const dx = e.x - t.x;
                  const dy = e.y - visualY;
                  return dx * dx + dy * dy <= rangeSq;
                });
                if (secondaryTarget) shoot(secondaryTarget, 0.7);
              }
              playSFX('shoot');
            }

            let fireRateBonus = 1;
            if (t.buffs.doubleShot > 0) fireRateBonus *= 0.5;
            if (bloodlustTimer > 0) fireRateBonus *= 0.5;
            
            t.cooldown = Math.floor(t.fireRate * fireRateBonus);
          }
        }
      });

      // Move projectiles
      for (let i = projectiles.length - 1; i >= 0; i--) {
        let p = projectiles[i];
        if (!enemies.includes(p.target)) {
          projectiles.splice(i, 1);
          continue;
        }

        const dx = p.target.x - p.x;
        const dy = p.target.y - p.y;
        const dist = Math.hypot(dx, dy);

        if (dist < p.speed) {
          // Hit
          if (p.splash) {
            createExplosion(p.target.x, p.target.y, p.color, 3);
            if (p.isNova) playSFX('hit_shield');
            else playSFX('hit');

            // Damage all enemies in radius using fast squared distance
            const sqSplash = p.splashRadius * p.splashRadius;
            const tx = p.target.x;
            const ty = p.target.y;
            
            for (let j = enemies.length - 1; j >= 0; j--) {
              let e2 = enemies[j];
              const dx2 = e2.x - tx;
              const dy2 = e2.y - ty;
              if (dx2 * dx2 + dy2 * dy2 <= sqSplash) {
                // Ghost Damage Mitigation: 50% chance to miss
                if (e2.isGhost && Math.random() > 0.5) {
                  addFloatingText(e2.x, e2.y - 10, '¡Evasión!', '#94A3B8', 'normal');
                } else {
                  applyDamageToEnemy(e2, p.damage, '#EF4444', p.sourceTower);
                  
                  // Apply Slow Effect
                  if (p.isSlow) {
                    if (!e2.originalSpeed) e2.originalSpeed = e2.speed;
                    e2.speed = e2.originalSpeed * 0.5;
                    e2.slowTimer = p.slowDuration;
                    addFloatingText(e2.x, e2.y - 20, '❄️', '#60A5FA');
                  }
                  
                  // Apply DoT Effect
                  if (p.isDoT) {
                    e2.dotTimer = p.dotDuration;
                    e2.dotDamage = p.damage * 0.2; // 20% damage per tick
                    addFloatingText(e2.x, e2.y - 25, '🔥', '#F97316');
                  }
                }
              }
            }
          } else {
            // Ghost Damage Mitigation: 50% chance to miss
            if (p.target.isGhost && Math.random() > 0.5) {
              addFloatingText(p.target.x, p.target.y - 10, '¡Evasión!', '#94A3B8', 'normal');
            } else {
              applyDamageToEnemy(p.target, p.damage, '#FCD34D', p.sourceTower);
            }
            createExplosion(p.target.x, p.target.y, p.color, 1);
            playSFX('hit');
          }
          projectiles.splice(i, 1);
        } else {
          p.x += (dx / dist) * p.speed;
          p.y += (dy / dist) * p.speed;
        }
      }

      // Move enemy projectiles
      for (let i = enemyProjectiles.length - 1; i >= 0; i--) {
        let p = enemyProjectiles[i];
        if (!towers.includes(p.target)) {
          enemyProjectiles.splice(i, 1);
          continue;
        }

        const dx = p.target.x - p.x;
        const dy = p.targetY - p.y;
        const dist = Math.hypot(dx, dy);

        if (dist < p.speed) {
          // Impact on tower visual center
          applyDamageToTower(p.target, p.damage);
          addFloatingText(p.target.x, p.targetY - 15, `-${Math.round(p.damage)}`, '#EF4444');
          createExplosion(p.target.x, p.targetY, p.color, 2);
          playSFX('hit');

          // Apply effects based on attack type
          if (p.attackType === 'ice') {
            p.target.buffs.freeze = Math.max(p.target.buffs.freeze, 90); // Freeze tower for 1.5s
            addFloatingText(p.target.x, p.targetY - 25, '❄️', '#60A5FA');
          } else if (p.attackType === 'plague') {
            // Plague Spit: Area DoT balanceado
            const plagueRadius = 80;
            const plagueDmg = p.damage * 0.5; // Damage spread across area
            
            towers.forEach(t => {
              const tgh = t.gridHeight || 1;
              const ty = t.y + ((tgh - 1) * GRID_SIZE) / 2;
              const dx = t.x - p.x;
              const dy = ty - p.targetY;
              const distSq = dx * dx + dy * dy;
              
              if (distSq <= plagueRadius * plagueRadius) {
                applyDamageToTower(t, plagueDmg);
                createExplosion(t.x, ty, '#10B981', 1);
                addFloatingText(t.x, ty - 25, '☠️ PESTE', '#10B981');
              }
            });
            createExplosion(p.x, p.targetY, '#10B981', 8); // Visual area effect
          } else if (p.attackType === 'inferno') {
            // Infernal Impact: Huge area burst around tower
            applyDamageToTower(p.target, p.damage * 1.5); 
            createExplosion(p.target.x, p.targetY, '#EF4444', 6);
            addScreenShake(5);
            addFloatingText(p.target.x, p.targetY - 30, '🔥 IMPACTO INFERNAL', '#F59E0B');
          } else if (p.attackType === 'axe') {
            // Axe Throw: Pure physical burst
            applyDamageToTower(p.target, p.damage * 0.4);
            createExplosion(p.target.x, p.targetY, '#D1D5DB', 1);
            addFloatingText(p.target.x, p.targetY - 20, '🪓', '#D1D5DB');
          }

          enemyProjectiles.splice(i, 1);
        } else {
          p.x += (dx / dist) * p.speed;
          p.y += (dy / dist) * p.speed;
        }
      }

      // Update combo timer
      if (comboTimer > 0) {
        comboTimer--;
        if (comboTimer <= 0) currentCombo = 0; // Reset combo
      }

      if (killComboTimer > 0) {
        killComboTimer--;
        if (killComboTimer <= 0) currentKillCombo = 0;
      }

      if (globalFreezeTimer > 0) globalFreezeTimer--;
      if (globalFrenzyTimer > 0) globalFrenzyTimer--;

      // Update particles
      for (let i = particles.length - 1; i >= 0; i--) {
        let p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.rotationSpeed;
        p.life -= p.decay;
        if (p.life <= 0) {
          particlePool.push(p); // Return to pool
          particles.splice(i, 1);
        }
      }

      // Update bonuses
      for (let i = bonuses.length - 1; i >= 0; i--) {
        let b = bonuses[i];

        // Ethereal movement
        b.x += b.vx;
        b.y += b.vy;

        // Add some slight wobble
        b.vx += (Math.random() - 0.5) * 0.5;
        b.vy += (Math.random() - 0.5) * 0.5;

        // Constraint within playable area (Avoid HUD at bottom and selection panels)
        const minX = 100;
        const maxX = canvas.width - 100;
        const minY = 50;
        const maxY = canvas.height - 100; // Leave space for HUD

        if (b.x < minX) { b.x = minX; b.vx *= -1; }
        if (b.x > maxX) { b.x = maxX; b.vx *= -1; }
        if (b.y < minY) { b.y = minY; b.vy *= -1; }
        if (b.y > maxY) { b.y = maxY; b.vy *= -1; }

        // Speed limit
        const maxSpeed = 2 + wave * 0.3;
        if (Math.abs(b.vx) > maxSpeed) b.vx = Math.sign(b.vx) * maxSpeed;
        if (Math.abs(b.vy) > maxSpeed) b.vy = Math.sign(b.vy) * maxSpeed;

        // Only decay life if we are actively playing and a wave is ongoing
        if (enemies.length > 0 && !isEventActive) {
          b.life--;
        }

        if (b.life <= 0) bonuses.splice(i, 1);
      }
      // Maldiciones aleatorias durante el juego
      if (wave > 0 && enemies.length > 0) {
        curseTimer++;
        if (curseTimer >= curseCooldown) {
          curseTimer = 0;
          curseCooldown = Math.floor(Math.random() * 300) + 400;
          executeCurse();
        }
      }
    }

    function createExplosion(x, y, color, count = 6) {
      // Reduced default particle count
      const runes = ['᚛', '᚜', 'ᚠ', 'ᚢ', 'ᚦ', 'ᚨ', 'ᚩ'];

      // Calculate how many particles we can actually add without exceeding the limit
      const availableSlots = MAX_PARTICLES - particles.length;
      const actualCount = Math.min(count, availableSlots);

      if (actualCount <= 0) return; // Pool full

      for (let i = 0; i < actualCount; i++) {
        const isRune = Math.random() > 0.7;

        let p;
        if (particlePool.length > 0) {
          p = particlePool.pop(); // Reuse object
          p.x = x;
          p.y = y;
          p.vx = (Math.random() - 0.5) * 8;
          p.vy = (Math.random() - 0.5) * 8;
          p.life = 1;
          p.decay = Math.random() * 0.03 + 0.02;
          p.color = color;
          p.isRune = isRune;
          p.rune = runes[Math.floor(Math.random() * runes.length)];
          p.rotation = Math.random() * Math.PI * 2;
          p.rotationSpeed = (Math.random() - 0.5) * 0.2;
        } else {
          p = {
            x,
            y,
            vx: (Math.random() - 0.5) * 8, // Faster spread
            vy: (Math.random() - 0.5) * 8,
            life: 1,
            decay: Math.random() * 0.03 + 0.02, // Slower decay
            color,
            isRune,
            rune: runes[Math.floor(Math.random() * runes.length)],
            rotation: Math.random() * Math.PI * 2,
            rotationSpeed: (Math.random() - 0.5) * 0.2,
          };
        }
        particles.push(p);
      }
    }

    function draw() {
      // Handle Screen Shake
      ctx.save();
      if (screenShake > 0) {
        const dx = (Math.random() - 0.5) * screenShake;
        const dy = (Math.random() - 0.5) * screenShake;
        ctx.translate(dx, dy);
        screenShake *= 0.9;
        if (screenShake < 0.5) screenShake = 0;
      }

      // Clear and draw cached background
      ctx.fillStyle = '#111827';
      ctx.fillRect(-20, -20, canvas.width + 40, canvas.height + 40);
      ctx.drawImage(bgCanvas, 0, 0);

      // --- PHASE 1: Draw Entities ---
      drawTowers();
      drawLinks(); // Visual Steel Bond links
      drawEnemies();
      drawProjectiles();
      drawParticles();

      // --- PHASE 1.5: Fog of War ---
      if (showFog) drawFog();

      // --- PHASE 1.7: Post-Fog Entities (Visible through fog) ---
      drawBonuses(); // War loot and enemy drops
      drawDarkRunes(); // Plague marks
      
      // --- PHASE 2: UI Overlays (Always on top) ---
      drawUIBarsAndLevels();
      drawTowerInfoPlate(); // Show inspection tooltip
      drawEnemyInfoPlate(); // Show enemy inspection tooltip
      drawPreviews();
      drawFloatingTexts();
      drawGameStates();
      drawToasts();
      drawStatusEffects();
      drawInteractionFeedback();

      ctx.restore();
    }

    function drawInteractionFeedback() {
      if (!lastInteractionPos || lastInteractionPos.life <= 0) return;
      
      const { x, y, radius, life } = lastInteractionPos;
      const alpha = life / 20;
      
      ctx.save();
      ctx.beginPath();
      ctx.arc(x, y, radius * (1 + (20 - life) * 0.05), 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(129, 140, 248, ${alpha})`;
      ctx.lineWidth = 2;
      ctx.stroke();
      
      // Outer ring
      ctx.beginPath();
      ctx.arc(x, y, radius * 0.5 * (life / 20), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(129, 140, 248, ${alpha * 0.2})`;
      ctx.fill();
      
      ctx.restore();
      lastInteractionPos.life--;
    }

    function drawTowerInfoPlate() {
      const container = document.getElementById('unit-info-plate');
      const towerView = document.getElementById('tower-inspect-view');
      const enemyView = document.getElementById('enemy-inspect-view');
      
      if (!inspectedTower) {
        if (towerView) towerView.classList.add('hidden');
        if (!inspectedEnemy && container) container.classList.add('hidden');
        return;
      }
      
      const t = inspectedTower;
      if (container) container.classList.remove('hidden');
      if (towerView) towerView.classList.remove('hidden');
      if (enemyView) enemyView.classList.add('hidden');
      
      // OPTIMIZATION: Update DOM only every 10 frames or if tower changed
      const now = Date.now();
      if (now - lastInspectUpdate < 160 && container.dataset.lastId === String(t.x + t.y)) {
        // Just draw the range indicator
        drawRangeIndicator(t);
        return;
      }
      lastInspectUpdate = now;
      container.dataset.lastId = String(t.x + t.y);

      // Update HTML content
      document.getElementById('inspect-name').innerText = t.name;
      document.getElementById('inspect-level').innerText = `Nv.${t.level}`;
      document.getElementById('inspect-dmg').innerText = Math.round(t.damage);
      document.getElementById('inspect-kills').innerText = t.kills;
      
      // Update Stamina (Health % for now)
      const stamina = Math.floor((t.hp / t.maxHp) * 100);
      document.getElementById('inspect-stamina').innerText = stamina;

      // Update Effects Badges
      const effectsContainer = document.getElementById('inspect-effects');
      let badges = '';
      if (t.isPaired) badges += '<span class="text-[7px] px-1 bg-indigo-900/50 text-indigo-300 rounded border border-indigo-500/30">🔗 VÍNCULO</span>';
      if (t.buffs.steelShield > 0) badges += '<span class="text-[7px] px-1 bg-slate-700 text-slate-200 rounded border border-slate-500/50">🛡️ ACERO</span>';
      if (t.buffs.doubleShot > 0) badges += '<span class="text-[7px] px-1 bg-red-900/50 text-red-400 rounded border border-red-500/30">🔥 FRENESÍ</span>';
      if (t.buffs.freeze > 0) badges += '<span class="text-[7px] px-1 bg-cyan-900/50 text-cyan-400 rounded border border-cyan-500/30">❄️ CONGELADO</span>';
      if (effectsContainer.innerHTML !== badges) effectsContainer.innerHTML = badges;
      
      // Update Special Ability Progress Bar
      const stats = TOWER_STATS[t.type];
      const progress = stats.specialThreshold ? Math.min(100, (t.shotsFired / stats.specialThreshold) * 100) : 0;
      const vetBar = document.getElementById('inspect-vet-bar');
      if (vetBar) {
        vetBar.style.width = `${progress}%`;
        vetBar.className = progress >= 100 ? 'h-full bg-amber-400 animate-pulse' : 'h-full bg-amber-500';
      }

      // Update tooltips and cost labels with current costs
      const repairCost = getTowerCost('repair');
      const upgradeCost = getTowerCost('upgrade');
      const repairBtn = document.getElementById('inspect-repair');
      const upgradeBtn = document.getElementById('inspect-upgrade');
      const sellBtn = document.getElementById('inspect-sell');
      const repairCostEl = document.getElementById('inspect-repair-cost');
      const upgradeCostEl = document.getElementById('inspect-upgrade-cost');
      const sellValueEl = document.getElementById('inspect-sell-value');

      const sellValue = calculateSellValue(t);

      if (repairBtn) repairBtn.title = `Reparar (${repairCost}t)`;
      if (upgradeBtn) upgradeBtn.title = `Mejorar (${upgradeCost}t)`;
      if (sellBtn) sellBtn.title = `Vender (${sellValue}a)`;
      if (repairCostEl) repairCostEl.innerText = `${repairCost}t`;
      if (upgradeCostEl) upgradeCostEl.innerText = `${upgradeCost}t`;
      if (sellValueEl) sellValueEl.innerText = `${sellValue}a`;

      drawRangeIndicator(t);
    }

    function drawRangeIndicator(t) {
      // Visual range indicator on canvas
      const gh = t.gridHeight || 1;
      const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
      ctx.beginPath();
      ctx.arc(t.x, visualY, t.range, 0, Math.PI * 2);
      ctx.strokeStyle = t.color + '33';
      ctx.lineWidth = 1;
      ctx.setLineDash([5, 5]);
      ctx.stroke();
      ctx.setLineDash([]);
    }

    function drawLinks() {
      ctx.save();
      ctx.setLineDash([2, 4]);
      ctx.lineWidth = 1;
      
      const basicTowers = towers.filter(t => t.type === 'basic' && t.isPaired);
      const processed = new Set();

      basicTowers.forEach(t1 => {
        processed.add(t1);
        const vY1 = t1.y + (((t1.gridHeight || 1) - 1) * GRID_SIZE) / 2;
        
        // Find its pair
        basicTowers.forEach(t2 => {
          if (processed.has(t2)) return;
          
          const vY2 = t2.y + (((t2.gridHeight || 1) - 1) * GRID_SIZE) / 2;
          const dx = t2.x - t1.x;
          const dy = vY2 - vY1;
          const distSq = dx * dx + dy * dy;
          
          if (distSq <= t1.range * t1.range) {
            // Draw energy link
            const grad = ctx.createLinearGradient(t1.x, vY1, t2.x, vY2);
            grad.addColorStop(0, 'rgba(148, 163, 184, 0.1)');
            grad.addColorStop(0.5, 'rgba(148, 163, 184, 0.4)');
            grad.addColorStop(1, 'rgba(148, 163, 184, 0.1)');
            
            ctx.beginPath();
            ctx.moveTo(t1.x, vY1);
            ctx.lineTo(t2.x, vY2);
            ctx.strokeStyle = grad;
            ctx.stroke();
            
            // Draw small glow at centers
            ctx.fillStyle = 'rgba(148, 163, 184, 0.2)';
            ctx.beginPath();
            ctx.arc(t1.x, vY1, 4, 0, Math.PI * 2);
            ctx.arc(t2.x, vY2, 4, 0, Math.PI * 2);
            ctx.fill();
          }
        });
      });
      ctx.restore();
    }

    function drawFog() {
      if (fogCanvas.width !== canvas.width || fogCanvas.height !== canvas.height) {
        fogCanvas.width = canvas.width;
        fogCanvas.height = canvas.height;
      }

      // 1. Fill with darkness
      fogCtx.globalCompositeOperation = 'source-over';
      fogCtx.fillStyle = 'rgba(0, 0, 0, 0.65)';
      fogCtx.fillRect(0, 0, fogCanvas.width, fogCanvas.height);

      // 2. Clear circles around towers (revealed areas)
      fogCtx.globalCompositeOperation = 'destination-out';
      
      // Always reveal around the start and end of path
      const startRadius = 160;
      const endRadius = 220;
      
      const startGrad = fogCtx.createRadialGradient(path[0].x, path[0].y, 0, path[0].x, path[0].y, startRadius);
      startGrad.addColorStop(0, 'rgba(0,0,0,1)');
      startGrad.addColorStop(1, 'rgba(0,0,0,0)');
      fogCtx.fillStyle = startGrad;
      fogCtx.beginPath();
      fogCtx.arc(path[0].x, path[0].y, startRadius, 0, Math.PI * 2);
      fogCtx.fill();

      const endGrad = fogCtx.createRadialGradient(path[path.length-1].x, path[path.length-1].y, 0, path[path.length-1].x, path[path.length-1].y, endRadius);
      endGrad.addColorStop(0, 'rgba(0,0,0,1)');
      endGrad.addColorStop(1, 'rgba(0,0,0,0)');
      fogCtx.fillStyle = endGrad;
      fogCtx.beginPath();
      fogCtx.arc(path[path.length-1].x, path[path.length-1].y, endRadius, 0, Math.PI * 2);
      fogCtx.fill();

      towers.forEach(t => {
        const gh = t.gridHeight || 1;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
        const revealRadius = t.range * 1.2; 
        
        const grad = fogCtx.createRadialGradient(t.x, visualY, revealRadius * 0.4, t.x, visualY, revealRadius);
        grad.addColorStop(0, 'rgba(0,0,0,1)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        
        fogCtx.fillStyle = grad;
        fogCtx.beginPath();
        fogCtx.arc(t.x, visualY, revealRadius, 0, Math.PI * 2);
        fogCtx.fill();
      });

      // 3. Draw fog canvas onto main canvas
      ctx.drawImage(fogCanvas, 0, 0);
    }

    function drawEnemyInfoPlate() {
      const container = document.getElementById('unit-info-plate');
      const towerView = document.getElementById('tower-inspect-view');
      const enemyView = document.getElementById('enemy-inspect-view');
      
      if (!inspectedEnemy) {
        if (enemyView) enemyView.classList.add('hidden');
        if (!inspectedTower && container) container.classList.add('hidden');
        return;
      }
      
      const e = inspectedEnemy;
      if (container) container.classList.remove('hidden');
      if (enemyView) enemyView.classList.remove('hidden');
      if (towerView) towerView.classList.add('hidden');
      
      const now = Date.now();
      if (now - lastInspectUpdate < 100) return;
      lastInspectUpdate = now;

      // Update HTML content
      const type = ENEMY_TYPES.find(t => t.id === e.id) || { name: 'Enemigo' };
      document.getElementById('enemy-inspect-name').innerText = type.name;
      document.getElementById('enemy-inspect-level').innerText = `NV. ${e.level || wave}`;
      
      const hpPercent = Math.max(0, Math.floor((e.hp / e.maxHp) * 100));
      document.getElementById('enemy-inspect-hp').innerText = hpPercent;
      document.getElementById('enemy-inspect-hp-bar').style.width = `${hpPercent}%`;
      
      // Calculate visual speed (including sprint)
      let visualSpeed = e.speed;
      if (e.noDamageTimer > 180) visualSpeed *= 1.4;
      document.getElementById('enemy-inspect-speed').innerText = visualSpeed.toFixed(1);
    }

    function drawUIBarsAndLevels() {
      // Health Bars and Levels for Towers
      towers.forEach((t) => {
        const gh = t.gridHeight || 1;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
        
        // HP Bar
        const barW = t.size * 1.5;
        const barH = 5;
        const barY = visualY + (gh * GRID_SIZE) / 2 - 5;
        
        ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
        ctx.fillRect(t.x - barW / 2 - 1, barY - 1, barW + 2, barH + 2);
        ctx.fillStyle = '#7F1D1D';
        ctx.fillRect(t.x - barW / 2, barY, barW, barH);
        ctx.fillStyle = '#10B981';
        ctx.fillRect(t.x - barW / 2, barY, barW * (t.hp / t.maxHp), barH);

        // Steel Reinforcement Indicator (Repair Bonus)
        if (t.buffs.steelShield > 0) {
          ctx.strokeStyle = '#94A3B8';
          ctx.lineWidth = 2;
          ctx.strokeRect(t.x - barW / 2 - 2, barY - 2, barW + 4, barH + 4);

          // Label and Timer Container (Above health/level) - MOVED HERE FOR TOP LAYERING
          const seconds = Math.ceil(t.buffs.steelShield / 60);
          const label = `🛡️ REFORZADO ${seconds}s`;
          ctx.font = 'bold 8px sans-serif';
          const textW = ctx.measureText(label).width;
          
          ctx.fillStyle = 'rgba(15, 23, 42, 0.9)';
          ctx.fillRect(t.x - textW / 2 - 4, barY - 22, textW + 8, 12);
          ctx.strokeStyle = '#94A3B8';
          ctx.lineWidth = 1;
          ctx.strokeRect(t.x - textW / 2 - 4, barY - 22, textW + 8, 12);

          ctx.fillStyle = '#94A3B8';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(label, t.x, barY - 16);
        }

        // Steel Bond Armor Bonus (Basic Tower Pairing)
        if (t.type === 'basic' && t.isPaired) {
          ctx.strokeStyle = '#6366F1'; // Indigo color
          ctx.lineWidth = 1.5;
          ctx.strokeRect(t.x - barW / 2 - 1.5, barY - 1.5, barW + 3, barH + 3);
          
          ctx.fillStyle = '#818CF8';
          ctx.font = 'bold 7px sans-serif';
          ctx.textAlign = 'center';
          ctx.fillText('🔗 VÍNCULO', t.x, barY - 16);
        }

        // Debuff Indicators
        if (t.buffs.weakened > 0 || t.buffs.blinded > 0 || t.buffs.rusted > 0 || t.buffs.freeze > 0) {
          let debuffLabel = '';
          if (t.buffs.freeze > 0) debuffLabel = '❄️ CONGELADO';
          else if (t.buffs.rusted > 0) debuffLabel = '⚙️ OXIDADO';
          else if (t.buffs.blinded > 0) debuffLabel = '🌫️ CEGADO';
          else if (t.buffs.weakened > 0) debuffLabel = '📉 DÉBIL';

          ctx.font = 'bold 9px sans-serif';
          const textW = ctx.measureText(debuffLabel).width;
          ctx.fillStyle = 'rgba(127, 29, 29, 0.9)'; // Dark red bg
          ctx.fillRect(t.x - textW / 2 - 4, barY - 34, textW + 8, 12);
          ctx.fillStyle = '#FCA5A5'; // Light red text
          ctx.fillText(debuffLabel, t.x, barY - 28);
        }

        // Level and Veterancy Stars
        ctx.fillStyle = '#FFFFFF';
        ctx.font = '900 11px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        const starsCount = t.veterancy - 1;
        const label = starsCount > 0 ? `${starsCount}★ Nv.${t.level || 1}` : `Nv.${t.level || 1}`;
        ctx.strokeText(label, t.x, barY - 8);
        ctx.fillText(label, t.x, barY - 8);

        // Low Health Alert
        if (t.hp / t.maxHp < 0.3) {
          const blink = Math.sin(Date.now() / 150) > 0;
          if (blink) {
            ctx.fillStyle = '#EF4444';
            ctx.font = 'black 9px sans-serif';
            ctx.fillText('¡REPARAR!', t.x, barY - 34); // Higher if reinforced label exists
          }
        }
      });

      // Health Bars and Levels for Enemies
      enemies.forEach((e) => {
        const barW = e.isBoss ? 44 : 24;
        const barH = e.isBoss ? 7 : 5;
        const barY = e.y + (e.isBoss ? 28 : 18);
        
        ctx.fillStyle = 'rgba(0, 0, 0, 0.6)';
        ctx.fillRect(e.x - barW / 2 - 1, barY - 1, barW + 2, barH + 2);
        ctx.fillStyle = '#7F1D1D';
        ctx.fillRect(e.x - barW / 2, barY, barW, barH);
        ctx.fillStyle = e.isBoss ? '#F59E0B' : '#10B981';
        ctx.fillRect(e.x - barW / 2, barY, barW * (e.hp / e.maxHp), barH);

        if (e.shield > 0) {
          ctx.fillStyle = '#3B82F6';
          ctx.fillRect(e.x - barW / 2, e.y + (e.isBoss ? 20 : 12), barW * (e.shield / (e.maxHp * 0.5)), 3);
        }

        ctx.fillStyle = '#FFFFFF';
        ctx.font = '900 11px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        const label = `Lv.${e.level || 1}`;
        ctx.strokeText(label, e.x, barY - 8);
        ctx.fillText(label, e.x, barY - 8);
      });
    }

    function drawTowers() {
      const sortedTowers = towers.slice().sort((a, b) => a.y - b.y);
      sortedTowers.forEach((t) => {
        const gh = t.gridHeight || 1;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
        const barY = visualY + (gh * GRID_SIZE) / 2 - 5;

        // Upgrade Range Expansion Pulse
        if (t.upgradePulse && t.upgradePulse > 0) {
          const oldR = t.oldRange || t.range * 0.9;
          const currentR = oldR + (t.range - oldR) * (1 - t.upgradePulse);
          ctx.beginPath();
          ctx.arc(t.x, visualY, currentR, 0, Math.PI * 2);
          ctx.strokeStyle = '#FCD34D';
          ctx.lineWidth = 3;
          ctx.stroke();
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range, 0, Math.PI * 2);
          ctx.strokeStyle = '#FCD34D33';
          ctx.lineWidth = 1;
          ctx.stroke();
          if (!isPaused) t.upgradePulse -= 0.02;
        }

        // Steel Reinforcement Aura (Repair Bonus)
        if (t.buffs.steelShield > 0) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.size * 1.0, 0, Math.PI * 2); // Reduced from 1.2 to 1.0
          ctx.strokeStyle = '#94A3B8';
          ctx.lineWidth = 2 + Math.sin(Date.now() / 100) * 1;
          ctx.setLineDash([3, 3]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Normal Range Pulse
        if (t.rangePulse && t.rangePulse > 0 && (!t.upgradePulse || t.upgradePulse <= 0)) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range * (1.5 - t.rangePulse * 0.5), 0, Math.PI * 2);
          ctx.strokeStyle = '#F59E0B';
          ctx.lineWidth = 1;
          ctx.stroke();
          if (!isPaused) t.rangePulse -= 0.02;
        }

        // Permanent Range Visualization
        if (showRanges) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range, 0, Math.PI * 2);
          ctx.strokeStyle = t.color + '44'; // Use tower color with low alpha
          ctx.lineWidth = 1;
          ctx.setLineDash([5, 5]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        if (spritesLoaded && SPRITE_MAP.towers[t.type]) {
          const s = SPRITE_MAP.towers[t.type];
          if (t.buffs.freeze > 0 || t.buffs.doubleShot > 0) {
            ctx.beginPath();
            ctx.arc(t.x, visualY, t.size * 1.5, 0, Math.PI * 2);
            ctx.fillStyle = t.buffs.freeze > 0 ? '#60A5FA44' : '#EF444444';
            ctx.fill();
          }
          const renderSize = t.size * 2.5;
          const renderH = renderSize * (gh > 1 ? 1.5 : 1);
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, t.x - renderSize / 2, visualY - renderH / 2, renderSize, renderH);
        } else {
          ctx.fillStyle = t.color;
          if (t.type === 'basic') ctx.fillRect(t.x - t.size / 2, visualY - t.size / 2, t.size, t.size);
          else { ctx.beginPath(); ctx.arc(t.x, visualY, t.size, 0, Math.PI * 2); ctx.fill(); }
        }

        // Veterancy Aura (Ground effect)
        if (t.veterancy > 1) {
          ctx.save();
          ctx.globalAlpha = 0.2 + (Math.sin(Date.now() / 300) * 0.1);
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.size * 1.0, 0, Math.PI * 2); // 50% smaller
          ctx.fillStyle = '#FCD34D';
          ctx.fill();
          ctx.restore();
        }
      });
    }

    function drawEnemies() {
      const sortedEnemies = enemies.slice().sort((a, b) => a.y - b.y);
      sortedEnemies.forEach((e) => {
        if (spritesLoaded && SPRITE_MAP.enemies[e.id]) {
          const s = SPRITE_MAP.enemies[e.id];
          const renderSize = e.isBoss ? 60 : 40;
          const animTime = Date.now() / 150;
          const bob = !isPaused ? Math.abs(Math.sin(animTime)) * 3 : 0;
          
          ctx.save();
          if (e.isGhost) ctx.globalAlpha = 0.6;
          if (e.isClone && e.lifeTimer) {
            // Fade out as life expires
            ctx.globalAlpha *= Math.min(1.0, e.lifeTimer / 30); 
          }
          ctx.translate(e.x, e.y - bob);
          ctx.beginPath();
          ctx.arc(0, 0, renderSize * 0.6, 0, Math.PI * 2);
          ctx.fillStyle = e.color + '22'; 
          ctx.fill();
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, -renderSize / 2, -renderSize / 2, renderSize, renderSize);
          ctx.restore();
        } else {
          ctx.fillStyle = e.color;
          const size = e.isBoss ? 20 : 10;
          ctx.fillRect(e.x - size, e.y - size, size * 2, size * 2);
        }

        if (e.hasRangeBuff && !e.isBoss) {
          ctx.strokeStyle = '#FCD34D';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.arc(e.x, e.y, 16, 0, Math.PI * 2);
          ctx.stroke();
        }
      });
    }

    function drawProjectiles() {
      projectiles.forEach((p) => {
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
        ctx.fill();
      });

      enemyProjectiles.forEach((p) => {
        ctx.fillStyle = p.color;
        ctx.beginPath();
        if (p.attackType === 'fire') {
          ctx.moveTo(p.x, p.y - 6);
          ctx.lineTo(p.x + 4, p.y + 4);
          ctx.lineTo(p.x - 4, p.y + 4);
          ctx.closePath();
        } else if (p.attackType === 'ice') {
          ctx.moveTo(p.x, p.y - 5);
          ctx.lineTo(p.x + 5, p.y);
          ctx.lineTo(p.x, p.y + 5);
          ctx.lineTo(p.x - 5, p.y);
          ctx.closePath();
        } else if (p.attackType === 'plague') {
          // Area plague: larger bubble with glow
          ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
          ctx.shadowBlur = 10;
          ctx.shadowColor = p.color;
        } else {
          ctx.arc(p.x, p.y, p.attackType === 'poison' ? 4 : 3, 0, Math.PI * 2);
        }
        ctx.fill();
        ctx.shadowBlur = 0; // Reset shadow
      });
    }

    function drawParticles() {
      particles.forEach((p) => {
        ctx.fillStyle = p.color;
        if (p.isRune) {
          ctx.font = `bold ${Math.floor(12 * p.life + 8)}px serif`;
          ctx.fillText(p.rune, p.x, p.y);
        } else {
          ctx.beginPath();
          ctx.arc(p.x, p.y, Math.max(1, 4 * p.life), 0, Math.PI * 2);
          ctx.fill();
        }
      });
    }

    function drawBonuses() {
      bonuses.forEach((b) => {
        const scale = 1 + Math.sin(Date.now() / 100) * 0.1;
        ctx.save();
        ctx.translate(b.x, b.y);
        ctx.scale(scale, scale);
        if (spritesLoaded && SPRITE_MAP.items[b.type]) {
          const s = SPRITE_MAP.items[b.type];
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, -20, -24, 40, 48);
        } else {
          let color = '#FCD34D'; let rune = 'ᚩ';
          if (b.type === 'abyssal_rune') { color = '#A855F7'; rune = 'ᛈ'; }
          else if (b.type === 'heal') { color = '#34D399'; rune = 'ᛉ'; }
          else if (b.type === 'freeze') { color = '#60A5FA'; rune = 'ᛁ'; }
          else if (b.type === 'frenzy') { color = '#EF4444'; rune = 'ᚱ'; }
          else if (b.type === 'nuke') { color = '#F59E0B'; rune = 'ᛒ'; }
          ctx.fillStyle = color; ctx.font = 'bold 24px serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(rune, 0, 0);
        }
        ctx.restore();
      });
    }

    function drawDarkRunes() {
      darkRunes.forEach((r) => {
        let color = '#D946EF'; let rune = 'ᛤ';
        if (r.type === 'shield') { color = '#60A5FA'; rune = 'ᚦ'; }
        else if (r.type === 'haste') { color = '#FCD34D'; rune = 'ᚢ'; }
        else if (r.type === 'heal') { color = '#10B981'; rune = 'ᛉ'; }
        ctx.fillStyle = color; ctx.font = 'bold 20px serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(rune, r.x, r.y);
      });
    }

    function drawPreviews() {
      if (gameState === 'playing' && enemies.length === 0 && !isPaused && !selectedTowerType) {
        const hoveredTower = towers.find((t) => Math.hypot(t.x - mouseX, t.y - mouseY) < 20);
        if (hoveredTower) {
          ctx.beginPath(); ctx.arc(hoveredTower.x, hoveredTower.y, hoveredTower.range, 0, Math.PI * 2);
          ctx.strokeStyle = '#60A5FA88'; ctx.lineWidth = 1; ctx.stroke();
        }
      }
      const previewType = isDragging ? draggedType : selectedTowerType;
      if (previewType) {
        const gridX = Math.round(mouseX / GRID_SIZE) * GRID_SIZE;
        const gridY = Math.round(mouseY / GRID_SIZE) * GRID_SIZE;
        const stats = TOWER_STATS[previewType];
        if (stats) {
          const h = stats.gridHeight || 1;
          let isValid = true;
          for (let i = 0; i < h; i++) {
            const checkY = gridY + i * GRID_SIZE;
            if (checkY > canvas.height - 40 || isCollidingWithPath(gridX, checkY)) isValid = false;
          }
          const inTopCenterUI = Math.abs(gridX - canvas.width / 2) < 250 && gridY < 100;
          const inRightUI = gridX > canvas.width - 80;
          const inLeftUI = gridX < 80;
          const inStartButton = gridX > canvas.width / 2 - 130 && gridX < canvas.width / 2 + 130 && gridY > canvas.height - 100;
          const inBottomUI = gridY > canvas.height - 60;
          if (inTopCenterUI || inRightUI || inLeftUI || inStartButton || inBottomUI) isValid = false;
          
          ctx.save();
          ctx.globalAlpha = 0.5;
          const visualGhostY = gridY + ((h - 1) * GRID_SIZE) / 2;
          if (spritesLoaded && SPRITE_MAP.towers[previewType]) {
            const s = SPRITE_MAP.towers[previewType];
            const renderSize = stats.size * 2.5; const renderH = renderSize * (h > 1 ? 1.5 : 1);
            ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, gridX - renderSize / 2, visualGhostY - renderH / 2, renderSize, renderH);
          } else {
            ctx.fillStyle = isValid ? stats.color : '#EF4444';
            if (previewType === 'basic') ctx.fillRect(gridX - stats.size / 2, visualGhostY - stats.size / 2, stats.size, stats.size);
            else { ctx.beginPath(); ctx.arc(gridX, visualGhostY, stats.size, 0, Math.PI * 2); ctx.fill(); }
          }
          ctx.restore();
          ctx.beginPath(); ctx.arc(gridX, gridY, stats.range, 0, Math.PI * 2);
          ctx.strokeStyle = isValid ? '#34D39944' : '#EF444444'; ctx.lineWidth = 1; ctx.stroke();
        }
      }
    }

    function drawFloatingTexts() {
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      const buffs = floatingTexts.filter(t => t.type === 'buff' || t.type === 'debuff');
      const shouldAccelerate = buffs.length > 3;
      let buffCount = 0;

      for (let i = 0; i < floatingTexts.length; i++) {
        let ft = floatingTexts[i];
        let fx = ft.x;
        let fy = ft.y + ft.vy;
        
        if (ft.type === 'buff' || ft.type === 'debuff') {
          fx = canvas.width / 2;
          fy = (canvas.height / 2 + 80) + (buffCount * 25) - ft.vy;
          buffCount++;
          ctx.font = '900 18px sans-serif';
          if (shouldAccelerate) ft.life -= 1.5;
        } else {
          ctx.font = 'bold 14px sans-serif';
        }

        if (ft.life < 20) ctx.globalAlpha = ft.life / 20;
        ctx.fillStyle = ft.color;
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.8)';
        ctx.lineWidth = 3;
        ctx.strokeText(ft.text, fx, fy);
        ctx.fillText(ft.text, fx, fy);
        ctx.globalAlpha = 1.0;
        ft.vy -= 0.1;
        ft.life--;
      }
      for (let i = floatingTexts.length - 1; i >= 0; i--) if (floatingTexts[i].life <= 0) floatingTexts.splice(i, 1);
    }

    function drawGameStates() {
      if (gameState === 'intro' || gameState === 'gameover') {
        ctx.fillStyle = '#000000DD';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.textAlign = 'center';
        ctx.font = '900 40px sans-serif';
        ctx.fillStyle = gameState === 'gameover' ? '#EF4444' : '#FFFFFF';
        ctx.fillText(gameState === 'gameover' ? 'La Ciudadela ha Caído' : 'Prepara tus Defensas', canvas.width / 2, canvas.height / 2);
      }

      if ((gameState === 'playing' && enemies.length === 0 && !isEventActive) || gameState === 'intro' || gameState === 'gameover') {
        const btnX = canvas.width / 2;
        const btnY = canvas.height / 2 + 150;
        
        // Draw Button Shadow/Glow
        ctx.shadowBlur = 15;
        ctx.shadowColor = 'rgba(79, 70, 229, 0.5)';
        
        // Draw Button Background
        ctx.fillStyle = '#4F46E5';
        ctx.beginPath();
        ctx.roundRect(btnX - 150, btnY - 50, 300, 100, 15);
        ctx.fill();
        
        ctx.shadowBlur = 0; // Reset shadow

        // Draw Button Border
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
        ctx.lineWidth = 2;
        ctx.stroke();

        ctx.fillStyle = '#FFFFFF';
        ctx.font = '900 24px sans-serif'; // Larger font for larger button
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.5)';
        ctx.lineWidth = 2;
        const btnText = gameState === 'intro' ? 'INICIAR PARTIDA' : gameState === 'gameover' ? 'REINTENTAR' : 'SIGUIENTE OLEADA';
        ctx.strokeText(btnText, btnX, btnY);
        ctx.fillText(btnText, btnX, btnY);
      }
    }

    function drawToasts() {
      for (let i = 0; i < canvasToasts.length; i++) {
        const toast = canvasToasts[i];
        let xPos = canvas.width / 2;
        let yPos = canvas.height / 2 - (i * 25) + (toast.yOffset -= 1);
        ctx.font = '900 18px sans-serif';
        ctx.fillStyle = toast.type === 'error' ? '#EF4444' : '#34D399';
        if (toast.life < 20) ctx.globalAlpha = toast.life / 20;
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.8)';
        ctx.lineWidth = 3;
        ctx.strokeText(toast.msg, xPos, yPos);
        ctx.fillText(toast.msg, xPos, yPos);
        ctx.globalAlpha = 1.0;
        toast.life--;
      }
      for (let i = canvasToasts.length - 1; i >= 0; i--) if (canvasToasts[i].life <= 0) canvasToasts.splice(i, 1);
    }

    function drawStatusEffects() {
      if (globalFreezeTimer > 0) {
        ctx.save();
        ctx.font = '900 18px sans-serif';
        ctx.fillStyle = '#60A5FA';
        const yOffset = Math.max(0, (30 - globalFreezeTimer) * 0.5);
        if (globalFreezeTimer < 20) ctx.globalAlpha = globalFreezeTimer / 20;
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.8)';
        ctx.lineWidth = 3;
        ctx.strokeText('❄️ HIELO ACTIVO', canvas.width / 2, canvas.height - 180 + yOffset);
        ctx.fillText('❄️ HIELO ACTIVO', canvas.width / 2, canvas.height - 180 + yOffset);
        ctx.restore();
      }

      if (curseNotification && curseNotification.life > 0) {
        ctx.save();
        ctx.font = '900 18px sans-serif';
        ctx.fillStyle = '#A855F7';
        const yOffset = Math.max(0, (20 - curseNotification.life) * 0.5);
        if (curseNotification.life < 20) ctx.globalAlpha = curseNotification.life / 20;
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.8)';
        ctx.lineWidth = 3;
        ctx.strokeText(`🔮 ${curseNotification.msg}`, canvas.width / 2, canvas.height - 210 + yOffset);
        ctx.fillText(`🔮 ${curseNotification.msg}`, canvas.width / 2, canvas.height - 210 + yOffset);
        ctx.restore();
        curseNotification.life--;
      }
    }
  </script>
</Layout>
