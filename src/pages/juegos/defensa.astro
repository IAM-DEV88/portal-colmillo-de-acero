    function getTowerCost(type, tower = null) {
      const waveFactor = Math.max(0, wave - 1);

      if (type === 'repair') {
        // AAA: Double repair cost as requested, but also scale with wave
        const inflation = 1 + waveFactor * GAME_CONFIG.economy.tactics.inflationRepair;
        const baseRepair = (GAME_CONFIG.economy.tactics.repairBase * 2) + wave * GAME_CONFIG.economy.tactics.repairWaveScaling; 
        return Math.ceil(baseRepair * inflation);
      }
      
      if (type === 'powerup') {
        // AAA: Centralized in GAME_CONFIG and reduced by 80% as requested
        const inflation = 1 + waveFactor * GAME_CONFIG.economy.steel.inflationPowerup;
        const basePower = GAME_CONFIG.economy.steel.powerupBase + wave * GAME_CONFIG.economy.steel.powerupWaveScaling;
        return Math.ceil(basePower * inflation);
      }
      
      if (type === 'upgrade') {
        const inflation = 1 + waveFactor * GAME_CONFIG.economy.tactics.inflationUpgrade;
        const towerLevel = tower ? (tower.level || 1) : 1;
        const baseUpgrade = GAME_CONFIG.economy.tactics.upgradeBase + (wave * GAME_CONFIG.economy.tactics.upgradeWaveScaling); 
        
        // Unified proportional scaling based on level
        const levelMultiplier = Math.pow(GAME_CONFIG.economy.tactics.upgradeLevelMultiplier, towerLevel - 1);
        
        // AAA FIX: Soften the impact of tower type on upgrade costs. 
        // Instead of direct cost ratio (e.g. 4x), we use a weighted factor (e.g. 1.75x) 
        // to keep special towers upgradeable without breaking the bank.
        const costRatio = tower ? (TOWER_STATS[tower.type].cost / TOWER_STATS.basic.cost) : 1;
        const towerTypeCostFactor = 1 + (costRatio - 1) * 0.25; 
        
        return Math.ceil(baseUpgrade * levelMultiplier * inflation * towerTypeCostFactor);
      }

      if (type === 'pause') return GAME_CONFIG.economy.tactics.pauseCost;
      if (type === 'sell') return 0;
      
      const inflation = 1 + waveFactor * GAME_CONFIG.economy.steel.inflation;
      const baseCost = TOWER_STATS[type].cost;
      return Math.ceil(baseCost * inflation);
    }

    function getStartingLevelStats(type) {
      const stats = TOWER_STATS[type];
      const startingLevel = 1 + Math.floor(wave / 5);
      const waveFactor = Math.max(0, wave - 1);
      const inflation = 1 + waveFactor * GAME_CONFIG.economy.steel.inflation;
      const levelStatsMultiplier = Math.pow(GAME_CONFIG.balance.levelUpDamageBonus, startingLevel - 1);

      return {
        level: startingLevel,
        hp: Math.round(stats.hp * inflation * levelStatsMultiplier),
        damage: stats.damage * inflation * levelStatsMultiplier,
        range: stats.range * (1 + (startingLevel - 1) * 0.08)
      };
    }

    // --- ADAPTIVE BALANCING SYSTEM ---
    let lastTensionUpdate = 0;
    let cachedTension = 1.0;
    function getTensionFactor() {
      // Throttle calculation: Only recalculate every 30 frames
      if (Date.now() - lastTensionUpdate < 500) return cachedTension;
      lastTensionUpdate = Date.now();

      // Optimized: Pre-calculate thresholds (Small numbers scale)
      const upgradeThreshold = 10 + wave * 2; 
      const abyssalThreshold = 15 + wave * 3;

      // Wealth calculation (Player's current buying power)
      const upgradeRatio = upgrades / upgradeThreshold;
      const abyssalRatio = abyssals / abyssalThreshold;
      
      // Tower Power calculation (Player's current defensive strength)
      let totalTowerPower = 0;
      const towerCount = towers.length;
      for (let i = 0; i < towerCount; i++) {
        const t = towers[i];
        const stats = TOWER_STATS[t.type];
        // Power normalized: (damage / fireRate) is very small now, so we use a relative scale
        const basePower = (t.damage || stats.damage) * (30 / stats.fireRate);
        totalTowerPower += basePower * (t.veterancy || 1);
      }
      
      // Power Threshold (scales with wave)
      const powerThreshold = 2 + wave * 1.5; 
      const powerRatio = totalTowerPower / powerThreshold;

      // Total Wealth & Power Index: If player is over-performing, increase challenge
      let overPerformanceIndex = (upgradeRatio * 0.15 + abyssalRatio * 0.15 + powerRatio * 0.7);
      
      // Adaptive multiplier (Tension)
      let tension = 1.0;
      if (overPerformanceIndex > 1.1) {
        tension = 1.0 + (overPerformanceIndex - 1.1) * 0.8;
      }
      
      // LATE GAME SURGE: Waves 25+ get an extra exponential push
      if (wave >= 25) {
        tension *= 1 + Math.pow(wave - 24, 1.2) * 0.1;
      }

      cachedTension = Math.min(5.0, Math.max(1.0, tension));
      return cachedTension;
    }

