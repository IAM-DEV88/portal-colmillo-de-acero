    function redrawBackground() {
      bgCanvas.width = canvas.width;
      bgCanvas.height = canvas.height;
      
      if (bgLoaded) {
        // Draw image background
        bgCtx.drawImage(bgImage, 0, 0, bgCanvas.width, bgCanvas.height);
        
        // Add a slight dark overlay to improve readability
        bgCtx.fillStyle = '#00000066'; // Fixed hex with alpha
        bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
      } else {
        bgCtx.fillStyle = '#111827';
        bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
      }

      if (path && path.length > 0) {
        bgCtx.beginPath();
        bgCtx.moveTo(path[0].x, path[0].y);
        for (let i = 1; i < path.length; i++) {
          bgCtx.lineTo(path[i].x, path[i].y);
        }
        bgCtx.strokeStyle = '#374151AA'; // gray-700 with fixed alpha
        bgCtx.lineWidth = 40;
        bgCtx.lineCap = 'round';
        bgCtx.lineJoin = 'round';
        bgCtx.stroke();

        // Path inner glow/line
        bgCtx.strokeStyle = '#1F2937AA';
        bgCtx.lineWidth = 36;
        bgCtx.stroke();
      }
    }

    function generateRandomPath() {
      // Ensure canvas has dimensions
      if (canvas.width <= 0) {
        canvas.width = 1000; // Fallback
        canvas.height = 600;
      }
      
      const maxW = canvas.width;
      const maxH = canvas.height;

      const newPath = [];

      // Start after the Left Tools Panel (approx x=80)
      let currentX = 80;
      let currentY = Math.random() * (maxH - 300) + 150; // Avoid top and bottom UI
      newPath.push({ x: currentX, y: currentY });

      // We want to avoid the Right Panel (x > 940)
      // We want to avoid the HUD at bottom (y > maxH - 80)
      // We want to avoid the Left Tools Panel (x < 80)
      while (currentX < maxW - 200) {
        currentX += Math.random() * (maxW * 0.15) + maxW * 0.15;
        if (currentX > maxW - 150) currentX = maxW - 150;

        // Vertical safe zone: y between 100 and maxH - 120
        let minY = 100;
        let maxY = maxH - 120;

        currentY = Math.random() * (maxY - minY) + minY;
        newPath.push({ x: currentX, y: currentY });
      }

      // End path: ALWAYS at the Portal location
      // Based on fondoDefensa.png, the portal is roughly at x=940, y=280
      const portalX = 940;
      const portalY = 280;
      newPath.push({ x: portalX, y: portalY });

      path = newPath;
      redrawBackground();

      return newPath;
    }

    // Check if position overlaps with path
    function isCollidingWithPath(x, y) {
      const pathRadius = 30; // Half of path width
      for (let i = 0; i < path.length - 1; i++) {
        const p1 = path[i];
        const p2 = path[i + 1];
        // Line segment collision logic (simplified distance to segment)
        const l2 = Math.pow(p1.x - p2.x, 2) + Math.pow(p1.y - p2.y, 2);
        if (l2 === 0) continue;
        let t = ((x - p1.x) * (p2.x - p1.x) + (y - p1.y) * (p2.y - p1.y)) / l2;
        t = Math.max(0, Math.min(1, t));
        const dist = Math.hypot(x - (p1.x + t * (p2.x - p1.x)), y - (p1.y + t * (p2.y - p1.y)));
        if (dist < pathRadius + 15) return true; // +15 for tower padding
      }
      return false;
    }

    let particlePool = []; // Object pool for particles
    const MAX_PARTICLES = 250; // Extremely strict limit for FPS

    function applyDamageToTower(t, damage) {
      if (!t || damage <= 0) return;
      
      let finalDamage = damage;
      // Steel Bond Armor Bonus: -30% damage if paired
      if (t.type === 'basic' && t.isPaired) {
        finalDamage *= 0.7;
      }
      
      t.hp -= finalDamage;
      addCombatZone(t.x, t.y, 1.2, 'blue'); // Defense point
      
      if (t.hp <= 0) {
        const index = towers.indexOf(t);
        if (index > -1) {
          towers.splice(index, 1);
          if (inspectedTower === t) inspectedTower = null;
          createExplosion(t.x, t.y, '#EF4444', 15);
          showCanvasToast('¡Puesto defensivo destruido!', 'error');
          playSFX('explosion');
          // Recalculate pairs after a tower is destroyed
          updateTowerPairing();
        }
      }
    }

    function updateTowerPairing() {
      // Group towers by type for synergy checks
      const towerGroups = {
        basic: [],
        sniper: [],
        splash: [],
        nova: []
      };
      
      for (let i = 0; i < towers.length; i++) {
        const t = towers[i];
        t.isPaired = false;
        t.synergyBonus = 1.0;
        if (towerGroups[t.type]) towerGroups[t.type].push(t);
      }

      // Check synergies for each group
      Object.keys(towerGroups).forEach(type => {
        const group = towerGroups[type];
        const paired = new Set();
        const len = group.length;

        for (let i = 0; i < len; i++) {
          if (paired.has(i)) continue;
          
          const t1 = group[i];
          const vY1 = t1.y + (((t1.gridHeight || 1) - 1) * GRID_SIZE) / 2;
          
          let bestPair = -1;
          let minDistSq = Infinity;

          for (let j = 0; j < len; j++) {
            if (i === j || paired.has(j)) continue;
            
            const t2 = group[j];
            const vY2 = t2.y + (((t2.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            
            const dx = t2.x - t1.x;
            const dy = vY2 - vY1;
            const distSq = dx * dx + dy * dy;
            
            // Synergy range is based on tower's own range
            const linkRange = t1.range * 1.2; 
            if (distSq <= linkRange * linkRange && distSq < minDistSq) {
              minDistSq = distSq;
              bestPair = j;
            }
          }

          if (bestPair !== -1) {
            const t2 = group[bestPair];
            t1.isPaired = true;
            t2.isPaired = true;
            
            // Apply specific synergy bonuses
            if (type === 'basic') {
              // Steel Bond: Damage Reduction (Handled in applyDamageToTower)
            } else if (type === 'sniper') {
              t1.synergyBonus = 1.15; // +15% range
              t2.synergyBonus = 1.15;
            } else if (type === 'splash') {
              t1.synergyBonus = 1.20; // +20% splash radius
              t2.synergyBonus = 1.20;
            } else if (type === 'nova') {
              t1.synergyBonus = 1.25; // +25% heal/damage power
              t2.synergyBonus = 1.25;
            }
            
            paired.add(i);
            paired.add(bestPair);
          }
        }
      });
    }

    function calculateSellValue(t) {
      if (!t || !t.type || !TOWER_STATS[t.type]) return 0;
      const stats = TOWER_STATS[t.type];
      const baseCost = stats.cost || 0;
      
      // Calculate a better estimation of investment
      // We use current inflation as a proxy for the average inflation paid during construction/upgrades
      const waveFactor = Math.max(0, wave - 1);
      const steelInflation = 1 + waveFactor * GAME_CONFIG.economy.steel.inflation;
      const tacticsInflation = 1 + waveFactor * GAME_CONFIG.economy.tactics.inflationUpgrade;
      
      const currentBaseCost = baseCost * steelInflation;
      const level = Number(t.level) || 1;
      
      // Approximate upgrade investment (Sum of previous upgrade costs)
      let upgradeInvestment = 0;
      for (let i = 1; i < level; i++) {
        const levelMultiplier = Math.pow(GAME_CONFIG.economy.tactics.upgradeLevelMultiplier, i - 1);
        const towerTypeCostFactor = stats.cost / TOWER_STATS.basic.cost;
        const approxUpgradeCost = (GAME_CONFIG.economy.tactics.upgradeBase + (wave * GAME_CONFIG.economy.tactics.upgradeWaveScaling)) * levelMultiplier * tacticsInflation * towerTypeCostFactor;
        upgradeInvestment += approxUpgradeCost;
      }
      
      const hp = Number(t.hp) || 0;
      const maxHp = Number(t.maxHp) || stats.hp || 80;
      const veterancy = Number(t.veterancy) || 1;
      
      // Veterancy multiplier: +10% per star (More valuable now)
      const stars = Math.max(0, veterancy - 1);
      const veterancyBonus = 1 + (stars * 0.10);
      
      // Health factor: Minimum 70% value even if damaged, up to 100% if healthy
      const healthFactor = 0.7 + (hp / maxHp) * 0.3;
      
      // Refund Rate from Config (75%)
      const refundRate = GAME_CONFIG.economy.sellRefundRate || 0.75;
      
      // Value in Steel (Base cost refund) + Value in Tactics (Upgrade refund) converted to Steel?
      // For simplicity, we return everything in Steel, but upgrades were paid in Tactics.
      // Let's return Steel for the tower and a bit of Tactics for the upgrades if possible,
      // but the current game logic only returns a single value.
      // We'll convert upgrade investment (tactics) to steel at a 1:1 rate for the refund.
      
      const val = Math.floor((currentBaseCost + upgradeInvestment) * refundRate * veterancyBonus * healthFactor);
      return Number.isNaN(val) ? 0 : val;
    }

    // --- INIT ---
    async function fetchCredits() {
      try {
        const res = await fetch('/api/game-state?t=' + Date.now(), { cache: 'no-store' });
        if (res.ok) {
          const data = await res.json();
          credits = data.credits;
          document.getElementById('credits-display').innerText = credits;
        }
      } catch (e) {
        console.error('Error loading credits', e);
      }
    }

