    // --- CANVAS & ENTITIES ---
    const canvas = document.getElementById('game-canvas');
    const ctx = canvas.getContext('2d');
    const bgCanvas = document.createElement('canvas');
    const bgCtx = bgCanvas.getContext('2d');

    // --- IN-CANVAS TOASTS & COMBOS ---
    function addCombatZone(x, y, intensity = 1, type = 'red') {
      // Find nearby existing zone to merge
      const existing = combatZones.find(z => Math.hypot(z.x - x, z.y - y) < 40 && z.type === type);
      if (existing) {
        existing.intensity = Math.min(5, existing.intensity + intensity * 0.5);
        existing.life = 600; // Reset life
      } else {
        combatZones.push({ x, y, intensity, type, life: 600 });
      }
    }

    function showCinematic(title, subtitle = '', type = 'info', onComplete = null, isWaveStart = false) {
      activeCinematic = { title, subtitle, type, life: 100, onComplete, isWaveStart };
      playSFX(type === 'boss' ? 'explosion' : 'start');
      updateHUD(); // Ensure button text updates immediately to PAUSE state
    }

    function drawCinematic() {
      if (!activeCinematic) return;
      
      const { title, subtitle, type, life } = activeCinematic;
      // Entry: fast (10 frames), Exit: slow (40 frames)
      const alpha = life > 90 ? (100 - life) / 10 : life < 40 ? life / 40 : 1.0;
      
      ctx.save();
      ctx.globalAlpha = alpha;
      
      // Full screen darkening
      ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // Decorative Bars (Cinematic aspect ratio feel)
      // Bars reach max height in 10 frames and start retracting in the last 40 frames
      const barProgress = life > 90 ? (100 - life) / 10 : life < 40 ? life / 40 : 1.0;
      const barHeight = 60 * barProgress;
      ctx.fillStyle = 'rgba(0, 0, 0, 0.9)';
      ctx.fillRect(0, 0, canvas.width, barHeight);
      ctx.fillRect(0, canvas.height - barHeight, canvas.width, barHeight);
      
      // Text Shadow/Glow
      ctx.shadowBlur = 20;
      ctx.shadowColor = type === 'boss' ? 'rgba(239, 68, 68, 0.6)' : 'rgba(129, 140, 248, 0.6)';
      
      // Main Title - DYNAMIC SCALING
      const baseFontSize = 32;
      const spacing = 8;
      ctx.font = `900 ${baseFontSize}px sans-serif`;
      ctx.letterSpacing = `${spacing}px`;
      
      // Ensure title fits screen width
      let textWidth = ctx.measureText(title.toUpperCase()).width + (title.length * spacing);
      let fontSize = baseFontSize;
      while (textWidth > canvas.width - 40 && fontSize > 14) {
        fontSize -= 2;
        ctx.font = `900 ${fontSize}px sans-serif`;
        textWidth = ctx.measureText(title.toUpperCase()).width + (title.length * (spacing * fontSize / baseFontSize));
      }

      ctx.fillStyle = 'white';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(title.toUpperCase(), canvas.width / 2, canvas.height / 2 - 15);
      
      // Subtitle - DYNAMIC SCALING
      if (subtitle) {
        ctx.shadowBlur = 0;
        let subFontSize = 12;
        const subSpacing = 3;
        ctx.font = `400 ${subFontSize}px sans-serif`;
        ctx.letterSpacing = `${subSpacing}px`;
        
        let subWidth = ctx.measureText(subtitle.toUpperCase()).width + (subtitle.length * subSpacing);
        while (subWidth > canvas.width - 60 && subFontSize > 9) {
          subFontSize -= 1;
          ctx.font = `400 ${subFontSize}px sans-serif`;
          subWidth = ctx.measureText(subtitle.toUpperCase()).width + (subtitle.length * (subSpacing * subFontSize / 12));
        }

        ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
        ctx.fillText(subtitle.toUpperCase(), canvas.width / 2, canvas.height / 2 + 25);
      }
      
      ctx.restore();
      
      if (!isPaused) activeCinematic.life--;
      if (activeCinematic.life <= 0) {
        const cb = activeCinematic.onComplete;
        activeCinematic = null; // Clear it before calling cb to avoid recursion if cb shows another cinematic
        updateHUD(); // Transition button back to NEXT WAVE or PAUSE
        if (cb) cb();
      }
    }

    function drawCombatZones() {
      ctx.save();
      const isIntermission = enemies.length === 0 && enemiesLeftToSpawn === 0;
      for (let i = combatZones.length - 1; i >= 0; i--) {
        const z = combatZones[i];
        const alpha = (z.life / 600) * (isIntermission ? 0.4 : 0.15);
        
        const grad = ctx.createRadialGradient(z.x, z.y, 0, z.x, z.y, 40 * z.intensity);
        const color = z.type === 'red' ? '239, 68, 68' : '129, 140, 248';
        
        grad.addColorStop(0, `rgba(${color}, ${alpha})`);
        grad.addColorStop(1, `rgba(${color}, 0)`);
        
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(z.x, z.y, 40 * z.intensity, 0, Math.PI * 2);
        ctx.fill();
        
        if (!isPaused) z.life--;
        if (z.life <= 0) combatZones.splice(i, 1);
      }
      ctx.restore();
    }

    function showCanvasToast(msg, type = 'info') {
      const isResource = msg.includes('Acero') || msg.includes('Táctica') || msg.includes('acero');
      // Accelerate fade of existing toasts of the same "zone"
      for (let i = 0; i < canvasToasts.length; i++) {
        const t = canvasToasts[i];
        const tIsResource = t.msg.includes('Acero') || t.msg.includes('Táctica') || t.msg.includes('acero');
        if (tIsResource === isResource) t.life = Math.min(t.life, 30);
      }
      
      canvasToasts.push({
        msg,
        type,
        life: 100, 
        yOffset: 0,
        isResource
      });
    }

