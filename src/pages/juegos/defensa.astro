    function executeMeteorStrike() {
      if (towers.length === 0) {
        health -= GAME_CONFIG.events.meteorCityDamage; 
        updateHUD();
        createExplosion(canvas.width / 2, canvas.height / 2, '#EF4444', 50);
        showCanvasToast(`¡Impacto en la Ciudadela! (-${GAME_CONFIG.events.meteorCityDamage} HP)`, 'error');
        addScreenShake(20);
        addScreenFlash(0.4, '#EF4444'); // AAA: Big red flash on city damage
        if (health <= 0) gameOver();
        return;
      }

      // Damage random tower instead of destroying it instantly
      const targetIndex = Math.floor(Math.random() * towers.length);
      const t = towers[targetIndex];
      const damage = GAME_CONFIG.events.meteorTowerDamage; 
      
      createExplosion(t.x, t.y, '#EF4444', 40); 
      addFloatingText(t.x, t.y - 30, `-${damage} ¡IMPACTO!`, '#EF4444', 'large');
      
      applyDamageToTower(t, damage);
      
      updateHUD();
      addScreenShake(15);
      playSFX('explosion');
    }

    function executeBonusDrop() {
      const dropCount = Math.floor(Math.random() * 3) + 2; 
      const types = ['abyssal_rune', 'upgrades', 'heal', 'freeze', 'frenzy', 'nuke']; 

      for (let i = 0; i < dropCount; i++) {
        const type = types[Math.floor(Math.random() * types.length)];
        bonuses.push({
          x: Math.random() * (canvas.width - 250) + 125, // Centered horizontally
          y: Math.random() * (canvas.height - 150) + 75, // Centered vertically, avoid HUD
          vx: (Math.random() - 0.5) * (1 + wave * 0.2), 
          vy: (Math.random() - 0.5) * (1 + wave * 0.2),
          life: 300, 
          type: type,
          reward:
            type === 'upgrades' || type === 'abyssal_rune'
              ? GAME_CONFIG.events.bonusRewardBase + Math.random() * GAME_CONFIG.events.bonusRewardRandom
              : 0,
        });
      }
      showCanvasToast('¡Recupera el botín antes de que desaparezca!', 'info');
    }

    function calculateBalancedDamage(damage, sourceTower = null) {
      let finalDamage = damage;
      const threshold = wave + 1;
      
      // --- DIMINISHING RETURNS ON DAMAGE (WAVE 25+) ---
      if (damage > threshold) {
        finalDamage = wave + threshold * 0.3;
      }
      
      // Splash penalty
      if (sourceTower && sourceTower.type === 'splash') {
        finalDamage *= 0.6;
      }
      
      return finalDamage;
    }

    function applyDamageToEnemy(e, damage, color, sourceTower = null) {
      e.noDamageTimer = 0; // Reset sprint timer

      // Apply unified balancing logic
      let finalDamage = calculateBalancedDamage(damage, sourceTower);
  
      if (e.shield && e.shield > 0) {
        const shieldDamage = Math.min(e.shield, finalDamage);
        e.shield -= shieldDamage;
        finalDamage -= shieldDamage;
        addFloatingText(e.x, e.y - 15, `-${Math.round(shieldDamage)} (Escudo)`, '#60A5FA');
        createExplosion(e.x, e.y, '#60A5FA', 3);
        if (e.shield <= 0) {
          e.color = e.originalColor || e.color;
          addFloatingText(e.x, e.y - 25, 'Escudo Roto', '#9CA3AF');
        }
      }

      if (finalDamage > 0) {
        e.hp -= finalDamage;
        addFloatingText(e.x, e.y - 10, `-${Math.round(finalDamage)}`, color || '#FCD34D');
        addCombatZone(e.x, e.y, 1, 'red'); // Action point
      }

      if (e.hp <= 0) {
        addCombatZone(e.x, e.y, 2, 'red'); // Significant kill point
        const index = enemies.indexOf(e);
        if (index > -1) {
          if (inspectedEnemy === e) inspectedEnemy = null;
          
          // --- TENSION REWARD SYSTEM ---
          const tension = getTensionFactor();
          const tensionBonus = Math.max(0, (tension - 1.0) * GAME_CONFIG.economy.tensionRewardMultiplier);
          const finalReward = e.reward * (1 + tensionBonus);
          
          abyssals += finalReward;
          upgrades += GAME_CONFIG.economy.tactics.killReward || 0; // Tactic reward per kill
          
          if (tensionBonus > 0.1) {
            addFloatingText(e.x, e.y - 30, `+${formatNumber(finalReward)}a (TENSIÓN!)`, '#94A3B8', 'normal');
          }
          
          addKillCombo();
          
          // Bloodlust Mechanic (Power Trip)
          globalBloodlust++;
          if (globalBloodlust >= BLOODLUST_THRESHOLD) {
            globalBloodlust = 0;
            bloodlustTimer = GAME_CONFIG.balance.bloodlustDuration; 
            bloodlustSource = { x: e.x, y: e.y }; // AAA: Record triggering kill position
            showCanvasToast('¡FRENESÍ DE SANGRE ACTIVADO!', 'success');
            playSFX('start');
            addScreenShake(25); // BIG SHAKE
            
            // Visual feedback for activation
            for (let i = 0; i < 20; i++) {
              particles.push({
                x: canvas.width / 2 + (Math.random() - 0.5) * 400,
                y: canvas.height / 2 + (Math.random() - 0.5) * 300,
                vx: (Math.random() - 0.5) * 10,
                vy: (Math.random() - 0.5) * 10,
                life: 60,
                color: '#EF4444',
                size: 4 + Math.random() * 6
              });
            }
          }

          // Veterancy System (Enhanced Feedback)
          if (sourceTower) {
            sourceTower.kills = (sourceTower.kills || 0) + 1;
            sourceTower.veterancy = (sourceTower.veterancy || 1) + 1;
            sourceTower.damage *= GAME_CONFIG.balance.veterancyDamageBonus;

            // Auto Level Up (Evolution)
            if (sourceTower.veterancy > GAME_CONFIG.balance.veterancyKillsPerLevel) {
              sourceTower.veterancy = 1;
              sourceTower.level = (sourceTower.level || 1) + 1;
              sourceTower.damage *= GAME_CONFIG.balance.levelUpDamageBonus; 
              sourceTower.maxHp += 5; // More HP on level up
              sourceTower.hp = Math.min(sourceTower.maxHp, sourceTower.hp + 5);
              
              addFloatingText(sourceTower.x, sourceTower.y - 35, '¡EVOLUCIÓN!', '#F59E0B', 'buff');
              createExplosion(sourceTower.x, sourceTower.y, '#F59E0B', 20); // BIGGER EXPLOSION
              addCombatZone(sourceTower.x, sourceTower.y, 4, 'blue'); 
              addScreenShake(10);
            } else {
              addFloatingText(sourceTower.x, sourceTower.y - 25, '+1 ⭐', '#FCD34D', 'normal');
              createExplosion(sourceTower.x, sourceTower.y, '#FCD34D', 8);
            }
          }

          // Random rune drop on enemy death (10% chance for normal, 100% for boss)
          if (e.isBoss || Math.random() > 0.9) {
            const types = ['abyssal_rune', 'heal', 'freeze', 'frenzy', 'nuke'];
            const type = types[Math.floor(Math.random() * types.length)];
            bonuses.push({
              x: e.x,
              y: e.y,
              vx: (Math.random() - 0.5) * 4, // Faster drops
              vy: (Math.random() - 0.5) * 4,
              life: 300,
              type: type,
              reward: type === 'abyssal_rune' ? 1 + Math.random() * 2 : 0, // Higher rune rewards
            });
          }

          if (e.isBoss) {
            addScreenShake(30);
            showCanvasToast(`¡COMANDANTE CAÍDO! +${formatNumber(finalReward)} Acero`, 'success');
          } else {
            addScreenShake(2); // Small shake for every kill
          }

          enemies.splice(index, 1);
          updateHUD();
          createExplosion(e.x, e.y, e.color, 10);

          if (isCityFallen && enemies.length === 0) {
            gameOver();
          }
        }
      }
    }

    function addFloatingText(x, y, text, color = '#FFFFFF', type = 'normal') {
      if (floatingTexts.length > 50) floatingTexts.shift(); // Slightly higher limit
      
      // Offset damage numbers so they don't cover characters
      let finalX = x;
      let finalY = y;
      
      if (type === 'normal') {
        finalX += (Math.random() - 0.5) * 30; // Random horizontal spread
        finalY -= 5 + Math.random() * 10;     // Random vertical offset
      }

      const speed = type === 'large' || type === 'buff' ? 1.2 : 0.8;
      
      floatingTexts.push({ 
        x: finalX, 
        y: finalY, 
        text, 
        color, 
        life: type === 'large' ? 100 : 70, 
        maxLife: type === 'large' ? 100 : 70,
        vx: (Math.random() - 0.5) * 0.6,
        vy: -speed, 
        type,
        phase: Math.random() * Math.PI * 2,
        freq: 0.08 + Math.random() * 0.05,
        scale: 0.5 // Start small for pop effect
      });
    }

    function addScreenShake(intensity = 10) {
      screenShake = Math.max(screenShake, intensity);
    }

    // --- RENDER & LOGIC ---
    let lastTime = 0;
    function gameLoop(timestamp) {
      lastTime = timestamp;

      if (gameState === 'playing' && !isPaused) {
        update();
        if (isTurbo) update(); // Double update for Turbo mode
      }
      draw();
      requestAnimationFrame(gameLoop);
    }

    function update() {
      // Common Scaling Variables for the entire update cycle
      const currentEnemyLevel = wave <= 7 ? 1 : wave - 6;
      const tension = getTensionFactor();
      const { hp: introHPMultiplier, dmg: introDmgMultiplier } = getWaveMultipliers();
      
      // Density Compensation (Approximation for entities spawned during update)
      // We cap at 15 enemies normally, so we use that ratio
      const approxEnemyCount = Math.min(GAME_CONFIG.balance.enemyMaxCount, 5 + Math.floor(wave / 2));
      const densityCompensation = wave > 0 ? Math.max(1.0, wave / approxEnemyCount) : 1.0;

      // Passive upgrades generation + limit drain
      if (
        gameState === 'playing' &&
        wave > 0 &&
        !isPaused &&
        (enemies.length > 0 || enemiesLeftToSpawn > 0)
      ) {
        // Random Event Chance (During wave)
        if (Math.random() < GAME_CONFIG.events.randomEventChance) { 
           triggerRandomEvent();
        }

        passiveUpgradesTimer++;
        if (passiveUpgradesTimer >= 60) {
          passiveUpgradesTimer = 0;
          
          // Passive generation (Small numbers scale)
          // Táctica (~0.1 per second)
          if (upgrades < (GAME_CONFIG.economy.tactics.genThreshold || 40)) { 
            upgrades += (GAME_CONFIG.economy.tactics.passiveGen || 0.1); 
          } else if (upgrades >= (GAME_CONFIG.economy.tactics.drainThreshold || 50)) {
            upgrades -= (GAME_CONFIG.economy.tactics.drainRate || 0.05);
          }

          // Acero (~0.15 per second)
          abyssals += (GAME_CONFIG.economy.steel.passiveGen || 0.1); 

          if (abyssals >= (GAME_CONFIG.economy.steel.drainThreshold || 60)) {
            abyssals -= (GAME_CONFIG.economy.steel.drainRate || 0.05);
          }
          updateHUD();
        }
      }

      // Check Game Over by starvation (No towers + No money to buy any tower)
      if (
        towers.length === 0 &&
        abyssals < getTowerCost('basic') &&
        wave > 0 &&
        gameState === 'playing' &&
        !isCityFallen
      ) {
        health = 0;
        isCityFallen = true;
        showCanvasToast('¡RECURSOS AGOTADOS! La Ciudadela ha quedado indefensa.', 'error');
        addScreenShake(30);
        playSFX('error');
      }

      // Dark Rune Spawner
      if (wave > 0 && enemies.length > 0 && !isPaused) {
        darkRuneTimer++;
        if (darkRuneTimer >= GAME_CONFIG.events.darkRuneFrequency) {
          darkRuneTimer = 0;
          if (path.length > 3) {
            // Pick a node closer to the start (between 2nd and 4th node)
            const maxNode = Math.min(path.length - 1, 4);
            const node = path[Math.floor(Math.random() * (maxNode - 1)) + 1];

            const types = ['power', 'shield', 'haste', 'heal'];
            const type = types[Math.floor(Math.random() * types.length)];

            darkRunes.push({ x: node.x, y: node.y, life: 1200, type }); // 20 seconds life
            showCanvasToast(`¡Marca de la Plaga (${type}) detectada!`, 'error');
            playSFX('error');
          }
        }
      }

      // Update dark runes
      for (let i = darkRunes.length - 1; i >= 0; i--) {
        let r = darkRunes[i];
        if (enemies.length > 0 && !isEventActive) r.life--;
        if (r.life <= 0) darkRunes.splice(i, 1);
      }

      // Move enemies
      for (let i = enemies.length - 1; i >= 0; i--) {
        let e = enemies[i];

        // Check Clone Expiration
        if (e.isClone && e.lifeTimer > 0) {
          e.lifeTimer--;
          if (e.lifeTimer <= 0) {
            createExplosion(e.x, e.y, e.color, 10);
            addFloatingText(e.x, e.y - 20, 'Desvanecido', '#9CA3AF');
            enemies.splice(i, 1);
            continue;
          }
        }

        // Check Dark Power expiration
        if (e.darkPowerTimer > 0) {
          e.darkPowerTimer--;
          if (e.darkPowerTimer <= 0) {
            e.attackRange /= 2;
            e.cooldownMultiplier = 1;
            e.speed *= 2;
            e.color = e.originalColor || e.color;
            addFloatingText(e.x, e.y - 25, 'Poder Desvanecido', '#9CA3AF');
          }
        }

        // Check Haste expiration
        if (e.hasteTimer > 0) {
          e.hasteTimer--;
          if (e.hasteTimer <= 0) {
            e.speed /= 2;
            e.color = e.originalColor || e.color;
            addFloatingText(e.x, e.y - 25, 'Celeridad Desvanecida', '#9CA3AF');
          }
        }

        // Last Enemy Frenzy
        if (enemies.length === 1 && enemiesLeftToSpawn <= 0 && !e.hasFrenzy) {
          e.hasFrenzy = true;
          e.speed *= 2.5;
          e.damage *= 1.5;
          e.color = '#F43F5E';
          addFloatingText(e.x, e.y - 20, '¡ÚLTIMO ALIENTO!', '#F43F5E', 'buff');
          showCanvasToast('¡El último enemigo saltó en furia!', 'error');
          addScreenShake(15);
          playSFX('error');
        }
        let target = path[e.pathIndex + 1];

        if (!target) {
          // Reached end
          if (!isCityFallen) {
            health -= 2; // Small numbers: -2 HP per escape (from 100 total)
            if (health <= 0) {
              isCityFallen = true;
              health = 0;
              showCanvasToast('¡La Ciudadela ha sido destruida!', 'error');
              addScreenShake(30);
              playSFX('error');
            } else {
              waveTookDamage = true;
              upgrades = Math.max(0, upgrades - GAME_CONFIG.economy.tactics.escapePenalty); 
              showCanvasToast(`¡Enemigo escapó! -2 HP, -${GAME_CONFIG.economy.tactics.escapePenalty}t`, 'error');
              addScreenShake(10); 
              playSFX('error');
            }
          }

          if (isCityFallen) {
            // Drain tactics for every enemy that arrives after falling
            upgrades = Math.max(0, upgrades - GAME_CONFIG.economy.tactics.fallPenalty);
            addFloatingText(e.x, e.y - 20, `-${GAME_CONFIG.economy.tactics.fallPenalty}t`, '#EF4444');
          }

          if (inspectedEnemy === e) inspectedEnemy = null;
          enemies.splice(i, 1);
          updateHUD();
          createExplosion(e.x, e.y, '#EF4444');

          // Check if it's game over time (city fallen AND no more enemies)
          if (isCityFallen && enemies.length === 0) {
            gameOver();
          }

          continue;
        }

        // Check collision with darkRunes
        for (let j = darkRunes.length - 1; j >= 0; j--) {
          const r = darkRunes[j];
          const dxR = e.x - r.x;
          const dyR = e.y - r.y;
          if (dxR * dxR + dyR * dyR < 900) { // 30^2 = 900
            darkRunes.splice(j, 1);
            if (!e.originalColor) e.originalColor = e.color;
            createExplosion(e.x, e.y, '#D946EF', 20);

            if (r.type === 'shield') {
              e.shield = (e.shield || 0) + e.maxHp * 0.5; // 50% max HP shield
              e.color = '#60A5FA'; // Blue shield
              addFloatingText(e.x, e.y - 25, '🛡️ Escudo', '#60A5FA', 'buff');
            } else if (r.type === 'haste') {
              if (e.hasteTimer > 0) e.speed /= 2; // Reset current haste speed before re-applying
              e.hasteTimer = 600; // 10 seconds
              e.speed *= 2;
              e.color = '#FCD34D'; // Yellow haste
              addFloatingText(e.x, e.y - 25, '⚡ Celeridad', '#FCD34D', 'buff');
            } else if (r.type === 'heal') {
              e.hp = Math.min(e.maxHp, e.hp + 5); // Fixed small heal
              // Area heal for nearby enemies
              for (let k = 0; k < enemies.length; k++) {
                const other = enemies[k];
                const dxH = e.x - other.x;
                const dyH = e.y - other.y;
                if (dxH * dxH + dyH * dyH < 10000) { // 100^2 = 10000
                  other.hp = Math.min(other.maxHp, other.hp + 2);
                  addFloatingText(other.x, other.y - 15, '+❤️', '#10B981');
                }
              }
              e.color = '#10B981'; // Green heal
              addFloatingText(e.x, e.y - 25, '💚 Sanación', '#10B981', 'buff');
            } else {
              // Default: 'power'
              if (e.darkPowerTimer > 0) {
                e.attackRange /= 2;
                e.speed *= 2;
              }
              e.darkPowerTimer = 600; // 10 seconds duration
              e.attackRange *= 2;
              e.cooldownMultiplier = 0.5;
              e.speed *= 0.5;
              e.color = '#D946EF';
              addFloatingText(e.x, e.y - 25, '¡Poder Oscuro!', '#D946EF', 'debuff');
            }
          }
        }

        // Necromancer Ability: Spawn Skeletons
        // Necromancer Ability: Spawn skeletons
        if (e.isNecromancer && !isPaused) {
          e.spawnTimer = (e.spawnTimer || 0) + 1;
          if (e.spawnTimer >= 180) {
            // Every 3 seconds (Accelerated)
            e.spawnTimer = 0;
            const skeletonHp = (2 + currentEnemyLevel * 0.5) * tension * densityCompensation * introHPMultiplier;
            const skeleton = {
              id: 'zombie', 
              x: e.x,
              y: e.y,
              hp: skeletonHp,
              maxHp: skeletonHp,
              speed: 1.5,
              pathIndex: e.pathIndex,
              color: '#F9FAFB', 
              isBoss: false,
              reward: 0,
              level: currentEnemyLevel,
              attackRange: 150,
              basicCooldown: 60,
              maxBasicCooldown: 60,
              basicDamage: 1,
              damage: 1,
              attackType: 'normal',
              lifeTimer: 300, 
              isClone: true,
              noDamageTimer: 0,
              isCasting: 0,
            };
            enemies.push(skeleton);
            
            // Focus redirection: Towers lose focus on the Warlock
            for (let k = 0; k < projectiles.length; k++) {
              if (projectiles[k].target === e) {
                projectiles[k].target = skeleton;
              }
            }

            // Move Warlock to end of array so towers pick skeleton first next frame
            const idx = enemies.indexOf(e);
            if (idx > -1) {
              enemies.splice(idx, 1);
              enemies.push(e);
            }

            createExplosion(e.x, e.y, '#F9FAFB', 6);
            addFloatingText(e.x, e.y, '¡Levántate!', '#F9FAFB', 'buff');
          }
        }

        // Berserker Ability: Rage speed
        if (e.isBerserker) {
          const healthRatio = e.hp / e.maxHp;
          const baseSpeed = (1.5 + currentEnemyLevel * 0.05);
          e.speed = baseSpeed * (1.5 - healthRatio * 0.5); // Faster when low hp
          if (e.slowTimer > 0) e.speed *= 0.5; // Apply slow even to berserkers
        }

        // --- STATUS TIMERS ---
        if (e.slowTimer > 0) {
          e.slowTimer--;
          if (e.slowTimer <= 0) {
            e.speed = e.originalSpeed || e.speed;
            e.originalSpeed = null;
          }
        }

        if (e.dotTimer > 0) {
          e.dotTimer--;
          if (e.dotTimer % 30 === 0) { // Tick every 0.5s
            applyDamageToEnemy(e, 1, '#F97316'); // Fixed small damage
          }
        }

        // Ghost Ability: Translucency
        if (e.isGhost) {
          e.ghostAlpha = (e.ghostAlpha || 0.5) + Math.sin(Date.now() / 200) * 0.05;
        }

        // --- TARGETING (Nearest Tower) ---
        // Refined Targeting: Must be truly within range to interact
        const rangeSq = e.attackRange * e.attackRange;
        let targetTower = null;
        let minDistanceSq = Infinity;

        const towerCount = towers.length;
        for (let i = 0; i < towerCount; i++) {
          const t = towers[i];
          const tdx = e.x - t.x;
          const gh = t.gridHeight || 1;
          const targetY = t.y + ((gh - 1) * GRID_SIZE) / 2;
          const tdy = e.y - targetY;
          const distSq = tdx * tdx + tdy * tdy;

          if (distSq <= rangeSq && distSq < minDistanceSq) {
            minDistanceSq = distSq;
            targetTower = t;
          }
        }

        // --- SPRINT & MOVEMENT ---
        e.noDamageTimer = (e.noDamageTimer || 0) + 1;
        
        if (e.isCasting <= 0) {
          // NOT CASTING: Can move (even if attacking slowly)
          const dx = target.x - e.x;
          const dy = target.y - e.y;
          const dist = Math.hypot(dx, dy);
          
          let moveSpeed = e.speed;
          
          if (targetTower) {
            // IN COMBAT: Advance much slower (25% speed) to stay in range of more towers
            // Logic: If I can attack, I slow down to fully utilize my range
            moveSpeed *= 0.25;
            e.noDamageTimer = 0;
            e.hasSprinted = false; // Reset sprint flag
          } else if (e.noDamageTimer > 180) { // 3s
            // SPRINT: 40% faster when not receiving damage for 3 seconds
            moveSpeed *= 1.4;
            if (!e.hasSprinted) {
              e.hasSprinted = true;
              const typeData = ENEMY_TYPES.find(t => t.id === e.id);
              const quotes = typeData ? typeData.sprintQuotes : ['¡A por ellos!', '¡Rápido!', '¡No paréis!'];
              const quote = quotes[Math.floor(Math.random() * quotes.length)];
              addFloatingText(e.x, e.y - 30, quote, '#FCD34D', 'large');
              playSFX('start');
            }
            if (e.noDamageTimer % 20 === 0) {
              createExplosion(e.x, e.y, '#FCD34D', 2);
            }
          }

          if (dist < moveSpeed) {
            e.x = target.x;
            e.y = target.y;
            e.pathIndex++;
          } else {
            e.x += (dx / dist) * moveSpeed;
            e.y += (dy / dist) * moveSpeed;
          }
        }

        // Enemy attacks towers
        if (e.cooldown > 0 && !isPaused) e.cooldown--;
        if (e.basicCooldown > 0 && !isPaused) e.basicCooldown--;
        
        // --- CASTING LOGIC (Special Attack) ---
        // Refined: Only start casting if target is STILL within range
        if (e.isCasting > 0) {
          e.isCasting--;
          
          // Mechanical fix: If target is destroyed or somehow moves out of range, stop casting
          if (e.castTarget && e.castTarget.hp <= 0) {
            e.isCasting = 0;
            e.castTarget = null;
          }

          if (e.isCasting <= 0 && e.castTarget) {
            // FINISH CASTING: Special Ability!
            if (e.attackType === 'clones') {
              // Shadow Clones: Spawn 2 smaller ghosts that last 3 seconds
              const spawnedClones = [];
              for (let j = 0; j < 2; j++) {
                const clone = {
                  ...e,
                  isCasting: 0,
                  cooldown: 180,
                  basicCooldown: 60,
                  hp: Math.max(1, e.hp / 5),
                  maxHp: Math.max(1, e.hp / 5),
                  isBoss: false,
                  reward: 0,
                  lifeTimer: 180, 
                  isClone: true,
                  x: e.x + (Math.random() - 0.5) * 40,
                  y: e.y + (Math.random() - 0.5) * 40,
                  noDamageTimer: 0,
                };
                enemies.push(clone);
                spawnedClones.push(clone);
              }

              for (let k = 0; k < projectiles.length; k++) {
                if (projectiles[k].target === e && spawnedClones.length > 0) {
                  projectiles[k].target = spawnedClones[Math.floor(Math.random() * spawnedClones.length)];
                }
              }

              const idx = enemies.indexOf(e);
              if (idx > -1) {
                enemies.splice(idx, 1);
                enemies.push(e);
              }

              addFloatingText(e.x, e.y - 30, '¡CLONES DE SOMBRA!', '#D946EF', 'large');
              playSFX('ghost');
            } else {
              // Projectile Special Attacks
              enemyProjectiles.push({
                x: e.x,
                y: e.y,
                target: e.castTarget,
                targetY: e.castTargetY,
                speed: e.attackType === 'axe' ? 7 : 4,
                damage: e.damage * 2.5, // Special deals more damage
                color: e.color,
                attackType: e.attackType,
              });
              if (e.attackType === 'inferno') playSFX('explosion');
              else if (e.attackType === 'plague') playSFX('hit_shield');
              else playSFX('shoot');
            }
            e.cooldown = e.maxCooldown || 360;
            e.castTarget = null;
          }
          continue; 
        }

        // Logic for basic and starting special attacks
        if (targetTower) {
          const gh = targetTower.gridHeight || 1;
          const targetY = targetTower.y + ((gh - 1) * GRID_SIZE) / 2;

          // Check for Special Attack first
          const abilityRangeSq = (e.abilityRange || 100) * (e.abilityRange || 100);
          if (e.cooldown <= 0 && minDistanceSq <= abilityRangeSq) {
            const baseType = ENEMY_TYPES.find(t => t.id === e.id);
            e.isCasting = baseType ? baseType.castTime : 180;
            e.maxCooldown = baseType ? baseType.cooldown : 360;
            e.castTarget = targetTower;
            e.castTargetY = targetY;
            
            // Show custom quote if available
            if (baseType && baseType.quote) {
              addFloatingText(e.x, e.y - 35, baseType.quote, e.color, 'large');
            } else {
              addFloatingText(e.x, e.y - 20, '¡CANALIZANDO!', e.color, 'normal');
            }
            continue; 
          }
          
          // Basic Attack while not casting and on basic cooldown
          if (e.basicCooldown <= 0) {
            enemyProjectiles.push({
              x: e.x,
              y: e.y,
              target: targetTower,
              targetY: targetY,
              speed: 5,
              damage: e.basicDamage || 10,
              color: e.color,
              attackType: 'normal',
            });
            e.basicCooldown = e.maxBasicCooldown || 60;
            playSFX('shoot');
          }
        }
      }

      // Update Bloodlust timer
      if (bloodlustTimer > 0) bloodlustTimer--;

      // Towers shoot
      for (let i = 0; i < towers.length; i++) {
        const t = towers[i];
        if (t.buffs.freeze > 0) {
          t.buffs.freeze--;
          continue; // Frozen towers can't shoot
        }

        if (t.buffs.doubleShot > 0) {
          t.buffs.doubleShot--;
        }

        if (t.buffs.steelShield > 0) {
          t.buffs.steelShield--;
        }

        if (t.buffs.weakened > 0) t.buffs.weakened--;
        if (t.buffs.blinded > 0) t.buffs.blinded--;
        if (t.buffs.rusted > 0) t.buffs.rusted--;

        if (t.cooldown > 0) t.cooldown--;
        else {
          const gh = t.gridHeight || 1;
          const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;

          // Range logic
        let effectiveRange = t.range;
        if (t.buffs.blinded > 0) effectiveRange *= 0.6;
        if (t.type === 'sniper' && t.isPaired) effectiveRange *= t.synergyBonus;
        
        const rangeSq = effectiveRange * effectiveRange;

          // Find target based on role
          let target = null;
          if (t.isHealer) {
            // RESTRICTION: Healers only work during active waves
            if (enemies.length === 0) continue;

            // Find most damaged nearby tower
            let minHpRatio = 1;
            for (let j = 0; j < towers.length; j++) {
              const other = towers[j];
              if (other === t) continue;
              const dx = other.x - t.x;
              const ghOther = other.gridHeight || 1;
              const vyOther = other.y + ((ghOther - 1) * GRID_SIZE) / 2;
              const dy = vyOther - visualY;
              if (dx * dx + dy * dy <= rangeSq) {
                const ratio = other.hp / other.maxHp;
                if (ratio < 1 && ratio < minHpRatio) {
                  minHpRatio = ratio;
                  target = other;
                }
              }
            }
          } else {
            // Find nearest enemy
            let minDistanceSq = Infinity;
            for (let j = 0; j < enemies.length; j++) {
              const e = enemies[j];
              const dx = e.x - t.x;
              const dy = e.y - visualY;
              // Fast distance check
              if (Math.abs(dx) > effectiveRange || Math.abs(dy) > effectiveRange) continue;
              
              const distSq = dx * dx + dy * dy;
              if (distSq <= rangeSq && distSq < minDistanceSq) {
                minDistanceSq = distSq;
                target = e;
              }
            }
          }

          if (target) {
            const isCrit = Math.random() < (t.critChance || 0.1);
            let finalValue = isCrit ? t.damage * 2 : t.damage;
            
            // --- SYNERGY POWER BONUS ---
            if (t.type === 'nova' && t.isPaired) {
              finalValue *= t.synergyBonus;
            }
            
            // --- BLOODLUST DAMAGE BONUS ---
            if (bloodlustTimer > 0) {
              finalValue *= GAME_CONFIG.balance.bloodlustDamageMultiplier;
            }
            
            // Apply Debuffs only if not healing (or maybe they affect heal too?)
            if (!t.isHealer) {
              if (t.buffs.weakened > 0) finalValue *= 0.6;
              if (t.buffs.rusted > 0) finalValue *= 0.4;
            }
            
            if (isCrit) {
              const quote = t.quotes[Math.floor(Math.random() * t.quotes.length)];
              addFloatingText(t.x, visualY - 40, `¡CRÍTICO! ${quote}`, '#EF4444', 'large'); // More pronounced
              addScreenShake(6); // More shake
              addScreenFlash(0.1, t.color); // AAA: Subtle flash on crit
              playSFX('hit_shield');
              
              // Extra critical hit particles
              for (let i = 0; i < 5; i++) {
                particles.push({
                  x: t.x,
                  y: visualY,
                  vx: (Math.random() - 0.5) * 6,
                  vy: (Math.random() - 0.5) * 6,
                  life: 30,
                  color: '#EF4444',
                  size: 2
                });
              }
            }

            // --- SPECIAL ABILITY LOGIC ---
            const stats = TOWER_STATS[t.type];
            if (stats.specialThreshold) {
              t.shotsFired = (t.shotsFired || 0) + 1;

              if (inspectedTower === t) {
                const percent = Math.min(100, (t.shotsFired / stats.specialThreshold) * 100);
                const vetBar = document.getElementById('inspect-vet-bar');
                if (vetBar) {
                  vetBar.style.width = `${percent}%`;
                  vetBar.className = percent >= 100 ? 'h-full bg-amber-400 animate-pulse' : 'h-full bg-amber-500';
                }
              }

              if (t.shotsFired >= stats.specialThreshold) {
                t.shotsFired = 0;
                addFloatingText(t.x, visualY - 40, stats.specialQuote, t.color, 'large');
                createExplosion(t.x, visualY, t.color, 25);
                playSFX('start');
                
                if (t.type === 'basic') {
                  t.buffs.doubleShot = 180;
                } else if (t.type === 'sniper') {
                  applyDamageToEnemy(target, t.damage * 4, '#FCD34D', t);
                  addScreenShake(6);
                } else if (t.type === 'splash') {
                  for (let j = 0; j < 3; j++) {
                    const ox = (Math.random() - 0.5) * 80;
                    const oy = (Math.random() - 0.5) * 80;
                    setTimeout(() => {
                      createExplosion(target.x + ox, target.y + oy, '#EF4444', 20);
                      const targetX = target.x + ox;
                      const targetY = target.y + oy;
                      for (let k = 0; k < enemies.length; k++) {
                        const en = enemies[k];
                        const dxE = en.x - targetX;
                        const dyE = en.y - targetY;
                        if (dxE * dxE + dyE * dyE < 6400) { // 80^2 = 6400
                          applyDamageToEnemy(en, t.damage * 0.8, '#EF4444', t);
                        }
                      }
                    }, j * 100);
                  }
                } else if (t.type === 'nova') {
                  // Special Healer: Divine Shield (Mass protection)
                  for (let j = 0; j < towers.length; j++) {
                    const other = towers[j];
                    const dx = other.x - t.x;
                    const dy = other.y - visualY;
                    if (dx * dx + dy * dy <= t.range * t.range * 4) { // double area for special
                      other.buffs.steelShield = 480; // 8 seconds of shield
                      other.hp = Math.min(other.maxHp, other.hp + 2); // Small heal
                      addFloatingText(other.x, other.y - 20, '¡ESCUDO!', '#60A5FA', 'buff');
                      createExplosion(other.x, other.y, '#60A5FA', 15);
                    }
                  }
                }
              }
            }

            if (t.isHealer) {
              // Healer logic: Heal target immediately
              target.hp = Math.min(target.maxHp, target.hp + finalValue);
              addFloatingText(target.x, target.y, `+${Math.round(finalValue)}`, t.color);
              createExplosion(target.x, target.y, t.color, 5);
              playSFX('blessing');
            } else {
              const shoot = (targetObj, damageMod = 1) => {
                let finalSplashRadius = t.splashRadius;
                if (t.type === 'splash' && t.isPaired) finalSplashRadius *= t.synergyBonus;

                projectiles.push({
                  x: t.x,
                  y: visualY,
                  target: targetObj,
                  speed: t.isNova ? 15 : 8,
                  damage: finalValue * damageMod,
                  color: t.color,
                  splash: t.splash,
                  splashRadius: finalSplashRadius,
                  isNova: t.isNova,
                  isSlow: t.isSlow,
                  slowDuration: t.slowDuration,
                  isDoT: t.isDoT,
                  dotDuration: t.dotDuration,
                  sourceTower: t, 
                  isCrit: isCrit,
                });
              };

              shoot(target);

            // Projectile Limit for performance (Strict limit during high activity)
            if (projectiles.length > 300) {
              projectiles.shift(); // Remove oldest projectile
            }

            if (t.buffs.steelShield > 0) {
                const sRangeSq = t.range * t.range;
                let secondaryTarget = null;
                for (let j = 0; j < enemies.length; j++) {
                  const e = enemies[j];
                  if (e === target) continue;
                  const dx = e.x - t.x;
                  const dy = e.y - visualY;
                  if (dx * dx + dy * dy <= sRangeSq) {
                    secondaryTarget = e;
                    break;
                  }
                }
                if (secondaryTarget) shoot(secondaryTarget, 0.7);
              }
              playSFX('shoot');
            }

            let fireRateBonus = 1;
            if (t.buffs.doubleShot > 0) fireRateBonus *= 0.5;
            if (bloodlustTimer > 0) fireRateBonus *= GAME_CONFIG.balance.bloodlustFireRate;
            
            t.cooldown = Math.floor(t.fireRate * fireRateBonus);
          }
        }
      }

      // Move projectiles
      for (let i = projectiles.length - 1; i >= 0; i--) {
        let p = projectiles[i];
        if (!enemies.includes(p.target)) {
          projectiles.splice(i, 1);
          continue;
        }

        const dx = p.target.x - p.x;
        const dy = p.target.y - p.y;
        const dist = Math.hypot(dx, dy);

        if (dist < p.speed) {
          // Hit
          if (p.splash) {
            createExplosion(p.target.x, p.target.y, p.color, 3);
            if (p.isNova) playSFX('hit_shield');
            else playSFX('hit');

            // Damage all enemies in radius using fast squared distance
            const sqSplash = p.splashRadius * p.splashRadius;
            const tx = p.target.x;
            const ty = p.target.y;
            
            for (let j = enemies.length - 1; j >= 0; j--) {
              let e2 = enemies[j];
              const dx2 = e2.x - tx;
              const dy2 = e2.y - ty;
              if (dx2 * dx2 + dy2 * dy2 <= sqSplash) {
                // Ghost Damage Mitigation: 50% chance to miss
                if (e2.isGhost && Math.random() > 0.5) {
                  addFloatingText(e2.x, e2.y - 10, '¡Evasión!', '#94A3B8', 'normal');
                } else {
                  applyDamageToEnemy(e2, p.damage, '#EF4444', p.sourceTower);
                  
                  // Apply Slow Effect
                  if (p.isSlow) {
                    if (!e2.originalSpeed) e2.originalSpeed = e2.speed;
                    e2.speed = e2.originalSpeed * 0.5;
                    e2.slowTimer = p.slowDuration;
                    addFloatingText(e2.x, e2.y - 20, '❄️', '#60A5FA');
                  }
                  
                  // Apply DoT Effect
                  if (p.isDoT) {
                    e2.dotTimer = p.dotDuration;
                    e2.dotDamage = p.damage * 0.2; // 20% damage per tick
                    addFloatingText(e2.x, e2.y - 25, '🔥', '#F97316');
                  }
                }
              }
            }
          } else {
            // Ghost Damage Mitigation: 50% chance to miss
            if (p.target.isGhost && Math.random() > 0.5) {
              addFloatingText(p.target.x, p.target.y - 10, '¡Evasión!', '#94A3B8', 'normal');
            } else {
              applyDamageToEnemy(p.target, p.damage, '#FCD34D', p.sourceTower);
            }
            createExplosion(p.target.x, p.target.y, p.color, 1);
            playSFX('hit');
          }
          projectiles.splice(i, 1);
        } else {
          p.x += (dx / dist) * p.speed;
          p.y += (dy / dist) * p.speed;
        }
      }

      // Move enemy projectiles
      for (let i = enemyProjectiles.length - 1; i >= 0; i--) {
        let p = enemyProjectiles[i];
        if (!towers.includes(p.target)) {
          enemyProjectiles.splice(i, 1);
          continue;
        }

        const dx = p.target.x - p.x;
        const dy = p.targetY - p.y;
        const dist = Math.hypot(dx, dy);

        if (dist < p.speed) {
          // Impact on tower visual center
          applyDamageToTower(p.target, p.damage);
          addFloatingText(p.target.x, p.targetY - 15, `-${Math.round(p.damage)}`, '#EF4444');
          createExplosion(p.target.x, p.targetY, p.color, 2);
          playSFX('hit');

          // Apply effects based on attack type
          if (p.attackType === 'ice') {
            p.target.buffs.freeze = Math.max(p.target.buffs.freeze, 150); // Congelación de 2.5s
            addFloatingText(p.target.x, p.targetY - 25, '❄️', '#60A5FA');
          } else if (p.attackType === 'plague') {
            // Plague Spit: Area DoT balanceado
            const plagueRadius = 80;
            const plagueRadiusSq = plagueRadius * plagueRadius;
            
            for (let j = 0; j < towers.length; j++) {
              const t = towers[j];
              const tgh = t.gridHeight || 1;
              const ty = t.y + ((tgh - 1) * GRID_SIZE) / 2;
              const dx = t.x - p.x;
              const dy = ty - p.targetY;
              const distSq = dx * dx + dy * dy;
              
              if (distSq <= plagueRadiusSq) {
                // Apply weakness instead of direct damage
                t.buffs.weakened = Math.max(t.buffs.weakened || 0, 180); // 3s of weakness
                createExplosion(t.x, ty, '#10B981', 1);
                addFloatingText(t.x, ty - 25, '☠️ PESTE (DEBILITADO)', '#10B981');
              }
            }
            createExplosion(p.x, p.targetY, '#10B981', 8); // Visual area effect
          } else if (p.attackType === 'inferno') {
            // Infernal Impact: Huge area burst around tower
            applyDamageToTower(p.target, p.damage * 1.5); 
            createExplosion(p.target.x, p.targetY, '#EF4444', 6);
            addScreenShake(5);
            addFloatingText(p.target.x, p.targetY - 30, '🔥 IMPACTO INFERNAL', '#F59E0B');
          } else if (p.attackType === 'axe') {
            // Axe Throw: Pure physical burst
            applyDamageToTower(p.target, p.damage * 0.4);
            createExplosion(p.target.x, p.targetY, '#D1D5DB', 1);
            addFloatingText(p.target.x, p.targetY - 20, '🪓', '#D1D5DB');
          }

          enemyProjectiles.splice(i, 1);
        } else {
          p.x += (dx / dist) * p.speed;
          p.y += (dy / dist) * p.speed;
        }
      }

      // Update combo timer
      if (comboTimer > 0) {
        comboTimer--;
        if (comboTimer <= 0) currentCombo = 0; // Reset combo
      }

      if (killComboTimer > 0) {
        killComboTimer--;
        if (killComboTimer <= 0) currentKillCombo = 0;
      }

      if (globalFreezeTimer > 0) globalFreezeTimer--;
      if (globalFrenzyTimer > 0) globalFrenzyTimer--;

      // Update particles
      for (let i = particles.length - 1; i >= 0; i--) {
        let p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.rotationSpeed;
        p.life -= p.decay;
        if (p.life <= 0) {
          particlePool.push(p); // Return to pool
          particles.splice(i, 1);
        }
      }

      // Update bonuses
      for (let i = bonuses.length - 1; i >= 0; i--) {
        let b = bonuses[i];

        // Ethereal movement
        b.x += b.vx;
        b.y += b.vy;

        // Add some slight wobble
        b.vx += (Math.random() - 0.5) * 0.5;
        b.vy += (Math.random() - 0.5) * 0.5;

        // Constraint within playable area (Avoid HUD at bottom and selection panels)
        const minX = 100;
        const maxX = canvas.width - 100;
        const minY = 50;
        const maxY = canvas.height - 100; // Leave space for HUD

        if (b.x < minX) { b.x = minX; b.vx *= -1; }
        if (b.x > maxX) { b.x = maxX; b.vx *= -1; }
        if (b.y < minY) { b.y = minY; b.vy *= -1; }
        if (b.y > maxY) { b.y = maxY; b.vy *= -1; }

        // Speed limit
        const maxSpeed = 2 + wave * 0.3;
        if (Math.abs(b.vx) > maxSpeed) b.vx = Math.sign(b.vx) * maxSpeed;
        if (Math.abs(b.vy) > maxSpeed) b.vy = Math.sign(b.vy) * maxSpeed;

        // Only decay life if we are actively playing and a wave is ongoing
        if (enemies.length > 0 && !isEventActive) {
          b.life--;
        }

        if (b.life <= 0) bonuses.splice(i, 1);
      }
      // Maldiciones aleatorias durante el juego
      if (wave > 0 && enemies.length > 0) {
        curseTimer++;
        if (curseTimer >= curseCooldown) {
          curseTimer = 0;
          curseCooldown = Math.floor(Math.random() * 300) + 400;
          executeCurse();
        }
      }
    }

    function createParticle(x, y, color, size = 4, vx = null, vy = null, isRune = false) {
      if (particles.length >= MAX_PARTICLES) return;
      
      const runes = ['᚛', '᚜', 'ᚠ', 'ᚢ', 'ᚦ', 'ᚨ', 'ᚩ'];
      let p;
      
      if (particlePool.length > 0) {
        p = particlePool.pop();
        p.x = x;
        p.y = y;
        p.vx = vx !== null ? vx : (Math.random() - 0.5) * 8;
        p.vy = vy !== null ? vy : (Math.random() - 0.5) * 8;
        p.life = 1;
        p.decay = Math.random() * 0.03 + 0.02;
        p.color = color;
        p.size = size;
        p.isRune = isRune;
        p.rune = runes[Math.floor(Math.random() * runes.length)];
        p.rotation = Math.random() * Math.PI * 2;
        p.rotationSpeed = (Math.random() - 0.5) * 0.2;
      } else {
        p = {
          x, y,
          vx: vx !== null ? vx : (Math.random() - 0.5) * 8,
          vy: vy !== null ? vy : (Math.random() - 0.5) * 8,
          life: 1,
          decay: Math.random() * 0.03 + 0.02,
          color,
          size,
          isRune,
          rune: runes[Math.floor(Math.random() * runes.length)],
          rotation: Math.random() * Math.PI * 2,
          rotationSpeed: (Math.random() - 0.5) * 0.2,
        };
      }
      particles.push(p);
    }

    function createExplosion(x, y, color, count = 6) {
      // Calculate how many particles we can actually add
      const availableSlots = MAX_PARTICLES - particles.length;
      const actualCount = Math.min(count, availableSlots);

      if (actualCount <= 0) return;

      for (let i = 0; i < actualCount; i++) {
        const isRune = Math.random() > 0.7;
        createParticle(x, y, color, 4, null, null, isRune);
      }
    }

    function drawGauges() {
      // 1. Bloodlust Meter (Top Right)
      if (bloodlustTimer > 0) {
        const x = canvas.width - 160;
        const y = 30;
        const w = 120;
        const h = 10;
        const progress = bloodlustTimer / GAME_CONFIG.balance.bloodlustDuration;
        const pulse = Math.sin(Date.now() / 100) * 0.1;

        ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';
        ctx.fillRect(x - 5, y - 15, w + 10, h + 25);
        
        ctx.fillStyle = '#EF4444';
        ctx.font = 'black 9px sans-serif';
        ctx.textAlign = 'left';
        ctx.fillText('¡FRENESÍ DE SANGRE!', x, y - 5);
        
        ctx.fillStyle = '#374151';
        ctx.fillRect(x, y, w, h);
        
        const grad = ctx.createLinearGradient(x, y, x + w, y);
        grad.addColorStop(0, '#7F1D1D');
        grad.addColorStop(1, '#EF4444');
        ctx.fillStyle = grad;
        ctx.fillRect(x, y, w * progress, h);
        
        // Pulse effect
        ctx.strokeStyle = `rgba(239, 68, 68, ${0.5 + pulse})`;
        ctx.lineWidth = 2;
        ctx.strokeRect(x - 2, y - 2, w + 4, h + 4);
      }

      // 2. Kill Combo Meter (Top Center)
      if (currentKillCombo > 1 && killComboTimer > 0) {
        const x = canvas.width / 2;
        const y = 80;
        const progress = killComboTimer / 60;
        const scale = 1 + (currentKillCombo * 0.05) + Math.sin(Date.now() / 50) * 0.1;
        
        ctx.save();
        ctx.translate(x, y);
        ctx.scale(scale, scale);
        
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        
        // Text Shadow
        ctx.fillStyle = 'rgba(0,0,0,0.5)';
        ctx.font = 'black 24px italic sans-serif';
        ctx.fillText(`${currentKillCombo} COMBO`, 2, 2);
        
        // Main Text
        const grad = ctx.createLinearGradient(-50, 0, 50, 0);
        grad.addColorStop(0, '#FCD34D');
        grad.addColorStop(1, '#F59E0B');
        ctx.fillStyle = grad;
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 3;
        ctx.strokeText(`${currentKillCombo} COMBO`, 0, 0);
        ctx.fillText(`${currentKillCombo} COMBO`, 0, 0);
        
        // Timer Bar under text
        const barW = 80;
        ctx.fillStyle = 'rgba(0,0,0,0.4)';
        ctx.fillRect(-barW / 2, 15, barW, 4);
        ctx.fillStyle = '#FCD34D';
        ctx.fillRect(-barW / 2, 15, barW * progress, 4);
        
        ctx.restore();
      }
    }

    let screenFlash = 0; // AAA: Screen flash intensity
    let flashColor = '#FFFFFF';

    function addScreenFlash(intensity = 0.3, color = '#FFFFFF') {
      screenFlash = intensity;
      flashColor = color;
    }

    function draw() {
      // 1. Clear Screen & Prepare
      ctx.save();
      
      // Handle Screen Shake
      if (screenShake > 0) {
        const dx = (Math.random() - 0.5) * screenShake;
        const dy = (Math.random() - 0.5) * screenShake;
        ctx.translate(dx, dy);
        screenShake *= 0.95; // Slightly slower decay for "heavy" feel
        if (screenShake < 0.1) screenShake = 0;
      }

      // Clear and draw cached background
      ctx.fillStyle = '#0f172a'; // Deeper dark blue
      ctx.fillRect(-50, -50, canvas.width + 100, canvas.height + 100);
      ctx.drawImage(bgCanvas, 0, 0);

      // --- PHASE 0: Ground Effects ---
      drawCombatZones(); // NEW: Heatmap stays on the ground, under towers

      // --- PHASE 1: Draw Entities ---
      drawTowers();
      drawSelectionIndicator(); 
      drawLinks(); 
      drawProjectiles();
      drawParticles();

      // --- PHASE 1.5: Fog of War ---
      if (showFog) drawFog();

      // --- PHASE 1.7: Post-Fog Entities (Visible through fog) ---
      drawEnemies(); 
      drawBonuses(); 
      drawDarkRunes(); 

      // --- PHASE 1.8: AAA Visual Effects (Post-Processing) ---
      drawDynamicLighting(); // GLOW from projectiles/explosions
      
      if (bloodlustTimer > 0) {
        drawBloodlustAura(); // Magical tunnel effect
      }

      // AAA: Screen Flash
      if (screenFlash > 0) {
        ctx.save();
        ctx.globalAlpha = screenFlash;
        ctx.fillStyle = flashColor;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.restore();
        screenFlash *= 0.85;
        if (screenFlash < 0.01) screenFlash = 0;
      }

      // --- PHASE 2: UI Overlays (Always on top) ---
      drawUIBarsAndLevels();
      drawTowerInfoPlate(); 
      drawEnemyInfoPlate(); 
      drawPreviews();
      drawFloatingTexts();
      drawGameStates();
      drawToasts();
      drawInteractionFeedback();
      drawCinematic(); 
      drawGauges(); 

      executeHUDUpdate(); 
      ctx.restore();
    }

    function drawDynamicLighting() {
      ctx.save();
      ctx.globalCompositeOperation = 'screen';
      
      // 1. Projectile Glow
      for (let i = 0; i < projectiles.length; i++) {
        const p = projectiles[i];
        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, 15);
        grad.addColorStop(0, p.color + '66');
        grad.addColorStop(1, p.color + '00');
        ctx.fillStyle = grad;
        ctx.fillRect(p.x - 15, p.y - 15, 30, 30);
      }
      
      // 2. Explosion Glow
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        if (p.life > 0.5) {
          const size = p.size * 5;
          const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, size);
          grad.addColorStop(0, p.color + '33');
          grad.addColorStop(1, p.color + '00');
          ctx.fillStyle = grad;
          ctx.fillRect(p.x - size, p.y - size, size * 2, size * 2);
        }
      }
      
      ctx.restore();
    }

    function drawBloodlustAura() {
      const time = Date.now() / 1000;
      const intensity = (bloodlustTimer / GAME_CONFIG.balance.bloodlustDuration) * 0.6;
      
      ctx.save();
      
      // 1. Deep "Tunnel" Vignette (Centered on source)
      const grad = ctx.createRadialGradient(
        bloodlustSource.x, bloodlustSource.y, canvas.width * 0.05,
        bloodlustSource.x, bloodlustSource.y, canvas.width * 1.5
      );
      grad.addColorStop(0, 'rgba(0,0,0,0)');
      grad.addColorStop(0.4, `rgba(127, 29, 29, ${0.05 * intensity})`);
      grad.addColorStop(0.7, `rgba(185, 28, 28, ${0.2 * intensity})`);
      grad.addColorStop(1, `rgba(0, 0, 0, ${0.7 * intensity})`); 
      
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // 2. Soft Magical Energy Ripples (Smoother expansion)
      ctx.globalCompositeOperation = 'screen';
      const rippleCount = 2;
      for (let i = 0; i < rippleCount; i++) {
        // Cycle time for smooth looping expansion
        const rippleProgress = (time * 0.8 + i * 0.5) % 1.0;
        const rippleRadius = rippleProgress * canvas.width * 1.2;
        const rippleAlpha = Math.sin(rippleProgress * Math.PI) * 0.15 * intensity;
        
        if (rippleAlpha > 0) {
          ctx.beginPath();
          ctx.arc(bloodlustSource.x, bloodlustSource.y, rippleRadius, 0, Math.PI * 2);
          
          // Use thick blurred stroke for "softness"
          ctx.strokeStyle = `rgba(239, 68, 68, ${rippleAlpha})`;
          ctx.lineWidth = 40 * (1 - rippleProgress); // Fade width as it expands
          ctx.shadowBlur = 30 * rippleAlpha;
          ctx.shadowColor = '#EF4444';
          ctx.stroke();
          ctx.shadowBlur = 0;
        }
      }
      ctx.restore();
    }

    function drawSelectionIndicator() {
      const selected = inspectedTower || inspectedEnemy;
      if (!selected) return;
      
      const isTower = towers.includes(selected);
      const gh = isTower ? (selected.gridHeight || 1) : 1;
      const visualY = selected.y + ((gh - 1) * GRID_SIZE) / 2;
      const color = isTower ? '129, 140, 248' : '239, 68, 68'; // Indigo for tower, Red for enemy
      const pulse = 1 + Math.sin(Date.now() / 250) * 0.05;
      const rotation = Date.now() / 1000;
      
      ctx.save();
      
      // 1. Bottom Glow (Ground)
      const groundGrad = ctx.createRadialGradient(selected.x, visualY, 0, selected.x, visualY, GRID_SIZE * 1.2);
      groundGrad.addColorStop(0, `rgba(${color}, 0.2)`);
      groundGrad.addColorStop(0.7, `rgba(${color}, 0.05)`);
      groundGrad.addColorStop(1, `rgba(${color}, 0)`);
      ctx.fillStyle = groundGrad;
      ctx.beginPath();
      ctx.ellipse(selected.x, visualY, GRID_SIZE * 1.2 * pulse, GRID_SIZE * 0.6 * pulse, 0, 0, Math.PI * 2);
      ctx.fill();

      // 2. Magical Rings
      ctx.lineWidth = 1.5;
      
      // Outer Dotted Ring
      ctx.strokeStyle = `rgba(${color}, 0.4)`;
      ctx.setLineDash([4, 4]);
      ctx.lineDashOffset = -Date.now() / 40;
      ctx.beginPath();
      ctx.arc(selected.x, visualY, (GRID_SIZE * 0.9) * pulse, 0, Math.PI * 2);
      ctx.stroke();
      
      // Middle Solid Ring
      ctx.setLineDash([]);
      ctx.strokeStyle = `rgba(${color}, 0.2)`;
      ctx.beginPath();
      ctx.arc(selected.x, visualY, (GRID_SIZE * 0.75), 0, Math.PI * 2);
      ctx.stroke();

      // 3. Directional "Runes" / Markers
      for (let i = 0; i < 4; i++) {
        const angle = rotation + (i * Math.PI) / 2;
        const rx = selected.x + Math.cos(angle) * (GRID_SIZE * 0.9 * pulse);
        const ry = visualY + Math.sin(angle) * (GRID_SIZE * 0.9 * pulse);
        
        ctx.fillStyle = `rgba(${color}, 0.8)`;
        ctx.shadowBlur = 10;
        ctx.shadowColor = `rgba(${color}, 1)`;
        
        // Draw small diamond/rune
        ctx.beginPath();
        ctx.moveTo(rx, ry - 4);
        ctx.lineTo(rx + 4, ry);
        ctx.lineTo(rx, ry + 4);
        ctx.lineTo(rx - 4, ry);
        ctx.closePath();
        ctx.fill();
      }
      
      // 4. Selection Bracket Corners (UI Feel)
      const bSize = GRID_SIZE * 0.6;
      const bOffset = GRID_SIZE * 0.7 * pulse;
      ctx.strokeStyle = `rgba(${color}, 0.6)`;
      ctx.lineWidth = 2;
      ctx.shadowBlur = 0;

      // Top Left
      ctx.beginPath();
      ctx.moveTo(selected.x - bOffset, visualY - bOffset + bSize/2);
      ctx.lineTo(selected.x - bOffset, visualY - bOffset);
      ctx.lineTo(selected.x - bOffset + bSize/2, visualY - bOffset);
      ctx.stroke();

      // Top Right
      ctx.beginPath();
      ctx.moveTo(selected.x + bOffset, visualY - bOffset + bSize/2);
      ctx.lineTo(selected.x + bOffset, visualY - bOffset);
      ctx.lineTo(selected.x + bOffset - bSize/2, visualY - bOffset);
      ctx.stroke();

      // Bottom Left
      ctx.beginPath();
      ctx.moveTo(selected.x - bOffset, visualY + bOffset - bSize/2);
      ctx.lineTo(selected.x - bOffset, visualY + bOffset);
      ctx.lineTo(selected.x - bOffset + bSize/2, visualY + bOffset);
      ctx.stroke();

      // Bottom Right
      ctx.beginPath();
      ctx.moveTo(selected.x + bOffset, visualY + bOffset - bSize/2);
      ctx.lineTo(selected.x + bOffset, visualY + bOffset);
      ctx.lineTo(selected.x + bOffset - bSize/2, visualY + bOffset);
      ctx.stroke();
      
      ctx.restore();
    }

    function drawInteractionFeedback() {
      if (!lastInteractionPos || lastInteractionPos.life <= 0) return;
      
      const { x, y, radius, life } = lastInteractionPos;
      const alpha = life / 20;
      
      ctx.save();
      ctx.beginPath();
      ctx.arc(x, y, radius * (1 + (20 - life) * 0.05), 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(129, 140, 248, ${alpha})`;
      ctx.lineWidth = 2;
      ctx.stroke();
      
      // Outer ring
      ctx.beginPath();
      ctx.arc(x, y, radius * 0.5 * (life / 20), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(129, 140, 248, ${alpha * 0.2})`;
      ctx.fill();
      
      ctx.restore();
      lastInteractionPos.life--;
    }

    function drawTowerInfoPlate() {
      const container = document.getElementById('unit-info-plate');
      const towerView = document.getElementById('tower-inspect-view');
      const enemyView = document.getElementById('enemy-inspect-view');
      
      // AAA: Allow inspection of selected tower type before placement
      let t = inspectedTower;
      let isPreview = false;

      if (!t && selectedTowerType && TOWER_STATS[selectedTowerType] && TOWER_STATS[selectedTowerType].name) {
        isPreview = true;
        const stats = TOWER_STATS[selectedTowerType];
        const waveFactor = Math.max(0, wave - 1);
        const inflation = 1 + waveFactor * GAME_CONFIG.economy.steel.inflation;
        const startingLevel = 1 + Math.floor(wave / 5);
        const levelStatsMultiplier = Math.pow(GAME_CONFIG.balance.levelUpDamageBonus, startingLevel - 1);
        
        const scaledHp = Math.round(stats.hp * inflation * levelStatsMultiplier);
        const scaledDamage = stats.damage * inflation * levelStatsMultiplier;
        const scaledRange = stats.range * (1 + (startingLevel - 1) * 0.08);

        t = {
          ...stats,
          level: startingLevel,
          veterancy: 1,
          kills: 0,
          hp: scaledHp,
          maxHp: scaledHp,
          damage: scaledDamage,
          range: scaledRange,
          buffs: { steelShield: 0, doubleShot: 0, freeze: 0, weakened: 0, blinded: 0, rusted: 0 },
          isPreview: true,
          type: selectedTowerType
        };
      }

      if (!t) {
        if (towerView) towerView.classList.add('hidden');
        if (!inspectedEnemy && container) container.classList.add('hidden');
        return;
      }
      
      if (container) container.classList.remove('hidden');
      if (towerView) towerView.classList.remove('hidden');
      if (enemyView) enemyView.classList.add('hidden');
      
      // OPTIMIZATION: Update DOM only every 10 frames or if tower changed
      const now = Date.now();
      const towerId = isPreview ? `preview-${t.type}` : String(t.x + t.y);
      if (now - lastInspectUpdate < 160 && container.dataset.lastId === towerId) {
        // Just draw the range indicator if not a preview (previews are drawn in loop)
        if (!isPreview) drawRangeIndicator(t);
        return;
      }
      lastInspectUpdate = now;
      container.dataset.lastId = towerId;

      // Update HTML content
      document.getElementById('inspect-name').innerText = isPreview ? `${t.name} (PREVISIÓN)` : t.name;
      document.getElementById('inspect-level').innerText = `Nv.${t.level}`;
      document.getElementById('inspect-stars').innerText = `${t.veterancy - 1}★`;
      
      // AAA FIX: Display balanced/effective damage in the HUD
      const effectiveDmg = calculateBalancedDamage(t.damage, t);
      document.getElementById('inspect-dmg').innerText = formatNumber(effectiveDmg);
      
      document.getElementById('inspect-kills').innerText = formatNumber(t.kills);
      document.getElementById('inspect-range').innerText = Math.round(t.range);
      document.getElementById('inspect-hp-text').innerText = `${formatNumber(t.hp)}/${formatNumber(t.maxHp)}`;
      
      // Synergy visibility
      const synergyEl = document.getElementById('inspect-synergy');
      if (synergyEl) {
        if (!isPreview && t.isPaired) synergyEl.classList.remove('hidden');
        else synergyEl.classList.add('hidden');
      }

      // Update Effects Badges
      const effectsContainer = document.getElementById('inspect-effects');
      let badges = '';
      if (isPreview) {
        badges = '<span class="text-[7px] px-1.5 py-0.5 bg-indigo-900/50 text-indigo-300 rounded border border-indigo-500/30 font-black">🛠️ POR CONSTRUIR</span>';
      } else {
        if (t.buffs.steelShield > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-slate-700 text-slate-200 rounded border border-slate-500/50 font-black">🛡️ REFUERZO</span>';
        if (t.buffs.doubleShot > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-red-900/50 text-red-400 rounded border border-red-500/30 font-black">🔥 FRENESÍ</span>';
        if (t.buffs.freeze > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-cyan-900/50 text-cyan-400 rounded border border-cyan-500/30 font-black">❄️ CONGELADO</span>';
        if (t.buffs.weakened > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-purple-900/50 text-purple-400 rounded border border-purple-500/30 font-black">🥀 DÉBIL</span>';
        if (t.buffs.blinded > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-gray-900/50 text-gray-400 rounded border border-gray-500/30 font-black">👁️ CEGADO</span>';
        if (t.buffs.rusted > 0) badges += '<span class="text-[7px] px-1.5 py-0.5 bg-orange-900/50 text-orange-400 rounded border border-orange-500/30 font-black">⚙️ OXIDADO</span>';
      }
      
      if (effectsContainer.innerHTML !== badges) effectsContainer.innerHTML = badges;
      
      // Update Special Ability Progress Bar
      const stats = TOWER_STATS[t.type];
      const progress = isPreview ? 0 : (stats.specialThreshold ? Math.min(100, ((t.shotsFired || 0) / stats.specialThreshold) * 100) : 0);
      const vetBar = document.getElementById('inspect-vet-bar');
      const abilityPercent = document.getElementById('inspect-ability-percent');
      
      if (vetBar) {
        vetBar.style.width = `${progress}%`;
        if (progress >= 100) {
          vetBar.classList.add('animate-pulse', 'from-amber-400', 'to-yellow-300');
        } else {
          vetBar.classList.remove('animate-pulse', 'from-amber-400', 'to-yellow-300');
        }
      }
      if (abilityPercent) abilityPercent.innerText = `${Math.floor(progress)}%`;

      // Update tooltips and cost labels with current costs
      const repairBtn = document.getElementById('inspect-repair');
      const upgradeBtn = document.getElementById('inspect-upgrade');
      const sellBtn = document.getElementById('inspect-sell');
      const repairCostEl = document.getElementById('inspect-repair-cost');
      const upgradeCostEl = document.getElementById('inspect-upgrade-cost');
      const sellValueEl = document.getElementById('inspect-sell-value');

      if (isPreview) {
        if (repairBtn) repairBtn.parentElement.classList.add('hidden');
        if (upgradeBtn) upgradeBtn.parentElement.classList.add('hidden');
        if (sellBtn) sellBtn.parentElement.classList.add('hidden');
      } else {
        if (repairBtn) repairBtn.parentElement.classList.remove('hidden');
        if (upgradeBtn) upgradeBtn.parentElement.classList.remove('hidden');
        if (sellBtn) sellBtn.parentElement.classList.remove('hidden');

        const repairCost = getTowerCost('repair', t);
        const upgradeCost = getTowerCost('upgrade', t);
        const sellValue = calculateSellValue(t);

        if (repairBtn) repairBtn.title = `Reparar (${formatNumber(repairCost)}t)`;
        if (upgradeBtn) upgradeBtn.title = `Mejorar (${formatNumber(upgradeCost)}t)`;
        if (sellBtn) sellBtn.title = `Vender (${formatNumber(sellValue)}a)`;
        if (repairCostEl) repairCostEl.innerText = `${formatNumber(repairCost)}t`;
        if (upgradeCostEl) upgradeCostEl.innerText = `${formatNumber(upgradeCost)}t`;
        if (sellValueEl) sellValueEl.innerText = `${formatNumber(sellValue)}a`;
      }

      if (!isPreview) drawRangeIndicator(t);
    }

    function drawRangeIndicator(t, isValid = true) {
      // Visual range indicator on canvas with magical tech style
      const gh = t.gridHeight || 1;
      const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
      const color = isValid ? (t.color || '#818CF8') : '#EF4444';
      const pulse = 1 + Math.sin(Date.now() / 300) * 0.03;
      
      ctx.save();
      
      // 1. Outer dashed ring (Basic Attack Range)
      ctx.beginPath();
      ctx.arc(t.x, visualY, (t.range || t.attackRange) * pulse, 0, Math.PI * 2);
      ctx.strokeStyle = color + '44';
      ctx.lineWidth = 2;
      ctx.setLineDash([8, 4]);
      ctx.lineDashOffset = -Date.now() / 30;
      ctx.stroke();

      // 1.1. Inner dashed ring for Enemies (Ability Range)
      if (t.abilityRange) {
        ctx.beginPath();
        ctx.arc(t.x, visualY, t.abilityRange * pulse, 0, Math.PI * 2);
        ctx.strokeStyle = '#F59E0B' + '66'; // Amber color for special ability
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4, 4]);
        ctx.stroke();
      }
      
      // 2. Inner solid faint ring
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.arc(t.x, visualY, (t.range || t.attackRange), 0, Math.PI * 2);
      ctx.strokeStyle = color + '11';
      ctx.lineWidth = 1;
      ctx.stroke();

      // 3. Faint area fill
      ctx.fillStyle = color + '08';
      ctx.fill();

      // 4. Directional "Compass" ticks
      ctx.strokeStyle = color + '66';
      ctx.lineWidth = 2;
      const range = (t.range || t.attackRange);
      for (let i = 0; i < 4; i++) {
        const angle = (i * Math.PI) / 2;
        const sX = t.x + Math.cos(angle) * (range * pulse - 5);
        const sY = visualY + Math.sin(angle) * (range * pulse - 5);
        const eX = t.x + Math.cos(angle) * (range * pulse + 5);
        const eY = visualY + Math.sin(angle) * (range * pulse + 5);
        ctx.beginPath();
        ctx.moveTo(sX, sY);
        ctx.lineTo(eX, eY);
        ctx.stroke();
      }

      ctx.restore();
    }

    function drawLinks() {
      // Draw Synergy Links
      ctx.save();
      ctx.setLineDash([5, 5]);
      ctx.lineWidth = 2;

      // Group by type to draw lines only between paired same-type towers
      const towerGroups = { basic: [], sniper: [], splash: [], nova: [] };
      towers.forEach(t => { if (t.isPaired) towerGroups[t.type].push(t); });

      Object.keys(towerGroups).forEach(type => {
        const group = towerGroups[type];
        if (group.length < 2) return;

        // Draw lines between all paired towers in the group
        for (let i = 0; i < group.length; i++) {
          for (let j = i + 1; j < group.length; j++) {
            const t1 = group[i];
            const t2 = group[j];
            
            const vY1 = t1.y + (((t1.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            const vY2 = t2.y + (((t2.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            
            // Calculate distance to ensure they are the actual pair
            const dx = t2.x - t1.x;
            const dy = vY2 - vY1;
            const distSq = dx * dx + dy * dy;
            
            if (distSq < (t1.range * 1.5) * (t1.range * 1.5)) {
              const grad = ctx.createLinearGradient(t1.x, vY1, t2.x, vY2);
              const color = type === 'basic' ? '#818CF8' : 
                            type === 'sniper' ? '#C084FC' : 
                            type === 'splash' ? '#F87171' : '#34D399';
              
              grad.addColorStop(0, `${color}22`);
              grad.addColorStop(0.5, `${color}88`);
              grad.addColorStop(1, `${color}22`);
              
              ctx.strokeStyle = grad;
              ctx.lineDashOffset = -Date.now() / 40;
              ctx.beginPath();
              ctx.moveTo(t1.x, vY1);
              ctx.lineTo(t2.x, vY2);
              ctx.stroke();
              
              // Draw a small magical node in the middle
              const mx = (t1.x + t2.x) / 2;
              const my = (vY1 + vY2) / 2;
              ctx.fillStyle = color;
              ctx.shadowBlur = 10;
              ctx.shadowColor = color;
              ctx.beginPath();
              ctx.arc(mx, my, 3, 0, Math.PI * 2);
              ctx.fill();
              ctx.shadowBlur = 0;
            }
          }
        }
      });

      ctx.restore();
    }

    function drawFog() {
      if (fogCanvas.width !== canvas.width || fogCanvas.height !== canvas.height) {
        fogCanvas.width = canvas.width;
        fogCanvas.height = canvas.height;
      }

      // 1. Fill with darkness
      fogCtx.globalCompositeOperation = 'source-over';
      fogCtx.fillStyle = 'rgba(0, 0, 0, 0.65)';
      fogCtx.fillRect(0, 0, fogCanvas.width, fogCanvas.height);

      // 2. Clear circles around towers (revealed areas)
      fogCtx.globalCompositeOperation = 'destination-out';
      
      // Always reveal around the start and end of path
      const startRadius = 160;
      const endRadius = 220;
      
      const startGrad = fogCtx.createRadialGradient(path[0].x, path[0].y, 0, path[0].x, path[0].y, startRadius);
      startGrad.addColorStop(0, 'rgba(0,0,0,1)');
      startGrad.addColorStop(1, 'rgba(0,0,0,0)');
      fogCtx.fillStyle = startGrad;
      fogCtx.beginPath();
      fogCtx.arc(path[0].x, path[0].y, startRadius, 0, Math.PI * 2);
      fogCtx.fill();

      const endGrad = fogCtx.createRadialGradient(path[path.length-1].x, path[path.length-1].y, 0, path[path.length-1].x, path[path.length-1].y, endRadius);
      endGrad.addColorStop(0, 'rgba(0,0,0,1)');
      endGrad.addColorStop(1, 'rgba(0,0,0,0)');
      fogCtx.fillStyle = endGrad;
      fogCtx.beginPath();
      fogCtx.arc(path[path.length-1].x, path[path.length-1].y, endRadius, 0, Math.PI * 2);
      fogCtx.fill();

      for (let i = 0; i < towers.length; i++) {
        const t = towers[i];
        const gh = t.gridHeight || 1;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
        const revealRadius = t.range * 1.2; 
        
        const grad = fogCtx.createRadialGradient(t.x, visualY, revealRadius * 0.4, t.x, visualY, revealRadius);
        grad.addColorStop(0, 'rgba(0,0,0,1)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        
        fogCtx.fillStyle = grad;
        fogCtx.beginPath();
        fogCtx.arc(t.x, visualY, revealRadius, 0, Math.PI * 2);
        fogCtx.fill();
      }

      // 3. Draw fog canvas onto main canvas
      ctx.drawImage(fogCanvas, 0, 0);
    }

    function drawEnemyInfoPlate() {
      const container = document.getElementById('unit-info-plate');
      const towerView = document.getElementById('tower-inspect-view');
      const enemyView = document.getElementById('enemy-inspect-view');
      
      if (!inspectedEnemy) {
        if (enemyView) enemyView.classList.add('hidden');
        if (!inspectedTower && !selectedTowerType && container) container.classList.add('hidden');
        return;
      }
      
      const e = inspectedEnemy;
      if (container) container.classList.remove('hidden');
      if (enemyView) enemyView.classList.remove('hidden');
      if (towerView) towerView.classList.add('hidden');
      
      const now = Date.now();
      if (now - lastInspectUpdate < 100) return;
      lastInspectUpdate = now;

      // Update HTML content
      const type = ENEMY_TYPES.find(t => t.id === e.id) || { name: 'Enemigo' };
      document.getElementById('enemy-inspect-name').innerText = e.isBoss ? `★ ${type.name}` : type.name;
      document.getElementById('enemy-inspect-level').innerText = `NV. ${e.level || 1}`;
      document.getElementById('enemy-inspect-type').innerText = e.isBoss ? 'JEFE' : e.isClone ? 'CLON' : 'NORMAL';
      
      const hpPercent = Math.max(0, Math.floor((e.hp / e.maxHp) * 100));
      document.getElementById('enemy-inspect-hp-text').innerText = `${formatNumber(e.hp)}/${formatNumber(e.maxHp)}`;
      document.getElementById('enemy-inspect-hp-bar').style.width = `${hpPercent}%`;
      
      // Calculate visual speed (including sprint and slow)
      let visualSpeed = e.speed;
      if (e.noDamageTimer > 180) visualSpeed *= 1.4;
      document.getElementById('enemy-inspect-speed').innerText = `${visualSpeed.toFixed(1)}x`;

      // Status text
      let statusText = 'ESTABLE';
      let statusColor = 'text-amber-400';
      if (e.slowTimer > 0) { statusText = 'RALENTIZADO'; statusColor = 'text-blue-400'; }
      else if (e.dotTimer > 0) { statusText = 'EN LLAMAS'; statusColor = 'text-orange-500'; }
      else if (e.isCasting > 0) { statusText = 'CANALIZANDO'; statusColor = 'text-purple-400 animate-pulse'; }
      else if (e.noDamageTimer > 180) { statusText = 'ESPRINTANDO'; statusColor = 'text-yellow-400'; }
      
      const statusEl = document.getElementById('enemy-inspect-status');
      statusEl.innerText = statusText;
      statusEl.className = `text-[9px] font-bold italic ${statusColor}`;
    }

    function drawUIBarsAndLevels() {
      // Health Bars and Levels for Towers
      for (let i = 0; i < towers.length; i++) {
        const t = towers[i];
        const gh = t.gridHeight || 1;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2;
        
        // HP Bar
        const barW = t.size * 1.5;
        const barH = 5;
        const barY = visualY + (gh * GRID_SIZE) / 2 - 5;
        
        ctx.fillStyle = 'rgba(0, 0, 0, 0.8)'; // Darker BG
        ctx.fillRect(t.x - barW / 2 - 1, barY - 1, barW + 2, barH + 2);
        ctx.fillStyle = '#1e293b'; // Neutral dark gray background
        ctx.fillRect(t.x - barW / 2, barY, barW, barH);
        ctx.fillStyle = '#34D399'; // Vibrant emerald green for player units
        const hpRatio = Math.min(1, Math.max(0, t.hp / Math.max(1, t.maxHp)));
        ctx.fillRect(t.x - barW / 2, barY, barW * hpRatio, barH);

        // Steel Reinforcement Indicator (Repair Bonus)
        if (t.buffs.steelShield > 0) {
          ctx.strokeStyle = '#60A5FA'; // Light blue for shield
          ctx.lineWidth = 2;
          ctx.strokeRect(t.x - barW / 2 - 2, barY - 2, barW + 4, barH + 4);
        }

        // Debuff Indicators (Runic Style)
        if (t.buffs.weakened > 0 || t.buffs.blinded > 0 || t.buffs.rusted > 0 || t.buffs.freeze > 0) {
          let icon = '';
          let color = '#FFFFFF';
          if (t.buffs.freeze > 0) { icon = '❄️'; color = '#60A5FA'; }
          else if (t.buffs.rusted > 0) { icon = '⚙️'; color = '#94A3B8'; }
          else if (t.buffs.blinded > 0) { icon = '🌫️'; color = '#94A3B8'; }
          else if (t.buffs.weakened > 0) { icon = '📉'; color = '#FCA5A5'; }

          ctx.save();
          ctx.shadowBlur = 10;
          ctx.shadowColor = color;
          ctx.font = '14px serif';
          ctx.textAlign = 'center';
          ctx.fillText(icon, t.x, barY - 45); // Icon only, no box
          ctx.restore();
        }

        // Level and Veterancy Stars (Two Lines)
        const starsCount = t.veterancy - 1;
        const levelLabel = `Nv.${t.level || 1}`;
        
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;

        // Line 1: Level
        ctx.fillStyle = '#FFFFFF';
        ctx.font = '900 11px sans-serif';
        ctx.strokeText(levelLabel, t.x, barY - 8);
        ctx.fillText(levelLabel, t.x, barY - 8);

        // Line 2: Stars
        if (starsCount > 0) {
          ctx.fillStyle = '#FCD34D'; // Golden stars
          ctx.font = '900 12px sans-serif';
          const starsLabel = `${starsCount}★`;
          ctx.strokeText(starsLabel, t.x, barY - 20); // Moved up to barY - 20
          ctx.fillText(starsLabel, t.x, barY - 20);
        }

        // Low Health Alert
        if (t.hp / t.maxHp < 0.3) {
          const blink = Math.sin(Date.now() / 150) > 0;
          if (blink) {
            ctx.fillStyle = '#EF4444';
            ctx.font = 'black 9px sans-serif';
            ctx.fillText('¡REPARAR!', t.x, barY - 60); // Moved up to barY - 60
          }
        }
      }
    }

    function drawTowers() {
      const sortedTowers = towers.slice().sort((a, b) => a.y - b.y);
      const time = Date.now() / 1000;

      for (let i = 0; i < sortedTowers.length; i++) {
        const t = sortedTowers[i];
        const gh = t.gridHeight || 1;
        
        // AAA: Subtle floating/bobbing animation
        const bob = Math.sin(time * 2 + (t.x + t.y) * 0.01) * 3;
        const visualY = t.y + ((gh - 1) * GRID_SIZE) / 2 + bob;
        const barY = visualY + (gh * GRID_SIZE) / 2 - 5;

        // Upgrade Range Expansion Pulse
        if (t.upgradePulse && t.upgradePulse > 0) {
          const oldR = t.oldRange || t.range * 0.9;
          const currentR = oldR + (t.range - oldR) * (1 - t.upgradePulse);
          ctx.beginPath();
          ctx.arc(t.x, visualY, currentR, 0, Math.PI * 2);
          ctx.strokeStyle = '#FCD34D';
          ctx.lineWidth = 3;
          ctx.stroke();
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range, 0, Math.PI * 2);
          ctx.strokeStyle = '#FCD34D33';
          ctx.lineWidth = 1;
          ctx.stroke();
          if (!isPaused) t.upgradePulse -= 0.02;
        }

        // Steel Reinforcement Aura (Repair Bonus)
        if (t.buffs.steelShield > 0) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.size * 1.0, 0, Math.PI * 2); 
          ctx.strokeStyle = '#94A3B8';
          ctx.lineWidth = 2 + Math.sin(Date.now() / 100) * 1;
          ctx.setLineDash([3, 3]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        // Blinded Visual Effect (Cloud/Smoke)
        if (t.buffs.blinded > 0) {
          ctx.save();
          ctx.globalAlpha = 0.7;
          for (let i = 0; i < 5; i++) {
            const time = Date.now() / 1000;
            const angle = time + (i * Math.PI * 2 / 5);
            const cloudX = t.x + Math.cos(angle * 0.8) * (15 + Math.sin(time) * 5);
            const cloudY = visualY - 18 + Math.sin(angle * 1.2) * 8;
            const size = 14 + Math.sin(time * 2 + i) * 4;
            
            const grad = ctx.createRadialGradient(cloudX, cloudY, 0, cloudX, cloudY, size);
            grad.addColorStop(0, 'rgba(15, 23, 42, 0.9)'); // Dark Navy
            grad.addColorStop(0.4, 'rgba(51, 65, 85, 0.6)');
            grad.addColorStop(1, 'rgba(75, 85, 99, 0)');
            
            ctx.fillStyle = grad;
            ctx.beginPath();
            ctx.arc(cloudX, cloudY, size, 0, Math.PI * 2);
            ctx.fill();
          }
          // Icon with floating effect
          ctx.font = '14px serif';
          ctx.textAlign = 'center';
          ctx.shadowBlur = 10;
          ctx.shadowColor = 'black';
          ctx.fillText('👁️‍🗨️', t.x, visualY - 32 + Math.sin(Date.now() / 250) * 4);
          ctx.restore();
        }

        // Rusted Visual Effect (Orange Particles)
        if (t.buffs.rusted > 0) {
          ctx.save();
          const time = Date.now() / 200;
          for (let i = 0; i < 6; i++) {
            const angle = time + (i * Math.PI * 2 / 6);
            const pX = t.x + (Math.cos(angle) * 18);
            const pY = visualY + (Math.sin(angle * 0.5) * 12);
            
            ctx.fillStyle = '#B45309'; // Darker Rust
            ctx.globalAlpha = 0.6 + Math.sin(time + i) * 0.3;
            ctx.shadowBlur = 5;
            ctx.shadowColor = '#D97706';
            
            ctx.beginPath();
            // Draw small gear-like shapes or rough particles
            ctx.rect(pX - 2, pY - 2, 4, 4);
            ctx.fill();
          }
          // Rusty icon
          ctx.font = '12px serif';
          ctx.textAlign = 'center';
          ctx.fillText('⚙️', t.x + 15, visualY - 20 + Math.sin(time * 0.8) * 3);
          ctx.restore();
        }

        // Weakened Visual Effect (Purple Aura)
        if (t.buffs.weakened > 0) {
          ctx.save();
          const time = Date.now() / 400;
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.size * 1.2, 0, Math.PI * 2);
          
          const grad = ctx.createRadialGradient(t.x, visualY, t.size * 0.8, t.x, visualY, t.size * 1.3);
          grad.addColorStop(0, 'rgba(168, 85, 247, 0)');
          grad.addColorStop(0.5, `rgba(168, 85, 247, ${0.2 + Math.abs(Math.sin(time)) * 0.3})`);
          grad.addColorStop(1, 'rgba(168, 85, 247, 0)');
          
          ctx.strokeStyle = grad;
          ctx.lineWidth = 3;
          ctx.stroke();
          
          // Floating purple particles
          ctx.fillStyle = '#A855F7';
          for (let i = 0; i < 3; i++) {
            const pY = visualY - 10 - ( (Date.now() / 10 + i * 20) % 30 );
            const pX = t.x + Math.sin(pY / 10 + i) * 10;
            ctx.globalAlpha = (30 - (visualY - 10 - pY)) / 30;
            ctx.beginPath();
            ctx.arc(pX, pY, 1.5, 0, Math.PI * 2);
            ctx.fill();
          }
          ctx.restore();
        }

        // Normal Range Pulse
        if (t.rangePulse && t.rangePulse > 0 && (!t.upgradePulse || t.upgradePulse <= 0)) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range * (1.5 - t.rangePulse * 0.5), 0, Math.PI * 2);
          ctx.strokeStyle = '#F59E0B';
          ctx.lineWidth = 1;
          ctx.stroke();
          if (!isPaused) t.rangePulse -= 0.02;
        }

        // Permanent Range Visualization
        if (showRanges) {
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.range, 0, Math.PI * 2);
          ctx.strokeStyle = t.color + '44'; // Use tower color with low alpha
          ctx.lineWidth = 1;
          ctx.setLineDash([5, 5]);
          ctx.stroke();
          ctx.setLineDash([]);
        }

        if (spritesLoaded && SPRITE_MAP.towers[t.type]) {
          const s = SPRITE_MAP.towers[t.type];
          if (t.buffs.freeze > 0 || t.buffs.doubleShot > 0) {
            ctx.beginPath();
            ctx.arc(t.x, visualY, t.size * 1.5, 0, Math.PI * 2);
            ctx.fillStyle = t.buffs.freeze > 0 ? '#60A5FA44' : '#EF444444';
            ctx.fill();
          }
          const renderSize = t.size * 2.5;
          const renderH = renderSize * (gh > 1 ? 1.5 : 1);
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, t.x - renderSize / 2, visualY - renderH / 2, renderSize, renderH);
        } else {
          ctx.fillStyle = t.color;
          if (t.type === 'basic') ctx.fillRect(t.x - t.size / 2, visualY - t.size / 2, t.size, t.size);
          else { ctx.beginPath(); ctx.arc(t.x, visualY, t.size, 0, Math.PI * 2); ctx.fill(); }
        }

        // Veterancy Aura (Ground effect)
        if (t.veterancy > 1) {
          ctx.save();
          ctx.globalAlpha = 0.2 + (Math.sin(Date.now() / 300) * 0.1);
          ctx.beginPath();
          ctx.arc(t.x, visualY, t.size * 1.0, 0, Math.PI * 2); // 50% smaller
          ctx.fillStyle = '#FCD34D';
          ctx.fill();
          ctx.restore();
        }
      }
    }

    function drawEnemies() {
      const sortedEnemies = enemies.slice().sort((a, b) => a.y - b.y);
      const time = Date.now() / 1000;

      for (let i = 0; i < sortedEnemies.length; i++) {
        const e = sortedEnemies[i];
        
        // AAA: Dynamic movement bobbing & tilt
        const animSpeed = e.isBoss ? 4 : 8;
        const bob = !isPaused ? Math.sin(time * animSpeed + (e.x + e.y) * 0.05) * 4 : 0;
        const tilt = !isPaused ? Math.cos(time * 4) * 0.1 : 0;
        const visualY = e.y + bob;

        if (spritesLoaded && SPRITE_MAP.enemies[e.id]) {
          const s = SPRITE_MAP.enemies[e.id];
          const renderSize = e.isBoss ? 60 : 40;
          
          ctx.save();
          ctx.translate(e.x, visualY);
          ctx.rotate(tilt);
          
          // Visibility Glow/Aura (Always visible)
          ctx.shadowBlur = 15;
          ctx.shadowColor = e.color;
          
          if (e.isGhost) ctx.globalAlpha = 0.6;
          if (e.isClone && e.lifeTimer) {
            // Fade out as life expires
            ctx.globalAlpha *= Math.min(1.0, e.lifeTimer / 30); 
          }
          
          // Outer Highlight Ring
          ctx.beginPath();
          ctx.arc(0, 0, renderSize * 0.55, 0, Math.PI * 2);
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.3)';
          ctx.lineWidth = 1.5;
          ctx.stroke();

          // Base fill for contrast
          ctx.beginPath();
          ctx.arc(0, 0, renderSize * 0.6, 0, Math.PI * 2);
          ctx.fillStyle = e.color + '22'; 
          ctx.fill();
          
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, -renderSize / 2, -renderSize / 2, renderSize, renderSize);
          ctx.restore();
        } else {
          ctx.fillStyle = e.color;
          const size = e.isBoss ? 20 : 10;
          ctx.fillRect(e.x - size, visualY - size, size * 2, size * 2);
        }

        if (e.hasRangeBuff && !e.isBoss) {
          ctx.strokeStyle = '#FCD34D';
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.arc(e.x, visualY, 16, 0, Math.PI * 2);
          ctx.stroke();
        }

        // HP Bar & Level (Positioned Below Enemy for clarity)
        const barW = e.isBoss ? 44 : 30;
        const barH = e.isBoss ? 6 : 4;
        const barY = visualY + (e.isBoss ? 35 : 25);
        
        ctx.fillStyle = 'rgba(0,0,0,0.8)'; // Darker outline
        ctx.fillRect(e.x - barW / 2 - 1, barY - 1, barW + 2, barH + 2);
        ctx.fillStyle = '#1e293b'; // Neutral dark gray background
        ctx.fillRect(e.x - barW / 2, barY, barW, barH);
        ctx.fillStyle = e.isBoss ? '#A855F7' : '#EF4444'; // Boss: Purple, Normal: Red
        const hpRatio = Math.min(1, Math.max(0, e.hp / Math.max(0.1, e.maxHp)));
        ctx.fillRect(e.x - barW / 2, barY, barW * hpRatio, barH);

        // Shield Bar (If active)
        if (e.shield > 0) {
          ctx.fillStyle = '#3B82F6';
          ctx.fillRect(e.x - barW / 2, barY + barH + 1, barW * (e.shield / (e.maxHp * 0.5)), 2);
        }

        // Level Label (Centered above bar)
        ctx.fillStyle = '#FFFFFF';
        ctx.font = '900 10px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'bottom';
        ctx.strokeStyle = '#000000';
        ctx.lineWidth = 2;
        const eLabel = `Nv.${e.level || 1}`;
        ctx.strokeText(eLabel, e.x, barY - 2);
        ctx.fillText(eLabel, e.x, barY - 2);
      }
    }

    function drawProjectiles() {
      for (let i = 0; i < projectiles.length; i++) {
        const p = projectiles[i];
        ctx.save();
        
        // Projectile Glow
        ctx.shadowBlur = 12;
        ctx.shadowColor = p.color;
        
        // Trail effect
        const trailLen = 3;
        for (let j = 0; j < trailLen; j++) {
          const trailAlpha = (1 - j / trailLen) * 0.3;
          ctx.globalAlpha = trailAlpha;
          ctx.fillStyle = p.color;
          ctx.beginPath();
          ctx.arc(p.x - (p.vx || 0) * j * 1.2, p.y - (p.vy || 0) * j * 1.2, 4 * (1 - j / trailLen), 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.globalAlpha = 1.0;
        ctx.fillStyle = '#FFFFFF'; // Core is bright
        ctx.beginPath();
        ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
        ctx.fill();
        
        // Magical particles
        if (Math.random() > 0.7) {
          createParticle(p.x, p.y, p.color, 2, (Math.random() - 0.5) * 2, (Math.random() - 0.5) * 2);
        }

        ctx.restore();
      }

      for (let i = 0; i < enemyProjectiles.length; i++) {
        const p = enemyProjectiles[i];
        ctx.save();
        ctx.fillStyle = p.color;
        ctx.beginPath();
        if (p.attackType === 'fire') {
          ctx.shadowBlur = 10;
          ctx.shadowColor = '#EF4444';
          ctx.moveTo(p.x, p.y - 6);
          ctx.lineTo(p.x + 4, p.y + 4);
          ctx.lineTo(p.x - 4, p.y + 4);
          ctx.closePath();
        } else if (p.attackType === 'ice') {
          ctx.shadowBlur = 10;
          ctx.shadowColor = '#60A5FA';
          ctx.moveTo(p.x, p.y - 5);
          ctx.lineTo(p.x + 5, p.y);
          ctx.lineTo(p.x, p.y + 5);
          ctx.lineTo(p.x - 5, p.y);
          ctx.closePath();
        } else if (p.attackType === 'plague') {
          // Area plague: larger bubble with glow
          ctx.arc(p.x, p.y, 6, 0, Math.PI * 2);
          ctx.shadowBlur = 10;
          ctx.shadowColor = p.color;
        } else {
          ctx.arc(p.x, p.y, p.attackType === 'poison' ? 4 : 3, 0, Math.PI * 2);
        }
        ctx.fill();
        ctx.restore();
      }
    }

    function drawParticles() {
      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        ctx.fillStyle = p.color;
        if (p.isRune) {
          ctx.font = `bold ${Math.floor(12 * p.life + 8)}px serif`;
          ctx.fillText(p.rune, p.x, p.y);
        } else {
          ctx.beginPath();
          ctx.arc(p.x, p.y, Math.max(1, (p.size || 4) * p.life), 0, Math.PI * 2);
          ctx.fill();
        }
      }
    }

    function drawBonuses() {
      for (let i = 0; i < bonuses.length; i++) {
        const b = bonuses[i];
        const floatY = Math.sin(Date.now() / 200) * 5;
        const scale = 1 + Math.sin(Date.now() / 150) * 0.05;
        ctx.save();
        ctx.translate(b.x, b.y + floatY);
        ctx.scale(scale, scale);
        
        // Magical Glow
        let color = '#FCD34D';
        if (b.type === 'abyssal_rune') color = '#A855F7';
        else if (b.type === 'heal') color = '#34D399';
        else if (b.type === 'freeze') color = '#60A5FA';
        else if (b.type === 'frenzy') color = '#EF4444';
        else if (b.type === 'nuke') color = '#F59E0B';
        
        ctx.shadowBlur = 15;
        ctx.shadowColor = color;

        if (spritesLoaded && SPRITE_MAP.items[b.type]) {
          const s = SPRITE_MAP.items[b.type];
          ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, -20, -24, 40, 48);
        } else {
          let rune = 'ᚩ';
          if (b.type === 'abyssal_rune') rune = 'ᛈ';
          else if (b.type === 'heal') rune = 'ᛉ';
          else if (b.type === 'freeze') rune = 'ᛁ';
          else if (b.type === 'frenzy') rune = 'ᚱ';
          else if (b.type === 'nuke') rune = 'ᛒ';
          ctx.fillStyle = color; ctx.font = 'bold 24px serif'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; ctx.fillText(rune, 0, 0);
        }

        // Life ring
        ctx.shadowBlur = 0;
        ctx.strokeStyle = 'rgba(255,255,255,0.2)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(0, 0, 22, -Math.PI/2, (Math.PI * 2 * (b.life / 300)) - Math.PI/2);
        ctx.stroke();

        ctx.restore();
      }
    }

    function drawDarkRunes() {
      for (let i = 0; i < darkRunes.length; i++) {
        const r = darkRunes[i];
        ctx.save();
        
        // Pulse animation
        const pulse = 1 + Math.sin(Date.now() / 150) * 0.1;
        ctx.translate(r.x, r.y);
        ctx.scale(pulse, pulse);

        let color = '#D946EF'; let rune = 'ᛤ';
        if (r.type === 'shield') { color = '#60A5FA'; rune = 'ᚦ'; }
        else if (r.type === 'haste') { color = '#FCD34D'; rune = 'ᚢ'; }
        else if (r.type === 'heal') { color = '#10B981'; rune = 'ᛉ'; }
        
        ctx.shadowBlur = 15;
        ctx.shadowColor = color;
        ctx.fillStyle = color; 
        ctx.font = 'bold 20px serif'; 
        ctx.textAlign = 'center'; 
        ctx.textBaseline = 'middle'; 
        ctx.fillText(rune, 0, 0);
        
        ctx.restore();
      }
    }

    function drawPreviews() {
      if (gameState === 'playing' && enemies.length === 0 && !isPaused && !selectedTowerType) {
        const hoveredTower = towers.find((t) => Math.hypot(t.x - mouseX, t.y - mouseY) < 20);
        if (hoveredTower) {
          drawRangeIndicator(hoveredTower);
        }
      }
      const previewType = isDragging ? draggedType : selectedTowerType;
      if (previewType) {
        const gridX = Math.round(mouseX / GRID_SIZE) * GRID_SIZE;
        const gridY = Math.round(mouseY / GRID_SIZE) * GRID_SIZE;
        const stats = TOWER_STATS[previewType];
        if (stats) {
          const h = stats.gridHeight || 1;
          let isValid = true;
          
          // 1. Path & Canvas Boundary Check
          for (let i = 0; i < h; i++) {
            const checkY = gridY + i * GRID_SIZE;
            if (checkY > canvas.height - 40 || isCollidingWithPath(gridX, checkY)) {
              isValid = false;
              break;
            }
          }
          
          // 2. UI Overlay Collision Check
          const inTopCenterUI = Math.abs(gridX - canvas.width / 2) < 250 && gridY < 100;
          const inRightUI = gridX > canvas.width - 80;
          const inLeftUI = gridX < 80;
          const inStartButton = gridX > canvas.width / 2 - 130 && gridX < canvas.width / 2 + 130 && gridY > canvas.height - 100;
          const inBottomUI = gridY > canvas.height - 60;
          if (inTopCenterUI || inRightUI || inLeftUI || inStartButton || inBottomUI) isValid = false;

          // 3. Existing Tower Collision Check (Corrected)
          if (isValid) {
            for (const t of towers) {
              const th = t.gridHeight || 1;
              // Check if any part of the new tower overlaps with any part of existing tower
              // Both are grid-aligned, so we check if X matches and Y ranges overlap
              if (t.x === gridX) {
                const newYRange = [gridY, gridY + (h - 1) * GRID_SIZE];
                const oldYRange = [t.y, t.y + (th - 1) * GRID_SIZE];
                
                if (newYRange[0] <= oldYRange[1] && newYRange[1] >= oldYRange[0]) {
                  isValid = false;
                  break;
                }
              }
            }
          }
          
          ctx.save();
          // Visual Ghost Effect
          ctx.globalAlpha = isValid ? 0.5 : 0.3;
          const visualGhostY = gridY + ((h - 1) * GRID_SIZE) / 2;
          
          if (spritesLoaded && SPRITE_MAP.towers[previewType]) {
            const s = SPRITE_MAP.towers[previewType];
            const renderSize = stats.size * 2.5; const renderH = renderSize * (h > 1 ? 1.5 : 1);
            
            // Add a red tint if invalid
            if (!isValid) {
              ctx.shadowBlur = 15;
              ctx.shadowColor = '#EF4444';
            }
            
            ctx.drawImage(spriteSheet, s.sx, s.sy, s.sw, s.sh, gridX - renderSize / 2, visualGhostY - renderH / 2, renderSize, renderH);
          } else {
            ctx.fillStyle = isValid ? stats.color : '#EF4444';
            if (previewType === 'basic') ctx.fillRect(gridX - stats.size / 2, visualGhostY - stats.size / 2, stats.size, stats.size);
            else { ctx.beginPath(); ctx.arc(gridX, visualGhostY, stats.size, 0, Math.PI * 2); ctx.fill(); }
          }
          ctx.restore();
          
          // Unified range indicator for preview (Pass isValid to show Red if blocked)
          drawRangeIndicator({ x: gridX, y: gridY, range: stats.range, color: stats.color, gridHeight: h }, isValid);
        }
      }
    }

    function drawFloatingTexts() {
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      let buffCount = 0;
      for (let i = 0; i < floatingTexts.length; i++) {
        const type = floatingTexts[i].type;
        if (type === 'buff' || type === 'debuff') buffCount++;
      }
      const shouldAccelerate = buffCount > 3;

      for (let i = 0; i < floatingTexts.length; i++) {
        let ft = floatingTexts[i];
        
        // Sinusoidal movement update for magic look
        ft.x += (ft.vx || 0) + Math.sin((ft.phase || 0) + ft.life * (ft.freq || 0.1)) * 0.4;
        ft.y += ft.vy;
        
        // Scale "pop" animation
        if (ft.scale < 1.0) ft.scale += 0.1;
        
        let fx = ft.x;
        let fy = ft.y;
        
        if (ft.type === 'buff' || ft.type === 'debuff') {
          ctx.font = '900 16px sans-serif'; // Slightly smaller than 18
          if (shouldAccelerate) ft.life -= 1.5;
        } else if (ft.type === 'large') {
          ctx.font = '900 15px sans-serif'; // Slightly smaller than 16
        } else {
          ctx.font = 'bold 10px sans-serif'; // Reduced from 12px
        }

        const alpha = ft.life < 20 ? ft.life / 20 : 1.0;
        ctx.globalAlpha = alpha;
        
        // Shadow/Glow
        ctx.shadowBlur = (ft.type === 'buff' || ft.type === 'large') ? 12 : 4;
        ctx.shadowColor = ft.color;

        ctx.save();
        ctx.translate(fx, fy);
        ctx.scale(ft.scale, ft.scale);
        
        ctx.fillStyle = ft.color;
        ctx.strokeStyle = 'rgba(0, 0, 0, 0.9)';
        ctx.lineWidth = 2.5;
        ctx.strokeText(ft.text, 0, 0);
        ctx.fillText(ft.text, 0, 0);
        ctx.restore();
        
        ctx.globalAlpha = 1.0;
        ctx.shadowBlur = 0;
        
        ft.vy -= 0.03; // Gentler vertical acceleration
        ft.life--;
      }
      for (let i = floatingTexts.length - 1; i >= 0; i--) if (floatingTexts[i].life <= 0) floatingTexts.splice(i, 1);
    }

    function drawGameStates() {
      if (gameState === 'intro' || gameState === 'gameover' || isPaused) {
        ctx.save();
        
        // 1. Dark Backdrop with Blur (via fillStyle alpha)
        ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        // 2. Cinematic Bars for Focus
        const barHeight = 60;
        ctx.fillStyle = 'rgba(0, 0, 0, 0.9)';
        ctx.fillRect(0, 0, canvas.width, barHeight);
        ctx.fillRect(0, canvas.height - barHeight, canvas.width, barHeight);

        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        
        // 3. Status Text
        let title = '';
        let subtitle = '';
        let color = '#FFFFFF';
        let glowColor = 'rgba(255, 255, 255, 0.5)';

        if (gameState === 'gameover') {
          title = 'LA CIUDADELA HA CAÍDO';
          subtitle = 'La Plaga ha reclamado el último bastión';
          color = '#EF4444';
          glowColor = 'rgba(239, 68, 68, 0.6)';
        } else if (isPaused) {
          title = 'JUEGO PAUSADO';
          subtitle = 'Revisa tus tácticas y planea tu defensa';
          color = '#F59E0B';
          glowColor = 'rgba(245, 158, 11, 0.6)';
        } else if (gameState === 'intro') {
          title = 'DEFENSA DE LA CIUDADELA';
          subtitle = 'Preparando suministros de guerra...';
          color = '#818CF8';
          glowColor = 'rgba(129, 140, 248, 0.6)';
        }

        // Glow Effect
        ctx.shadowBlur = 20;
        ctx.shadowColor = glowColor;
        
        // Title
        ctx.font = '900 48px sans-serif';
        ctx.fillStyle = color;
        ctx.letterSpacing = '8px';
        ctx.fillText(title, canvas.width / 2, canvas.height / 2 - 10);
        
        // Subtitle
        ctx.shadowBlur = 0;
        ctx.font = '400 16px sans-serif';
        ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';
        ctx.letterSpacing = '4px';
        ctx.fillText(subtitle.toUpperCase(), canvas.width / 2, canvas.height / 2 + 40);

        // Instructions for Restart
        const isWaiting = (enemies.length === 0 && !isEventActive) || wave === 0;
        if (isPaused || gameState === 'gameover' || (gameState === 'playing' && isWaiting)) {
          ctx.font = '900 12px sans-serif';
          ctx.fillStyle = 'rgba(239, 68, 68, 0.8)';
          ctx.letterSpacing = '2px';
          ctx.fillText(`PRESIONA '${KEYBINDS.restart.toUpperCase()}' PARA REINICIAR`, canvas.width / 2, canvas.height / 2 + 80);
        }

        // Icon/Decoration
        ctx.font = '32px serif';
        const icon = isPaused ? '⏸️' : gameState === 'gameover' ? '💀' : '🛡️';
        ctx.fillText(icon, canvas.width / 2, canvas.height / 2 - 80 + Math.sin(Date.now() / 400) * 5);

        ctx.restore();
      }
    }

    function drawToasts() {
      ctx.save();
      const count = canvasToasts.length;
      for (let i = 0; i < count; i++) {
        const toast = canvasToasts[i];
        let xPos = canvas.width / 2;
        const relativeIndex = count - 1 - i;
        let yPos = (canvas.height - 110) - (relativeIndex * 35) + (toast.yOffset -= 0.7);
        renderToast(toast, xPos, yPos);
      }

      for (let i = canvasToasts.length - 1; i >= 0; i--) {
        canvasToasts[i].life--;
        if (canvasToasts[i].life <= 0) canvasToasts.splice(i, 1);
      }
      ctx.restore();
    }

    function renderToast(toast, xPos, yPos) {
      // Fade out more prominently as life decreases
      const alpha = toast.life > 40 ? 1.0 : toast.life / 40;
      ctx.globalAlpha = alpha;

      const text = toast.msg.toUpperCase();
      
      // Dynamic scaling for toast text
      let fontSize = 12;
      ctx.font = `900 ${fontSize}px sans-serif`;
      let metrics = ctx.measureText(text);
      
      // If text is too long for small screens, scale down
      while (metrics.width > canvas.width * 0.8 && fontSize > 9) {
        fontSize--;
        ctx.font = `900 ${fontSize}px sans-serif`;
        metrics = ctx.measureText(text);
      }

      const textWidth = metrics.width + 40;
      const textHeight = fontSize + 16;

      // 1. Shadow/Glow
      ctx.shadowBlur = 15;
      ctx.shadowColor = toast.type === 'error' ? 'rgba(239, 68, 68, 0.4)' : toast.type === 'success' ? 'rgba(52, 211, 153, 0.4)' : 'rgba(129, 140, 248, 0.4)';

      // 2. Glass Background
      const grad = ctx.createLinearGradient(xPos - textWidth/2, yPos, xPos + textWidth/2, yPos);
      grad.addColorStop(0, 'rgba(0, 0, 0, 0)');
      grad.addColorStop(0.2, 'rgba(0, 0, 0, 0.85)');
      grad.addColorStop(0.5, 'rgba(15, 23, 42, 0.95)');
      grad.addColorStop(0.8, 'rgba(0, 0, 0, 0.85)');
      grad.addColorStop(1, 'rgba(0, 0, 0, 0)');
      
      ctx.fillStyle = grad;
      ctx.fillRect(xPos - textWidth/2, yPos - textHeight/2, textWidth, textHeight);

      // 3. Decorative Borders
      ctx.shadowBlur = 0;
      ctx.lineWidth = 1.5;
      ctx.strokeStyle = toast.type === 'error' ? 'rgba(239, 68, 68, 0.5)' : toast.type === 'success' ? 'rgba(52, 211, 153, 0.5)' : 'rgba(129, 140, 248, 0.5)';
      
      // Horizontal lines that fade with the toast
      ctx.beginPath();
      ctx.moveTo(xPos - textWidth/3, yPos - textHeight/2);
      ctx.lineTo(xPos + textWidth/3, yPos - textHeight/2);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(xPos - textWidth/3, yPos + textHeight/2);
      ctx.lineTo(xPos + textWidth/3, yPos + textHeight/2);
      ctx.stroke();

      // 4. Text
      ctx.fillStyle = toast.type === 'error' ? '#FECACA' : toast.type === 'success' ? '#D1FAE5' : '#E0E7FF';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.letterSpacing = '1px';
      ctx.fillText(text, xPos, yPos);
      
      ctx.globalAlpha = 1.0;
      ctx.shadowBlur = 0;
    }
  </script>
</Layout>
