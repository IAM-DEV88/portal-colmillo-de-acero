      function updateSoundUI() {
        if (soundsEnabled) {
          toggleSound.classList.remove('bg-gray-900/50', 'border-white/10');
          toggleSound.classList.add('bg-indigo-900/50', 'border-indigo-500/50');
          soundSwitch.classList.remove('translate-x-0');
          soundSwitch.classList.add('translate-x-6');
        } else {
          toggleSound.classList.remove('bg-indigo-900/50', 'border-indigo-500/50');
          toggleSound.classList.add('bg-gray-900/50', 'border-white/10');
          soundSwitch.classList.remove('translate-x-6');
          soundSwitch.classList.add('translate-x-0');
        }
      }

      function renderKeybinds() {
        const list = document.getElementById('keybinds-list');
        if (!list) return;
        list.innerHTML = '';
        Object.keys(KEYBINDS).forEach(key => {
          const btn = document.createElement('button');
          btn.className = `flex flex-col items-center p-1.5 rounded-md border transition-all ${isRebinding === key ? 'bg-indigo-600 border-white ring-1 ring-indigo-400' : 'bg-white/5 border-white/10 hover:bg-white/10'}`;
          
          const label = document.createElement('span');
          label.className = 'text-[6px] text-gray-500 uppercase font-black leading-tight';
          label.innerText = KEY_LABELS[key];
          
          const val = document.createElement('span');
          val.className = 'text-[10px] text-white font-bold uppercase';
          const keyVal = KEYBINDS[key];
          val.innerText = keyVal === ' ' ? 'ESP' : keyVal.toUpperCase();
          
          btn.appendChild(label);
          btn.appendChild(val);
          
          btn.onclick = () => {
            isRebinding = key;
            renderKeybinds();
          };
          
          list.appendChild(btn);
        });
      }

      configBtn.addEventListener('click', () => {
        configModal.classList.remove('hidden');
        updateSoundUI();
        updateTurboUI();
        updateFogUI();
        updateRangesUI();
        renderKeybinds();
      });

      closeConfig.addEventListener('click', () => {
        configModal.classList.add('hidden');
      });

      toggleSound.addEventListener('click', () => {
        soundsEnabled = !soundsEnabled;
        updateSoundUI();
        playSFX('click');
      });

      window.addEventListener('keydown', (e) => {
        if (gameState !== 'playing' && gameState !== 'intro') return;

        // --- REBINDING LOGIC ---
        if (isRebinding) {
          e.preventDefault();
          const key = e.key.toLowerCase();
          
          // Basic validation
          if (key === 'escape') {
            isRebinding = null;
            renderKeybinds();
            return;
          }

          // Check for duplicates
          const exists = Object.entries(KEYBINDS).find(([k, v]) => v === key && k !== isRebinding);
          if (exists) {
            showCanvasToast(`¡Tecla ${key} ya en uso por ${KEY_LABELS[exists[0]]}!`, 'error');
            playSFX('error');
            return;
          }

          KEYBINDS[isRebinding] = key;
          isRebinding = null;
          renderKeybinds();
          showCanvasToast('¡Control reasignado!', 'success');
          playSFX('click');
          return;
        }

        if (e.key === 'Shift') isShiftDown = true;
        const key = e.key.toLowerCase();

        // --- TAB NAVIGATION (Cycle focus by lowest HP) ---
        if (key === 'tab') {
          e.preventDefault();
          if (towers.length === 0) return;

          // Sort towers by health percentage (ascending)
          const sorted = [...towers].sort((a, b) => (a.hp / a.maxHp) - (b.hp / b.maxHp));
          
          if (!inspectedTower) {
            inspectedTower = sorted[0];
          } else {
            // Find next in sorted list
            const currentIndex = sorted.indexOf(inspectedTower);
            const nextIndex = (currentIndex + 1) % sorted.length;
            inspectedTower = sorted[nextIndex];
          }
          
          selectedTowerType = null;
          playSFX('click');
          return;
        }

        // --- SPACE / ACTION KEY (Start Game / Next Wave) ---
        if (key === KEYBINDS.action) {
          e.preventDefault();
          
          if (gameState === 'intro' || gameState === 'gameover') {
            // Start game if possible
            if (credits > 0) {
              playSFX('start');
              startGame(gameState === 'intro');
            } else {
              playSFX('error');
              if (window.showToast) window.showToast('No tienes turnos suficientes', 'error');
            }
          } else if (gameState === 'playing') {
            const isWaiting = getIsWaiting();
            if (isWaiting) {
              // Start next wave
              if (isPaused) isPaused = false;
              playSFX('start');
              if (wave === 0) wave = 1;
              spawnWave();
            }
          }
          return;
        }

        // --- RESTART KEY (L) ---
        if (key === KEYBINDS.restart) {
          e.preventDefault();
          const rb = document.getElementById('restart-btn');
          if (rb && !rb.classList.contains('hidden')) {
            showRestartConfirm();
          }
          return;
        }

        // --- PAUSE KEY (Cost 1t) ---
        if (key === KEYBINDS.pause) {
          e.preventDefault();
          if (gameState === 'playing' && UI.mainActionBtn) {
            UI.mainActionBtn.click();
          }
          return;
        }

        // --- REPAIR / POWERUP / UPGRADE KEYS ---
        if (key === KEYBINDS.repair) {
          if (inspectedTower) {
            const rb = document.getElementById('inspect-repair');
            if (rb) rb.click();
          } else {
            const btn = document.querySelector(`[data-type="repair"]`);
            if (btn) btn.click();
          }
          return;
        }

        if (key === KEYBINDS.powerup) {
          if (inspectedTower) {
            const pb = document.getElementById('inspect-powerup');
            if (pb) pb.click();
          } else {
            const btn = document.querySelector(`[data-type="powerup"]`);
            if (btn) btn.click();
          }
          return;
        }

        if (key === KEYBINDS.upgrade) {
          if (inspectedTower) {
            const ub = document.getElementById('inspect-upgrade');
            if (ub) ub.click();
          } else {
            const btn = document.querySelector(`[data-type="upgrade"]`);
            if (btn) btn.click();
          }
          return;
        }

        // --- SELL KEY (T) ---
        if (key === KEYBINDS.sell) {
          if (inspectedTower) {
            const sb = document.getElementById('inspect-sell');
            if (sb) sb.click();
          } else {
            const btn = document.querySelector(`[data-type="sell"]`);
            if (btn) btn.click();
          }
          return;
        }

        // --- TOWER SELECTION KEYS ---
        const towerMap = {
          [KEYBINDS.tower1]: 'basic',
          [KEYBINDS.tower2]: 'sniper',
          [KEYBINDS.tower3]: 'splash',
          [KEYBINDS.tower4]: 'nova',
        };

        if (towerMap[key]) {
          const btn = document.querySelector(`[data-type="${towerMap[key]}"]`);
          if (btn) btn.click();
        }

        // --- FULLSCREEN & SOUND TOGGLES ---
        if (key === KEYBINDS.fullscreen) {
          const fb = document.getElementById('fullscreen-btn');
          if (fb) fb.click();
        }

        if (key === KEYBINDS.sounds) {
          const sb = document.getElementById('toggle-sound');
          if (sb) sb.click();
        }
      });

      window.addEventListener('keyup', (e) => {
        if (e.key === 'Shift') isShiftDown = false;
      });

      canvas.addEventListener('mousedown', (e) => {
        isMouseDown = true;
        handleCanvasAction(e);
      });

      canvas.addEventListener('touchstart', (e) => {
        isMouseDown = true;
        const touch = e.touches[0];
        // Create a fake event object that handleCanvasAction expects
        const fakeEvent = {
          clientX: touch.clientX,
          clientY: touch.clientY,
          type: 'touchstart'
        };
        handleCanvasAction(fakeEvent);
        if (e.cancelable) e.preventDefault();
      }, { passive: false });

      window.addEventListener('mouseup', () => {
        isMouseDown = false;
      });

      window.addEventListener('touchend', () => {
        isMouseDown = false;
      });

      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        mouseX = (e.clientX - rect.left) * scaleX;
        mouseY = (e.clientY - rect.top) * scaleY;

        if (isMouseDown && isShiftDown && selectedTowerType) {
          handleCanvasAction(e);
        }

        if (selectedTowerType) {
          updateHUD();
        }
      });

      function handleCanvasAction(e) {
        const rect = canvas.getBoundingClientRect();
        const scaleX = canvas.width / rect.width;
        const scaleY = canvas.height / rect.height;
        const x = (e.clientX - rect.left) * scaleX;
        const y = (e.clientY - rect.top) * scaleY;
        
        // Fat Finger Compensation: Use larger radius for touch
        const isTouch = e.type && e.type.startsWith('touch');
        const clickRadius = isTouch ? 65 : 30; // Increased for mobile
        const towerHitRadius = isTouch ? GRID_SIZE * 1.6 : GRID_SIZE * 0.8; // Increased for mobile

        // Visual Feedback for touch interaction
        if (isMouseDown && isTouch) {
          lastInteractionPos = { x, y, radius: clickRadius, life: 20 };
        }

        if (gameState !== 'playing') return;

        // PRIORITIZE BONUSES (Runes) - Especially on mobile
        if (isMouseDown) {
          for (let i = bonuses.length - 1; i >= 0; i--) {
            const b = bonuses[i];
            const dist = Math.hypot(b.x - x, b.y - y);
            if (dist < clickRadius) {
              // Click radius
              if (b.type === 'abyssal_rune') {
                abyssals += b.reward;
                showCanvasToast(`¡+${formatNumber(b.reward)} Acero!`, 'success');
                createExplosion(b.x, b.y, '#94A3B8', 20);
                addFloatingText(b.x, b.y, `+${formatNumber(b.reward)}a`, '#94A3B8');
                addCombo();
              } else if (b.type === 'upgrades') {
                upgrades += b.reward;
                showCanvasToast(`¡+${formatNumber(b.reward)} Táctica!`, 'success');
                createExplosion(b.x, b.y, '#FCD34D', 20);
                addFloatingText(b.x, b.y, `+${formatNumber(b.reward)}t`, '#FCD34D');
                addCombo();
              } else if (b.type === 'heal') {
                health = Math.min(100, health + 2);
                showCanvasToast('¡Ciudadela Reforzada (+2)!', 'success');
                createExplosion(b.x, b.y, '#10B981', 20);
                addFloatingText(b.x, b.y, '+2 HP', '#10B981', 'buff');
              } else if (b.type === 'freeze') {
                for (let k = 0; k < enemies.length; k++) {
                  enemies[k].speed *= 0.5;
                }
                globalFreezeTimer = 300;
                showCanvasToast('¡Enemigos de la Plaga ralentizados!', 'info');
                createExplosion(b.x, b.y, '#60A5FA', 30);
                addFloatingText(b.x, b.y, '❄️ Lentos', '#60A5FA', 'debuff');
              } else if (b.type === 'frenzy') {
                for (let k = 0; k < towers.length; k++) {
                  towers[k].buffs.doubleShot = 300;
                }
                globalFrenzyTimer = 300;
                showCanvasToast('¡Frenesí! Colmillos acelerados.', 'error');
                createExplosion(b.x, b.y, '#EF4444', 30);
                addFloatingText(b.x, b.y, '🔥 Frenesí', '#EF4444', 'buff');
              } else if (b.type === 'nuke') {
                const nukeDamage = 5 + Math.floor(wave / 2); // Small damage
                for (let k = 0; k < enemies.length; k++) {
                  applyDamageToEnemy(enemies[k], nukeDamage, '#F59E0B');
                }
                showCanvasToast(`¡Bombardeo! Daño masivo (${nukeDamage})`, 'success');
                createExplosion(canvas.width / 2, canvas.height / 2, '#F59E0B', 50);
                addFloatingText(b.x, b.y, '💥 Bombardeo', '#F59E0B', 'buff');
                addScreenShake(15);
              }
              updateHUD();
              bonuses.splice(i, 1);
              playSFX('pickup');
              return;
            }
          }
        }

        // SMART SELECTION CYCLING (TAB-LIKE)
        if (isMouseDown && !selectedTowerType) {
          const nearbyTowers = towers.filter((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - x, (t.y + i * GRID_SIZE) - y) < towerHitRadius) return true;
            }
            return false;
          });

          const nearbyEnemies = enemies.filter((en) => {
            return Math.hypot(en.x - x, en.y - y) < clickRadius; 
          });

          const candidates = [...nearbyTowers, ...nearbyEnemies];

          if (candidates.length > 0) {
            let nextIndex = 0;
            // If something is already selected and it's in our candidates, pick the next one
            const currentSelected = inspectedTower || inspectedEnemy;
            if (currentSelected) {
              const currentIndex = candidates.indexOf(currentSelected);
              if (currentIndex !== -1) {
                nextIndex = (currentIndex + 1) % candidates.length;
              }
            }

            const selection = candidates[nextIndex];
            if (towers.includes(selection)) {
              inspectedTower = selection;
              inspectedEnemy = null;
            } else {
              inspectedEnemy = selection;
              inspectedTower = null;
            }
            playSFX('click');
            updateHUD();
            return;
          }

          // Clicked empty space
           inspectedTower = null;
           inspectedEnemy = null;
           updateHUD();
         }
 
         if (!selectedTowerType) return;
         handleConstruction(x, y, selectedTowerType, towerHitRadius);
       }

      function handleConstruction(x, y, type, hitRadius = GRID_SIZE * 0.8) {
        const cost = getTowerCost(type);

        // Snap to Grid
        const gridX = Math.round(x / GRID_SIZE) * GRID_SIZE;
        const gridY = Math.round(y / GRID_SIZE) * GRID_SIZE;

        // --- SELL MODE ---
        if (type === 'sell') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            const refund = calculateSellValue(targetTower);
            const visualY = targetTower.y + (((targetTower.gridHeight || 1) - 1) * GRID_SIZE) / 2;
            
            abyssals += refund;
            const index = towers.indexOf(targetTower);
            if (index > -1) {
              towers.splice(index, 1);
              if (inspectedTower === targetTower) inspectedTower = null;
            }
            
            addFloatingText(targetTower.x, visualY, `+${refund}a`, '#34D399');
            showCanvasToast(`Puesto retirado: +${refund} acero`, 'success');
            createExplosion(targetTower.x, visualY, '#EF4444', 15);
            playSFX('pickup');
            updateHUD();
            updateTowerPairing();
          }
          return;
        }

        // --- REPAIR MODE ---
        if (type === 'repair') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            if (targetTower.hp >= targetTower.maxHp) {
              showCanvasToast('El puesto ya tiene la salud máxima', 'error');
              playSFX('error');
              return;
            }
            if (upgrades >= cost) {
              upgrades -= cost;
              // AAA: Increased heal amount as requested (from 2 to 10 or 25% of max)
              const healAmount = Math.max(10, Math.ceil(targetTower.maxHp * 0.25));
              targetTower.hp = Math.min(targetTower.maxHp, targetTower.hp + healAmount); 
              
              updateHUD();
              addFloatingText(targetTower.x, targetTower.y, `+${healAmount} HP`, '#10B981');
              createExplosion(targetTower.x, targetTower.y, '#10B981', 8); // Performance: Reduced particles
              playSFX('build');
            } else {
              showCanvasToast(`Táctica insuficiente (${cost}t)`, 'error');
              playSFX('error');
            }
          }
          return;
        }

        // --- POWERUP MODE ---
        if (type === 'powerup') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            if (abyssals >= cost) {
              abyssals -= cost;
              // Apply Steel Reinforcement (Special Bond Ready)
              targetTower.buffs.steelShield = 900; // Increased to 15 seconds
              showCanvasToast(`¡Sobrecarga de Acero! Vínculos activos`, 'success');
              
              updateHUD();
              createExplosion(targetTower.x, targetTower.y, '#94A3B8', 12);
              playSFX('build');
            } else {
              showCanvasToast(`Acero insuficiente (${cost}a)`, 'error');
              playSFX('error');
            }
          }
          return;
        }

        // --- UPGRADE MODE ---
        else if (type === 'upgrade') {
          const targetTower = towers.find((t) => {
            const th = t.gridHeight || 1;
            for (let i = 0; i < th; i++) {
              if (Math.hypot(t.x - gridX, t.y + i * GRID_SIZE - gridY) < hitRadius)
                return true;
            }
            return false;
          });
          if (targetTower) {
            const upgradeCount = isShiftDown ? 3 : 1;
            let upgradedLevels = 0;

            for (let i = 0; i < upgradeCount; i++) {
              const currentUpgradeCost = getTowerCost('upgrade', targetTower);
              if (upgrades >= currentUpgradeCost) {
                upgrades -= currentUpgradeCost;
                targetTower.level = (targetTower.level || 1) + 1;
                
                // Slow statistics scaling: +1 damage every 2 levels
                if (targetTower.level % 2 === 0) targetTower.damage += 1;
                
                // HP increases by 2 per level
                targetTower.maxHp += 2;
                targetTower.hp += 2;
                
                targetTower.rangePulse = 1.0; 
                upgradedLevels++;
                playSFX('build');
              } else {
                if (i === 0) {
                  showCanvasToast(`Táctica insuficiente (${currentUpgradeCost}t)`, 'error');
                  playSFX('error');
                }
                break;
              }
            }

            if (upgradedLevels > 0) {
              updateHUD();
              showCanvasToast(
                upgradedLevels > 1
                  ? `¡Evolución Táctica! Nivel ${targetTower.level}`
                  : `Puesto Nivel ${targetTower.level}`,
                'success'
              );
              createExplosion(targetTower.x, targetTower.y, '#F59E0B', 20 + upgradedLevels * 5);
            }
          }
          return;
        }

        // Check Collisions
        if (isCollidingWithPath(gridX, gridY)) {
          if (!isShiftDown) {
            showCanvasToast('No puedes construir sobre el camino', 'error');
            playSFX('error');
          }
          return;
        }

        // Define UI bounding boxes for construction validation (Unified Bottom HUD)
        const inRightUI = gridX > canvas.width - 60; 
        const inLeftUI = gridX < 60; 
        const inBottomHUD = gridY > canvas.height - 64; 

        if (inRightUI || inLeftUI || inBottomHUD) {
          if (!isShiftDown) {
            showCanvasToast('No puedes construir sobre la interfaz', 'error');
            playSFX('error');
          }
          return;
        }

        const stats = TOWER_STATS[type];
        const h = stats.gridHeight || 1;
        let isOccupied = false;
        let isOnPath = false;
        let outOfBounds = false;

        for (let i = 0; i < h; i++) {
          const checkY = gridY + i * GRID_SIZE;
          if (checkY > canvas.height - 40) outOfBounds = true; // Much lower limit now

          if (
            towers.some((t) => {
              const th = t.gridHeight || 1;
              for (let j = 0; j < th; j++) {
                if (Math.hypot(t.x - gridX, t.y + j * GRID_SIZE - checkY) < GRID_SIZE * 0.8)
                  return true;
              }
              return false;
            })
          )
            isOccupied = true;

          if (isCollidingWithPath(gridX, checkY)) isOnPath = true;
        }

        if (isOccupied || isOnPath || outOfBounds) {
          if (!isShiftDown) {
            showCanvasToast(
              isOccupied
                ? 'Espacio ocupado'
                : isOnPath
                  ? 'No puedes construir en el camino'
                  : 'Fuera de límites',
              'error'
            );
            playSFX('error');
          }
          return;
        }

        if (towers.length >= GAME_CONFIG.balance.towerLimit) {
          if (!isShiftDown) {
            showCanvasToast(`Límite total de puestos alcanzado (${GAME_CONFIG.balance.towerLimit})`, 'error');
            playSFX('error');
          }
          return;
        }

        const currentTypeCount = towers.filter(t => t.type === type).length;
        if (stats.limit && currentTypeCount >= stats.limit) {
          if (!isShiftDown) {
            showCanvasToast(`Límite de ${stats.name} alcanzado (${stats.limit})`, 'error');
            playSFX('error');
          }
          return;
        }

        if (abyssals >= cost) {
          const scaledStats = getStartingLevelStats(type);

          towers.push({
            x: gridX,
            y: gridY,
            type,
            level: scaledStats.level,
            kills: 0,
            veterancy: 1,
            shotsFired: 0, // ADDED: Initialize special ability counter
            cooldown: 0,
            buffs: {
              doubleShot: 0,
              freeze: 0,
              steelShield: 0,
              weakened: 0, // Debuff: Reduced damage
              blinded: 0,  // Debuff: Reduced range
              rusted: 0    // Debuff: Very reduced damage
            },
            ...stats,
            hp: scaledStats.hp,
            maxHp: scaledStats.hp,
            damage: scaledStats.damage,
            range: scaledStats.range
          });
          abyssals -= cost;
          updateHUD();
          playSFX('build');
          
          if (scaledStats.level > 1) {
            showCanvasToast(`¡${stats.name} de Élite Nv.${scaledStats.level} desplegado!`, 'success');
          }
          
          // Recalculate pairs after a new tower is built
          updateTowerPairing();

          // Deselect if shift is not pressed
          if (!isShiftDown) {
            selectedTowerType = null;
            document
              .querySelectorAll('.tower-btn')
              .forEach((b) => b.classList.remove('ring-4', 'ring-amber-400'));
          }
        } else {
          if (!isShiftDown) {
            showCanvasToast('Acero insuficiente', 'error');
          }
        }
      }
    });

    // --- SOUND EFFECTS ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    function playSFX(type) {
      if (!soundsEnabled) return;
      if (audioCtx.state === 'suspended') audioCtx.resume();
      const osc = audioCtx.createOscillator();
      const gainNode = audioCtx.createGain();
      osc.connect(gainNode);
      gainNode.connect(audioCtx.destination);

      const now = audioCtx.currentTime;
      if (type === 'shoot') {
        osc.type = 'square';
        osc.frequency.setValueAtTime(400, now);
        osc.frequency.exponentialRampToValueAtTime(100, now + 0.1);
        gainNode.gain.setValueAtTime(0.08, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
        osc.start(now);
        osc.stop(now + 0.1);
      } else if (type === 'nova') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(800, now);
        osc.frequency.exponentialRampToValueAtTime(100, now + 0.5);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.5);
        osc.start(now);
        osc.stop(now + 0.5);
      } else if (type === 'hit') {
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(150, now);
        osc.frequency.exponentialRampToValueAtTime(50, now + 0.2);
        gainNode.gain.setValueAtTime(0.08, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
        osc.start(now);
        osc.stop(now + 0.2);
      } else if (type === 'hit_shield') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(300, now);
        osc.frequency.exponentialRampToValueAtTime(200, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
        osc.start(now);
        osc.stop(now + 0.1);
      } else if (type === 'build') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(600, now);
        osc.frequency.setValueAtTime(800, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.3);
        osc.start(now);
        osc.stop(now + 0.3);
      } else if (type === 'error') {
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(200, now);
        osc.frequency.setValueAtTime(150, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.3);
        osc.start(now);
        osc.stop(now + 0.3);
      } else if (type === 'start') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(440, now);
        osc.frequency.linearRampToValueAtTime(880, now + 0.3);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.5);
        osc.start(now);
        osc.stop(now + 0.5);
      } else if (type === 'pickup') {
        osc.type = 'sine';
        osc.frequency.setValueAtTime(800, now);
        osc.frequency.setValueAtTime(1200, now + 0.1);
        gainNode.gain.setValueAtTime(0.1, now);
        gainNode.gain.linearRampToValueAtTime(0, now + 0.2);
        osc.start(now);
        osc.stop(now + 0.2);
      }
    }

    // --- HELPERS ---
    function formatNumber(num) {
      if (num >= 1000000) return (num / 1000000).toFixed(2) + 'M';
      if (num >= 1000) return (num / 1000).toFixed(2) + 'K';
      return Number.isInteger(num) ? num.toString() : num.toFixed(1);
    }

    // Modal Confirmation for Restart
    let pendingRestartAction = null;
    function showRestartConfirm() {
      if (gameState === 'intro') {
        startGame(true); // Keep path if we haven't even started
        return;
      }
      
      // If already game over, just start (no need to confirm "losing progress")
      if (gameState === 'gameover') {
        if (credits > 0) startGame(false); // New path on game over re-attempt
        else if (window.showToast) window.showToast('No tienes turnos suficientes', 'error');
        return;
      }

      const modal = document.getElementById('restart-confirm-modal');
      if (modal) modal.classList.remove('hidden');
      isPaused = true; // Auto-pause while confirming
      updateHUD();
    }

    // --- GAME LOOP ---
    async function startGame(keepCurrentPath = false) {
      if (credits <= 0) return;

      credits -= 1;
      document.getElementById('credits-display').innerText = credits;

      // Reset Stats from GAME_CONFIG
      health = GAME_CONFIG.economy.initial.health;
      upgrades = GAME_CONFIG.economy.initial.tactics;
      abyssals = GAME_CONFIG.economy.initial.steel; 
      wave = 0; 
      enemiesLeftToSpawn = 0;
      passiveUpgradesTimer = 0;
      towers.length = 0;
      enemies.length = 0;
      projectiles.length = 0;
      enemyProjectiles.length = 0;
      bonuses.length = 0;
      darkRunes.length = 0;
      darkRuneTimer = 0;
      particles.length = 0;
      floatingTexts.length = 0;
      isEventActive = false;
      isCityFallen = false;
      isPaused = false;
      globalFreezeTimer = 0;
      globalFrenzyTimer = 0;
      inspectedTower = null;
      inspectedEnemy = null;

      gameState = 'playing';

      // Regenerate Path on Restart (only if NOT told to keep current)
      if (!keepCurrentPath) {
        generateRandomPath();
      }

      updateHUD();
      showCanvasToast('Fase de preparación: Construye tus defensas', 'info');
    }

    function addEnemyLevel(enemy) {
      // Rule: Level 1 for the first 7 waves, then strictly increase (Wave 8 = Lvl 2)
      enemy.level = wave <= 7 ? 1 : wave - 6;
    }

    function getWaveMultipliers() {
      let hp = 1.0;
      let dmg = 1.0;
      if (wave <= 7 && wave > 0) {
        hp = 0.5 + (wave - 1) * 0.08; 
        dmg = 0.6 + (wave - 1) * 0.06;
      }
      return { hp, dmg };
    }

    function spawnWave() {
      updateHUD(); // Hide button with animation
      let tension = getTensionFactor();
      currentWaveTension = tension;
      waveStartTime = Date.now();
      waveTookDamage = false;
      const currentEnemyLevel = wave <= 7 ? 1 : wave - 6;
      
      if (tension > 1.1) {
        showCanvasToast(`¡TENSIÓN ALTA! La Plaga se adapta a tu táctica (x${tension.toFixed(1)}).`, 'error');
      }

      const isBossWave = wave > 0 && wave % 5 === 0;

      // Update Repair Cost UI immediately
      updateHUD();

      // Function to actually spawn enemies
      const executeSpawn = () => {
        const { hp: introHPMultiplier, dmg: introDmgMultiplier } = getWaveMultipliers();
        let enemyCount = wave;

        if (wave <= 7) {
          enemyCount = wave + 1;
          if (wave <= 3) tension = 1.0; 
        } else {
          enemyCount = Math.min(15, 5 + Math.floor(wave / 2)); 
        }

        const densityCompensation = Math.max(1.0, wave / enemyCount);
        enemiesLeftToSpawn = 0; 

        if (isBossWave) {
          showCanvasToast('¡ALERTA! Un Comandante de la Plaga se aproxima...', 'error');
          playSFX('error');
        }

        const buffedIndices = new Set();
        if (!isBossWave) {
          const numBuffs = Math.floor(Math.random() * (1 + Math.floor(wave / 4)));
          for (let i = 0; i < numBuffs; i++) {
            buffedIndices.add(Math.floor(Math.random() * enemyCount));
          }
        }

        for (let spawned = 0; spawned < enemyCount; spawned++) {
          const offsetX = (Math.random() - 0.5) * 40;
          const offsetY = (Math.random() - 0.5) * 40;

          if (isBossWave && spawned === Math.floor(enemyCount / 2)) {
            const type = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
            const bossHp = (GAME_CONFIG.balance.enemyBaseHP + currentEnemyLevel * GAME_CONFIG.balance.bossHPFactor) * type.hpMod * tension * densityCompensation * introHPMultiplier;
            const newEnemy = {
              id: type.id,
              x: path[0].x - 10 + offsetX,
              y: path[0].y + offsetY,
              hp: bossHp,
              maxHp: bossHp,
              speed: (GAME_CONFIG.balance.enemyBaseSpeed * 0.5 + currentEnemyLevel * 0.015) * type.speedMod * (1 + (tension - 1) * 0.2),
              pathIndex: 0,
              color: type.color,
              isBoss: true,
              hasRangeBuff: true,
              isNecromancer: type.isNecromancer || false,
              isBerserker: type.isBerserker || false,
              isGhost: type.isGhost || false,
              reward: GAME_CONFIG.balance.bossRewardBase + currentEnemyLevel * GAME_CONFIG.balance.bossRewardScaling,
              cooldown: 40,
              maxCooldown: type.cooldown || 300,
              basicCooldown: type.basicRate || 45,
              maxBasicCooldown: type.basicRate || 45,
              basicDamage: (type.basicDamage || 1) * 2 * tension * densityCompensation * introDmgMultiplier,
              attackRange: 220,
              abilityRange: type.abilityRange || 110,
              damage: (2 + Math.floor(currentEnemyLevel * 0.5)) * tension * densityCompensation * introDmgMultiplier,
              attackType: type.attackType,
              noDamageTimer: 0,
              isCasting: 0,
            };
            addEnemyLevel(newEnemy);
            enemies.push(newEnemy);
          } else {
            const type = ENEMY_TYPES[Math.floor(Math.random() * ENEMY_TYPES.length)];
            const hasBuff = buffedIndices.has(spawned);
            const enemyHp = (GAME_CONFIG.balance.enemyBaseHP + currentEnemyLevel * GAME_CONFIG.balance.enemyHPScaling) * type.hpMod * tension * densityCompensation * introHPMultiplier;
            const newEnemy = {
              id: type.id,
              x: path[0].x - 10 + offsetX,
              y: path[0].y + offsetY,
              hp: enemyHp,
              maxHp: enemyHp,
              speed: (GAME_CONFIG.balance.enemyBaseSpeed + currentEnemyLevel * GAME_CONFIG.balance.enemySpeedScaling) * type.speedMod * (1 + (tension - 1) * 0.2),
              pathIndex: 0,
              color: type.color,
              isBoss: false,
              hasRangeBuff: hasBuff,
              isNecromancer: type.isNecromancer || false,
              isBerserker: type.isBerserker || false,
              isGhost: type.isGhost || false,
              reward: GAME_CONFIG.balance.normalReward,
              cooldown: Math.random() * 60 + 20,
              maxCooldown: type.cooldown || 300,
              basicCooldown: type.basicRate || 45,
              maxBasicCooldown: type.basicRate || 45,
              basicDamage: (type.basicDamage || 1) * tension * densityCompensation * introDmgMultiplier,
              attackRange: hasBuff ? 260 : 180,
              abilityRange: type.abilityRange || 110,
              damage: (1 + Math.floor(currentEnemyLevel * 0.2)) * tension * densityCompensation * introDmgMultiplier,
              attackType: type.attackType,
              noDamageTimer: 0,
              isCasting: 0,
            };
            addEnemyLevel(newEnemy);
            enemies.push(newEnemy);
          }
        }
        checkWaveClear();
      };

      // Show cinematic and delay spawning until it finishes
      if (isBossWave) {
        showCinematic('¡JEFE DE LA PLAGA DETECTADO!', 'Una presencia oscura emerge del vacío', 'boss', executeSpawn, true);
      } else {
        showCinematic(`OLEADA ${wave}`, tension > 1.1 ? 'La Plaga ha evolucionado' : 'La Plaga se aproxima...', 'info', executeSpawn, true);
      }
    }

    function checkWaveClear() {
      const checkInterval = setInterval(() => {
        if (gameState !== 'playing') {
          clearInterval(checkInterval);
          return;
        }

        if (enemies.length === 0) {
          clearInterval(checkInterval);

          // Check map generation milestone (every 7 waves, triggers AFTER wave clear)
          if (wave > 0 && wave % 7 === 0) {
            showCinematic('¡TERREMOTO ABISAL!', 'El terreno se fractura y cambia', 'boss');
            path = generateRandomPath();
            
            // Destruir solo las torres que se interpongan en el nuevo camino
            let destroyedCount = 0;
            let recoveredSteel = 0;
            for (let i = towers.length - 1; i >= 0; i--) {
              const t = towers[i];
              const gh = t.gridHeight || 1;
              let collides = false;
              for (let j = 0; j < gh; j++) {
                if (isCollidingWithPath(t.x, t.y + j * GRID_SIZE)) {
                  collides = true;
                  break;
                }
              }
              
              if (collides) {
                // Refund for "forceful" destruction (100% of current fair sell value)
                const refund = calculateSellValue(t); 
                recoveredSteel += refund;
                abyssals += refund;

                createExplosion(t.x, t.y, '#EF4444', 15);
                addFloatingText(t.x, t.y, `+${refund}a`, '#94A3B8');
                towers.splice(i, 1);
                destroyedCount++;
              }
            }

            if (destroyedCount > 0) {
              showCanvasToast(`¡TERREMOTO! ${destroyedCount} puestos destruidos. Recuperaste ${Math.round(recoveredSteel)} acero.`, 'error');
            } else {
              showCanvasToast('¡TERREMOTO! El terreno ha cambiado.', 'info');
            }
            
            addScreenShake(30); // Massive shake for map reset
            if (inspectedTower && !towers.includes(inspectedTower)) inspectedTower = null;
          }

          applySurvivalBonus();
          wave++;
          updateHUD();
          showCinematic(`OLEADA ${wave - 1} COMPLETADA`, 'La Ciudadela resiste un día más', 'success');

          // Random events between waves (70% chance after wave 1)
          if (wave > 1 && Math.random() < 0.7) {
            triggerRandomEvent();
          }
          // The next wave is now triggered manually by the button on canvas
        }
      }, 1000);
    }

    function applySurvivalBonus() {
      const completedWave = wave;
      if (completedWave <= 0) return;

      const { wave: waveCfg, milestone } = GAME_CONFIG.economy.survival;
      
      // 1. Regular Wave Bonus
      let steelReward = waveCfg.steelBase + (completedWave * waveCfg.steelScaling);
      let tacticsReward = waveCfg.tacticsBase + (completedWave * waveCfg.tacticsScaling);
      
      // 2. Performance Bonuses
      let perfMsg = '';
      if (!waveTookDamage) {
        const bonus = GAME_CONFIG.economy.perfectWaveBonus;
        tacticsReward += bonus;
        perfMsg += ` ¡IMPECABLE! (+${bonus}t)`;
        createExplosion(canvas.width / 2, canvas.height / 3, '#60A5FA', 40);
        addFloatingText(canvas.width / 2, canvas.height / 3, 'PERFECTO', '#60A5FA', 'large');
        addScreenShake(10);
      }

      const waveDuration = (Date.now() - waveStartTime) / 1000;
      const expectedTime = 15 + completedWave * 2; // Rough estimate
      if (waveDuration < expectedTime) {
        const bonus = GAME_CONFIG.economy.speedClearBonus;
        tacticsReward += bonus;
        perfMsg += ` ¡VELOZ! (+${bonus}t)`;
        createExplosion(canvas.width / 2, canvas.height / 2.5, '#F59E0B', 40);
        addFloatingText(canvas.width / 2, canvas.height / 2.5, 'VELOZ', '#F59E0B', 'large');
        addScreenShake(10);
      }
      
      abyssals += steelReward;
      upgrades += tacticsReward;

      let msg = `¡Oleada ${completedWave} completada! +${formatNumber(steelReward)}a, +${formatNumber(tacticsReward)}t${perfMsg}`;

      // 3. Milestone Bonus (Every X rounds)
      if (completedWave % milestone.interval === 0) {
        abyssals += milestone.milestoneBonusSteel || milestone.steelBonus;
        upgrades += milestone.milestoneBonusTactics || milestone.tacticsBonus;
        const oldHealth = health;
        health = Math.min(100, health + milestone.healthRecovery);
        
        msg = `¡HITO DE OLEADA ${completedWave}! +${milestone.steelBonus}a, +${milestone.tacticsBonus}t, +${health - oldHealth} HP`;
        
        createExplosion(canvas.width / 2, canvas.height / 2, '#FCD34D', 60);
        addFloatingText(canvas.width / 2, canvas.height / 2, '¡HITO ALCANZADO!', '#FCD34D', 'large');
        addScreenShake(30);
        playSFX('start');
      }

      showCanvasToast(msg, 'success');
      updateHUD();
    }

    function gameOver() {
      gameState = 'gameover';
    }

    // HUD State tracking for optimized updates
    const lastHUDState = {
      health: -1,
      upgrades: -1,
      abyssals: -1,
      wave: -1,
      towerCount: -1,
      mainAction: '',
      isPaused: false,
      gameState: '',
      btnCosts: {},
      btnAvailability: {},
      hadCinematic: false
    };

    function updateHUD() {
      hudUpdatePending = true;
    }

    function getIsWaiting() {
      if (gameState === 'intro' || gameState === 'gameover') return true;
      if (wave === 0) return true;
      
      if (enemies.length > 0 || enemiesLeftToSpawn > 0 || isEventActive) return false;

      if (activeCinematic) {
        if (activeCinematic.type === 'boss' || activeCinematic.isWaveStart) return false;
        if (activeCinematic.type === 'success') return true;
        return false; 
      }

      return true;
    }

    function executeHUDUpdate() {
      if (!hudUpdatePending) return;
      hudUpdatePending = false;

      // NaN Protection
      if (Number.isNaN(abyssals)) abyssals = 0;
      if (Number.isNaN(upgrades)) upgrades = 0;
      if (Number.isNaN(health)) health = 0;

      // Update basic numbers
      if (UI.health) UI.health.innerText = Math.ceil(health);
      if (UI.wave) UI.wave.innerText = wave;
      if (UI.abyssals) UI.abyssals.innerText = formatNumber(abyssals);
      if (UI.upgrades) UI.upgrades.innerText = formatNumber(upgrades);

      const emptyState = document.getElementById('selection-empty');
      const towerView = document.getElementById('tower-inspect-view');
      const enemyView = document.getElementById('enemy-inspect-view');

      if (!emptyState || !towerView || !enemyView) return;

      // Selection Logic (Unified Central Slot)
      let t = inspectedTower;
      let e = inspectedEnemy;
      let isPreview = false;

      // Priority: 1. Selected Tower, 2. Selected Enemy, 3. Build Preview
      if (!t && !e && selectedTowerType && TOWER_STATS[selectedTowerType] && TOWER_STATS[selectedTowerType].name) {
        isPreview = true;
        const stats = TOWER_STATS[selectedTowerType];
        const scaledStats = getStartingLevelStats(selectedTowerType);
        t = {
          ...stats,
          level: scaledStats.level,
          hp: scaledStats.hp,
          maxHp: scaledStats.hp,
          damage: scaledStats.damage,
          range: scaledStats.range,
          veterancy: 1,
          isPreview: true,
          type: selectedTowerType
        };
      }

      if (t) {
        emptyState.classList.add('hidden');
        enemyView.classList.add('hidden');
        towerView.classList.remove('hidden');
        
        const nameEl = document.getElementById('inspect-name');
        const levelEl = document.getElementById('inspect-level');
        const starsEl = document.getElementById('inspect-stars');
        const dmgEl = document.getElementById('inspect-dmg');
        const rangeEl = document.getElementById('inspect-range');
        const hpEl = document.getElementById('inspect-hp-text');
        
        if (nameEl) nameEl.innerText = isPreview ? `${t.name} (PREVISIÓN)` : t.name;
        if (levelEl) levelEl.innerText = `Nv.${t.level}`;
        if (starsEl) starsEl.innerText = isPreview ? '---' : '★'.repeat(Math.min(5, Math.floor((t.veterancy || 1) / 20)));
        if (dmgEl) dmgEl.innerText = formatNumber(isPreview ? t.damage : calculateBalancedDamage(t.damage, t));
        if (rangeEl) rangeEl.innerText = Math.round(t.range);
        if (hpEl) hpEl.innerText = `${Math.ceil(t.hp)}/${t.maxHp}`;
        
        const abilityPercent = isPreview ? 0 : Math.min(100, ((t.shotsFired || 0) / (TOWER_STATS[t.type].specialThreshold || 10)) * 100);
        const abilityEl = document.getElementById('inspect-ability-percent');
        if (abilityEl) abilityEl.innerText = `${Math.round(abilityPercent)}%`;
        const vetBar = document.getElementById('inspect-vet-bar');
        if (vetBar) vetBar.style.width = `${abilityPercent}%`;

        // Action buttons visibility
        const actionsContainer = towerView.querySelector('.shrink-0');
        if (actionsContainer) actionsContainer.classList.toggle('hidden', isPreview);

        if (!isPreview) {
          const repairCost = Math.ceil((t.maxHp - t.hp) * 0.2);
          const repairCostEl = document.getElementById('inspect-repair-cost');
          if (repairCostEl) repairCostEl.innerText = `${repairCost}t`;
          
          const powerupCost = getTowerCost('powerup');
          const powerupCostEl = document.getElementById('inspect-powerup-cost');
          if (powerupCostEl) powerupCostEl.innerText = `${powerupCost}a`;

          const upgradeCost = getTowerCost('upgrade', t);
          const upgradeCostEl = document.getElementById('inspect-upgrade-cost');
          if (upgradeCostEl) upgradeCostEl.innerText = `${upgradeCost}t`;
          
          const sellValueEl = document.getElementById('inspect-sell-value');
          if (sellValueEl) sellValueEl.innerText = `${calculateSellValue(t)}a`;
        }

      } else if (e) {
        emptyState.classList.add('hidden');
        towerView.classList.add('hidden');
        enemyView.classList.remove('hidden');
        
        const enNameEl = document.getElementById('enemy-inspect-name');
        const enHpEl = document.getElementById('enemy-inspect-hp-text');
        const enHpBar = document.getElementById('enemy-inspect-hp-bar');
        const enSpeedEl = document.getElementById('enemy-inspect-speed');
        const enStatusEl = document.getElementById('enemy-inspect-status');

        if (enNameEl) enNameEl.innerText = e.id.toUpperCase();
        if (enHpEl) enHpEl.innerText = `${Math.ceil(e.hp)}/${Math.ceil(e.maxHp)}`;
        if (enHpBar) enHpBar.style.width = `${(e.hp / (e.maxEnemyHp || e.maxHp)) * 100}%`;
        if (enSpeedEl) enSpeedEl.innerText = `${(e.speed / GAME_CONFIG.balance.enemyBaseSpeed).toFixed(1)}x`;
        if (enStatusEl) enStatusEl.innerText = e.hp < e.maxHp * 0.3 ? 'CRÍTICO' : 'ESTABLE';
      } else {
        emptyState.classList.remove('hidden');
        towerView.classList.add('hidden');
        enemyView.classList.add('hidden');
      }

      // Update Main Action Button
      if (UI.mainActionBtn && UI.mainActionSpan) {
        const isWaiting = getIsWaiting();
        const pauseCost = GAME_CONFIG.economy.tactics.pauseCost || 1;
        let btnText = '';
        if (gameState === 'intro') btnText = 'INICIAR';
        else if (gameState === 'gameover') btnText = 'REINTENTAR';
        else if (isWaiting) btnText = wave === 0 ? 'INICIAR' : 'SIGUIENTE';
        else if (isPaused) btnText = 'REANUDAR';
        else btnText = `PAUSAR (${pauseCost}t)`;

        UI.mainActionSpan.innerText = btnText;
        const showWaiting = isWaiting || gameState === 'intro' || gameState === 'gameover';
        UI.mainActionBtn.classList.toggle('bg-indigo-950/40', showWaiting);
        UI.mainActionBtn.classList.toggle('bg-amber-950/40', !showWaiting);
      }

      // Affordable Towers Notifications
      const inflation = 1 + Math.max(0, wave - 1) * GAME_CONFIG.economy.steel.inflation;
      const towerTypes = Object.keys(TOWER_STATS);
      for (let i = 0; i < towerTypes.length; i++) {
        const type = towerTypes[i];
        if (!TOWER_STATS[type].name) continue;
        const currentCost = Math.ceil(TOWER_STATS[type].cost * inflation);
        const canAfford = abyssals >= currentCost;
        if (canAfford && !affordableTowersState[type]) {
          showCanvasToast(`¡DISPONIBLE: ${TOWER_STATS[type].name.toUpperCase()}!`, 'success');
          affordableTowersState[type] = true;
        } else if (!canAfford && affordableTowersState[type]) {
          affordableTowersState[type] = false;
        }
      }

      if (UI.restartBtn) {
        UI.restartBtn.classList.remove('hidden');
      }

      // 4. Tower Buttons (Sidebars)
      for (let i = 0; i < UI.towerBtns.length; i++) {
        const btn = UI.towerBtns[i];
        const type = btn.getAttribute('data-type');
        if (!type) continue;

        const cost = (type === 'upgrade' && inspectedTower) ? getTowerCost(type, inspectedTower) : getTowerCost(type);
        const isTactic = type === 'repair' || type === 'upgrade' || type === 'pause';
        const isSteel = type === 'powerup' || type === 'basic' || type === 'sniper' || type === 'splash' || type === 'nova';
        const canAfford = isTactic ? upgrades >= cost : abyssals >= cost;
        const stateKey = `${type}_${inspectedTower?.id || 'none'}`;

        // Only update cost text if changed
        if (lastHUDState.btnCosts[stateKey] !== cost) {
          const costEl = btn.querySelector('.cost-tag');
          if (costEl) costEl.innerText = `${formatNumber(cost)}${isTactic ? 't' : 'a'}`;
          lastHUDState.btnCosts[stateKey] = cost;
        }

        // Only update availability/opacity if changed
        if (lastHUDState.btnAvailability[stateKey] !== canAfford) {
          if (type !== 'sell') {
            btn.classList.toggle('border-green-500/50', canAfford);
            btn.classList.toggle('border-red-500/50', !canAfford);
            btn.classList.toggle('opacity-50', !canAfford);
          }
          lastHUDState.btnAvailability[stateKey] = canAfford;
        }

        // Tower limits feedback
        const stats = TOWER_STATS[type];
        if (stats && stats.limit) {
          const currentCount = towers.reduce((acc, t) => acc + (t.type === type ? 1 : 0), 0);
          const countKey = `count_${type}`;
          if (lastHUDState[countKey] !== currentCount) {
            const countEl = btn.querySelector('.count-tag');
            if (countEl) {
              countEl.innerText = `${currentCount}/${stats.limit}`;
              countEl.classList.toggle('bg-red-500', currentCount >= stats.limit);
              countEl.classList.toggle('text-white', currentCount >= stats.limit);
              countEl.classList.toggle('scale-110', currentCount >= stats.limit);
            }
            lastHUDState[countKey] = currentCount;
          }
        }
      }
    }


    // --- RANDOM EVENTS ---
    function triggerRandomEvent() {
      // Safety check: Only trigger if wave is active and not preparation
      if (gameState !== 'playing' || wave === 0 || (enemies.length === 0 && enemiesLeftToSpawn === 0)) return;
      
      isEventActive = true;
      const events = ['meteor', 'bonus', 'curse', 'blessing'];
      const chosenEvent = events[Math.floor(Math.random() * events.length)];

      let warningMsg = '';
      let toastType = 'info';

      if (chosenEvent === 'meteor') {
        warningMsg = '¡FUEGO DEL VACÍO INMINENTE!';
        toastType = 'error';
      } else if (chosenEvent === 'curse') {
        warningMsg = '¡MALDICIÓN DE LA PLAGA!';
        toastType = 'error';
      } else if (chosenEvent === 'blessing') {
        warningMsg = '¡BENDICIÓN DE LA LUZ!';
        toastType = 'success';
      } else {
        warningMsg = '¡BOTÍN DE GUERRA DETECTADO!';
        toastType = 'success';
      }

      showCanvasToast(warningMsg, toastType);

      setTimeout(() => {
        // Execute event
        if (chosenEvent === 'meteor') executeMeteorStrike();
        else if (chosenEvent === 'curse') executeCurse();
        else if (chosenEvent === 'blessing') executeBlessing();
        else executeBonusDrop();

        isEventActive = false;
      }, 3000);
    }

