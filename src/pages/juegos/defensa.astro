---
import Layout from '../../components/layout/Layout.astro';
---

<Layout
  title="Defensa de la Ciudadela"
  description="Defiende el portal contra oleadas de adds. Gasta tus turnos para participar."
>
  <main class="relative z-10 flex flex-col items-center py-12 px-2 md:px-4 min-h-screen overflow-x-hidden">
    <!-- Header -->
    <div
      class="w-full max-w-6xl mx-auto mb-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-black/90 p-4 rounded-xl border border-indigo-500/30 shadow-[0_0_30px_rgba(79,70,229,0.2)]"
    >
      <div>
        <h1
          class="text-2xl md:text-3xl font-black text-indigo-400 uppercase tracking-widest italic"
        >
          Defensa de la Ciudadela
        </h1>
        <p class="text-gray-400 text-xs md:text-sm">Etapa de pruebas. Cada intento costara 1 Turno.</p>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex flex-col items-center md:items-end">
          <span class="text-[10px] text-amber-500/70 uppercase font-bold tracking-widest"
            >Tus Turnos</span
          >
          <span
            id="credits-display"
            class="text-white text-2xl font-extrabold drop-shadow-[0_0_10px_rgba(251,191,36,0.5)]"
            >--</span
          >
        </div>
      </div>
    </div>

    <!-- Game Area -->
    <div
      id="game-container"
      class="w-full max-w-6xl mx-auto relative rounded-xl overflow-hidden border-2 border-indigo-900/50 shadow-2xl bg-gray-900 aspect-video flex items-center justify-center"
    >
      <!-- UI Overlay (Bottom HUD - Optimized & Floating) -->
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-40 w-auto pointer-events-none">
        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-1.5 shadow-2xl flex items-center gap-4 px-5 border-b-indigo-500/50 pointer-events-auto">
          <!-- Main Stats Group -->
          <div class="flex items-center gap-4">
            <!-- Health -->
            <div class="flex items-center gap-2" title="Salud Ciudadela">
              <span class="text-xs">❤️</span>
              <span id="health-display" class="text-red-500 font-black text-sm font-mono">100</span>
            </div>
            
            <div class="w-[1px] h-4 bg-white/10"></div>

            <!-- Steel -->
            <div class="flex items-center gap-2" title="Acero (Construcción)">
              <span class="text-xs">⚙️</span>
              <span id="abyssals-display" class="text-slate-200 font-black text-sm font-mono">100</span>
            </div>

            <div class="w-[1px] h-4 bg-white/10"></div>

            <!-- Tactics -->
            <div class="flex flex-col items-center justify-center min-w-[60px]" title="Táctica (Acciones)">
              <div class="flex items-center gap-1.5">
                <span class="text-[10px]">⚡</span>
                <span id="upgrades-display" class="text-amber-400 font-black text-sm font-mono">0</span>
              </div>
              <div class="flex items-center gap-2 mt-0.5 opacity-60 scale-90">
                <span class="text-[8px] text-green-500 font-bold">🔧<span id="repair-cost-display">50</span></span>
                <span class="text-[8px] text-orange-500 font-bold">⬆️<span id="upgrade-cost-display">150</span></span>
              </div>
            </div>
          </div>

          <div class="w-[1px] h-6 bg-indigo-500/30"></div>

          <!-- Progress Group -->
          <div class="flex items-center gap-4">
            <!-- Wave -->
            <div class="flex flex-col items-center">
              <span class="text-[6px] text-indigo-400 font-black uppercase tracking-tighter">Oleada</span>
              <span id="wave-display" class="text-white font-black text-sm leading-none">0</span>
            </div>
            <!-- Towers -->
            <div class="flex flex-col items-center">
              <span class="text-[6px] text-blue-400 font-black uppercase tracking-tighter">Puestos</span>
              <span id="tower-count-display" class="text-white font-black text-xs leading-none">0/30</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Unit Info Plate (Top Center - Inspect) -->
      <div id="unit-info-plate" class="absolute top-2 left-1/2 -translate-x-1/2 z-50 hidden pointer-events-auto">
        <div class="bg-black/95 border border-indigo-500/50 rounded-xl p-2 shadow-2xl flex items-center gap-4 min-w-[300px] md:min-w-[280px] backdrop-blur-md">
          <!-- Tower View -->
          <div id="tower-inspect-view" class="flex items-center gap-4 w-full">
            <div class="flex flex-col gap-0.5 flex-1">
              <div class="flex items-center gap-2">
                <span id="inspect-name" class="text-[10px] font-black text-indigo-400 uppercase italic">NOMBRE</span>
                <span id="inspect-level" class="text-[9px] bg-indigo-900/50 text-white px-1 rounded border border-indigo-500/30">Nv.1</span>
              </div>
              <div class="flex gap-3 text-[9px] text-gray-400 font-mono">
                <span>DMG: <span id="inspect-dmg" class="text-white">0</span></span>
                <span>BAJAS: <span id="inspect-kills" class="text-white">0</span></span>
                <span class="text-amber-500/80">⚡ <span id="inspect-stamina" class="text-amber-400">100</span>%</span>
              </div>
              <div id="inspect-effects" class="flex gap-1 mt-1 empty:hidden"></div>
              <div class="w-full h-1 bg-gray-800 rounded-full mt-1 overflow-hidden">
                <div id="inspect-vet-bar" class="h-full bg-amber-500" style="width: 0%"></div>
              </div>
            </div>
            <div class="w-[1px] h-8 bg-white/10"></div>
            <div class="flex items-center gap-2">
              <button id="inspect-repair" class="flex flex-col items-center justify-center min-w-[40px] md:min-w-[32px] h-12 md:h-10 rounded-lg bg-green-900/40 border border-green-500/50 hover:bg-green-800 transition-all shadow-lg active:scale-90" title="Reparar">
                <span class="text-base md:text-sm">🔧</span>
                <span id="inspect-repair-cost" class="text-[8px] md:text-[7px] font-bold text-green-400">50t</span>
              </button>
              <button id="inspect-upgrade" class="flex flex-col items-center justify-center min-w-[40px] md:min-w-[32px] h-12 md:h-10 rounded-lg bg-orange-900/40 border border-orange-500/50 hover:bg-orange-800 transition-all shadow-lg active:scale-90" title="Mejorar">
                <span class="text-base md:text-sm">⬆️</span>
                <span id="inspect-upgrade-cost" class="text-[8px] md:text-[7px] font-bold text-orange-400">150t</span>
              </button>
              <button id="inspect-sell" class="flex flex-col items-center justify-center min-w-[40px] md:min-w-[32px] h-12 md:h-10 rounded-lg bg-red-900/40 border border-red-500/50 hover:bg-red-800 transition-all shadow-lg active:scale-90" title="Vender">
                <span class="text-base md:text-sm">💰</span>
                <span id="inspect-sell-value" class="text-[8px] md:text-[7px] font-bold text-red-400">0a</span>
              </button>
              <button id="inspect-close" class="w-8 h-8 md:w-6 md:h-6 rounded-lg bg-red-900/40 border border-red-500/50 hover:bg-red-800 transition-all flex items-center justify-center text-xs md:text-[10px] opacity-60 hover:opacity-100" title="Cerrar">✕</button>
            </div>
          </div>

          <!-- Enemy View -->
          <div id="enemy-inspect-view" class="hidden flex items-center gap-4 w-full">
            <div class="flex flex-col gap-0.5 flex-1">
              <div class="flex items-center gap-2">
                <span id="enemy-inspect-name" class="text-[10px] font-black text-red-400 uppercase italic">ENEMIGO</span>
                <span id="enemy-inspect-level" class="text-[9px] bg-red-900/50 text-white px-1 rounded border border-red-500/30">Nv.1</span>
              </div>
              <div class="flex gap-3 text-[9px] text-gray-400 font-mono">
                <span class="text-red-500/80">HP: <span id="enemy-inspect-hp" class="text-red-400">100</span>%</span>
                <span class="text-blue-500/80">SPD: <span id="enemy-inspect-speed" class="text-blue-400">1.0</span>x</span>
              </div>
              <div class="w-full h-1 bg-gray-800 rounded-full mt-1 overflow-hidden">
                <div id="enemy-inspect-hp-bar" class="h-full bg-red-600" style="width: 100%"></div>
              </div>
            </div>
            <div class="w-[1px] h-8 bg-white/10"></div>
            <button id="enemy-inspect-close" class="w-6 h-6 rounded-lg bg-red-900/40 border border-red-500/50 hover:bg-red-800 transition-all flex items-center justify-center text-[10px] opacity-60 hover:opacity-100" title="Cerrar">✕</button>
          </div>
        </div>
      </div>

      <!-- Tools Menu (Left Floating Dock) -->
      <div
        class="absolute left-2 md:left-3 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none"
      >
        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-2 md:p-1.5 shadow-2xl flex flex-col gap-4 md:gap-4 pointer-events-auto border-l-indigo-500/50">
          <div class="flex flex-col gap-4 md:gap-3">
            <!-- Fullscreen -->
            <button
              id="fullscreen-btn"
              class="w-11 h-11 md:w-10 md:h-10 rounded-xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group"
              title="Pantalla Completa"
            >
              <span class="text-lg md:text-base group-hover:scale-110 transition-transform">⛶</span>
            </button>

            <!-- Config -->
            <button
              id="config-btn"
              class="w-11 h-11 md:w-10 md:h-10 rounded-xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group"
              title="Configuración"
            >
              <span class="text-lg md:text-base group-hover:rotate-45 transition-transform">⚙️</span>
            </button>
          </div>

          <div class="w-8 md:w-6 h-[1px] bg-white/10 mx-auto"></div>

          <div class="flex flex-col gap-5 md:gap-4">
            <!-- Repair -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-green-900/30 border border-green-500/40 hover:bg-green-800/50 hover:border-green-400 transition-all flex items-center justify-center"
              data-type="repair"
            >
              <span class="text-lg md:text-base">🔧</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-green-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-green-900/50 z-10 pointer-events-none">FIX</span>
            </button>

            <!-- Upgrade -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-orange-900/30 border border-orange-500/40 hover:bg-orange-800/50 hover:border-orange-400 transition-all flex items-center justify-center"
              data-type="upgrade"
            >
              <span class="text-lg md:text-base">⬆️</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-orange-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-orange-900/50 z-10 pointer-events-none">UP</span>
            </button>

            <!-- Sell -->
            <button
              class="tower-btn w-11 h-11 md:w-10 md:h-10 rounded-xl bg-red-900/30 border border-red-500/40 text-red-500/60 flex items-center justify-center hover:bg-red-800/50 hover:text-red-400 hover:border-red-400 transition-all group"
              data-type="sell"
              title="Vender Torre"
            >
              <span class="text-lg md:text-base group-hover:scale-110 transition-transform">💰</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Config Modal -->
      <div
        id="config-modal"
        class="absolute inset-0 z-[100] flex items-center justify-center bg-black/80 backdrop-blur-sm hidden p-2"
      >
        <div
          class="w-full max-w-lg max-h-[95vh] bg-gray-950 border border-indigo-500/40 rounded-xl shadow-2xl flex flex-col overflow-hidden"
        >
          <div class="p-4 overflow-y-auto custom-scrollbar flex-1">
            <h2 class="text-lg font-black text-indigo-400 uppercase tracking-widest mb-4 italic text-center">Configuración</h2>
            
            <div class="space-y-4">
              <!-- Keybinds Section -->
              <div class="space-y-2">
                <div class="flex items-center justify-between border-b border-white/5 pb-1">
                  <span class="text-[10px] text-white font-bold uppercase tracking-tight">Atajos de Teclado</span>
                  <span class="text-[7px] text-indigo-400 font-black italic">CLIC PARA REASIGNAR</span>
                </div>
                
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-1.5" id="keybinds-list">
                  <!-- Keybinds will be injected here -->
                </div>
              </div>

              <!-- Toggles Section -->
              <div class="grid grid-cols-2 gap-2 mt-2">
                <!-- Sounds -->
                <div class="flex items-center justify-between bg-white/[0.03] p-2 rounded-lg border border-white/5">
                  <span class="text-[9px] text-gray-400 font-bold uppercase">Sonidos</span>
                  <button id="toggle-sound" class="w-10 h-5 rounded-full bg-indigo-950 border border-indigo-500/30 relative transition-colors">
                    <div id="sound-switch" class="absolute top-0.5 left-0.5 w-3.5 h-3.5 rounded-full bg-indigo-400 transition-transform translate-x-5"></div>
                  </button>
                </div>

                <!-- Turbo -->
                <div class="flex items-center justify-between bg-white/[0.03] p-2 rounded-lg border border-white/5">
                  <span class="text-[9px] text-gray-400 font-bold uppercase">Turbo x2</span>
                  <button id="toggle-turbo" class="w-10 h-5 rounded-full bg-gray-800 border border-gray-600 relative transition-colors">
                    <div id="turbo-switch" class="absolute top-0.5 left-0.5 w-3.5 h-3.5 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>

                <!-- Fog of War -->
                <div class="flex items-center justify-between bg-white/[0.03] p-2 rounded-lg border border-white/5">
                  <span class="text-[9px] text-gray-400 font-bold uppercase">Niebla de Guerra</span>
                  <button id="toggle-fog" class="w-10 h-5 rounded-full bg-indigo-950 border border-indigo-500/30 relative transition-colors">
                    <div id="fog-switch" class="absolute top-0.5 left-0.5 w-3.5 h-3.5 rounded-full bg-indigo-400 transition-transform translate-x-7"></div>
                  </button>
                </div>

                <!-- Show Ranges -->
                <div class="flex items-center justify-between bg-white/[0.03] p-2 rounded-lg border border-white/5">
                  <span class="text-[9px] text-gray-400 font-bold uppercase">Ver Rangos</span>
                  <button id="toggle-ranges" class="w-10 h-5 rounded-full bg-gray-800 border border-gray-600 relative transition-colors">
                    <div id="ranges-switch" class="absolute top-0.5 left-0.5 w-3.5 h-3.5 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="p-3 bg-gray-900/50 border-t border-white/5">
            <button
              id="close-config"
              class="w-full py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black uppercase tracking-widest rounded-lg transition-colors shadow-lg shadow-indigo-600/20"
            >
              Cerrar
            </button>
          </div>
        </div>
      </div>

      <!-- Build Menu (Right Floating Dock) -->
      <div
        class="absolute right-2 md:right-3 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none"
      >
        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-2 md:p-1.5 shadow-2xl flex flex-col gap-4 md:gap-4 pointer-events-auto border-r-indigo-500/50">
          <div class="flex flex-col gap-6 md:gap-5">
            <!-- Tower 1 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-slate-900/30 border border-slate-500/40 hover:bg-slate-800/50 hover:border-slate-400 transition-all flex items-center justify-center shadow-lg"
              data-type="basic"
              data-cost="40"
              title="Colmillo Ligero: Defensa rápida y económica"
            >
              <div class="w-5 h-5 md:w-5 md:h-5 bg-slate-400 rounded-sm group-hover:scale-110 transition-transform"></div>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-slate-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-slate-900/50 z-10 pointer-events-none">40a</span>
            </button>

            <!-- Tower 2 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-purple-900/30 border border-purple-500/40 hover:bg-purple-800/50 hover:border-purple-400 transition-all flex items-center justify-center shadow-lg"
              data-type="sniper"
              data-cost="150"
              title="Mirada del Lobo: Gran alcance y daño crítico"
            >
              <div class="w-4 h-4 md:w-3.5 md:h-3.5 bg-purple-400 rounded-full group-hover:scale-110 transition-transform"></div>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-purple-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-purple-900/50 z-10 pointer-events-none">150a</span>
            </button>

            <!-- Tower 3 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-red-900/30 border border-red-500/40 hover:bg-red-800/50 hover:border-red-400 transition-all flex items-center justify-center shadow-lg"
              data-type="splash"
              data-cost="300"
              title="Rugido de Acero: Daño en área devastador"
            >
              <div class="w-4.5 h-4.5 md:w-4 md:h-4 bg-red-400 rotate-45 group-hover:scale-110 transition-transform"></div>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-red-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-red-900/50 z-10 pointer-events-none">300a</span>
            </button>

            <!-- Tower 4 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-emerald-900/30 border border-emerald-500/40 hover:bg-emerald-800/50 hover:border-emerald-400 transition-all flex items-center justify-center shadow-lg"
              data-type="nova"
              data-cost="70"
              title="Santuario de Vida: Sana a los puestos cercanos"
            >
              <div class="w-5 h-5 md:w-5 md:h-5 bg-emerald-400 rounded-sm group-hover:scale-110 transition-transform flex items-center justify-center">
                <span class="text-[9px] md:text-[10px] text-black font-black">➕</span>
              </div>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-emerald-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-emerald-900/50 z-10 pointer-events-none">70a</span>
            </button>
          </div>

          <div class="w-8 md:w-6 h-[1px] bg-white/10 mx-auto"></div>

          <!-- Pause -->
          <button
            id="pause-btn"
            class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-yellow-900/30 border border-yellow-500/40 hover:bg-yellow-800/50 hover:border-yellow-400 transition-all flex items-center justify-center"
            data-type="pause"
          >
            <span class="text-lg md:text-base">⏸️</span>
            <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-yellow-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-yellow-900/50 z-10 pointer-events-none">10t</span>
          </button>
        </div>
      </div>

      <!-- Canvas -->
      <canvas
        id="game-canvas"
        width="1024"
        height="600"
        class="w-full h-full bg-gray-900 block cursor-crosshair object-contain"></canvas>

      <!-- Event Warning Overlay (Tension UI) -->
      <div
        id="event-warning"
        class="absolute top-2 z-25 pointer-events-none opacity-0 transition-opacity duration-300 left-1/2 -translate-x-1/2"
      >
        <div
          class="bg-red-950/95 border border-red-500/40 px-2 py-0.5 rounded-lg shadow-2xl transform scale-[0.65] transition-transform duration-300"
          id="warning-box"
        >
          <h3
            class="text-[8px] md:text-[10px] font-black text-red-500 uppercase tracking-widest animate-pulse flex items-center gap-1"
          >
            <span>⚠️</span>
            <span id="warning-text">¡PELIGRO!</span>
            <span>⚠️</span>
          </h3>
        </div>
      </div>
    </div>

    <div class="mt-8">
      <a
        href="/juegos"
        class="text-gray-500 hover:text-indigo-400 text-sm font-bold uppercase tracking-widest transition-colors flex items-center gap-2"
      >
        <i class="fas fa-arrow-left"></i> Volver a Zona de Juegos
      </a>
    </div>
  </main>

  <script is:inline>
    // --- GAME STATE ---
    let credits = 0;
    let gameState = 'intro'; // intro, playing, gameover
    let abyssals = 50;
    let upgrades = 0; // Renamed from gold
    let health = 100;
    let wave = 0;
    let selectedTowerType = null;
    let isEventActive = false;
    let isCityFallen = false; // Tracks if health is 0 but enemies are still arriving
    let isPaused = false;
    let isTurbo = false;
    let enemiesLeftToSpawn = 0;
    let isMouseDown = false;
    let mouseX = 0;
    let mouseY = 0;
    let inspectedTower = null; // Currently inspected tower for info plate
    let inspectedEnemy = null; // Currently inspected enemy for info plate
    let lastInspectUpdate = 0; // Throttle UI updates
    const fogCanvas = document.createElement('canvas');
    const fogCtx = fogCanvas.getContext('2d');
    let showFog = false; 
    let showRanges = true;
    let isRebinding = null; // Key being currently rebound

    const KEYBINDS = {
      tower1: 'a',
      tower2: 's',
      tower3: 'd',
      tower4: 'f',
      repair: 'r',
      upgrade: 'e',
      action: ' ', // Space
      fullscreen: 'w',
      sounds: 'q',
    };

    const KEY_LABELS = {
      tower1: 'Colmillo',
      tower2: 'Mirada',
      tower3: 'Rugido',
      tower4: 'Aullido',
      repair: 'Reparar',
      upgrade: 'Mejorar',
      action: 'Pausa/Inicio',
      fullscreen: 'Pantalla Completa',
      sounds: 'Sonidos',
    };
    let isShiftDown = false;
    let screenShake = 0; // Current screen shake intensity
    let lastInteractionPos = null; // {x, y, radius, life} for visual feedback
    
    // Sound state
    let soundsEnabled = true;

    // Drag and Drop Mobile state
    let isDragging = false;
    let draggedType = null;
    let dragStartX = 0;
    let dragStartY = 0;

    let curseTimer = 0;
    let curseCooldown = 600;
    let curseNotification = null;

    let globalFreezeTimer = 0;
    let globalFrenzyTimer = 0;
