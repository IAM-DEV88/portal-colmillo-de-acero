      // UI Listeners
      const fullscreenBtn = document.getElementById('fullscreen-btn');
      const gameContainer = document.getElementById('game-container');
      // Turbo Toggle Handlers
      const toggleTurbo = document.getElementById('toggle-turbo');
      const turboSwitch = document.getElementById('turbo-switch');

      function updateTurboUI() {
        if (isTurbo) {
          toggleTurbo.classList.remove('bg-gray-800', 'border-gray-600');
          toggleTurbo.classList.add('bg-amber-900/50', 'border-amber-500/50');
          turboSwitch.classList.remove('translate-x-0', 'bg-gray-400');
          turboSwitch.classList.add('translate-x-7', 'bg-amber-400');
