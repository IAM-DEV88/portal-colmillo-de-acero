    function getTowerCost(type) {
      if (type === 'repair') return Math.floor(50 + wave * 3.5);
      if (type === 'upgrade') return Math.floor(150 + wave * 7);
      if (type === 'pause') return 10;
      if (type === 'sell') return 0;
      const baseCost = TOWER_STATS[type].cost;
      // Inflation: +5% cost per wave after wave 1
      return Math.floor(baseCost * (1 + Math.max(0, wave - 1) * 0.05));
    }

    function applyDamageToTower(t, damage) {
      if (!t || damage <= 0) return;
      
      let finalDamage = damage;
      // Steel Bond Armor Bonus: -30% damage if paired
      if (t.type === 'basic' && t.isPaired) {
        finalDamage *= 0.7;
      }
      
      t.hp -= finalDamage;
      
      if (t.hp <= 0) {
        const index = towers.indexOf(t);
        if (index > -1) {
          towers.splice(index, 1);
          if (inspectedTower === t) inspectedTower = null;
          createExplosion(t.x, t.y, '#EF4444', 15);
          showCanvasToast('¡Puesto defensivo destruido!', 'error');
          playSFX('explosion');
          // Recalculate pairs after a tower is destroyed
          updateTowerPairing();
        }
      }
    }

    function updateTowerPairing() {
      // Reset pairing for all basic towers
      towers.forEach(t => {
        if (t.type === 'basic') t.isPaired = false;
      });

      const basicTowers = towers.filter(t => t.type === 'basic');
      const paired = new Set();

      for (let i = 0; i < basicTowers.length; i++) {
        if (paired.has(i)) continue;
        
        const t1 = basicTowers[i];
        const vY1 = t1.y + (((t1.gridHeight || 1) - 1) * GRID_SIZE) / 2;
        
        let bestPair = -1;
        let minDistSq = Infinity;

        for (let j = 0; j < basicTowers.length; j++) {
          if (i === j || paired.has(j)) continue;
          
          const t2 = basicTowers[j];
          const vY2 = t2.y + (((t2.gridHeight || 1) - 1) * GRID_SIZE) / 2;
          
          const dx = t2.x - t1.x;
          const dy = vY2 - vY1;
          const distSq = dx * dx + dy * dy;
          
          // Must be within influence (range) of each other
          // We use the smaller range for safety or just a fixed link range
          const linkRange = t1.range; 
          if (distSq <= linkRange * linkRange && distSq < minDistSq) {
            minDistSq = distSq;
            bestPair = j;
          }
        }

        if (bestPair !== -1) {
          t1.isPaired = true;
          basicTowers[bestPair].isPaired = true;
          paired.add(i);
          paired.add(bestPair);
        }
      }
    }

    function calculateSellValue(t) {
      if (!t) return 0;
      const stats = TOWER_STATS[t.type];
      const baseCost = stats.cost || 0;
      const upgradeCost = 150; // Base upgrade cost
      const level = t.level || 1;
      
      // Base value: construction + level upgrades
      const totalInvestment = baseCost + (level - 1) * upgradeCost;
      
      // Veterancy multiplier: +5% per star (kill since last level up)
      const stars = t.veterancy - 1;
      const veterancyBonus = 1 + (stars * 0.05);
      
      // Health penalty: Selling a damaged tower is less profitable
      // (Linear scale: 100% HP = full value, 50% HP = 75% value, 0% HP = 50% value)
      const healthFactor = 0.5 + (t.hp / t.maxHp) * 0.5;
      
      // Base refund is 50% of total investment
      const baseRefundRate = 0.5;
      
      return Math.floor(totalInvestment * baseRefundRate * veterancyBonus * healthFactor);
    }

