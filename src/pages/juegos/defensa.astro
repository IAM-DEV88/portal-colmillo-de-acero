---
import Layout from '../../components/layout/Layout.astro';
---

<Layout
  title="Defensa de la Ciudadela"
  description="Defiende el portal contra oleadas de adds. Gasta tus turnos para participar."
>
  <main class="relative z-10 flex flex-col items-center py-12 px-2 md:px-4 min-h-screen overflow-x-hidden">
    <!-- Header -->
    <div
      class="w-full max-w-6xl mx-auto mb-6 flex flex-col md:flex-row justify-between items-center gap-4 bg-black/90 p-4 rounded-xl border border-indigo-500/30 shadow-[0_0_30px_rgba(79,70,229,0.2)]"
    >
      <div>
        <h1
          class="text-2xl md:text-3xl font-black text-indigo-400 uppercase tracking-widest italic"
        >
          Defensa de la Ciudadela
        </h1>
        <p class="text-gray-400 text-xs md:text-sm">Etapa de pruebas. Cada intento costara 1 Turno.</p>
      </div>

      <div class="flex items-center gap-6">
        <div class="flex flex-col items-center md:items-end">
          <span class="text-[10px] text-amber-500/70 uppercase font-bold tracking-widest"
            >Tus Turnos</span
          >
          <span
            id="credits-display"
            class="text-white text-2xl font-extrabold drop-shadow-[0_0_10px_rgba(251,191,36,0.5)]"
            >--</span
          >
        </div>
      </div>
    </div>

    <!-- Game Area -->
    <div
      id="game-container"
      class="w-full max-w-6xl mx-auto relative rounded-xl overflow-hidden border-2 border-indigo-900/50 shadow-2xl bg-gray-900 aspect-video flex items-center justify-center"
    >
      <!-- UI Overlay (Bottom HUD - Optimized & Floating) -->
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-40 w-auto pointer-events-none flex flex-col items-center gap-2">
        <!-- Modern Start/Wave Button (Floating Above) -->
        <div class="flex items-center gap-3 pointer-events-auto">
          <button
            id="main-action-btn"
            class="opacity-0 translate-y-2 px-6 py-1.5 bg-black/85 backdrop-blur-xl border border-white/10 border-b-indigo-500/50 rounded-xl shadow-2xl transition-all duration-700 pointer-events-none z-50 group active:scale-95"
          >
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-indigo-400 group-hover:text-white transition-colors">INICIAR PARTIDA</span>
          </button>
          
          <button
            id="restart-btn"
            class="hidden px-4 py-1.5 bg-red-950/40 backdrop-blur-xl border border-red-500/30 rounded-xl shadow-2xl transition-all group active:scale-95 z-50"
            title="Reiniciar partida (Consume 1 turno)"
          >
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-red-400 group-hover:text-white transition-colors">REINICIAR</span>
          </button>
        </div>

        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-1.5 shadow-2xl flex items-center justify-center border-b-indigo-500/50 pointer-events-auto relative min-h-[46px] min-w-[320px]">
          <!-- Main Stats Group -->
          <div id="hud-stats-content" class="flex items-center gap-4 px-5">
            <div class="flex items-center gap-4">
              <!-- Health -->
              <div class="flex items-center gap-2" title="Salud Ciudadela">
                <span class="text-xs">❤️</span>
                <span id="health-display" class="text-red-500 font-black text-sm font-mono">100</span>
              </div>
              
              <div class="w-[1px] h-4 bg-white/10"></div>

              <!-- Steel -->
              <div class="flex items-center gap-2" title="Acero (Construcción)">
                <span class="text-xs">⚙️</span>
                <span id="abyssals-display" class="text-slate-200 font-black text-sm font-mono">8</span>
              </div>

              <div class="w-[1px] h-4 bg-white/10"></div>

              <!-- Tactics -->
              <div class="flex flex-col items-center justify-center min-w-[60px]" title="Táctica (Acciones)">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px]">⚡</span>
                  <span id="upgrades-display" class="text-amber-400 font-black text-sm font-mono">5</span>
                </div>
                <div class="flex items-center gap-2 mt-0.5 opacity-60 scale-90">
                  <span class="text-[8px] text-green-500 font-bold">🔧<span id="repair-cost-display">1.2</span></span>
                  <span class="text-[8px] text-orange-500 font-bold">⬆️<span id="upgrade-cost-display">3</span></span>
                </div>
              </div>
            </div>

            <div class="w-[1px] h-6 bg-indigo-500/30"></div>

            <!-- Progress Group -->
            <div class="flex items-center gap-4">
              <!-- Wave -->
              <div class="flex flex-col items-center">
                <span class="text-[6px] text-indigo-400 font-black uppercase tracking-tighter">Oleada</span>
                <span id="wave-display" class="text-white font-black text-sm leading-none">0</span>
              </div>
              <!-- Towers -->
              <div class="flex flex-col items-center">
                <span class="text-[6px] text-blue-400 font-black uppercase tracking-tighter">Puestos</span>
                <span id="tower-count-display" class="text-white font-black text-xs leading-none">0/15</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Unit Info Plate (Top Center - Inspect) -->
      <div id="unit-info-plate" class="absolute top-2 left-1/2 -translate-x-1/2 z-50 hidden pointer-events-auto">
        <div class="bg-black/90 border border-indigo-500/40 rounded-2xl p-3 shadow-[0_0_40px_rgba(79,70,229,0.25)] flex items-center gap-4 min-w-[320px] backdrop-blur-xl">
          <!-- Tower View -->
          <div id="tower-inspect-view" class="flex items-center gap-4 w-full">
            <div class="flex flex-col gap-1.5 flex-1">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span id="inspect-name" class="text-xs font-black text-indigo-400 uppercase tracking-wider italic">NOMBRE</span>
                  <div class="flex gap-1">
                    <span id="inspect-level" class="text-[9px] bg-indigo-900/40 text-white px-1.5 py-0.5 rounded border border-indigo-500/30 font-black">NV.1</span>
                    <span id="inspect-stars" class="text-[10px] text-amber-400 font-black drop-shadow-[0_0_5px_rgba(251,191,36,0.5)]">0★</span>
                  </div>
                </div>
                <span id="inspect-synergy" class="text-[8px] font-black text-blue-400 bg-blue-900/30 px-1.5 py-0.5 rounded border border-blue-500/30 hidden animate-pulse">🔗 VÍNCULO</span>
              </div>

              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[9px] text-gray-400 font-mono">
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>DAÑO:</span><span id="inspect-dmg" class="text-white font-bold">0</span></div>
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>BAJAS:</span><span id="inspect-kills" class="text-white font-bold">0</span></div>
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>RANGO:</span><span id="inspect-range" class="text-indigo-300 font-bold">0</span></div>
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>SALUD:</span><span id="inspect-hp-text" class="text-red-400 font-bold">0/0</span></div>
              </div>

              <!-- Special Ability Progress -->
              <div class="space-y-1 mt-1">
                <div class="flex justify-between items-center px-0.5">
                  <span class="text-[7px] text-amber-500/70 font-black uppercase tracking-widest">Habilidad Especial</span>
                  <span id="inspect-ability-percent" class="text-[7px] text-amber-400 font-mono">0%</span>
                </div>
                <div class="w-full h-1.5 bg-gray-900/80 rounded-full overflow-hidden border border-white/5">
                  <div id="inspect-vet-bar" class="h-full bg-gradient-to-r from-amber-600 to-amber-400 transition-all duration-300 shadow-[0_0_10px_rgba(251,191,36,0.3)]" style="width: 0%"></div>
                </div>
              </div>

              <!-- Status Effects -->
              <div id="inspect-effects" class="flex flex-wrap gap-1 mt-1 empty:hidden"></div>
            </div>

            <div class="w-[1px] h-16 bg-white/10 mx-1"></div>

            <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-1.5">
                <button id="inspect-repair" class="flex flex-col items-center justify-center w-10 h-10 rounded-xl bg-green-900/30 border border-green-500/40 hover:bg-green-800/50 hover:border-green-400 transition-all shadow-lg active:scale-90 group" title="Reparar">
                  <span class="text-sm group-hover:scale-110 transition-transform">🔧</span>
                  <span id="inspect-repair-cost" class="text-[7px] font-black text-green-400">2t</span>
                </button>
                <button id="inspect-upgrade" class="flex flex-col items-center justify-center w-10 h-10 rounded-xl bg-orange-900/30 border border-orange-500/40 hover:bg-orange-800/50 hover:border-orange-400 transition-all shadow-lg active:scale-90 group" title="Mejorar">
                  <span class="text-sm group-hover:scale-110 transition-transform">⬆️</span>
                  <span id="inspect-upgrade-cost" class="text-[7px] font-black text-orange-400">5t</span>
                </button>
              </div>
              <div class="flex items-center gap-1.5">
                <button id="inspect-sell" class="flex flex-col items-center justify-center w-10 h-10 rounded-xl bg-red-900/30 border border-red-500/40 hover:bg-red-800/50 hover:border-red-400 transition-all shadow-lg active:scale-90 group" title="Vender">
                  <span class="text-sm group-hover:scale-110 transition-transform">💰</span>
                  <span id="inspect-sell-value" class="text-[7px] font-black text-red-400">0a</span>
                </button>
                <button id="inspect-close" class="w-10 h-10 rounded-xl bg-slate-900/40 border border-white/10 hover:bg-red-900/40 hover:border-red-500/50 transition-all flex items-center justify-center text-xs opacity-60 hover:opacity-100" title="Cerrar">✕</button>
              </div>
            </div>
          </div>

          <!-- Enemy View -->
          <div id="enemy-inspect-view" class="hidden flex items-center gap-4 w-full">
            <div class="flex flex-col gap-1.5 flex-1">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span id="enemy-inspect-name" class="text-xs font-black text-red-400 uppercase tracking-wider italic">ENEMIGO</span>
                  <span id="enemy-inspect-level" class="text-[9px] bg-red-900/40 text-white px-1.5 py-0.5 rounded border border-red-500/30 font-black">NV.1</span>
                </div>
                <span id="enemy-inspect-type" class="text-[8px] font-black text-purple-400 bg-purple-900/30 px-1.5 py-0.5 rounded border border-purple-500/30 uppercase">NORMAL</span>
              </div>

              <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[9px] text-gray-400 font-mono">
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>SALUD:</span><span id="enemy-inspect-hp-text" class="text-red-400 font-bold">0/0</span></div>
                <div class="flex justify-between border-b border-white/5 pb-0.5"><span>VELOC.:</span><span id="enemy-inspect-speed" class="text-blue-400 font-bold">1.0x</span></div>
                <div class="flex justify-between border-b border-white/5 pb-0.5 col-span-2"><span>ESTADO:</span><span id="enemy-inspect-status" class="text-amber-400 font-bold italic">ESTABLE</span></div>
              </div>

              <div class="w-full h-1.5 bg-gray-900/80 rounded-full mt-1 overflow-hidden border border-white/5 shadow-inner">
                <div id="enemy-inspect-hp-bar" class="h-full bg-gradient-to-r from-red-700 to-red-500 transition-all duration-300 shadow-[0_0_10px_rgba(239,68,68,0.3)]" style="width: 100%"></div>
              </div>
            </div>
            <div class="w-[1px] h-16 bg-white/10 mx-1"></div>
            <button id="enemy-inspect-close" class="w-12 h-12 rounded-xl bg-slate-900/40 border border-white/10 hover:bg-red-900/40 hover:border-red-500/50 transition-all flex items-center justify-center text-sm opacity-60 hover:opacity-100 shadow-lg" title="Cerrar">✕</button>
          </div>
        </div>
      </div>

      <!-- Tools Menu (Left Floating Dock) -->
      <div
        class="absolute left-2 md:left-3 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none"
      >
        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-2 md:p-1.5 shadow-2xl flex flex-col gap-4 md:gap-4 pointer-events-auto border-l-indigo-500/50">
          <div class="flex flex-col gap-4 md:gap-3">
            <!-- Fullscreen -->
            <button
              id="fullscreen-btn"
              class="w-11 h-11 md:w-10 md:h-10 rounded-xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group"
              title="Pantalla Completa"
            >
              <span class="text-lg md:text-base group-hover:scale-110 transition-transform">⛶</span>
            </button>

            <!-- Config -->
            <button
              id="config-btn"
              class="w-11 h-11 md:w-10 md:h-10 rounded-xl bg-slate-900/40 border border-white/10 text-white/60 flex items-center justify-center hover:bg-indigo-900/60 hover:text-white hover:border-indigo-500/50 transition-all group"
              title="Configuración"
            >
              <span class="text-lg md:text-base group-hover:rotate-45 transition-transform">⚙️</span>
            </button>

            <!-- Reset (In Tools Menu) -->
            <button
              id="tools-restart-btn"
              class="w-11 h-11 md:w-10 md:h-10 rounded-xl bg-red-900/20 border border-red-500/20 text-red-500/40 flex items-center justify-center hover:bg-red-800/40 hover:text-red-400 hover:border-red-400 transition-all group"
              title="Reiniciar partida (Consume 1 turno)"
            >
              <span class="text-lg md:text-base group-hover:scale-110 transition-transform">🔄</span>
            </button>
          </div>

          <div class="w-8 md:w-6 h-[1px] bg-white/10 mx-auto"></div>

          <div class="flex flex-col gap-5 md:gap-4">
            <!-- Repair -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-green-900/30 border border-green-500/40 hover:bg-green-800/50 hover:border-green-400 transition-all flex items-center justify-center"
              data-type="repair"
            >
              <span class="text-lg md:text-base">🔧</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-green-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-green-900/50 z-10 pointer-events-none">FIX</span>
            </button>

            <!-- Upgrade -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-orange-900/30 border border-orange-500/40 hover:bg-orange-800/50 hover:border-orange-400 transition-all flex items-center justify-center"
              data-type="upgrade"
            >
              <span class="text-lg md:text-base">⬆️</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-orange-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-orange-900/50 z-10 pointer-events-none">UP</span>
            </button>

            <!-- Sell -->
            <button
              class="tower-btn w-11 h-11 md:w-10 md:h-10 rounded-xl bg-red-900/30 border border-red-500/40 text-red-500/60 flex items-center justify-center hover:bg-red-800/50 hover:text-red-400 hover:border-red-400 transition-all group"
              data-type="sell"
              title="Vender Torre"
            >
              <span class="text-lg md:text-base group-hover:scale-110 transition-transform">💰</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Config Modal -->
      <div id="restart-confirm-modal" class="hidden absolute inset-0 z-[110] flex items-center justify-center bg-black/60 backdrop-blur-md p-4">
        <div class="w-full max-w-sm bg-black/85 backdrop-blur-2xl border border-white/10 border-b-red-500/50 rounded-3xl shadow-[0_0_50px_rgba(239,68,68,0.3)] p-6 transform animate-in zoom-in duration-200">
          <div class="text-center space-y-4">
            <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto border border-red-500/20">
              <span class="text-3xl">🔄</span>
            </div>
            <div class="space-y-2">
              <h3 class="text-xl font-black text-white tracking-tight uppercase italic">¿REINICIAR PARTIDA?</h3>
              <p class="text-slate-400 text-xs leading-relaxed uppercase tracking-wider">
                Perderás todo el progreso de la oleada actual. Esta acción consume <span class="text-indigo-400 font-bold">1 turno</span>.
              </p>
            </div>
            <div class="flex gap-3 pt-2">
              <button 
                id="cancel-restart-btn"
                class="flex-1 px-4 py-3 rounded-2xl bg-white/5 text-slate-300 font-black text-[10px] hover:bg-white/10 transition-all uppercase tracking-[0.2em]"
              >
                Cancelar
              </button>
              <button 
                id="confirm-restart-btn"
                class="flex-1 px-4 py-3 rounded-2xl bg-red-600 text-white font-black text-[10px] hover:bg-red-500 transition-all shadow-lg shadow-red-600/20 uppercase tracking-[0.2em]"
              >
                Reiniciar
              </button>
            </div>
          </div>
        </div>
      </div>

      <div
        id="config-modal"
        class="absolute inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-md hidden p-4"
      >
        <div
          class="w-full max-w-lg max-h-[90vh] bg-black/85 backdrop-blur-2xl border border-white/10 border-b-indigo-500/50 rounded-3xl shadow-[0_0_50px_rgba(79,70,229,0.3)] flex flex-col overflow-hidden"
        >
          <div class="p-6 overflow-y-auto custom-scrollbar flex-1">
            <div class="flex items-center justify-center gap-3 mb-6">
              <div class="w-8 h-[1px] bg-indigo-500/50"></div>
              <h2 class="text-xl font-black text-indigo-400 uppercase tracking-[0.3em] italic text-center">Configuración</h2>
              <div class="w-8 h-[1px] bg-indigo-500/50"></div>
            </div>
            
            <div class="space-y-6">
              <!-- Keybinds Section -->
              <div class="space-y-3">
                <div class="flex items-center justify-between border-b border-white/10 pb-2">
                  <span class="text-[10px] text-white font-black uppercase tracking-widest">Atajos de Teclado</span>
                  <span class="text-[8px] text-indigo-400 font-black italic animate-pulse">CLIC PARA REASIGNAR</span>
                </div>
                
                <div class="grid grid-cols-3 sm:grid-cols-4 gap-2" id="keybinds-list">
                  <!-- Keybinds will be injected here -->
                </div>
              </div>

              <!-- Toggles Section -->
              <div class="grid grid-cols-2 gap-3 mt-4">
                <!-- Sounds -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Sonidos</span>
                  <button id="toggle-sound" class="w-12 h-6 rounded-full bg-indigo-950/50 border border-indigo-500/30 relative transition-all group shadow-inner">
                    <div id="sound-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-indigo-400 shadow-[0_0_10px_rgba(129,140,248,0.5)] transition-transform translate-x-6"></div>
                  </button>
                </div>

                <!-- Turbo -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Turbo x2</span>
                  <button id="toggle-turbo" class="w-12 h-6 rounded-full bg-gray-900/50 border border-white/10 relative transition-all group shadow-inner">
                    <div id="turbo-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>

                <!-- Fog of War -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Niebla</span>
                  <button id="toggle-fog" class="w-12 h-6 rounded-full bg-indigo-950/50 border border-indigo-500/30 relative transition-all group shadow-inner">
                    <div id="fog-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-indigo-400 shadow-[0_0_10px_rgba(129,140,248,0.5)] transition-transform translate-x-6"></div>
                  </button>
                </div>

                <!-- Show Ranges -->
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-2xl border border-white/5 hover:bg-white/[0.05] transition-colors">
                  <span class="text-[10px] text-gray-400 font-black uppercase tracking-wider">Rangos</span>
                  <button id="toggle-ranges" class="w-12 h-6 rounded-full bg-gray-900/50 border border-white/10 relative transition-all group shadow-inner">
                    <div id="ranges-switch" class="absolute top-1 left-1 w-4 h-4 rounded-full bg-gray-400 transition-transform"></div>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="p-4 bg-white/[0.02] border-t border-white/5 flex gap-3">
            <button
              id="close-config"
              class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-black uppercase tracking-[0.2em] rounded-2xl transition-all shadow-lg shadow-indigo-600/20 active:scale-[0.98]"
            >
              Confirmar Cambios
            </button>
          </div>
        </div>
      </div>

      <!-- Build Menu (Right Floating Dock) -->
      <div
        class="absolute right-2 md:right-3 top-1/2 -translate-y-1/2 z-30 flex flex-col items-center gap-2 pointer-events-none"
      >
        <div class="bg-black/85 backdrop-blur-md border border-white/10 rounded-2xl p-2 md:p-1.5 shadow-2xl flex flex-col gap-4 md:gap-4 pointer-events-auto border-r-indigo-500/50">
          <div class="flex flex-col gap-6 md:gap-5">
            <!-- Tower 1 -->
            <button
              class="tower-btn group relative w-11 h-11 md:w-10 md:h-10 shrink-0 rounded-xl bg-slate-900/30 border border-slate-500/40 hover:bg-slate-800/50 hover:border-slate-400 transition-all flex items-center justify-center shadow-lg"
              data-type="basic"
              data-cost="4"
              title="Colmillo Ligero: Defensa rápida (Límite: 8)"
            >
              <div class="w-5 h-5 md:w-5 md:h-5 bg-slate-400 rounded-sm group-hover:scale-110 transition-transform"></div>
              <span class="count-tag absolute -top-1.5 -right-1.5 bg-slate-800 text-slate-400 text-[7px] font-black px-1 rounded-full border border-slate-500/30 z-10 pointer-events-none">0/8</span>
              <span class="cost-tag absolute -bottom-1.5 left-1/2 -translate-x-1/2 bg-black/90 text-slate-400 text-[8px] md:text-[7px] font-black px-1 rounded border border-slate-900/50 z-10 pointer-events-none">4a</span>
            </button>

            <!-- Tower 2 -->
            <button
