---
import Layout from '@/components/layout/Layout.astro';
---

<Layout title="RPG Test - Colmillo de Acero">
  <div class="flex flex-col items-center justify-center min-h-screen py-10 bg-[#0a0a0a]">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-amber-600 uppercase tracking-tighter mb-2">RPG Adventure</h1>
      <p class="text-gray-500 text-sm font-medium tracking-widest uppercase">Fase de Pruebas: Motor Alpha</p>
    </div>

    <div class="relative w-full h-[calc(100vh-200px)] min-h-[500px] group">
      <!-- Glow Effect -->
      <div class="absolute -inset-1 bg-gradient-to-r from-amber-500/20 to-blue-500/20 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
      
      <div class="relative w-full h-full bg-black rounded-xl border border-white/10 shadow-2xl overflow-hidden" id="canvas-container">
        <!-- Overlay Controls -->
        <div class="absolute top-4 right-4 z-50 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
          <button id="toggle-fullscreen" type="button" class="bg-black/60 hover:bg-amber-500/80 text-white p-2 rounded-lg backdrop-blur-md border border-white/10 transition-all active:scale-95" title="Maximizar">
            <i class="fas fa-expand"></i>
          </button>
          <button id="toggle-settings" type="button" class="bg-black/60 hover:bg-blue-500/80 text-white p-2 rounded-lg backdrop-blur-md border border-white/10 transition-all active:scale-95" title="Configuración">
            <i class="fas fa-cog"></i>
          </button>
        </div>
        
        <canvas id="rpg-canvas" class="w-full h-full block bg-[#111] transition-all duration-500"></canvas>
      </div>
    </div>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl w-full px-4">
      <div class="bg-white/5 border border-white/5 p-4 rounded-xl">
        <h3 class="text-amber-500 text-xs font-black uppercase tracking-widest mb-3 flex items-center gap-2">
          <i class="fas fa-keyboard"></i> Controles Mundo
        </h3>
        <ul class="space-y-2 text-[11px] text-gray-400 font-bold uppercase">
          <li class="flex justify-between"><span>Moverse</span> <span class="text-white">WASD / Flechas</span></li>
          <li class="flex justify-between"><span>Forzar Combate</span> <span class="text-white">Tecla B</span></li>
        </ul>
      </div>

      <div class="bg-white/5 border border-white/5 p-4 rounded-xl">
        <h3 class="text-blue-500 text-xs font-black uppercase tracking-widest mb-3 flex items-center gap-2">
          <i class="fas fa-swords"></i> Controles Combate
        </h3>
        <ul class="space-y-2 text-[11px] text-gray-400 font-bold uppercase">
          <li class="flex justify-between"><span>Seleccionar</span> <span class="text-white">WASD / Flechas</span></li>
          <li class="flex justify-between"><span>Confirmar</span> <span class="text-white">Enter / Espacio</span></li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { RPGGame } from '@/lib/rpg/RPGGame';

  const canvas = document.getElementById('rpg-canvas') as HTMLCanvasElement;
  if (canvas) {
    // Inicializar tamaño antes de empezar el juego
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;

    const game = new RPGGame(canvas);
    game.start();

    // Redimensionar canvas cuando la ventana cambie
    window.addEventListener('resize', () => {
      const rect = canvas.getBoundingClientRect();
      game.resize(rect.width, rect.height);
    });

    // Fullscreen / Maximize Logic
    const fullscreenBtn = document.getElementById('toggle-fullscreen');
    const canvasContainer = document.getElementById('canvas-container');
    
    fullscreenBtn?.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        canvasContainer?.requestFullscreen().catch(err => {
          console.error(`Error attempting to enable full-screen mode: ${err.message}`);
        });
      } else {
        document.exitFullscreen();
      }
    });

    // Handle resize on fullscreen change
    document.addEventListener('fullscreenchange', () => {
      setTimeout(() => {
        const rect = canvas.getBoundingClientRect();
        game.resize(rect.width, rect.height);
      }, 50);
    });
  }
</script>

<style>
  #rpg-canvas {
    image-rendering: pixelated;
    cursor: crosshair;
  }
</style>
