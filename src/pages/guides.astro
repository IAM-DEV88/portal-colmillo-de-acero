---
import Layout from '../components/layout/Layout.astro';
import { supabase } from '../lib/supabase';
import ShareButton from '../components/guides/ShareButton.astro';
import { staticGuides, categories, colorClasses } from '../data/guides';

// Obtener votos de Supabase
const { data: votesData } = await supabase.from('guide_votes').select('guide_id');
const votesCount: Record<string, number> = {};
votesData?.forEach(v => {
  votesCount[v.guide_id] = (votesCount[v.guide_id] || 0) + 1;
});
---

<Layout 
  title="Guías de Raid y Addons" 
  description="Domina el contenido PvE de WoW 3.3.5a con nuestras guías detalladas. Estrategias para ICC, Halion, configuración de addons y notas públicas."
>
  <main 
    class="" 
    x-data="{ 
      activeCategory: 'Mecánicas',
      init() {
        const urlParams = new URLSearchParams(window.location.search);
        const category = urlParams.get('category');
        if (category) {
          this.activeCategory = category;
        }
      }
    }"
  >
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <header class="text-center mb-12 animate-fade-in">
        <h1 class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-amber-300 to-amber-500 font-title tracking-wider uppercase">
          Portal de Guías
        </h1>
        <p class="text-gray-400 mt-2 text-sm max-w-lg mx-auto italic">
          Aprende, domina y comparte tus conocimientos con la comunidad de Colmillo de Acero.
        </p>
        <div class="w-48 h-0.5 bg-gradient-to-r from-amber-900/0 via-amber-500/80 to-amber-900/0 mx-auto my-6"></div>
      </header>

      <!-- Category Navigation -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {categories.map(cat => (
          <button
            @click={`activeCategory = '${cat}'`}
            class="px-6 py-2.5 rounded-full text-xs font-black uppercase tracking-widest transition-all border-2"
            :class={`activeCategory === '${cat}' ? 'bg-amber-600 border-amber-500 text-white shadow-lg shadow-amber-900/40 scale-105' : 'bg-gray-900/40 border-white/5 text-gray-500 hover:text-gray-300 hover:border-white/10'`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Guides Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {staticGuides.map(guide => {
          const classes = colorClasses[guide.color] || colorClasses.blue;
          const initialVotes = votesCount[guide.id] || 0;
          return (
            <div 
              x-show={`activeCategory === '${guide.category}'`}
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 transform translate-y-4"
              x-transition:enter-end="opacity-100 transform translate-y-0"
              class={`relative group bg-gray-900/60 backdrop-blur-sm border ${classes.border} rounded-lg p-6 transition-all duration-300 ${classes.hoverBorder} ${classes.shadow} hover:-translate-y-1 overflow-hidden`}
              x-data={`{ 
                guideId: '${guide.id}', 
                voteCount: ${initialVotes},
                voted: false,
                init() {
                  this.voted = localStorage.getItem('voted_' + this.guideId) === 'true';
                },
                async toggleVote() {
                  const originalVoted = this.voted;
                  const originalCount = this.voteCount;
                  this.voted = !this.voted;
                  this.voteCount = this.voted ? this.voteCount + 1 : Math.max(0, this.voteCount - 1);
                  try {
                    const res = await fetch('/api/guides/vote', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ guideId: this.guideId, action: this.voted ? 'add' : 'remove' })
                    });
                    const data = await res.json();
                    if (data.success) {
                      localStorage.setItem('voted_' + this.guideId, this.voted);
                      // Mostrar notificación si se ganó un turno
                      if (data.rewarded && window.showRewardToast) {
                        window.showRewardToast('¡Por apoyar nuestras guías!');
                      }
                    } else {
                      this.voted = originalVoted;
                      this.voteCount = originalCount;
                    }
                  } catch (e) {
                    this.voted = originalVoted;
                    this.voteCount = originalCount;
                  }
                }
              }`}
            >
              <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
              
              <div class="relative z-10 flex flex-col h-full">
                <div class="flex items-start justify-between mb-4">
                  <div class={`p-3 rounded-lg ${classes.iconBg} border ${classes.iconBorder}`}>
                    <i class={`fas ${guide.icon} ${classes.iconText} text-xl`}></i>
                  </div>
                  
                  <!-- Interactive Like Button -->
                  <button 
                    @click="toggleVote()"
                    class="flex items-center gap-1.5 bg-black/40 px-2.5 py-1.5 rounded-md border border-white/5 hover:border-red-500/30 transition-all active:scale-95 group/heart"
                    title="Me gusta"
                  >
                    <i 
                      class="fas fa-heart transition-all duration-300"
                      :class="voted ? 'text-red-500 scale-110' : 'text-gray-600 group-hover/heart:text-red-400'"
                    ></i>
                    <span class="text-[10px] font-bold transition-colors" :class="voted ? 'text-white' : 'text-gray-400'" x-text="voteCount"></span>
                  </button>
                </div>

                <h2 class="text-lg font-bold text-white mb-3 group-hover:text-amber-400 transition-colors leading-tight">
                  {guide.title}
                </h2>
                
                <p class="text-gray-400 text-xs leading-relaxed mb-6 flex-grow italic">
                  {guide.description}
                </p>

                <div class="flex items-center justify-between mt-auto pt-4 border-t border-white/5 gap-3">
                  <a
                    href={guide.href}
                    class={`flex-grow inline-flex items-center justify-center px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest ${classes.btnBg} ${classes.btnText} ${classes.btnHoverBg} group-hover:text-white transition-all`}
                  >
                    Leer Guía
                    <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                  </a>
                  <ShareButton url={`https://portal.colmillo.com${guide.href}`} variant="compact" />
                </div>
              </div>
            </div>
          );
        })}

        {/* Placeholder for empty categories */}
        {categories.map(cat => (
          <div 
            x-show={`activeCategory === '${cat}' && ${staticGuides.filter(g => g.category === cat).length === 0}`}
            class="col-span-full py-20 text-center bg-gray-900/20 rounded-lg border border-dashed border-white/10"
          >
            <i class="fas fa-folder-open text-gray-700 text-4xl mb-4"></i>
            <p class="text-gray-500 font-medium tracking-wide">Aún no hay guías en la categoría {cat}.</p>
            <p class="text-gray-600 text-xs mt-1">¡Pronto añadiremos nuevo contenido!</p>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(circle, #ffffff 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>
