---
import Layout from '../components/layout/Layout.astro';
import RosterTable from '../components/roster/RosterTable.astro';
import { validatePublicNote } from '../utils/rosterUtils';
import { supabase } from '../lib/supabase';
import { rosterService } from '../services/rosterService';

// Use rosterService to fetch data with caching
const rosterFormattedData = await rosterService.getFormattedRoster();
const rosterData = rosterFormattedData; 
const rosterError = null;

const globalLastUpdate = rosterFormattedData.globalLastUpdate;
const lastUpdatedBy = rosterFormattedData.lastUpdatedBy || 'Desconocido';
const lastUpdatedAt = rosterFormattedData.lastUpdatedAt || null;
const totalCount = rosterFormattedData.totalCount || 0;

if (rosterError) {
  console.error('Error loading roster from Supabase:', rosterError);
}

// Definir el tipo para los miembros del roster
interface RosterMember {
  name: string;
  officerNote?: string;
  class: string;
  publicNote?: string;
  rank?: string;
  noteValidation?: any;
}

// Asegurarse de que los datos tengan la estructura esperada
const players = (rosterData as any).players || {};
const formattedRosterData = Object.entries(players)
  .filter(([_, memberData]: [string, any]) => !memberData.guildLeave) // Filtrar jugadores que han salido
  .map(([name, memberData]: [string, any]) => {
  const member = { ...memberData, name }; // Asegurar que el nombre esté incluido

  try {
    // Validar la nota pública si existe
    const publicNote = String(member.publicNote || '').trim();
    const noteValidation = validatePublicNote(publicNote, member.name || 'Desconocido');

    // Asegurar que la clase sea válida
    const className = String(member.class || 'Desconocido').trim();

    return {
      ...member,
      name: String(name || 'Sin nombre').trim(),
      class: className,
      rank: String(member.rank || 'Miembro').trim(),
      publicNote,
      noteValidation,
      officerNote: String(member.officerNote || '').trim(),
      mainAlt: member.mainAlt || 'A',
      level: Number(member.level) || 80,
      gearScore: Number(member.gearScore) || 0,
      // Asegurar que los campos de validación estén presentes
      validation: {
        ...noteValidation,
        isValid: noteValidation.isValid || false,
        missingFields: Array.isArray(noteValidation.missingFields)
          ? noteValidation.missingFields
          : [],
      },
    };
  } catch (error) {
    console.error('Error procesando miembro:', member, error);
    return {
      ...member,
      name: String(member.name || 'Error en datos').trim(),
      class: 'Desconocido',
      rank: 'Error',
      publicNote: '',
      noteValidation: {
        isValid: false,
        errors: ['Error al procesar datos del personaje'],
        missingFields: ['Datos inválidos'],
      },
      officerNote: '',
      mainAlt: 'M',
      level: 0,
      gearScore: 0,
      validation: {
        isValid: false,
        errors: ['Error al procesar datos del personaje'],
        missingFields: ['Datos inválidos'],
      },
    };
  }
});

// Fetch active raid registrations
const { data: raidRegistrations } = await supabase
  .from('raid_registrations')
  .select('*')
  .in('status', ['aceptado', 'en_revision', 'en_espera']);
---

<Layout 
  title="Roster y Miembros" 
  description="Conoce a los héroes de Colmillo de Acero. Lista completa de miembros, rangos y normas de nuestra hermandad."
>
  <div class="mx-auto animate-fade-in max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Tabla de Roster -->
    <div class="relative z-40">
      <RosterTable
        initialRosterData={formattedRosterData}
        raidRegistrations={raidRegistrations || []}
        lastUpdatedBy={lastUpdatedBy}
        globalLastUpdate={globalLastUpdate}
        lastUpdatedAt={lastUpdatedAt}
        totalMembersCount={totalCount}
      />
    </div>

  </div></Layout
>
