---

<Layout 
  title="Guía Guerrero Protección 3.3.5a " 
  description="Guía del Guerrero Tanque (Protección) para WotLK 3.3.5a. Equipo BIS, cap de defensa, gemas y rotación de mitigación física."
>
  <div>
    <WoWCharacterPanel {...specData}>
      <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/ability_warrior_defensivestance.jpg" alt="Prot" class="w-full h-full object-cover" />
    </WoWCharacterPanel>

    <div class="mt-4">
      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-12"></div>
      <GuideInteractions guide_id={guideId} />
    </div>
  </div>
</Layout>

<style is:global>
  .text-orange-400 { color: #C79C6E; }
  .border-orange-500\/30 { border-color: rgba(199, 156, 110, 0.3); }
  .bg-orange-500\/10 { background-color: rgba(199, 156, 110, 0.1); }
</style>
