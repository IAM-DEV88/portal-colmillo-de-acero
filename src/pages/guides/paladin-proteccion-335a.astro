---

<Layout 
  title="Guía Paladín Protección 3.3.5a " 
  description="Guía del Paladín Tanque (Protección) para WotLK 3.3.5a. Equipo BIS, cap de defensa, gemas, encantamientos y rotación 96969."
>
  <div>
    <!-- WoW Character Panel -->
    <WoWCharacterPanel {...specData}>
      <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/ability_paladin_shieldofthetemplar.jpg" alt="Prot" class="w-full h-full object-cover" />
    </WoWCharacterPanel>

    <!-- Community Section -->
    <div class="mt-4">
      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-12"></div>
      <GuideInteractions guide_id={guideId} />
    </div>
  </div>
</Layout>

<style is:global>
  /* Colores de clase personalizados */
  .text-pink-400 { color: #F48CBA; }
  .border-pink-500\/30 { border-color: rgba(244, 140, 186, 0.3); }
  .bg-pink-500\/10 { background-color: rgba(244, 140, 186, 0.1); }
</style>
