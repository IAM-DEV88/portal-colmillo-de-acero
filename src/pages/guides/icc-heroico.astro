---
export const prerender = false;
import Layout from '../../components/layout/Layout.astro';
import GuideInteractions from '../../components/guides/GuideInteractions.astro';
import ShareButton from '../../components/guides/ShareButton.astro';

const guideId = 'icc-heroico';
---

<Layout 
  title="Guía de ICC Heroico - Mecánicas" 
  description="Aprende todas las mecánicas de Ciudadela de la Corona de Hielo (ICC) en modo Heroico. Guía visual para dominar los encuentros de la raid."
>
  <main class="">
    <div class="max-w-6xl mx-auto">
      <!-- Botón Volver y Compartir -->
      <div class="mb-8 flex items-center justify-between gap-4">
        <a 
          href="/guides?category=Mecánicas" 
          class="flex items-center gap-3 px-5 py-2.5 rounded-lg bg-gray-900/60 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all text-[10px] font-black uppercase tracking-[0.2em] no-underline group backdrop-blur-md shadow-lg"
        >
          <i class="fas fa-chevron-left group-hover:-translate-x-1 transition-transform"></i>
          Volver al Portal
        </a>
        <ShareButton variant="full" />
      </div>

      <!-- Header -->
      <header class="text-center mb-12 animate-fade-in">
        <h1
          class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-300 to-blue-500 font-title tracking-wider"
        >
          ICC 25 HEROICO - MECÁNICAS
        </h1>
        <div
          class="w-48 h-0.5 bg-gradient-to-r from-blue-900/0 via-blue-500/80 to-blue-900/0 mx-auto my-6"
        >
        </div>
      </header>

      <!-- Video Section -->
      <div
        class="bg-gray-800/50 backdrop-blur-sm rounded-lg overflow-hidden border border-blue-900/30 mb-6"
      >
        <div class="relative" style="padding-bottom: 56.25%;">
          <iframe
            id="youtube-player"
            class="absolute top-0 left-0 w-full h-full"
            src="https://www.youtube.com/embed/Pty46HvdmEo?enablejsapi=1&rel=0"
            title="Guía de Mecánicas ICC Heroico"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          >
          </iframe>
        </div>
        <div class="p-4 text-sm text-gray-400 border-t border-blue-900/30 bg-gray-900/20">
          <div class="flex flex-wrap justify-between items-center">
            <div>
              <span class="text-gray-500">Video original por:</span>
              <a
                href="https://www.youtube.com/@muchamiel"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-400 hover:text-blue-300 ml-1"
              >
                Muchamiel
              </a>
            </div>
            <div class="mt-2 sm:mt-0">
              <span class="text-gray-500">Aportado por:</span>
              <span class="text-amber-400 ml-1">EdielP</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Timeline Navigation -->
      <div class="bg-gray-800/50 backdrop-blur-sm rounded-lg p-6 mb-8 border border-blue-900/30">
        <h2 class="text-2xl font-bold text-blue-300 mb-4 flex items-center">
          <i class="fas fa-list-ul mr-2"></i>
          Navegación por Tiempo
        </h2>
        <div class="space-y-2">
          <a
            href="#"
            data-timestamp="0"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">0:00</span>
            <span class="text-blue-100 group-hover:text-white">Lord Tuétano</span>
          </a>
          <a
            href="#"
            data-timestamp="344"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">5:44</span>
            <span class="text-blue-100 group-hover:text-white">Lady Susurramuerte</span>
          </a>
          <a
            href="#"
            data-timestamp="837"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">13:57</span
            >
            <span class="text-blue-100 group-hover:text-white">Batalla Naval</span>
          </a>
          <a
            href="#"
            data-timestamp="1154"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">19:14</span
            >
            <span class="text-blue-100 group-hover:text-white">Libramorte Colmillosauro</span>
          </a>
          <a
            href="#"
            data-timestamp="1724"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">28:44</span
            >
            <span class="text-blue-100 group-hover:text-white">Panzachancro</span>
          </a>
          <a
            href="#"
            data-timestamp="1972"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">32:52</span
            >
            <span class="text-blue-100 group-hover:text-white">Carapútrea</span>
          </a>
          <a
            href="#"
            data-timestamp="2200"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">36:40</span
            >
            <span class="text-blue-100 group-hover:text-white">Profesor Putricidio</span>
          </a>
          <a
            href="#"
            data-timestamp="2655"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">44:15</span
            >
            <span class="text-blue-100 group-hover:text-white">Príncipes de Sangre (Council)</span>
          </a>
          <a
            href="#"
            data-timestamp="3108"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">51:48</span
            >
            <span class="text-blue-100 group-hover:text-white">Reina de Sangre Lana'thel</span>
          </a>
          <a
            href="#"
            data-timestamp="3380"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">56:20</span
            >
            <span class="text-blue-100 group-hover:text-white">Valithria</span>
          </a>
          <a
            href="#"
            data-timestamp="3599"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300">59:59</span
            >
            <span class="text-blue-100 group-hover:text-white">Sindragosa</span>
          </a>
          <a
            href="#"
            data-timestamp="4132"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300"
              >1:08:52</span
            >
            <span class="text-blue-100 group-hover:text-white">REY EXÁNIME LK</span>
          </a>
          <a
            href="#"
            data-timestamp="4956"
            class="flex items-center p-3 rounded-md hover:bg-blue-900/30 transition-colors group"
          >
            <span class="w-20 text-blue-400 text-sm font-mono group-hover:text-blue-300"
              >1:22:36</span
            >
            <span class="text-blue-100 group-hover:text-white">Final</span>
          </a>
        </div>
      </div>

      <!-- Interacciones de la Comunidad -->
      <GuideInteractions guide_id={guideId} />

      <!-- Botón Volver Inferior -->
      <div class="mt-16 flex justify-center">
        <a 
          href="/guides?category=Mecánicas" 
          class="flex items-center gap-4 px-8 py-4 rounded-lg bg-gray-900/60 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all text-xs font-black uppercase tracking-[0.3em] no-underline group backdrop-blur-md shadow-2xl hover:scale-105"
        >
          <i class="fas fa-th-large group-hover:rotate-90 transition-transform duration-500"></i>
          Volver al Portal
        </a>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const player = document.getElementById('youtube-player');
      const timeLinks = document.querySelectorAll('[data-timestamp]');

      // Function to send command to YouTube iframe
      function sendCommand(func, ...args) {
        player.contentWindow.postMessage(
          JSON.stringify({
            event: 'command',
            func: func,
            args: args || [],
            id: 'youtube-player',
          }),
          'https://www.youtube.com'
        );
      }

      // Wait for player to be ready
      function onYouTubeIframeAPIReady() {
        // This function is called by YouTube's API when ready
      }

      // Handle timestamp clicks
      timeLinks.forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const timestamp = parseInt(link.getAttribute('data-timestamp'));

          // Seek to the timestamp
          sendCommand('seekTo', timestamp, true);
          sendCommand('playVideo');

          // Update active state
          timeLinks.forEach((l) => l.classList.remove('bg-blue-900/50', 'ring-2', 'ring-blue-500'));
          link.classList.add('bg-blue-900/50', 'ring-2', 'ring-blue-500');
        });
      });

      // Add global reference for YouTube API
      window.onYouTubeIframeAPIReady = onYouTubeIframeAPIReady;
    });
  </script>

  <!-- Load YouTube IFrame API -->
  <script src="https://www.youtube.com/iframe_api"></script>

  <style>
    .aspect-w-16 {
      position: relative;
      padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    }
    .aspect-w-16 iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  </style>
</Layout>
