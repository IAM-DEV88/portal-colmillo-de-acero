    <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/spell_nature_magicimmunity.jpg" alt="Resto" class="w-full h-full object-cover" />
  </WoWCharacterPanel>

  <GuideInteractions guide_id={guideId} />
</Layout>

<style is:global>
  .text-blue-400 { color: #0070DE; }
