---

<Layout 
  title="Guía Paladín Retribución 3.3.5a " 
  description="Guía del Paladín Retribución para WotLK 3.3.5a. Equipo BIS, talentos, gemas, encantamientos y rotación para ICC 25 Heroico."
>
  <div>
    <!-- WoW Character Panel -->
    <WoWCharacterPanel {...specData}>
      <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/spell_holy_auraoflight.jpg" alt="Ret" class="w-full h-full object-cover" />
    </WoWCharacterPanel>

    <!-- Community Section -->
    <div class="mt-4">
      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-12"></div>
      <GuideInteractions guide_id={guideId} />
    </div>
  </div>
</Layout>

<style is:global>
  /* Colores de clase personalizados */
  .text-pink-400 { color: #F48CBA; }
  .border-pink-500\/30 { border-color: rgba(244, 140, 186, 0.3); }
  .bg-pink-500\/10 { background-color: rgba(244, 140, 186, 0.1); }
</style>
