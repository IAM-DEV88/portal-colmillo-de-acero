---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Guía de Halion (Sagrario Rubí)">
  <main class="min-h-screen py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <!-- Header -->
      <header class="text-center mb-12 animate-fade-in">
        <h1
          class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-red-400 via-red-300 to-red-500 font-title tracking-wider"
        >
          HALION - SAGRARIO RUBÍ
        </h1>
        <div
          class="w-48 h-0.5 bg-gradient-to-r from-red-900/0 via-red-500/80 to-red-900/0 mx-auto my-6"
        >
        </div>
        <p class="text-red-100/80 max-w-2xl mx-auto">
          Colección de guías visuales y estrategias para dominar el encuentro contra Halion en el Sagrario Rubí.
        </p>
      </header>

      <!-- Videos Grid -->
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        
        <!-- Video 1 -->
        <div class="bg-gray-900/60 backdrop-blur-sm border border-red-900/30 rounded-xl overflow-hidden hover:border-red-500/30 transition-all duration-300 group">
          <div class="relative aspect-video">
            <iframe
              class="absolute top-0 left-0 w-full h-full"
              src="https://www.youtube.com/embed/maMyulXXX_w"
              title="Halion 25H - Guía Visual"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-4">
            <h3 class="text-lg font-bold text-red-200 mb-2 group-hover:text-red-300 transition-colors">
              <i class="fas fa-eye text-red-500 mr-2"></i>Guía Visual Simplificada
            </h3>
            <p class="text-sm text-gray-400 mb-3">
              Estrategia visual y parches para facilitar el posicionamiento en Halion 25 Heroico.
            </p>
            <div class="flex flex-wrap justify-between items-center text-xs border-t border-red-900/30 pt-3 mt-2">
              <div>
                <span class="text-gray-500">Video original por:</span>
                <span class="text-red-400 ml-1">Dange</span>
              </div>
              <div class="mt-1 sm:mt-0">
                <span class="text-gray-500">Aportado por:</span>
                <span class="text-amber-400 ml-1">Krauzz</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Video 2 -->
        <div class="bg-gray-900/60 backdrop-blur-sm border border-red-900/30 rounded-xl overflow-hidden hover:border-red-500/30 transition-all duration-300 group">
          <div class="relative aspect-video">
            <iframe
              class="absolute top-0 left-0 w-full h-full"
              src="https://www.youtube.com/embed/VtRSGh1WUPw"
              title="Guía Halion - Santuario Rubí"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-4">
            <h3 class="text-lg font-bold text-red-200 mb-2 group-hover:text-red-300 transition-colors">
              <i class="fas fa-book text-red-500 mr-2"></i>Guía General SR
            </h3>
            <p class="text-sm text-gray-400 mb-3">
              Explicación detallada de las mecánicas y fases del encuentro en El Santuario Rubí.
            </p>
            <div class="flex flex-wrap justify-between items-center text-xs border-t border-red-900/30 pt-3 mt-2">
              <div>
                <span class="text-gray-500">Video original por:</span>
                <span class="text-red-400 ml-1">Yuki Series</span>
              </div>
              <div class="mt-1 sm:mt-0">
                <span class="text-gray-500">Aportado por:</span>
                <span class="text-amber-400 ml-1">Krauzz</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Video 3 -->
        <div class="bg-gray-900/60 backdrop-blur-sm border border-red-900/30 rounded-xl overflow-hidden hover:border-red-500/30 transition-all duration-300 group">
          <div class="relative aspect-video">
            <iframe
              class="absolute top-0 left-0 w-full h-full"
              src="https://www.youtube.com/embed/GCJmjM65D5w"
              title="Halion 25 HC/NM Guía Muchamiel"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-4">
            <h3 class="text-lg font-bold text-red-200 mb-2 group-hover:text-red-300 transition-colors">
              <i class="fas fa-crown text-red-500 mr-2"></i>Guía Muchamiel 25HC
            </h3>
            <p class="text-sm text-gray-400 mb-3">
              Guía completa de Muchamiel para Halion en modalidades Normal y Heroica.
            </p>
            <div class="flex flex-wrap justify-between items-center text-xs border-t border-red-900/30 pt-3 mt-2">
              <div>
                <span class="text-gray-500">Video original por:</span>
                <span class="text-red-400 ml-1">Muchamiel</span>
              </div>
              <div class="mt-1 sm:mt-0">
                <span class="text-gray-500">Aportado por:</span>
                <span class="text-amber-400 ml-1">Krauzz</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Back Link -->
      <div class="mt-12 text-center">
        <a href="/guides" class="inline-flex items-center text-red-400 hover:text-red-300 transition-colors">
          <i class="fas fa-arrow-left mr-2"></i> Volver a Guías
        </a>
      </div>
    </div>
  </main>
</Layout>
