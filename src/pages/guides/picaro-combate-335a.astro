<Layout 
  title="Guía Pícaro Combate 3.3.5a " 
  description="Guía del Pícaro Combate para WotLK 3.3.5a. Equipo BIS, cap de ArP (100%), gemas y rotación de daño sostenido."
>
  <WoWCharacterPanel {...specData}>
    <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/ability_backstab.jpg" alt="Combat" class="w-full h-full object-cover" />
  </WoWCharacterPanel>

  <GuideInteractions guide_id={guideId} />
</Layout>

<style is:global>
  .text-yellow-400 { color: #FFF569; }
  .border-yellow-500\/30 { border-color: rgba(255, 245, 105, 0.3); }
  .bg-yellow-500\/10 { background-color: rgba(255, 245, 105, 0.1); }
</style>
