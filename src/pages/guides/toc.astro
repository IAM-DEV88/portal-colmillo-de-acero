---
import Layout from '../../components/layout/Layout.astro';
---

<Layout 
  title="Guía de Prueba del Cruzado (ToC)" 
  description="Guía de estrategias para Prueba del Cruzado (ToC) 10/25 Normal y Heroico. Domina el Coliseo de los Cruzados."
>
  <main class="">
    <div class="max-w-5xl mx-auto">
      <!-- Botón Volver -->
      <div class="mb-8 flex items-center">
        <a 
          href="/guides?category=Mecánicas" 
          class="flex items-center gap-3 px-5 py-2.5 rounded-lg bg-gray-900/60 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all text-[10px] font-black uppercase tracking-[0.2em] no-underline group backdrop-blur-md shadow-lg"
        >
          <i class="fas fa-chevron-left group-hover:-translate-x-1 transition-transform"></i>
          Volver al Portal
        </a>
      </div>

      <!-- Header -->
      <header class="text-center mb-12 animate-fade-in">
        <h1
          class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-amber-300 to-amber-500 font-title tracking-wider"
        >
          PRUEBA DEL CRUZADO (ToC)
        </h1>
        <div
          class="w-48 h-0.5 bg-gradient-to-r from-amber-900/0 via-amber-500/80 to-amber-900/0 mx-auto my-6"
        >
        </div>
        <p class="text-amber-100/80 max-w-2xl mx-auto">
          Guías completas para todos los encuentros del Coliseo de los Cruzados.
        </p>
      </header>

      <!-- Video Container -->
      <div class="max-w-4xl mx-auto mb-12">
        <div class="bg-gray-900/60 backdrop-blur-sm border border-amber-900/30 rounded-lg overflow-hidden hover:border-amber-500/30 transition-all duration-300 group shadow-lg shadow-amber-900/10">
          <div class="relative aspect-video">
            <iframe
              class="absolute top-0 left-0 w-full h-full"
              src="https://www.youtube.com/embed/re1YDu4tUxA"
              title="Prueba del Cruzado 25H/N"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-amber-200 mb-3 group-hover:text-amber-300 transition-colors flex items-center">
              <i class="fas fa-shield-alt text-amber-500 mr-3"></i>Guía Completa 25H/N
            </h3>
            <p class="text-gray-300 mb-4">
              Recorrido completo por todos los encuentros de la Prueba del Cruzado (Trial of the Crusader), cubriendo estrategias para modos Normal y Heroico.
            </p>
            <div class="flex flex-wrap justify-between items-center text-sm border-t border-amber-900/30 pt-4 mb-4">
              <div>
                <span class="text-gray-500">Video original por:</span>
                <span class="text-amber-400 ml-1">Yuki Series</span>
              </div>
              <div class="mt-2 sm:mt-0">
                <span class="text-gray-500">Aportado por:</span>
                <span class="text-amber-400 ml-1">Krauzz</span>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
               <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-900/40 text-amber-200 border border-amber-700/50">
                  Bestias de Rasganorte
               </span>
               <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-900/40 text-amber-200 border border-amber-700/50">
                  Lord Jaraxxus
               </span>
               <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-900/40 text-amber-200 border border-amber-700/50">
                  Campeones de Facción
               </span>
               <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-900/40 text-amber-200 border border-amber-700/50">
                  Gemelas Val'kyr
               </span>
               <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-900/40 text-amber-200 border border-amber-700/50">
                  Anub'arak
               </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Botón Volver Inferior -->
      <div class="mt-16 flex justify-center">
        <a 
          href="/guides?category=Mecánicas" 
          class="flex items-center gap-4 px-8 py-4 rounded-lg bg-gray-900/60 border border-white/5 text-gray-400 hover:text-amber-400 hover:border-amber-500/30 transition-all text-xs font-black uppercase tracking-[0.3em] no-underline group backdrop-blur-md shadow-2xl hover:scale-105"
        >
          <i class="fas fa-th-large group-hover:rotate-90 transition-transform duration-500"></i>
          Volver al Portal
        </a>
      </div>
    </div>
  </main>
</Layout>
