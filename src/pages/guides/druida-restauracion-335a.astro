---

<Layout 
  title="Guía Druida Restauración 3.3.5a " 
  description="Guía del Druida Healer (Restauración) para WotLK 3.3.5a. Equipo BIS, caps de celeridad, gemas y rotación de HoTs."
>
  <div>
    <WoWCharacterPanel {...specData}>
      <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/spell_nature_healingtouch.jpg" alt="Resto" class="w-full h-full object-cover" />
    </WoWCharacterPanel>

    <div class="mt-4">
      <div class="w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-12"></div>
      <GuideInteractions guide_id={guideId} />
    </div>
  </div>
</Layout>

<style is:global>
  .text-orange-400 { color: #FF7D0A; }
  .border-orange-500\/30 { border-color: rgba(255, 125, 10, 0.3); }
  .bg-orange-500\/10 { background-color: rgba(255, 125, 10, 0.1); }
</style>
