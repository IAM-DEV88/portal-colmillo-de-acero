<Layout 
  title="Guía Druida Equilibrio 3.3.5a " 
  description="Guía del Druida Cásterr (Pollo) para WotLK 3.3.5a. Equipo BIS, caps de celeridad y rotación de Eclipses."
>
  <WoWCharacterPanel {...specData}>
    <img slot="spec-icon" src="https://wotlk.ultimowow.com/static/images/wow/icons/large/spell_nature_starfall.jpg" alt="Boomie" class="w-full h-full object-cover" />
  </WoWCharacterPanel>

  <GuideInteractions guide_id={guideId} />
</Layout>

<style is:global>
  .text-orange-400 { color: #FF7D0A; }
  .border-orange-500\/30 { border-color: rgba(255, 125, 10, 0.3); }
  .bg-orange-500\/10 { background-color: rgba(255, 125, 10, 0.1); }
</style>
