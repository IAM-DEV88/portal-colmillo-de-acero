﻿﻿﻿﻿﻿﻿﻿---
import Layout from '../components/layout/Layout.astro';
const PAYPAL_CLIENT_ID = import.meta.env.PAYPAL_CLIENT_ID || 'sb';
---

<Layout 
  title="Ruleta de la Fortuna" 
  description="¡Prueba tu suerte en la Ruleta de la Fortuna! Gana premios exclusivos, oro y objetos en el juego diariamente."
>
      <main class="relative z-10 flex flex-col items-center" data-paypal-id={PAYPAL_CLIENT_ID}>
      
      <!-- Paytable Toggle (Mobile) / Visible (Desktop) -->
      <!-- Keeping Paytable at top or moving to bottom? User didn't specify, but implies main game UI first. -->
      <!-- Let's keep paytable collapsible or smaller at bottom, or top as "Leyenda" -->
      
      <!-- Message Area (Moved to Top) -->
      <div class="w-full max-w-4xl mx-auto mb-4">
        <div class="w-full bg-black/40 rounded-lg border border-amber-500/20 p-4 min-h-[4rem] flex items-center justify-center text-center backdrop-blur-sm">
            <div id="message-display" class="text-amber-100/80 text-lg md:text-xl font-light tracking-wide animate-fade-in">
                ¿Te atreves a desafiar a la Reina?
            </div>
        </div>
      </div>

      <div class="w-full max-w-4xl mx-auto flex flex-col gap-4">
        
        <!-- ROW 1: REELS + SPIN BUTTON -->
        <div id="game-container" class="flex flex-col md:flex-row items-center justify-center gap-4 w-full transition-all duration-300 rounded-lg">
            
            <!-- Reels Container (Flexible width now) -->
            <div class="flex gap-2 md:gap-4 justify-center bg-black/80 p-4 rounded-lg border border-amber-900/50 shadow-inner w-full max-w-lg md:max-w-3xl flex-shrink-0 md:flex-shrink">
                <!-- Reel 1 -->
                <div class="reel-container flex-1 min-w-[5rem] h-20 md:h-28 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-900 rounded border border-amber-500/30 overflow-hidden relative">
                    <div class="reel-strip absolute top-0 left-0 w-full" id="reel-1"></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/90 pointer-events-none z-10"></div>
                    <div class="absolute inset-0 border-2 border-amber-900/30 pointer-events-none z-20"></div>
                </div>
                
                <!-- Reel 2 -->
                <div class="reel-container flex-1 min-w-[5rem] h-20 md:h-28 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-900 rounded border border-amber-500/30 overflow-hidden relative">
                    <div class="reel-strip absolute top-0 left-0 w-full" id="reel-2"></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/90 pointer-events-none z-10"></div>
                    <div class="absolute inset-0 border-2 border-amber-900/30 pointer-events-none z-20"></div>
                </div>
                
                <!-- Reel 3 -->
                <div class="reel-container flex-1 min-w-[5rem] h-20 md:h-28 bg-gradient-to-b from-gray-900 via-gray-800 to-gray-900 rounded border border-amber-500/30 overflow-hidden relative">
                    <div class="reel-strip absolute top-0 left-0 w-full" id="reel-3"></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/90 pointer-events-none z-10"></div>
                    <div class="absolute inset-0 border-2 border-amber-900/30 pointer-events-none z-20"></div>
                </div>
            </div>

            <!-- Spin Button (Right of Reels on Desktop, Below on Mobile) -->
            <button id="spin-btn" class="group relative px-8 py-4 md:py-8 bg-gradient-to-b from-amber-600 to-amber-800 rounded-lg border-4 border-amber-400 shadow-[0_0_20px_rgba(245,158,11,0.5)] transform active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed hover:shadow-[0_0_40px_rgba(245,158,11,0.8)] flex flex-col items-center justify-center">
                <span class="text-3xl md:text-4xl mb-1 filter drop-shadow-lg group-hover:animate-bounce">🎰</span>
                <span class="font-black text-white text-lg md:text-xl uppercase tracking-widest drop-shadow-md">GIRAR</span>
                <span class="text-xs text-amber-200 font-bold mt-1 bg-black/30 px-2 py-0.5 rounded">-1 Turno</span>
                
                <!-- Shiny effect -->
                <div class="absolute inset-0 rounded-lg bg-gradient-to-tr from-white/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            </button>
        </div>

        <!-- ROW 2: STATS & STACK -->
        <div class="flex flex-col md:flex-row gap-4 w-full">
            
            <!-- Left Column: Stats & History -->
            <div class="flex-1 flex flex-col gap-4">
                
                <!-- Stats (Turnos y Pozo) -->
                <div class="flex flex-row justify-between items-center bg-black/60 p-4 rounded-lg border border-amber-900/30 backdrop-blur-sm">
                    <div class="flex flex-col relative">
                        <span class="text-xs text-amber-500/70 uppercase font-bold tracking-widest">Tus Turnos</span>
                        <span id="credits-display" class="text-white text-3xl font-extrabold drop-shadow-[0_0_10px_rgba(251,191,36,0.5)]">5</span>
                    </div>
                    
                    <!-- Actions (Middle) -->
                    <div class="flex flex-col items-center gap-1 mx-2">
                         <div class="flex gap-1 opacity-50 hover:opacity-100 transition-opacity">
                            <!--
                            <button onclick="resetGame()" class="text-[0.6rem] text-gray-600 hover:text-gray-400 border border-gray-800 rounded px-1 py-0.5 transition-colors" title="Reset Game">
                                ⚠️
                            </button>
                            -->
                            <!--
                            <button onclick="simulateChokerSpin()" class="text-[0.6rem] text-purple-600 hover:text-purple-400 border border-purple-800 rounded px-1 py-0.5 transition-colors" title="Simulate Win">
                                ✨
                            </button>
                            -->
                         </div>
                         <button id="claim-btn" onclick="claimReward()" class="text-[0.6rem] text-green-600 hover:text-green-400 border border-green-800 rounded px-2 py-1 transition-colors hidden" disabled>
                            ✅ RECLAMAR
                         </button>
                    </div>

                    <div class="flex flex-col items-end relative">
                        <span class="text-xs text-red-500/70 uppercase font-bold tracking-widest">Pozo Acumulado</span>
                        <span class="text-amber-200 text-2xl font-bold font-mono tracking-tighter drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">
                            <span id="pool-display">100</span> ⚜️
                        </span>
                    </div>
                </div>

                <!-- Code Redemption -->
                <div class="flex flex-row justify-center items-center bg-black/60 p-4 rounded-lg border border-amber-900/30 backdrop-blur-sm">
                    <div class="flex items-center gap-1">
                        <input type="text" id="redeem-code-input" placeholder="INGRESA TU CÓDIGO" class="bg-gray-900/80 border border-gray-700 rounded px-3 py-2 text-sm flex-grow text-white placeholder-gray-500 focus:outline-none focus:border-amber-500 uppercase tracking-widest font-mono text-center shadow-inner" />
                        <button onclick="redeemCode()" class="bg-gradient-to-b from-amber-600 to-amber-700 hover:from-amber-500 hover:to-amber-600 text-white text-sm font-bold px-3 py-2 rounded transition-all shadow-md border border-amber-500/50">
                            CANJEAR
                        </button>
                    </div>
                </div>

                <!-- History Stack (Moved here) -->
                <div class="bg-black/60 border border-amber-900/50 rounded-lg p-2 backdrop-blur-sm">
                    <div class="text-[0.6rem] text-amber-500/70 uppercase font-bold tracking-widest mb-1 text-center">Últimos Giros</div>
                    <div id="history-stack" class="flex flex-wrap justify-center gap-2 min-h-[2.5rem]">
                        <!-- History items will be injected here -->
                        <div class="text-xs text-gray-500 italic">Sin historial</div>
                    </div>
                </div>

            </div>

            <!-- Right Column: Paytable Mini -->
            <div class="flex-1 bg-black/60 border border-amber-900/50 rounded-lg p-2 backdrop-blur-sm flex items-center justify-center">
                <div class="grid grid-cols-3 gap-2 w-full max-w-sm mx-auto">
                  <!-- Condensed Paytable Items -->
                  <div class="flex flex-col items-center p-2 min-w-[3rem] bg-purple-900/20 rounded border border-purple-500/30">
                    <span class="text-2xl">📿</span>
                    <span class="text-[0.6rem] text-purple-300 font-bold uppercase mt-1 leading-tight text-center">Gargantilla carmesí de la Reina de Sangre</span>
                  </div>
                  <div class="flex flex-col items-center p-2 min-w-[3rem] bg-blue-900/20 rounded border border-blue-500/30">
                    <span class="text-2xl">📦</span>
                    <span class="text-[0.6rem] text-blue-300 font-bold uppercase mt-1 leading-tight text-center">Cofre<br>7000 Oro</span>
                  </div>
                  <div class="flex flex-col items-center p-2 min-w-[3rem] bg-yellow-900/20 rounded border border-yellow-500/30">
                    <span class="text-2xl">💰</span>
                    <span class="text-[0.6rem] text-yellow-300 font-bold uppercase mt-1 leading-tight text-center">Bolsa<br>2900 Oro</span>
                  </div>
                  <div class="flex flex-col items-center p-2 min-w-[3rem] bg-yellow-900/10 rounded border border-yellow-500/20">
                    <span class="text-2xl">⚜️</span>
                    <span class="text-[0.6rem] text-yellow-200 font-bold uppercase mt-1 leading-tight text-center">Moneda<br>600 Oro</span>
                  </div>
                  <div class="flex flex-col items-center p-2 min-w-[3rem] bg-green-900/20 rounded border border-green-500/30">
                    <span class="text-2xl">🗡️</span>
                    <span class="text-[0.6rem] text-green-400 font-bold uppercase mt-1 leading-tight text-center">Pícaro<br>+5 Turnos</span>
                  </div>
                   <div class="flex flex-col items-center p-2 min-w-[3rem] bg-red-900/20 rounded border border-red-500/30">
                    <span class="text-2xl">💀</span>
                    <span class="text-[0.6rem] text-red-400 font-bold uppercase mt-1 leading-tight text-center">Maldición<br>Pozo</span>
                  </div>
                </div>
            </div>
        </div>

        <!-- ROW 3: INDICATORS (Removed, moved to top) -->
        <!-- Old location was here -->

        <!-- Buy Credits Section -->
        <div id="buy-section" class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4 w-full">
            <button onclick="showBuyModal(0)" class="bg-gradient-to-r from-gray-800 to-gray-900 border border-gray-600 hover:border-amber-500 p-4 rounded-lg group transition-all">
                <div class="text-amber-400 font-bold text-lg group-hover:scale-110 transition-transform">5 Turnos</div>
                <div class="text-gray-400 text-sm">$1 USD</div>
                <div class="text-amber-300 text-xs mt-1">Incluye 500 Oro ⚜️</div>
            </button>
            <button onclick="showBuyModal(1)" class="bg-gradient-to-r from-gray-800 to-gray-900 border border-gray-600 hover:border-amber-500 p-4 rounded-lg group transition-all relative overflow-hidden">
                <div class="absolute top-0 right-0 bg-amber-600 text-black text-[0.6rem] font-bold px-2 py-0.5 transform rotate-0 rounded-bl">POPULAR</div>
                <div class="text-amber-400 font-bold text-lg group-hover:scale-110 transition-transform">15 Turnos</div>
                <div class="text-gray-400 text-sm">$2 USD</div>
                <div class="text-amber-300 text-xs mt-1">Incluye 1500 Oro ⚜️</div>
            </button>
            <button onclick="showBuyModal(2)" class="bg-gradient-to-r from-gray-800 to-gray-900 border border-gray-600 hover:border-amber-500 p-4 rounded-lg group transition-all">
                <div class="text-amber-400 font-bold text-lg group-hover:scale-110 transition-transform">50 Turnos</div>
                <div class="text-gray-400 text-sm">$5 USD</div>
                <div class="text-amber-300 text-xs mt-1">Incluye 5000 Oro ⚜️</div>
            </button>
        </div>

      </div>
    </main>

  <style>
    .font-title { font-family: 'Arial', sans-serif; }
    
    @keyframes shine {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }
    .animate-shine { animation: shine 2s infinite; }

    .reel-strip {
      display: flex;
      flex-direction: column;
      transition: transform 0.1s linear; /* Default, will be overridden by JS */
    }
    

    .reel-container {
      box-shadow: inset 0 -20px 20px -10px rgba(0,0,0,0.8);

      
        white-space: nowrap; /* Force single line */
        
        text-overflow: ellipsis; /* Dot dot dot if it still overflows */
    }

    .symbol.highlight {
      border: 2px solid #fbbf24;
      box-shadow: 0 0 15px rgba(251, 191, 36, 0.5);
      background-color: rgba(251, 191, 36, 0.1);
      z-index: 25;
      border-radius: 0.5rem;
    }

    .symbol span {
        font-size: 3rem;
        line-height: 1;
    }
    
    .symbol-label {
        font-size: 0.5rem; 
        color: #fbbf24; 
        text-transform: uppercase;
        font-weight: 800;
        text-shadow: 1px 1px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;
        text-align: center;
        margin-top: 0.1rem;
        
    }

    @media (min-width: 768px) {
        .symbol {
            height: 10rem; 
        }
        .symbol span {
            font-size: 4rem;
        }
        .symbol-label {
            font-size: 0.75rem; /* Increased slightly for desktop as we shortened names */
        }
    }

    @keyframes floatUpFade {
      0% { transform: translate(-50%, -50%) translateY(0) scale(1); opacity: 1; }
      100% { transform: translate(-50%, -50%) translateY(-30px) scale(1.1); opacity: 0; }
    }
    .floating-stat {
      /* Base styles in JS class string, animation here */
      animation: floatUpFade 2s ease-out forwards;
    }
  </style>

  <script is:inline>
    // Configuración de Discord Webhook
    // Los webhooks ahora se manejan a través del endpoint /api/discord-webhook para seguridad.
    // Ver src/pages/api/discord-webhook.ts y archivo .env

    // Game Logic
    const SYMBOLS = [
      { id: 'skull', icon: '💀', weight: 50, name: 'MALDICIÓN' }, 
      { id: 'gold_small', icon: '⚜️', weight: 28, name: 'MONEDA' }, 
      { id: 'gold_bag', icon: '💰', weight: 16, name: 'BOLSA' }, 
      { id: 'chest', icon: '📦', weight: 2.5, name: 'COFRE' }, 
      { id: 'choker', icon: '📿', weight: 0.5, name: 'GARGANTILLA' }, 
      { id: 'thief', icon: '🗡️', weight: 3, name: 'PÍCARO' } 
    ];

    let credits = 5; 
    let goldPool = 100; 
    let isSpinning = false;
    let hasWonChoker = false; 
    let hasClickedAd = false;
    let isAdBlockerActive = false;
    const spinHistory = [];

    function getRandomSymbol() {
      const totalWeight = SYMBOLS.reduce((sum, s) => sum + s.weight, 0);
      let rand = Math.random() * totalWeight;
      for (const symbol of SYMBOLS) {
        if (rand < symbol.weight) return symbol;
        rand -= symbol.weight;
      }
      return SYMBOLS[0];
    }

    // Sincronización con API (Persistencia por IP)
    async function fetchGameState() {
        try {
            // Añadir timestamp para evitar caché del navegador
            const res = await fetch('/api/game-state?t=' + Date.now(), {
                cache: 'no-store'
            });
            if (res.ok) {
                const data = await res.json();
                credits = data.credits;
                goldPool = data.gold_pool;
                hasWonChoker = data.has_won_choker;
                if (data.spin_history && Array.isArray(data.spin_history)) {
                    spinHistory.length = 0;
                    data.spin_history.forEach(s => spinHistory.push(s));
                }
                
                // Actualizar UI inmediatamente
                const creditsEl = document.getElementById('credits-display');
                const poolEl = document.getElementById('pool-display');
                if(creditsEl) creditsEl.innerHTML = credits.toLocaleString();
                if(poolEl) poolEl.innerHTML = goldPool.toLocaleString();
                updateHistoryDisplay();
                updateDisplay(true);
            } else {
                console.error("Error del servidor al cargar estado:", await res.text());
            }
        } catch (e) { console.error("Error loading state", e); }
    }

    async function checkAdBlocker() {
      try {
        const testAd = await fetch('https://www.highperformanceformat.com/bc3afce27a408298cd40496786edc9ca/invoke.js', { 
          method: 'HEAD', 
          mode: 'no-cors' 
        });
        isAdBlockerActive = false;
      } catch (e) {
        isAdBlockerActive = true;
      }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', async () => {
      // Verificar AdBlocker al inicio
      await checkAdBlocker();
      
      // Load credits from Server (IP based persistence)
      fetchGameState();

      // Initial display without animation
      const creditsEl = document.getElementById('credits-display');
      const poolEl = document.getElementById('pool-display');
      if(creditsEl) creditsEl.innerHTML = credits.toLocaleString();
      if(poolEl) poolEl.innerHTML = goldPool.toLocaleString();
      
      updateHistoryDisplay();
      updateDisplay(true); 
      
      // Init Reels
      initReel('reel-1');
      initReel('reel-2');
      initReel('reel-3');
      
      // Event Listeners
      document.getElementById('spin-btn').addEventListener('click', spin);
      
      window.addCredits = async (amount) => {
        // Just refresh state from server after purchase
        await fetchGameState();
        showMessage(`¡GIROS ACTUALIZADOS!`, 'text-green-400');
      };
    });

    function updateHistoryDisplay() {
        const container = document.getElementById('history-stack');
        if (!container) return;
        
        container.innerHTML = '';
        if (spinHistory.length === 0) {
            container.innerHTML = '<div class="text-xs text-gray-500 italic p-2">Sin historial</div>';
            return;
        }

        spinHistory.forEach(spin => { 
            const div = document.createElement('div');
            div.className = 'flex items-center gap-1 bg-black/40 px-2 py-1 rounded border border-gray-800 min-w-max animate-fade-in';
            
            spin.forEach(sym => {
                const span = document.createElement('span');
                span.textContent = sym.icon;
                span.className = 'text-lg leading-none';
                div.appendChild(span);
            });
            
            container.appendChild(div);
        });
    }

    async function redeemCode() {
        const input = document.getElementById('redeem-code-input');
        const code = input.value.trim();
        
        if (!code) {
            alert('Por favor ingresa un código.');
            return;
        }

        input.disabled = true;
        
        try {
            const res = await fetch('/api/redeem-code', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code })
            });

            const data = await res.json();

            if (data.success) {
                window.addCredits(data.credits); 
                alert(data.message);
                input.value = '';
            } else {
                alert(data.error || 'Código inválido');
            }
        } catch (err) {
            console.error(err);
            alert('Error al canjear código');
        } finally {
            input.disabled = false;
        }
    }

    function initReel(elementId) {
      const reel = document.getElementById(elementId);
      reel.innerHTML = '';
      
      // Generate random strip
      for (let i = 0; i < 20; i++) {
        const symbol = getRandomSymbol();
        const div = createSymbolElement(symbol);
        reel.appendChild(div);
      }
    }

    function getRandomSymbol() {
      // Weighted random
      const totalWeight = SYMBOLS.reduce((sum, s) => sum + s.weight, 0);
      let random = Math.random() * totalWeight;
      
      for (const symbol of SYMBOLS) {
        random -= symbol.weight;
        if (random <= 0) return symbol;
      }
      return SYMBOLS[0];
    }

    // Number Animation Helper
    function animateValue(obj, start, end, duration) {
        if (start === end) return;
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            // Ease-out cubic
            const ease = 1 - Math.pow(1 - progress, 3);
            const value = Math.floor(ease * (end - start) + start);
            obj.innerHTML = value.toLocaleString();
            if (progress < 1) {
                window.requestAnimationFrame(step);
            } else {
                obj.innerHTML = end.toLocaleString();
            }
        };
        window.requestAnimationFrame(step);
    }

    // Floating Text Helper
    function showFloatingText(elementId, change) {
        if (change === 0) return;
        const el = document.getElementById(elementId);
        if (!el) return;
        
        // Find closest relative parent or use immediate parent
        let parent = el.closest('.relative') || el.parentElement;
        
        // Ensure parent is relative if not already (safeguard)
        if (getComputedStyle(parent).position === 'static') {
            parent.style.position = 'relative';
        }

        const floatEl = document.createElement('div');
        // Use absolute positioning with transform to center
        floatEl.className = 'floating-stat pointer-events-none absolute top-1/2 -translate-y-1/2 text-xl font-bold z-50 whitespace-nowrap ' + 
                            (change > 0 ? 'text-green-400 drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]' : 'text-red-500 drop-shadow-[0_2px_2px_rgba(0,0,0,0.8)]');
        
        floatEl.innerText = (change > 0 ? '+' : '') + change.toLocaleString();

        // Adjust position based on elementId
        if (elementId === 'pool-display') {
            // Override the left-1/2 from the class to move it 30px to the right
            floatEl.style.left = 'calc(50% + 30px)'; 
        } else if (elementId === 'credits-display') {
            // Adjust for credits-display to be 30px to the right
            floatEl.style.left = 'calc(50%)';
        }
        // The -translate-x-1/2 from the class will still apply, centering it relative to this new left.
        // For other elements, the default left-1/2 from the class will apply.
        
        // Append to parent
        parent.appendChild(floatEl);
        
        // Remove after animation (match CSS duration)
        setTimeout(() => {
            if (floatEl.parentNode) floatEl.remove();
        }, 2000);
    }

    // Game State
    function updateDisplay(finalUpdate = false, amountChanged = null) {
       const creditsEl = document.getElementById('credits-display');
       const poolEl = document.getElementById('pool-display');
       
       let currentCredits = creditsEl ? parseInt(creditsEl.innerText.replace(/[^\d-]/g, '')) : 0;
       let currentPool = poolEl ? parseInt(poolEl.innerText.replace(/[^\d-]/g, '')) : 0;

       if (isNaN(currentCredits)) currentCredits = 0;
       if (isNaN(currentPool)) currentPool = 0;

       if(creditsEl && currentCredits !== credits) {
           const diff = credits - currentCredits;
           animateValue(creditsEl, currentCredits, credits, 1000);
           showFloatingText('credits-display', diff);
       }
       if(poolEl && currentPool !== goldPool) {
           const diff = goldPool - currentPool;
           animateValue(poolEl, currentPool, goldPool, 1500);
           
           const displayChange = (amountChanged !== null) ? amountChanged : diff;
           showFloatingText('pool-display', displayChange);
       }



       const claimBtn = document.getElementById('claim-btn');
       if (claimBtn) {
           const shouldBeActive = (credits <= 0 || hasWonChoker) && !isSpinning;
           claimBtn.disabled = !shouldBeActive;
           claimBtn.classList.toggle('hidden', !shouldBeActive);
       }

       if (credits <= 0 && !isSpinning && finalUpdate) {
         document.getElementById('spin-btn').disabled = true;
         document.getElementById('spin-btn').classList.add('opacity-50', 'cursor-not-allowed');
         // Wait for animation (1000ms) + small delay
         setTimeout(() => showGameOver(hasWonChoker), 1200); 
       } else if (!isSpinning) {
         document.getElementById('spin-btn').disabled = false;
         document.getElementById('spin-btn').classList.remove('opacity-50', 'cursor-not-allowed');
       }
    }

    let modalCountdownIntervalId;

    function getFormattedTimeUntilMidnight() {
      const timeZone = 'Europe/London';
      const now = new Date();
      
      // Obtener partes de la fecha actual en Londres
      const formatter = new Intl.DateTimeFormat('en-GB', {
        timeZone,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false
      });
      
      const parts = formatter.formatToParts(now);
      const getPart = (type) => parts.find(p => p.type === type).value;
      
      // Crear una representación de la hora de Londres en milisegundos "ficticios" para el cálculo
      const londonNowMs = Date.UTC(
        parseInt(getPart('year')),
        parseInt(getPart('month')) - 1,
        parseInt(getPart('day')),
        parseInt(getPart('hour')),
        parseInt(getPart('minute')),
        parseInt(getPart('second'))
      );
      
      // Calcular la próxima medianoche en Londres
      const londonMidnight = new Date(londonNowMs);
      londonMidnight.setUTCHours(24, 0, 0, 0);
      const londonMidnightMs = londonMidnight.getTime();
      
      const timeLeft = londonMidnightMs - londonNowMs;
      
      const hours = Math.floor(timeLeft / (1000 * 60 * 60));
      const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((timeLeft % (1000 * 60)) / 1000);

      // Formatear la fecha de reinicio (mañana en Londres)
      const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
      // Usamos el objeto londonMidnight que ya apunta al inicio del próximo día
      const restartDate = londonMidnight.toLocaleDateString('es-ES', options);

      return {
        time: `${hours.toString().padStart(2, '0')}h ${minutes.toString().padStart(2, '0')}m ${seconds.toString().padStart(2, '0')}s`,
        date: restartDate
      };
    }

    async function handleDiscordClaim(type) {
      let claimText = "";
      let subText = "";
      let userIP = "Desconocida";
      let claimedAmount = 0;

      try {
        const res = await fetch('/api/game-claim', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type })
        });
        
        const data = await res.json();
        if (data.success) {
          claimedAmount = data.claimed_amount;
          const oldPool = goldPool;
          goldPool = data.gold_pool;
          hasWonChoker = data.has_won_choker;
          updateDisplay(false, -oldPool);
        } else {
          throw new Error(data.error);
        }
      } catch (e) {
        console.error("Claim Error:", e);
        alert("Error al procesar el reclamo. Intenta de nuevo.");
        return;
      }

      try {
        const ipResponse = await fetch('https://api.ipify.org?format=json');
        const ipData = await ipResponse.json();
        userIP = ipData.ip;
      } catch (e) {}

      if (type === 'pool') {
        claimText = `TIQUET GANADOR DE ${claimedAmount.toLocaleString()} ORO`;
        subText = "¡La suerte te sonríe!";
      } else if (type === 'choker') {
        claimText = `¡GARGANTILLA + ${claimedAmount.toLocaleString()} ORO!`;
        subText = "Item Legendario Obtenido";
      }

      // Create Canvas for Ticket
      const canvas = document.createElement('canvas');
      canvas.width = 600;
      canvas.height = 400;
      const ctx = canvas.getContext('2d');

      // Background
      const gradient = ctx.createLinearGradient(0, 0, 0, 400);
      gradient.addColorStop(0, '#1a1a1a');
      gradient.addColorStop(1, '#000000');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // Border
      ctx.strokeStyle = '#F59E0B'; 
      ctx.lineWidth = 8;
      ctx.strokeRect(4, 4, canvas.width-8, canvas.height-8);
      
      // Inner Border
      ctx.strokeStyle = '#92400E'; 
      ctx.lineWidth = 2;
      ctx.strokeRect(15, 15, canvas.width-30, canvas.height-30);

      // Title
      ctx.fillStyle = '#F59E0B';
      ctx.font = 'bold 32px Arial';
      ctx.textAlign = 'center';
      ctx.shadowColor = "rgba(245, 158, 11, 0.5)";
      ctx.shadowBlur = 10;
      ctx.fillText(claimText, canvas.width/2, 100);
      ctx.shadowBlur = 0;

      // Subtext
      ctx.fillStyle = '#D1D5DB';
      ctx.font = 'italic 20px Arial';
      ctx.fillText(subText, canvas.width/2, 140);

      // Date
      const dateOptions = { dateStyle: 'full', timeStyle: 'short' };
      const date = new Date().toLocaleString('es-ES', dateOptions);
      ctx.fillStyle = '#9CA3AF';
      ctx.font = '16px Arial';
      ctx.fillText(`Fecha: ${date}`, canvas.width/2, 200);
      
      // Verification Code
      const uniqueCode = `R-${Date.now().toString(36).toUpperCase()}-${Math.floor(Math.random()*1000)}`;
      ctx.fillStyle = '#4B5563';
      ctx.font = 'bold 18px Courier New';
      ctx.fillText(`ID VERIFICACIÓN:`, canvas.width/2, 280);
      
      ctx.fillStyle = '#FFF';
      ctx.font = 'bold 24px Courier New';
      ctx.fillText(uniqueCode, canvas.width/2, 310);
      
      // Footer
      ctx.fillStyle = '#6B7280';
      ctx.font = '14px Arial';
      ctx.fillText("Sube esta imagen a WhatsApp para validar tu premio", canvas.width/2, 360);

      canvas.toBlob(async (blob) => {
        // 1. Siempre descargar la imagen para el usuario
        downloadTicket(canvas, type);

        const filename = `TICKET-${type.toUpperCase()}-${Date.now()}.png`;
        const promises = [];

        // 2. Enviar al Webhook Admin (con código)
        {
            const formData = new FormData();
            const payload = {
                username: "Portal Web Colmillo de Acero",
                content: `**NUEVO RECLAMO DE PREMIO**\nUsuario: IP ${userIP}\nDetalle: ${claimText}\nCódigo: \`${uniqueCode}\``
            };
            formData.append('payload_json', JSON.stringify(payload));
            formData.append('file', blob, filename);

            promises.push(
                fetch('/api/discord-webhook?type=admin', { method: 'POST', body: formData })
                .then(async res => {
                    if (!res.ok) throw new Error(`Admin Webhook Error: ${res.status} ${await res.text()}`);
                    return "Admin OK";
                })
            );
        }

        // 3. Enviar al Webhook Público (SIN código en el texto y SIN imagen)
        {
            const payload = {
                username: "Portal Web Colmillo de Acero",
                content: `🔥 **¡EL POZO HA SIDO RECLAMADO!**\nUn jugador ha obtenido: ${claimText}\n🏆 ¡Felicidades al ganador!\n\n📩 Para reclamar el premio:
Comparte el ticket generado en el grupo de [WhatsApp](https://chat.whatsapp.com/Ek9BcgjvzrCAcyRRvWL72g).`
            };

            promises.push(
                fetch('/api/discord-webhook?type=public', { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload) 
                })
                .then(async res => {
                    if (!res.ok) throw new Error(`Public Webhook Error: ${res.status} ${await res.text()}`);
                    return "Public OK";
                })
            );
        }

        if (promises.length > 0) {
            try {
                const results = await Promise.allSettled(promises);
                const errors = results.filter(r => r.status === 'rejected');
                
                if (errors.length > 0) {
                    console.error('Algunos envíos fallaron:', errors);
                    alert('Ticket descargado. Hubo un problema enviando a Discord automáticamente, por favor súbelo manualmente.');
                    window.open('https://discord.gg/Rq5Y54kh', '_blank');
                } else {
                    alert('¡Felicidades! Ticket notificado en Discord exitosamente.\nSigue las instrucciones en Discord para reclamar tu premio.');
                }
            } catch (err) {
                console.error('Error general en envío:', err);
            }
        } else {
            // Si no hay webhooks, solo abrir discord
            setTimeout(() => {
                window.open('https://discord.gg/Rq5Y54kh', '_blank');
            }, 1000);
        }
      }, 'image/png');
      
      closeModalAndClearInterval();
    }

    function downloadTicket(canvas, type) {
      try {
        const dataUrl = canvas.toDataURL('image/png');
        const link = document.createElement('a');
        link.download = `TICKET-${type.toUpperCase()}-${Date.now()}.png`;
        link.href = dataUrl;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      } catch (e) {
        console.error("Error generating ticket:", e);
        alert("Error generando ticket. Por favor toma una captura de pantalla.");
      }
    }

