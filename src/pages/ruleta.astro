                    }]
                });
            },
            onApprove: async (data, actions) => {
                const orderID = data.orderID;
                try {
                    const response = await fetch('/api/paypal/verify-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ orderID, option })
                    });
                    
