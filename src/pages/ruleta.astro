    function getOutcome() {
      // 3 Skulls = Lose Pool (Bad luck)
      // 5% chance of 3 matching (Win)
      // 35% chance of Near Miss
      
      const rand = Math.random();
      
      // 1% Chance of TOTAL LOSS (3 Skulls)
      if (rand < 0.01) {
          const skull = SYMBOLS.find(s => s.id === 'skull');
          return [skull, skull, skull];
      }
      
      // 4% Chance of WIN
      if (rand < 0.05) {
        // WIN!
        let sym = getRandomSymbol();
        // Prevent skulls from being a "win" in this block unless we want small prize
        while (sym.id === 'skull') {
            sym = getRandomSymbol();
        }
        return [sym, sym, sym];
      } 
      
      // 35% Chance of NEAR MISS
      if (rand < 0.40) {
        // NEAR MISS (2 matching)
        const sym = getRandomSymbol();
        const other = getRandomSymbol();
        return [sym, sym, other];
      } 
      
      // Random
      return [getRandomSymbol(), getRandomSymbol(), getRandomSymbol()];
    }

    function createSymbolElement(sym) {
        const div = document.createElement('div');
        div.className = 'symbol';
        
        const iconSpan = document.createElement('span');
        iconSpan.textContent = sym.icon;
        
        const labelSpan = document.createElement('span');
        labelSpan.className = 'symbol-label';
        labelSpan.textContent = sym.name;
        
        div.appendChild(iconSpan);
        div.appendChild(labelSpan);
        
        div.style.flex = '0 0 100%';
        div.style.height = '100%'; // Ensure it fills the container exactly
        return div;
    }

    function animateReel(reelId, finalSymbol, duration, callback) {
      const reel = document.getElementById(reelId);
      
      // Calculate strip size
      const totalItems = 50; 
      const finalIndex = 45; // Must be large enough to spin for a while

      // Create new strip content
      reel.innerHTML = '';
      for (let i = 0; i < totalItems; i++) {
         let sym;
         if (i === finalIndex) {
             sym = finalSymbol;
         } else {
             sym = getRandomSymbol();
         }
         
         const div = createSymbolElement(sym);
         if (i === finalIndex) {
             div.id = `${reelId}-target`;
         }
         reel.appendChild(div);
      }
      
      // Reset position 
      reel.style.transition = 'none';
      reel.style.transform = 'translateY(0)';
      
      // Force reflow
      void reel.offsetWidth;
      
      // Animate to center the final symbol
      // The strip is inside a container of height H.
      // Each item is height H.
      // To show item i, we translate by -i * 100% of item height.
      // But since we are translating the strip relative to its own height (which is totalItems * H),
      // we need to translate by - (i / totalItems) * 100%.
      
      const percentage = (finalIndex / totalItems) * 100;
      
      reel.style.transition = `transform ${duration}ms cubic-bezier(0.25, 0.1, 0.25, 1)`;
      reel.style.transform = `translateY(-${percentage}%)`;
      
      setTimeout(() => {
        if (callback) callback();
      }, duration);
    }

    // Simplified checkWin to use prizes from pool, not credits
    function checkWin(outcome) {
      let won = false;
      let prizeName = '';
      let prizeAmount = 0;
      let colorClass = 'text-white';
      
      // Calculate multiplier or prize
      const id1 = outcome[0].id;
      const id2 = outcome[1].id;
      const id3 = outcome[2].id;

      if (id1 === 'skull' && id2 === 'skull' && id3 === 'skull') {
        // BAD LUCK: LOSE POOL
        goldPool = Math.floor(goldPool / 2); // Lose half pool
        localStorage.setItem('ruleta_pool', goldPool);
        showMessage('☠️ ¡LA REINA RECLAMA TU ALMA! (Pozo reducido) ☠️', 'text-red-600 font-bold text-xl animate-pulse');
        updateDisplay();
        return;
      }

      // 3 Match Logic (Jackpots)
      if (outcome[0].id === outcome[1].id && outcome[1].id === outcome[2].id) {
          won = true;
          const symbolId = outcome[0].id;

          if (symbolId === 'choker') {
             prizeName = "¡GARGANTILLA LEGENDARIA! (RECLAMA EN DISCORD)";
             colorClass = "text-purple-400";
             prizeAmount = 0;
             hasWonChoker = true; // Establecer a true cuando se gana una gargantilla
             updateDisplay(true); // Asegurarse de que updateDisplay actualice el botón Reclamar
             setTimeout(() => showGameOver(true), 2000); // Forzar modal de victoria
          } else if (symbolId === 'chest') {
              prizeAmount = 7000;
              prizeName = "¡GRAN COFRE! (+7000)";
              colorClass = "text-amber-400 drop-shadow-[0_0_10px_rgba(251,191,36,0.8)]";
          } else if (symbolId === 'gold_bag') {
              prizeAmount = 2900;
              prizeName = "¡BOLSA DE ORO! (+2900)";
              colorClass = "text-yellow-300";
          } else if (symbolId === 'gold_small') {
              prizeAmount = 600;
              prizeName = "¡MONEDAS! (+600)";
              colorClass = "text-yellow-200";
          } else if (symbolId === 'thief') {
               // Bonus Turns
               credits += 5;
               prizeName = "¡PÍCARO! (+5 TURNOS)";
               colorClass = "text-purple-400";
               // Don't add gold
               prizeAmount = 0;
          } else {
              // 3 Skulls = Loss
              won = false;
              prizeName = "INTÉNTALO DE NUEVO";
              colorClass = "text-gray-400";
          }

      } else {
          // 2 Match Logic (Consolation)
          // Check for pairs
          let pairSymbol = null;
          if (outcome[0].id === outcome[1].id) pairSymbol = outcome[0].id;
          else if (outcome[1].id === outcome[2].id) pairSymbol = outcome[1].id;
          else if (outcome[0].id === outcome[2].id) pairSymbol = outcome[0].id;

          if (pairSymbol) {
               if (pairSymbol === 'thief') {
                   won = true;
                   credits += 2;
                   prizeName = "PAR DE PÍCAROS (+2 TURNOS)";
                   colorClass = "text-purple-300";
              } else if (pairSymbol !== 'skull' && pairSymbol !== 'gold_small') {
                  // Only high value pairs pay gold
                  won = true;
                  prizeAmount = 100;
                  prizeName = "PAR GANADOR (+100)";
                  colorClass = "text-yellow-100";
              }
          }
      }

      if (won) {
         if (prizeAmount > 0) {
             goldPool += prizeAmount; // Add to pool (Accumulated Winnings)
             showMessage(`🎉 ${prizeName} (+${prizeAmount} ORO) 🎉`, colorClass);
         } else if (prizeName.includes("TURNOS")) {
             // Turns message
             showMessage(`🎉 ${prizeName} 🎉`, colorClass);
         } else {
              // Real item message
              showMessage(`🎉 ${prizeName} (RECLAMA EN DISCORD) 🎉`, colorClass);
         }
        
        // Trigger confetti or visual effect here if possible
        const machine = document.getElementById('game-container');
        if (machine) {
            machine.classList.add('ring-4', 'ring-yellow-400', 'ring-opacity-100');
            setTimeout(() => machine.classList.remove('ring-4', 'ring-yellow-400', 'ring-opacity-100'), 1000);
        }
      } else {
        const msgs = [
            'La Reina exige más sacrificios...',
            'Tu suerte se agota...',
            '¿Te atreves a girar de nuevo?',
            'El abismo te observa...',
            'Casi... pero no.'
        ];
        const randomMsg = msgs[Math.floor(Math.random() * msgs.length)];
        showMessage(randomMsg, 'text-gray-500');
      }
      
      isSpinning = false;
      document.getElementById('spin-btn').disabled = false;
    }

  </script>
</Layout>
