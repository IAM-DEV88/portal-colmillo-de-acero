    function spin() {
      if (credits <= 0 || isSpinning) return;
      
      // Set spinning state first
      isSpinning = true;
      document.getElementById('spin-btn').disabled = true;
      document.getElementById('spin-btn').classList.add('opacity-50', 'cursor-not-allowed');

      credits--;
      // Add a small amount to the pool each spin
      goldPool += 10;
      
      localStorage.setItem('ruleta_credits', credits);
      localStorage.setItem('ruleta_pool', goldPool);
      
      // DO NOT update display yet, wait for animation
      // updateDisplay();
      
      showMessage('LA REINA DECIDE TU DESTINO...', 'text-red-400');
      
      // Determine outcome
      const outcome = getOutcome();
      
      // Animate reels
      // Reset highlights
      document.querySelectorAll('.symbol.highlight').forEach(el => el.classList.remove('highlight'));

      animateReel('reel-1', outcome[0], 1500, () => {
          highlightReel('reel-1');
          showMessage(`${outcome[0].name}`, 'text-amber-200');
      });
      
      animateReel('reel-2', outcome[1], 2500, () => {
          highlightReel('reel-2');
          if (outcome[0].id === outcome[1].id) {
             showMessage(`¡DOS ${outcome[1].name}S!`, 'text-yellow-400 font-bold animate-pulse');
          } else {
             showMessage(`${outcome[1].name}`, 'text-amber-200');
          }
      });
      
      animateReel('reel-3', outcome[2], 3500, () => {
        highlightReel('reel-3');
        isSpinning = false;
        
        // Check win first to potentially add credits
        checkWin(outcome);
        
        // Add outcome to history reliably AFTER spin completes
        spinHistory.unshift([outcome[0], outcome[1], outcome[2]]);
        if (spinHistory.length > 3) spinHistory.pop(); // Keep only last 3
        updateHistoryDisplay();

        // Then update display (will show modal only if credits are still 0)
        updateDisplay(true); // finalUpdate = true
      });
    }

