                    if (result.success) {
                        closeBuyModal();
                        addCredits(option.turns); 
                        alert(`¡Pago Exitoso! Se han añadido ${option.turns} turnos.`);
                    } else {
                        throw new Error(result.error || 'Error al verificar el pago');
                    }
                } catch (err) {
                    console.error('Error de verificación:', err);
                    alert(`Error: ${err.message}`);
                }
            },
            onError: (err) => {
                console.error('PayPal Error:', err);
                alert('Hubo un error con el pago de PayPal. Intenta de nuevo.');
            }
        }).render('#paypal-button-container');
    }

    function closeBuyModal() {
        const modal = document.getElementById('buy-modal');
        if (modal) modal.remove();
    }
    
    async function sendPaymentWebhook(details, option) {
        // Esta función ya no se usa desde el cliente para compras de PayPal
        // porque la validación ocurre en el servidor
    }



    function claimReward() {
      showMessage('¡PREMIO RECLAMADO! Redirigiendo...', 'text-green-400', 1000);
      // Optionally, clear the pool after claiming if it's a one-time claim
      // goldPool = 0;
      
      // Show the game over modal which has the Discord link
      setTimeout(() => showGameOver(hasWonChoker), 1500); 
    }

    function showMessage(msg, colorClass = 'text-amber-300', duration = 3000) {
      const el = document.getElementById('message-display');
      if (!el) return;
      el.textContent = msg;
      el.className = `text-lg md:text-xl font-medium tracking-wide animate-pulse ${colorClass}`;

      if (duration > 0) {
        setTimeout(() => {
          // Revert to default message and classes after duration
          el.textContent = '¿Te atreves a desafiar a la Reina?';
          el.className = 'text-amber-100/80 text-lg md:text-xl font-light tracking-wide animate-fade-in';
        }, duration);
      }
    }



    async function spin() {
      if (!hasClickedAd) {
        showAdModal();
        return;
      }

      if (credits <= 0 || isSpinning) return;
      
      isSpinning = true;
      document.getElementById('spin-btn').disabled = true;
      document.getElementById('spin-btn').classList.add('opacity-50', 'cursor-not-allowed');

      // Animación inmediata local: descontar crédito y sumar 10 al pozo
      credits--;
      goldPool += 10;
      updateDisplay(false, 10);

      const startPool = goldPool;
      showMessage('LA REINA DECIDE TU DESTINO...', 'text-red-400');

      try {
        const res = await fetch('/api/game-spin', { method: 'POST' });
        const data = await res.json();
        
        if (!res.ok) throw new Error(data.error);

        const outcome = data.outcome;
        
        document.querySelectorAll('.symbol.highlight').forEach(el => el.classList.remove('highlight'));

        animateReel('reel-1', outcome[0], 1500, () => {
            highlightReel('reel-1');
            showMessage(`${outcome[0].name}`, 'text-amber-200');
        });
        
        animateReel('reel-2', outcome[1], 2500, () => {
            highlightReel('reel-2');
            if (outcome[0].id === outcome[1].id) {
               showMessage(`¡DOS ${outcome[1].name}S!`, 'text-yellow-400 font-bold animate-pulse');
            } else {
               showMessage(`${outcome[1].name}`, 'text-amber-200');
            }
        });
        
        animateReel('reel-3', outcome[2], 3500, () => {
          highlightReel('reel-3');
          isSpinning = false;
          
          // Update state from server response
          credits = data.credits;
          goldPool = data.gold_pool;
          hasWonChoker = data.has_won_choker;
          
          if (data.prize.type !== 'none') {
            handleServerPrize(data.prize);
          }

          spinHistory.length = 0;
          data.spin_history.forEach(s => spinHistory.push(s));
          updateHistoryDisplay();

          updateDisplay(true, goldPool - startPool);
        });

      } catch (e) {
        console.error("Spin Error:", e);
        isSpinning = false;
        document.getElementById('spin-btn').disabled = false;
        document.getElementById('spin-btn').classList.remove('opacity-50', 'cursor-not-allowed');
        showMessage('ERROR AL GIRAR', 'text-red-500');
      }
    }

    function handleServerPrize(prize) {
      let colorClass = 'text-white';
      if (prize.type === 'item') colorClass = 'text-purple-400';
      if (prize.type === 'gold') colorClass = 'text-amber-400 drop-shadow-[0_0_10px_rgba(251,191,36,0.8)]';
      if (prize.type === 'turns') colorClass = 'text-green-400';

      if (prize.type === 'item') {
        showMessage(`🎉 ${prize.name} (RECLAMA EN DISCORD) 🎉`, colorClass);
        setTimeout(() => showGameOver(true), 2000);
      } else if (prize.type === 'gold') {
        showMessage(`🎉 ${prize.name} (+${prize.amount} ORO) 🎉`, colorClass);
      } else if (prize.type === 'turns') {
        showMessage(`🎉 ${prize.name} 🎉`, colorClass);
      } else if (prize.type === 'loss') {
        showMessage('☠️ ¡LA REINA RECLAMA TU ALMA! (Pozo reducido) ☠️', 'text-red-600 font-bold text-xl animate-pulse');
      }

      const machine = document.getElementById('game-container');
      if (machine) {
          machine.classList.add('ring-4', 'ring-yellow-400', 'ring-opacity-100');
          setTimeout(() => machine.classList.remove('ring-4', 'ring-yellow-400', 'ring-opacity-100'), 1000);
      }
    }

    function resetGame() {
        alert("El reseteo manual está deshabilitado por seguridad. Los créditos se reinician automáticamente cada 24h.");
    }

    function highlightReel(reelId) {
        const target = document.getElementById(`${reelId}-target`);
        if (target) {
            target.classList.add('highlight');
        }
    }

    function createSymbolElement(sym) {
        const div = document.createElement('div');
        div.className = 'symbol';
        
        const iconSpan = document.createElement('span');
        iconSpan.textContent = sym.icon;
        
        const labelSpan = document.createElement('span');
        labelSpan.className = 'symbol-label';
        labelSpan.textContent = sym.name;
        
        div.appendChild(iconSpan);
        div.appendChild(labelSpan);
        
        div.style.flex = '0 0 100%';
        div.style.height = '100%'; // Ensure it fills the container exactly
        return div;
    }

    function animateReel(reelId, finalSymbol, duration, callback) {
      const reel = document.getElementById(reelId);
      
      // Calculate strip size
      const totalItems = 50; 
      const finalIndex = 45; // Must be large enough to spin for a while

      // Create new strip content
      reel.innerHTML = '';
      for (let i = 0; i < totalItems; i++) {
         let sym;
         if (i === finalIndex) {
             sym = finalSymbol;
         } else {
             sym = getRandomSymbol();
         }
         
         const div = createSymbolElement(sym);
         if (i === finalIndex) {
             div.id = `${reelId}-target`;
         }
         reel.appendChild(div);
      }
      
      // Reset position 
      reel.style.transition = 'none';
      reel.style.transform = 'translateY(0)';
      
      // Force reflow
      void reel.offsetWidth;
      
      // Animate to center the final symbol
      // The strip is inside a container of height H.
      // Each item is height H.
      // To show item i, we translate by -i * 100% of item height.
      // But since we are translating the strip relative to its own height (which is totalItems * H),
      // we need to translate by - (i / totalItems) * 100%.
      
      const percentage = (finalIndex / totalItems) * 100;
      
      reel.style.transition = `transform ${duration}ms cubic-bezier(0.25, 0.1, 0.25, 1)`;
      reel.style.transform = `translateY(-${percentage}%)`;
      
      setTimeout(() => {
        if (callback) callback();
      }, duration);
    }

  </script>
</Layout>
